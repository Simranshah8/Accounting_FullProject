<script>
    function toggleFullScreen() {
        const iframe = document.querySelector('iframe');
        if (iframe.requestFullscreen) {
            iframe.requestFullscreen();
        } else if (iframe.mozRequestFullScreen) { // Firefox
            iframe.mozRequestFullScreen();
        } else if (iframe.webkitRequestFullscreen) { // Chrome, Safari, and Opera
            iframe.webkitRequestFullscreen();
        } else if (iframe.msRequestFullscreen) { // IE/Edge
            iframe.msRequestFullscreen();
        }
    }
</script>
<script>
    $('body').on("click", ".dropdown-menu", function (e) {
        $(this).parent().is(".open") && e.stopPropagation();
    });

    $('.selectall').click(function () {
        const isChecked = $(this).is(':checked');
        $('.option').prop('checked', isChecked);
        $('.option').closest('li').toggleClass('selected', isChecked); // Add or remove class
        updateSelectedCount();
        $(".select-text").html(isChecked ? ' Deselect' : ' Select');
    });

    $("input[type='checkbox'].justone").change(function () {
        const totalOptions = $("input[type='checkbox'].justone").length;
        const checkedOptions = $("input[type='checkbox'].justone:checked").length;

        $('.selectall').prop('checked', totalOptions === checkedOptions);
        $(".select-text").html(totalOptions === checkedOptions ? ' Deselect' : ' Select');

        $(this).closest('li').toggleClass('selected', $(this).is(':checked')); // Add or remove class
        updateSelectedCount();
    });

    $('.dropdown-toggle').on('keydown', function (e) {
        if (e.key === 'ArrowDown') {
            e.preventDefault();
            const firstFocusable = $('.dropdown-menu').find('input:visible').first();
            firstFocusable.focus();
        }
    });

    $('.dropdown-menu').on('keydown', 'input', function (e) {
        const focusableItems = $('.dropdown-menu').find('input:visible');
        const currentIndex = focusableItems.index(this);

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            const nextIndex = (currentIndex + 1) % focusableItems.length;
            focusableItems.eq(nextIndex).focus();
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            const prevIndex = (currentIndex - 1 + focusableItems.length) % focusableItems.length;
            focusableItems.eq(prevIndex).focus();
        } else if (e.key === 'Enter') {
            e.preventDefault();
            // Toggle the checkbox state
            $(this).prop('checked', !$(this).prop('checked')).trigger('change');
        }
    });

    function updateSelectedCount() {
        const total = $('input[name="options[]"]:checked').length;
        $(".dropdown-text").html(`(${total}) Selected`);
    }
</script>

