<style>
    .dropdown-menu li.selected {
        background-color: #d9edf7; 
    }
    .dropdown-menu {
        padding: 0;
        border: 1px solid #ccc;
    }

    .dropdown-header {
        position: sticky;
        top: 0;
        background-color: #fff;
        z-index: 1;
        padding: 8px;
        border-bottom: 1px solid #ececec;
    }

        .dropdown-header label,
        .dropdown-menu li label {
            display: flex;
            align-items: flex-start;
            gap: 5px; /* Space between checkbox and label text */
            line-height: 1.2; /* Adjust line height for better readability */
        }

        .dropdown-header input[type="checkbox"],
        .dropdown-menu input[type="checkbox"] {
            flex-shrink: 0; /* Prevent the checkbox from resizing */
            margin-top: 2px; /* Align with the label text */
        }

    .dropdown-options {
        max-height: 250px; /* Set the desired height for the scrollable area */
        overflow-y: auto;
        padding: 8px;
    }

    .dropdown-menu li {
        padding: 5px; /* Add padding for better spacing between options */
    }

        .dropdown-menu li:hover {
            background-color: #f0f0f0; /* Highlight background on hover */
            border-radius: 4px;
        }


</style>

