
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>
<div ng-app="myApp" ng-controller="LeaveRequestController" ng-init="LoadData()">
    <div class="box-body">
        <div class="content">
            <div class="p-1"></div>
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> Employee Leave Request</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">Student Leave Request</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body p-2">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <div class="row">
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label for="">Date From</label>
                                            <input type="text"
                                                   class="form-control form-control-sm" date-picker ng-model="newEmployeeLeaveRequest.DateFrom_TMP" date-detail="newEmployeeLeaveRequest.DateFromDet">
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label for="">Date To</label>
                                            <input type="text"
                                                   class="form-control form-control-sm" date-picker ng-model="newEmployeeLeaveRequest.DateTo_TMP" date-detail="newEmployeeLeaveRequest.DateToDet">
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label for="">Status</label>
                                            <select class="form-control form-control-sm select2" ng-model="newEmployeeLeaveRequest.LeaveStatus">
                                                <option ng-value="ls.id" ng-repeat="ls in LeaveStatusColl" ng-selected="newEmployeeLeaveRequest.LeaveStatus==ls.id">{{ls.text}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <button class="btn load btn-primary mt-4 float-right" style="min-width:70px;" ng-click="GetEmpLeaveReqList()">Load</button>
                                    </div>
                                </div>
                                <div class="">
                                    <header class="row">
                                        <div class="col-md-7">
                                            <div class="clearfix">
                                                <form class="form-inline">
                                                    <div class="input-group input-group-sm mr-sm-2">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text cstm">Show</span>
                                                        </div>
                                                        <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.EmployeeLeaveRequest">
                                                            <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.EmployeeLeaveRequest">{{pp.text}}</option>
                                                        </select>
                                                        <div class="input-group-append">
                                                            <span class="input-group-text bg-white"><small>entries</small></span>
                                                        </div>
                                                    </div>
                                                    <div class="input-group input-group-sm table-search-filed">
                                                        <input class="form-control form-control-navbar"
                                                               type="search" placeholder="Search" ng-model="searchData.EmployeeLeaveRequest"
                                                               aria-label="Search">
                                                        <div class="input-group-append">
                                                            <button class="btn btn-default border-left-0" type="submit">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>

                                       
                                        <div class="col-md-5 text-right">
                                            <div class="dropdown dnld-file"
                                                 data-placement="top" title="Download File">
                                                <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                        id="dropdownMenuButton" data-toggle="dropdown"
                                                        aria-haspopup="true" aria-expanded="false">
                                                    <i class="fas fa-download"></i>
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right"
                                                     aria-labelledby="dropdownMenuButton">
                                                    <span class="dropdown-item">Choose an option:</span>
                                                    <a class="dropdown-item wait" export-excel table-id="'#ELeaveRequest'" sheet-name="'debtorcreditortypes'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                    <a class="dropdown-item wait" onClick="$('#ELeaveRequest').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                                    <a class="dropdown-item wait" onClick="$('#ELeaveRequest').tableExport({type:'pdf',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image"> PDF</a>
                                                    <a class="dropdown-item wait" onClick="$('#ELeaveRequest').tableExport({type:'doc',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image"> Word</a>
                                                    <a class="dropdown-item wait" onClick="$('#ELeaveRequest').tableExport({type:'json',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image"> JSON</a>
                                                </div>
                                                <a print-tbl table-id="'#ELeaveRequest'" class="btn btn-secondary btn-light btn-sm wait"
                                                   title="Print">
                                                    <i class="fas fa-print"></i>
                                                </a>
                                            </div>
                                        </div>

                                    </header>
                                    <div>
                                        <div class="table-scroll-x-y table-scroll">
                                            <table id="ELeaveRequest"
                                                   class="main-table table table-sm table-bordered bg-white">
                                                <thead class="text-nowrap">
                                                    <tr>
                                                        <th style="width: 60px">S.No</th>
                                                        <th style="width: 170px">Name</th>
                                                        <th style="width: 120px">Leave Type</th>
                                                        <th style="width: 180px">Leave Reason</th>
                                                        <th style="width: 110px">Leave Duration</th>
                                                        <th style="width: 170px">Leave Date ( From - To )</th>
                                                        <th style="width: 60px">Doc.</th>
                                                        <th style="width: 90px">Status</th>
                                                        <th style="width: 150px">Approved By</th>
                                                        <th style="width: 80px">Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr dir-paginate="cl in EmpLeaveRequestColl | filter:searchData.EmployeeLeaveRequest | itemsPerPage: perPage.EmployeeLeaveRequest" current-page="currentPages.EmployeeLeaveRequest" pagination-id="EmployeeLeaveRequestPagination">
                                                        <td>{{$index+1}}</td>
                                                        <td>{{cl.Name}}</td>
                                                        <td>{{cl.LeaveType}}</td>
                                                        <td>{{cl.Remarks}}</td>
                                                        <td>{{cl.LeaveDuration}}</td>
                                                        <td>{{cl.MitiFrom}} TO {{cl.MitiTo}} </td>
                                                        <td><i class="fas fa-file-pdf text-success" style="font-size:20px;" ng-click="ShowDocImg(cl)" ng-show="cl.DocumentColl.length>0"></i></td>
                                                        <td>{{cl.ApprovedType}}</td>
                                                        <td>{{cl.ApprovedBy}}</td>
                                                        <td>
                                                            <button class="btn btn-success" ng-click="ShowApprovedDialog(cl)" style="padding:0.5px 7px;">Action</button>
                                                        </td>
                                                    </tr>

                                                </tbody>
                                            </table>
                                        </div>
                                        <!-- table end -->
                                    </div>
                                    <footer class="row align-items-center">
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="EmployeeLeaveRequestPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)"></dir-pagination-controls>
                                        </div>
                                    </footer>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label for="">Class/Sec</label>
                                            <select class="form-control form-control-sm select2" ng-model="newStudentLeaveRequest.SelectedClass">
                                                <option ng-value="0">**All Class**</option>
                                                <option ng-value="cl" ng-repeat="cl in ClassList.SectionList">{{cl.text}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label for="">Date From</label>
                                            <input type="text"
                                                   class="form-control form-control-sm" date-picker ng-model="newStudentLeaveRequest.DateFrom_TMP" date-detail="newStudentLeaveRequest.DateFromDet">
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label for="">Date To</label>
                                            <input type="text"
                                                   class="form-control form-control-sm" date-picker ng-model="newStudentLeaveRequest.DateTo_TMP" date-detail="newStudentLeaveRequest.DateToDet">
                                        </div>
                                    </div>
                                    <div class="col-sm-2">
                                        <div class="form-group">
                                            <label>Status</label>
                                            <select class="form-control form-control-sm select2" ng-model="newStudentLeaveRequest.LeaveStatus">
                                                <option ng-value="ls.id" ng-repeat="ls in LeaveStatusColl" ng-selected="newStudentLeaveRequest.LeaveStatus==ls.id">{{ls.text}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-sm-2 col-lg-2 col-md-2">
                                        <button class="btn load btn-primary mt-4 float-right" style="min-width:80px;" ng-click="GetStudentLeaveReqList()">Load</button>
                                    </div>
                                </div>

                                <div class="">
                                    <header class="row">
                                        <div class="col-md-7">
                                            <div class="clearfix">
                                                <form class="form-inline">
                                                    <div class="input-group input-group-sm mr-sm-2">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text cstm">Show</span>
                                                        </div>
                                                        <!-- <input type="text" class="form-control border-left-0" placeholder=""> -->
                                                        <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.StudentLeaveRequest">
                                                            <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.StudentLeaveRequest">{{pp.text}}</option>
                                                        </select>
                                                        <div class="input-group-append">
                                                            <span class="input-group-text bg-white"><small>entries</small></span>
                                                        </div>
                                                    </div>
                                                    <div class="input-group input-group-sm table-search-filed">
                                                        <input class="form-control form-control-navbar"
                                                               type="search" placeholder="Search"
                                                               aria-label="Search" ng-model="searchData.StudentLeaveRequest">
                                                        <div class="input-group-append">
                                                            <button class="btn btn-default border-left-0"
                                                                    type="submit">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                        <!-- end col-md-8 -->
                                       
                                        <div class="col-md-5 text-right">
                                            <div class="dropdown dnld-file"
                                                 data-placement="top" title="Download File">
                                                <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                        id="dropdownMenuButton" data-toggle="dropdown"
                                                        aria-haspopup="true" aria-expanded="false">
                                                    <i class="fas fa-download"></i>
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right"
                                                     aria-labelledby="dropdownMenuButton">
                                                    <span class="dropdown-item">Choose an option:</span>
                                                    <a class="dropdown-item wait" export-excel table-id="'#SLeaveRequest'" sheet-name="'debtorcreditortypes'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                    <a class="dropdown-item wait" onClick="$('#SLeaveRequest').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                                    <a class="dropdown-item wait" onClick="$('#SLeaveRequest').tableExport({type:'pdf',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image"> PDF</a>
                                                    <a class="dropdown-item wait" onClick="$('#SLeaveRequest').tableExport({type:'doc',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image"> Word</a>
                                                    <a class="dropdown-item wait" onClick="$('#SLeaveRequest').tableExport({type:'json',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image"> JSON</a>
                                                </div>
                                                <a print-tbl table-id="'#SLeaveRequest'" class="btn btn-secondary btn-light btn-sm wait"
                                                   title="Print">
                                                    <i class="fas fa-print"></i>
                                                </a>
                                            </div>


                                        </div>
                                    </header>
                                    <div>
                                        <div class="table-scroll-x-y table-scroll">
                                            <table id="SLeaveRequest"
                                                   class="main-table table table-sm table-bordered bg-white">
                                                <thead>
                                                    <tr>
                                                        <th style="width: 120px">Request Date</th>
                                                        <th style="width: 160px">Name/ Roll No</th>
                                                        <th style="width: 130px">Class/Sec</th>
                                                        <th style="width: 180px">Leave Request(From-To)</th>
                                                        <th style="width: 50px">Days</th>
                                                        <th style="width: 200px">Leave Reason</th>
                                                        <th style="width: 80px">Document</th>
                                                        <th style="width: 130px">Approved By/Date</th>
                                                        <th style="width: 80px"> Status</th>
                                                        <th style="width: 90px">Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr ng-repeat="sr in StudentLeaveRequestColl">
                                                        <td>{{sr.LogMiti}}</td>
                                                        <td>{{sr.Name}} <br />{{sr.RollNo}}</td>
                                                        <td>{{sr.ClassName}} {{sr.SectionName}}</td>
                                                        <td>{{sr.MitiFrom}} - {{sr.MitiTo}}</td>
                                                        <td>{{sr.TotalDays}}</td>
                                                        <td>{{sr.Remarks}}</td>
                                                        <td><i class="fas fa-file-pdf text-success" style="font-size:20px;" ng-click="ShowDocImg(sr)" ng-show="sr.DocumentColl.length>0"></i></td>
                                                        <td>{{sr.ApprovedBy}} <br />{{sr.ApprovedLogMiti}}1</td>
                                                        <td>{{sr.ApprovedType}}</td>
                                                        <td>
                                                            <button type="button" class="btn  btn-success" style="min-width: 70px;padding: 2px 10px;font-size: 13px;" ng-click="ShowSTApprovedDialog(sr)">
                                                                Action
                                                            </button>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                            <!-- table end -->
                                        </div>
                                    </div>
                                    <footer class="row align-items-center">
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="StudentLeaveRequestPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>
                                    </footer>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>

                <!--Employee Leave Request Modal Starts-->
                <div class="modal fade" id="modal-xl">
                    <div class="modal-dialog modal-xl">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h6 class="modal-title">Leave Request From ::  {{CurLeave.EmployeeCode}}-{{CurLeave.Name}} {{CurLeave.ClassName}} {{CurLeave.SectionName}} - {{CurLeave.RollNo}}</h6>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="">Leave Type</label><br />
                                            <label class="form-control form-control-sm">{{CurLeave.LeaveType}}</label>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Leave Duration</label>
                                            <input type="text" class="form-control form-control-sm" ng-model="CurLeave.LeaveDuration" disabled>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label>Date From</label>
                                            <label class="form-control form-control-sm">{{CurLeave.MitiFrom}}</label>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label>Date To</label>
                                            <label class="form-control form-control-sm">{{CurLeave.MitiTo}}</label>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label for="">No of Days</label>
                                            <label class="form-control form-control-sm">{{CurLeave.TotalDays}}</label>
                                        </div>
                                    </div>
                                    <div class="col-md-10">
                                        <div class="form-group">
                                            <label for="">Leave Reason</label>
                                            <textarea class="form-control form-control-sm" rows="1" ng-model="CurLeave.Remarks" disabled></textarea>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <label>Attachment</label><br />
                                        <i class="fas fa-file-pdf text-success" style="font-size:25px;" ng-click="ShowDocImg(CurLeave)" ng-show="CurLeave.DocumentColl.length>0"></i>
                                    </div>
                                    <div class="col-md-3">
                                        <label>Status</label>
                                        <select class="form-control form-control-sm select2" ng-model="CurLeave.LeaveStatus" ng-show="CurLeave.ApprovedTypeId<=1">
                                            <option ng-value="ls.id" ng-repeat="ls in LeaveStatusColl" ng-selected="CurLeave.LeaveStatus==ls.id">{{ls.text}}</option>
                                        </select>
                                        <label class="form-control form-control-sm" ng-hide="CurLeave.ApprovedTypeId<=1">{{CurLeave.ApprovedType}}</label>
                                    </div>
                                    <div class="col-md-9">
                                        <div class="form-group">
                                            <label>Remarks</label>
                                            <textarea class="form-control form-control-sm" rows="1" placeholder="" ng-model="CurLeave.ApprovedRemarks"></textarea>
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div class="row">
                                    <div class="col-md-3">
                                        <label><b>Leave Details:</b></label>
                                    </div>
                                    <div class="col-md-3">
                                        <label><b>Total: {{EmpWiseRequestColl.length}}</b></label>
                                    </div>
                                    <div class="col-md-3">
                                        <label><b>Used: </b></label>
                                    </div>
                                    <div class="col-md-3">
                                        <label><b>Balance: </b></label>
                                    </div>
                                </div>
                                <div class="table-scroll-x-y table-scroll">
                                    <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                        <thead>
                                            <tr>
                                                <th style="width: 140px;">Leave Type</th>
                                                <th style="width: 140px;">Leave Duration</th>
                                                <th style="width: 200px;">Leave Request(From- To)</th>
                                                <th style="width: 120px;">Total Days</th>
                                                <th style="width: 200px;">Reason</th>
                                                <th style="width: 120px;">Status</th>
                                                <th style="width: 150px;">Approve By</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="ew in EmpWiseRequestColl">
                                                <td>{{ew.LeaveType}}</td>
                                                <td>{{ew.LeaveDuration}}</td>
                                                <td>{{ew.MitiFrom}} TO {{ew.MitiTo}}</td>
                                                <td>{{ew.TotalDays}}</td>
                                                <td>{{ew.Remarks}}</td>
                                                <td>{{ew.ApprovedType}}</td>
                                                <td>{{ew.ApprovedBy}}</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="time-label">
                                <span class="d-block border-0 p-3 text-center">
                                    <button type="button" class="btn btn-sm btn-info" data-dismiss="modal" style="min-width: 90px;">Back to List</button>
                                    @*<button type="button" class="btn btn-sm btn-default" style="min-width: 90px;" ng-click="ClearEmployeeLeaveRequest()">Reset</button>*@
                                    <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="LeaveApproved()" ng-show="CurLeave.ApprovedTypeId<=1">Accept</button>
                                </span>
                            </div>
                        </div>
                    </div>
                    <!-- /.modal-content -->
                </div>
                <!--Employee Leave Request Modal ends-->
                <!--Student Leave Request Modal starts-->
                <div class="modal fade" id="stleavereq">
                    <div class="modal-dialog modal-xl">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h6 class="modal-title">Ram Prashad Sharma</h6>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label for="">Leave Approved From</label>
                                            <input type="text"
                                                   class="form-control form-control-sm" date-picker ng-model="newStudentLeaveRequest.LeaveApprovedFrom_TMP" date-detail="newStudentLeaveRequest.LeaveApprovedFromDet" disabled>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label for="">Leave Approved To</label>
                                            <input type="text"
                                                   class="form-control form-control-sm" date-picker ng-model="newStudentLeaveRequest.LeaveApprovedTo_TMP" date-detail="newStudentLeaveRequest.LeaveApprovedToDet" disabled>
                                        </div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Leave Type</label>
                                            <select class="form-control form-control-sm select2" disabled ng-model="newStudentLeaveRequest.LeaveTypeId">
                                                <option value="1">Sick</option>
                                                <option value="2">Personal</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-9">
                                        <div class="form-group">
                                            <label>Leave Reason</label>
                                            <textarea class="form-control form-control-sm" rows="1" placeholder="" disabled ng-model="newStudentLeaveRequest.LeaveReason"></textarea>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <label>Document</label><br />
                                        <i class="fas fa-file-alt text-success" style="font-size:30px;" ng-model="newStudentLeaveRequest.Document"></i>
                                    </div>
                                    <div class="col-md-3">
                                        <label>Status</label>
                                        <select class="form-control form-control-sm" ng-model="newStudentLeaveRequest.Status">
                                            <option value="1">Approve</option>
                                            <option value="2">Deny</option>
                                            <option value="3">All</option>
                                        </select>
                                    </div>
                                    <div class="col-md-9">
                                        <div class="form-group">
                                            <label>Remarks</label>
                                            <textarea class="form-control form-control-sm" rows="1" placeholder="" ng-model="newStudentLeaveRequest.Remarks"></textarea>
                                        </div>
                                    </div>
                                </div>
                                <label>Leave Details</label>
                                <div class="table-scroll-x-y table-scroll">
                                    <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                        <thead>
                                            <tr>
                                                <th style="width: 140px;">Leave Type</th>
