@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>
<script src="~/jslib/appcms/AcademicProgram.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="AcademicProgramController" ng-init="LoadData()">
    <section class="iframe-content-starts-here">
        <div class="tab-content" id="table-listing">
            <!-- Second Tab Content -->
            <div class="container-fluid">
                <div class="card p-2">
                    <header class="row mb-2">
                        <div class="col-md-7">
                            <div class="clearfix">
                                <form class="form-inline">
                                    <div class="input-group input-group-sm mr-sm-2">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text cstm">Show</span>
                                        </div>

                                        <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.AcademicProgram">
                                            <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.AcademicProgram">{{pp.text}}</option>
                                        </select>
                                        <div class="input-group-append">
                                            <span class="input-group-text bg-white"><small>entries</small></span>
                                        </div>
                                    </div>
                                    <div class="input-group input-group-sm table-search-filed">
                                        <input class="form-control form-control-navbar"
                                               type="search"
                                               placeholder="Search"
                                               aria-label="Search" ng-model="searchData.AcademicProgram" />
                                        <div class="input-group-append">
                                            <button class="btn btn-default border-left-0"
                                                    type="submit">
                                                <i class="fas fa-search"></i>
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <!-- end col-md-8 -->
                        <div class="col-md-5 text-right">

                            <div class="dropdown dnld-file">
                                <button class="btn btn-secondary btn-light dropdown-toggle" type="button"
                                        id="dropdownMenuButton" data-toggle="dropdown"
                                        aria-haspopup="true" aria-expanded="false">
                                    <i class="fas fa-download"></i>
                                </button>
                                <div class="dropdown-menu dropdown-menu-right"
                                     aria-labelledby="dropdownMenuButton">
                                    <span class="dropdown-item">Choose an option:</span>
                                    <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'debtorcreditortypes'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                    <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                    <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'pdf',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image"> PDF</a>
                                    <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'doc',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image"> Word</a>
                                    <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'json',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image"> JSON</a>
                                </div>
                                <a print-tbl table-id="'#datatable'" class="btn btn-secondary btn-light wait">
                                    <i class="fas fa-print"></i>
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-primary"
                                        id="open-form-btn" style="font-size:14px;">
                                    <i class="fas fa-plus w-t"></i> Add Academic Programs
                                </button>
                            </div>

                        </div>

                    </header>
                    <div>
                        <div class="table-scroll-x-y table-scroll"style="max-height: calc(100vh - 100px);">
                            <table id="main-table"
                                   class="main-table table table-sm table-bordered bg-white">
                                <thead>
                                    <tr>
                                        <th style="width: 70px">S.No.</th>
                                        <th style="width: 200px">Title</th>
                                        <th style="width: 400px">Description</th>
                                        <th class="text-center" style="width: 70px">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr dir-paginate="ap in AcademicProgramList | filter:searchData.AcademicProgram | itemsPerPage: perPage.AcademicProgram" current-page="currentPages.AcademicProgram" pagination-id="academicprogramPagination">
                                        <td>{{ap.OrderNo}}</td>
                                        <td>{{ap.Title}}</td>
                                        <td>{{ap.Description}}</td>
                                        <td class="text-center">
                                            <a class="p-1" href="#" ng-click="GetAcademicProgramById(ap)">
                                                <i class="fas fa-edit text-info"></i>
                                            </a>
                                            <a class="p-1" href="#" ng-click="DelAcademicProgramById(ap)">
                                                <i class="fas fa-trash-alt text-danger"></i>
                                            </a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                            <!-- table end -->
                        </div>
                    </div>
                    <footer class="row align-items-center">
                        <div class="col-md-12">
                            <dir-pagination-controls pagination-id="academicprogramPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                            </dir-pagination-controls>
                        </div>
                    </footer>
                </div>
            </div>
        </div>
        <!-- form area starts -->
        <div id="notice-form">
            <!-- The time line -->
            <!-- timeline item -->
            <div class="container-fluid">
                <!-- <i class="fas fa-envelope bg-blue"></i> -->
                <div class="card">
                    <div class="card-body">
                        <div class="timeline-item">
                            <div class="row">
                                <div class="col-md-9">
                                    <div class="row">
                                        <!-- select for others -->
                                        <div class="col-md-8" id="meet-others">
                                            <div class="form-group">
                                                <label for="">Title</label>
                                                <input type="text"
                                                       class="form-control form-control-sm" ng-model="newAcademicProgram.Title" />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="">Order No.</label>
                                                <input type="number"
                                                       class="form-control form-control-sm" ng-model="newAcademicProgram.OrderNo" />
                                            </div>
                                        </div>
                                        <!-- fields after clicking radio button ends -->
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label>Description</label>
                                                <textarea class="form-control form-control-sm"
                                                          rows="1" ng-model="newAcademicProgram.Description"></textarea>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label for="">Content</label>
                                                <textarea class="textarea" placeholder="Place some text here"
                                                          style="width: 100%; height: 200px; font-size: 14px; line-height: 18px; border: 1px solid #dddddd; padding: 10px;" html-editor ng-model="newAcademicProgram.Content">

                                                                </textarea>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="time-label">
                                        <span class="d-block border-0 p-3 text-center">
                                            <button type="button"
                                                    class="btn btn-info"
                                                    id="back-to-list"
                                                    style="min-width: 90px">
                                                Back to List
                                            </button>
                                            <button type="button"
                                                    class="btn btn-default"
                                                    style="min-width: 90px" ng-click="ClearAcademicProgram()">
                                                Reset
                                            </button>
                                            <button type="button"
                                                    class="btn  btn-success"
                                                    style="min-width: 90px" ng-click="SaveUpdateAcademicProgram()">
                                                {{newAcademicProgram.Mode}}
                                            </button>
                                        </span>
                                    </div>
                                </div>
                                <!-- col-md-9 -->
                                <div class="col-md-3">
                                    <label for="" class="invisible">Photo</label>
                                    <div class="person-photo-attachment-wrap text-center">
                                        <div class="img-wrap mx-auto">
                                            <img ng-src="{{newAcademicProgram.PhotoData || newAcademicProgram.ImagePath}}" class="img-fluid" alt="" id="imgPhoto1">
                                        </div>
                                        <!-- Button trigger modal -->
                                        <button type="button" class="btn btn-outline-secondary btn-sm" data-toggle="modal" data-target="#updatePhoto"style="font-size:14px;">
                                            <i class="fas fa-camera w-t"></i> Upload Image
                                        </button>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END timeline item -->
        </div>
        <!-- form area ends -->
    </section>

    @* photo upload Modal*@
    <div class="modal fade" id="updatePhoto" tabindex="-1" aria-labelledby="updatePhotoLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="updatePhotoLabel">Upload Photo</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <i class="flaticon-close"></i>
                    </button>
                </div>
                <div class="modal-body text-center" border-0 pb-0" file-dropzone="[image/png, image/jpeg]"
                     data-max-file-size="3" ng-model="newAcademicProgram.Photo_TMP" @*after-selected="AddAcademicProgramPhoto()"*@ fileread="newAcademicProgram.PhotoData">
                    <div class="photo-upload-wrap">
                        <span class="static-content">
                            <img ng-src="{{newAcademicProgram.PhotoData  || newAcademicProgram.ImagePath}}" class="img-fluid" id="imgPhoto">
                            <span>Drag & Drop your<br>image here</span>
                        </span>
                    </div>
                    <div class="text-muted pb-3">or</div>
                    <label for="choose-file" type="button" class="btn btn-secondary btn-light btn-sm">Upload Image</label>
                    <input id="choose-file" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newAcademicProgram.Photo_TMP" @*after-selected="AddStudentPhoto()"*@ fileread="newAcademicProgram.PhotoData" />
                    <a ng-click="ClearAcademicProgramPhoto()" href="#" class="text-danger d-block mt-3">remove current image</a>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-dafault" data-dismiss="modal">Ok</button>
                    @*<button type="button" class="btn btn-secondary px-4" ng-click="AddAcademicProgramImage()">Save</button>*@
                </div>
            </div>
        </div>
    </div>
</div>

