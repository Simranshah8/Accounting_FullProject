                    <input id="choose-fileAcadImage" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newAcademicPrograms.PhotoAcadImage_TMP" @*after-selected="AddStudentPhoto()"*@ fileread="newAcademicPrograms.PhotoDataAcadImage" />
