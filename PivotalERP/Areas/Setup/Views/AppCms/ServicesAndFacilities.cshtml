@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>
<script src="~/jslib/AppCMS/ServicesAndFacilities.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="ServicesAndFacilitiesController" ng-init="LoadData()">
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <div class="p-1"></div>
            <div class="card">
                <div class="card-header p-0 border-bottom-0">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <a class="nav-link active" id="home-tab" data-toggle="tab" href="#home" role="tab"
                                   aria-controls="home" aria-selected="true">Services & Facilities</a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" id="profile-tab" data-toggle="tab" href="#profile" role="tab"
                                   aria-controls="profile" aria-selected="false">Academic Programs</a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" id="fee-tab" data-toggle="tab" href="#fee" role="tab" aria-controls="fee"
                                   aria-selected="false">Feedback/Suggestions</a>
                            </li>
                        </ul>
                    </div>
                </div>
                    <div class="card-body">
                        <div class="tab-content" id="myTabContent">
                            <!-- Services & Facilitiest Tab Starts -->
                            <div class="tab-pane fade show active main-section" id="home" role="tabpanel"
                                 aria-labelledby="home-tab">
                                <div id="sf-table-listing">
                                    <!-- Second Tab Content -->
                                    <div>
                                        <header class="row mb-2">
                                            <div class="col-md-7">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm mr-sm-2">
                                                            <div class="input-group-prepend">
                                                                <span class="input-group-text cstm">Show</span>
                                                            </div>
                                                            <!-- <input type="text" class="form-control border-left-0" placeholder=""> -->
                                                            <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.ServicesFacilities">
                                                                <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.ServicesFacilities">{{pp.text}}</option>
                                                            </select>
                                                            <div class="input-group-append">
                                                                <span class="input-group-text bg-white"><small>entries</small></span>
                                                            </div>
                                                        </div>
                                                        <div class="input-group input-group-sm table-search-filed">
                                                            <input class="form-control form-control-navbar"
                                                                   type="search" placeholder="Search"
                                                                   aria-label="Search" ng-model="searchData.ServicesFacilities">
                                                            <div class="input-group-append">
                                                                <button class="btn btn-default border-left-0" type="submit">
                                                                    <i class="fas fa-search"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                            <!-- end col-md-8 -->
                                            <div class="col-md-5 text-right">
                                                <div class="dropdown dnld-file">
                                                    <button class="btn btn-secondary btn-light dropdown-toggle" type="button"
                                                            id="dropdownMenuButton" data-toggle="dropdown"
                                                            aria-haspopup="true" aria-expanded="false">
                                                        <i class="fas fa-download"></i>
                                                    </button>
                                                    <div class="dropdown-menu dropdown-menu-right"
                                                         aria-labelledby="dropdownMenuButton">
                                                        <span class="dropdown-item">Choose an option:</span>
                                                        <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'debtorcreditortypes'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'pdf',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image"> PDF</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'doc',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image"> Word</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'json',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image"> JSON</a>
                                                    </div>
                                                    <a print-tbl table-id="'#datatable'" class="btn btn-secondary btn-light wait">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                    <button type="button" class="btn btn-sm btn-primary" id="add-sf" style="font-size:14px;">
                                                        <i class="fas fa-plus w-t"></i> Add Services & Facilities
                                                    </button>
                                                </div>
                                            </div>


                                        </header>
                                        <div>
                                            <div class="table-scroll-x-y table-scroll" style="max-height: calc(100vh - 100px);">
                                                <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 70px">Order No.</th>
                                                            <th style="width: 250px">Title</th>
                                                            <th style="width: 350px">Description</th>
                                                            <th style="width: 70px">Action</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr dir-paginate="cl in ServicesFacilitiesList | filter:searchData.ServicesFacilities | itemsPerPage: perPage.ServicesFacilities" current-page="currentPages.ServicesFacilities" pagination-id="ServicesFacilitiesPagination">
                                                            <td>{{cl.OrderNo}}</td>
                                                            <td>{{cl.Title}}</td>
                                                            <td>{{cl.Description}}</td>
                                                            <td>
                                                                <a class="p-1" ng-click="ShowPersonalImg(cl)">
                                                                    <i class="fas fa-eye text-secondary"></i>
                                                                </a>
                                                                <a class="p-1" ng-click="GetServicesFacilitiesById(cl)">
                                                                    <i class="fas fa-edit text-info"></i>
                                                                </a>
                                                                <a class="p-1" ng-click="DelServicesAndFacilities(cl)">
                                                                    <i class="fas fa-trash-alt text-danger"></i>
                                                                </a>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                                <!-- table end -->
                                            </div>
                                        </div>
                                        <footer class="row align-items-center">
                                            <div class="col-md-12">
                                                <dir-pagination-controls pagination-id="ServicesFacilitiesPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                                </dir-pagination-controls>
                                            </div>
                                        </footer>
                                    </div>
                                </div>
                                <!-- form area starts -->
                                <div id="sf-form">

                                    <div class="timeline-item">
                                        <div class="row">
                                            <div class="col-md-9">
                                                <div class="row">
                                                    <!-- select for others -->
                                                    <div class="col-md-9">
                                                        <div class="form-group">
                                                            <label for="">Title</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newServicesFacilities.Title" />
                                                        </div>
                                                    </div>

                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label for="">Order No.</label>
                                                            <input type="number" class="form-control form-control-sm" ng-model="newServicesFacilities.OrderNo" />
                                                        </div>
                                                    </div>
                                                    <!-- fields after clicking radio button ends -->
                                                    <div class="col-md-12">
                                                        <div class="form-group">
                                                            <label>Description</label>
                                                            <textarea class="form-control form-control-sm" rows="1" ng-model="newServicesFacilities.Description"></textarea>
                                                        </div>
                                                    </div>

                                                    <div class="col-md-12">
                                                        <div class="form-group">
                                                            <label for="">Content</label>
                                                            <textarea class="textarea" placeholder="Place some text here"
                                                                      style="width: 100%; height: 200px; font-size: 14px; line-height: 18px; border: 1px solid #dddddd; padding: 10px;" ng-model="newServicesFacilities.Content" html-editor></textarea>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-3">
                                                <label for="" class="invisible">Photo</label>
                                                <div class="person-photo-attachment-wrap text-center">
                                                    <div class="img-wrap mx-auto" style="width:100%;">
                                                        <img ng-src="{{newServicesFacilities.PhotoData || newServicesFacilities.ImagePath}}" class="img-fluid" alt="" id="imgPhoto1">
                                                    </div>
                                                    <!-- Button trigger modal -->
                                                    <button type="button" class="btn btn-outline-secondary btn-sm" data-toggle="modal" data-target="#updatePhoto" style="font-size:14px;">
                                                        <i class="fas fa-camera w-t"></i> Upload Image
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="time-label">
                                            <span class="d-block border-0 p-3 text-center">
                                                <button type="button" class="btn  btn-info" id="back-to-sf-list"
                                                        style="min-width: 90px">
                                                    Back to List
                                                </button>
                                                <button type="button" class="btn  btn-default" style="min-width: 90px;" ng-click="ClearServicesFacilities()">Reset</button>
                                                <button type="button" class="btn  btn-success" style="min-width: 90px;" ng-click="SaveUpdateServicesFacilities()">{{newServicesFacilities.Mode}}</button>
                                            </span>
                                        </div>
                                    </div>

                                </div>
                                <!-- form area ends -->

                            </div>
                            <!-- Services & Facilities Tab Ends -->
                            <!-- Academic Programs Tab Starts -->
                            <div class="tab-pane fade main-section" id="profile" role="tabpanel" aria-labelledby="profile-tab">
                                <div id="acad-prog-table-listing" style="margin-top: -10px;">
                                    <!-- Second Tab Content -->
                                    <div>
                                        <header class="row mb-2">
                                            <div class="col-md-7">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm mr-sm-2">
                                                            <div class="input-group-prepend">
                                                                <span class="input-group-text cstm">Show</span>
                                                            </div>
                                                            <!-- <input type="text" class="form-control border-left-0" placeholder=""> -->
                                                            <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.AcademicPrograms">
                                                                <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.AcademicPrograms">{{pp.text}}</option>
                                                            </select>
                                                            <div class="input-group-append">
                                                                <span class="input-group-text bg-white"><small>entries</small></span>
                                                            </div>
                                                        </div>
                                                        <div class="input-group input-group-sm table-search-filed">
                                                            <input class="form-control form-control-navbar"
                                                                   type="search" placeholder="Search"
                                                                   aria-label="Search" ng-model="searchData.AcademicPrograms">
                                                            <div class="input-group-append">
                                                                <button class="btn btn-default border-left-0" type="submit">
                                                                    <i class="fas fa-search"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                            <!-- end col-md-8 -->

                                            <div class="col-md-5 text-right">
                                                <div class="dropdown dnld-file">
                                                    <button class="btn btn-secondary btn-light dropdown-toggle" type="button"
                                                            id="dropdownMenuButton" data-toggle="dropdown"
                                                            aria-haspopup="true" aria-expanded="false">
                                                        <i class="fas fa-download"></i>
