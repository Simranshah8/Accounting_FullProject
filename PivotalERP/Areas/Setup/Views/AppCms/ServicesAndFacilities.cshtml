                                                        <span class="dropdown-item">Choose an option:</span>
                                                        <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'debtorcreditortypes'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'pdf',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image"> PDF</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'doc',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image"> Word</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'json',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image"> JSON</a>
                                                    </div>
                                                    <a print-tbl table-id="'#datatable'" class="btn btn-secondary btn-light wait">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                    <button type="button" class="btn btn-sm btn-primary" id="add-acad-prog"
                                                            style="font-size:14px;">
                                                        <i class="fas fa-plus w-t"></i> Add Academic Programs
                                                    </button>
                                                </div>
                                            </div>


                                        </header>
                                        <div>
                                            <div class="table-scroll-x-y table-scroll" style="max-height: calc(100vh - 100px);">
                                                <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 70px">Order No.</th>
                                                            <th style="width: 200px">Title</th>
                                                            <th style="width: 300px">Description</th>
                                                            <th style="width: 100px">Action</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr dir-paginate="cl in AcademicProgramsList | filter:searchData.AcademicPrograms | itemsPerPage: perPage.AcademicPrograms" current-page="currentPages.AcademicPrograms" pagination-id="AcademicProgramsPagination">
                                                            <td>{{cl.OrderNo}}</td>
                                                            <td>{{cl.Title}}</td>
                                                            <td>{{cl.Description}}</td>
                                                            <td>
                                                                <a class="p-1" href="#" ng-click="ShowPersonalImg(cl)">
                                                                    <i class="fas fa-eye text-secondary"></i>
                                                                </a>
                                                                <a class="p-1" href="#" ng-click="GetAcademicProgramsById(cl)">
                                                                    <i class="fas fa-edit text-info"></i>
                                                                </a>
                                                                <a class="p-1" href="#" ng-click="DelAcademicProgramsById(cl)">
                                                                    <i class="fas fa-trash-alt text-danger"></i>
                                                                </a>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                                <!-- table end -->
                                            </div>
                                        </div>
                                        <footer class="row align-items-center">
                                            <div class="col-md-12">
                                                <dir-pagination-controls pagination-id="AcademicProgramsPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                                </dir-pagination-controls>
                                            </div>
                                        </footer>
                                    </div>
                                </div>
                                <!-- form area starts -->
                                <div id="acad-prog-form">

                                    <div class="row">
                                        <div class="col-md-9">
                                            <div class="row">
                                                <!-- select for others -->
                                                <div class="col-md-9" id="meet-others">
                                                    <div class="form-group">
                                                        <label for="">Title</label>
                                                        <input type="text" class="form-control form-control-sm" ng-model="newAcademicPrograms.Title" />
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="form-group">
                                                        <label for="">Order No.</label>
                                                        <input type="number" class="form-control form-control-sm" ng-model="newAcademicPrograms.OrderNo" />
                                                    </div>
                                                </div>
                                                <!-- fields after clicking radio button ends -->
                                                <div class="col-md-12">
                                                    <div class="form-group">
                                                        <label>Description</label>
                                                        <textarea class="form-control form-control-sm" rows="1" ng-model="newAcademicPrograms.Description"></textarea>
                                                    </div>
                                                </div>
                                                <div class="col-md-12">
                                                    <div class="form-group">
                                                        <label for="">Content</label>
                                                        <textarea class="textarea" placeholder="Place some text here"
                                                                  style="width: 100%; height: 200px; font-size: 14px; line-height: 18px; border: 1px solid #dddddd; padding: 10px;" html-editor ng-model="newAcademicPrograms.Content"></textarea>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-3">
                                            <label for="" class="invisible">Photo</label>
                                            <div class="person-photo-attachment-wrap text-center">
                                                <div class="img-wrap mx-auto" style="width:100%">
                                                    <img ng-src="{{newAcademicPrograms.PhotoDataAcadImage || newAcademicPrograms.ImagePath}}" class="img-fluid" alt="" id="imgAcadImage1">
                                                </div>
                                                <!-- Button trigger modal -->
                                                <button type="button" class="btn btn-outline-secondary btn-sm" data-toggle="modal" data-target="#updateAcadImage" style="font-size:14px;">
                                                    <i class="fas fa-camera w-t"></i> Upload Image
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="time-label">
                                        <span class="d-block border-0 p-3 text-center">
                                            <button type="button" class="btn btn-info" id="back-to-acad-prog-list"
                                                    style="min-width: 90px">
                                                Back to List
                                            </button>
                                            <button type="button" class="btn  btn-default" style="min-width: 90px;" ng-click="ClearAcademicPrograms()">Reset</button>
                                            <button type="button" class="btn btn-success" style="min-width: 90px;" ng-click="SaveUpdateAcademicPrograms()">{{newAcademicPrograms.Mode}}</button>
                                        </span>
                                    </div>
                                </div>

                            </div>
                            <!-- Academic Programs Tab Ends -->
                            <!-- Feedback/Suggestions Starts -->
                            <div class="tab-pane fade main-section" id="fee" role="tabpanel" aria-labelledby="fee-tab">
                                <div id="feedback-table-listing" style="margin-top: -10px;">
                                    <div>
                                        <header class="row mb-2">
                                            <div class="col-md-7">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm mr-sm-2">
                                                            <div class="input-group-prepend">
                                                                <span class="input-group-text cstm">Show</span>
                                                            </div>
                                                            <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.Feedback">
                                                                <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.Feedback">{{pp.text}}</option>
                                                            </select>
                                                            <div class="input-group-append">
                                                                <span class="input-group-text bg-white"><small>entries</small></span>
                                                            </div>
                                                        </div>
                                                        <div class="input-group input-group-sm table-search-filed">
                                                            <input class="form-control form-control-navbar"
                                                                   type="search" placeholder="Search"
                                                                   aria-label="Search" ng-model="searchData.Feedback">
                                                            <div class="input-group-append">
                                                                <button class="btn btn-default border-left-0" type="submit">
                                                                    <i class="fas fa-search"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                            <div class="col-md-5 text-right">
                                                <div class="dropdown dnld-file">
                                                    <button class="btn btn-secondary btn-light dropdown-toggle" type="button"
                                                            id="dropdownMenuButton" data-toggle="dropdown"
                                                            aria-haspopup="true" aria-expanded="false">
                                                        <i class="fas fa-download"></i>
                                                    </button>
                                                    <div class="dropdown-menu dropdown-menu-right"
                                                         aria-labelledby="dropdownMenuButton">
                                                        <span class="dropdown-item">Choose an option:</span>
                                                        <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'debtorcreditortypes'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'pdf',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image"> PDF</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'doc',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image"> Word</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'json',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image"> JSON</a>
                                                    </div>
                                                    <a print-tbl table-id="'#datatable'" class="btn btn-secondary btn-light wait">
                                                        <i class="fas fa-print"></i>
                                                    </a>

                                                </div>
                                            </div>
                                        </header>
                                        <div>
                                            <div class="table-scroll-x-y table-scroll" style="max-height: calc(100vh - 100px);">
                                                <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 80px">S.No.</th>
                                                            <th style="width: 110px">Date</th>
                                                            <th style="width: 150px">Feedback By</th>
                                                            <th style="width: 120px">Contact No</th>
                                                            <th style="width: 150px">Email</th>
                                                            <th style="width: 250px">Message</th>
                                                            <th style="width: 70px">Action</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr dir-paginate="cl in FeedbackList | filter:searchData.Feedback | itemsPerPage: perPage.Feedback" current-page="currentPages.Feedback" pagination-id="FeedbackPagination">
                                                            <td>{{clOrderNo}}</td>
                                                            <td>{{cl.PostDateTime}}</td>
                                                            <td>{{cl.Name}}</td>
                                                            <td>{{cl.ContactNo}}</td>
                                                            <td>{{cl.Email}}</td>
                                                            <td>{{cl.Feedback}}</td>
                                                            <td>
                                                                <button class="btn btn-sm py-0 btn-secondary" ng-click="ShowResponeDialog(cl)">Reply</button>
