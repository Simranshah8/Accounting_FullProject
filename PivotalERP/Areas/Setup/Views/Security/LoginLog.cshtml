
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.LoginLog)";
</script>
<script src="~/jslib/Setup/UserWiseLog.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="CtrlLoginLog">
    <!-- Main content -->
    <section class="content">
        <div class="">
            <section class="iframe-content-starts-here">
                <div class="tab-content">
                    <div id="day-book-section">
                        <div class="card p-2">
                            <div class="row">
                                <div class="col-sm-3">
                                    <div class="d-inline-block">
                                        <div class="input-group input-group-sm">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">For Date:</span>
                                            </div>
                                            <input class="form-control text-dark input-sm" type="text" date-picker ng-model="beData.ForDate_TMP" style="max-width:100px" date-detail="beData.ForDateDet" />
                                            @*<div class="input-group-prepend">
                                                <span class="input-group-text">To:</span>
                                            </div>
                                            <input class="form-control text-dark input-sm" type="text" date-picker ng-model="beData.DateTo_TMP" style="max-width:100px" date-detail="beData.DateToDet" />*@
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                   
                                </div>
                                <div class="col-sm-2">
                                   
                                </div>
                                <div class="col-sm-3">
                                   
                                </div>
                                <div class="col-md-1">
                                    <button type="button" class="btn btn-sm btn-success load float-right" style="min-width: 90px;" ng-click="GetLogReport()">Load</button>
                                </div>
                                <div class="col-md-1">
                                    <a class="btn btn-secondary btn-light wait"
                                       title="Print" ng-click="Print()">
                                        <i class="fas fa-print"></i>
                                    </a>
                                </div>

                            </div>

                        </div>
                        <div class="card p-2">
                            <header class="row">
                                <div class="col-md-8">
                                    <div class="clearfix">
                                        <form class="form-inline">
                                            <div class="input-group input-group-sm">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text cstm">Show</span>
                                                </div>
                                                <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.UserWiseLog">
                                                    <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.UserWiseLog">{{pp.text}}</option>
                                                </select>
                                                <div class="input-group-append">
                                                    <span class="input-group-text bg-white"><small>entries</small></span>
                                                </div>
                                            </div>
                                            <div class="input-group input-group-sm table-search-filed">
                                                <input class="form-control form-control-navbar" type="search"
                                                       placeholder="Search" aria-label="Search" ng-model="searchData.UserWiseLog">
                                                <div class="input-group-append">
                                                    <button class="btn btn-default border-left-0" type="submit">
                                                        <i class="fas fa-search"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                                <!-- end col-md-8 -->
                                <div class="col-md-4 text-right">
                                    <div class="dropdown dnld-file">
                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                id="dropdownMenuButton" data-toggle="dropdown"
                                                aria-haspopup="true" aria-expanded="false">
                                            <i class="fas fa-download"></i>
                                        </button>
                                        <div class="dropdown-menu dropdown-menu-right"
                                             aria-labelledby="dropdownMenuButton">
                                            <span class="dropdown-item">Choose an option:</span>
                                            <a class="dropdown-item wait" export-excel table-id="'#maintable'" sheet-name="'userlog'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                            <a class="dropdown-item wait" onClick="$('#maintable').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            <a class="dropdown-item wait" onClick="$('#maintable').tableExport({type:'pdf',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image"> PDF</a>
                                            <a class="dropdown-item wait" onClick="$('#maintable').tableExport({type:'doc',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image"> Word</a>
                                            <a class="dropdown-item wait" onClick="$('#maintable').tableExport({type:'json',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image"> JSON</a>
                                        </div>
                                        <a print-tbl table-id="'#maintable'" class="btn btn-secondary btn-light btn-sm wait"
                                           title="Print">
                                            <i class="fas fa-print"></i>
                                        </a>
                                    </div>


                                </div>
                            </header>
                            <div class="table-scroll-x-y table-scroll mt-2" style="height:100%">
                                <table id="maintable" class="table table-bordered table-hover table-sm">
                                    <thead>
                                        <tr style="text-align:center;font-weight:bold">
                                            <th style="width:60px">
                                                S.No
                                            </th>
                                            <th style="width:90px">
                                                Group
                                            </th>
                                            <th style="width:90px">
                                                User
                                            </th>
                                            <th style="width:100px">
                                                Local IP
                                            </th>
                                            <th style="width: 150px">
                                                Public IP
                                            </th>
                                            <th style="width:150px">
                                                PC Name
                                            </th>
                                            <th style="width:150px">
                                                App Version
                                            </th>
                                            <th style="width:150px">
                                                In DateTime
                                            </th>
                                            <th style="width: 150px">
                                                OutDateTime

                                            </th>
                                    
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr dir-paginate="l in DataColl|orderBy:sortKey:reverse|filter:searchData.UserWiseLog|itemsPerPage:perPage.UserWiseLog" current-page="currentPages.UserWiseLog" pagination-id="UserWiseLogPagination">
                                            <td style="text-align:center">
                                                {{$index+1}}
                                            </td>
                                            <td style="text-align:center">
                                                {{l.GroupName}}
                                            </td>
                                            <td>
                                                {{l.UserName}}
                                            </td>
                                            <td style="text-align:center">
                                                {{l.LocalIP}}
                                            </td>
                                            <td>
                                                {{l.PublicIP}}
                                            </td>
                                            <td>
                                                {{l.PCName}}
                                            </td>
                                            <td>
                                                {{l.AppVersion}}
                                            </td>
                                            <td>
                                                {{l.InDateTime}}
                                            </td>
                                            <td>
                                                {{l.OutDateTime}}
                                            </td>
                                          
                                        </tr>


                                    </tbody>
                                </table>
                            </div>
                            <footer class="row align-items-center pb-3 mt-2">
                                <div class="col-md-12">
                                    <dir-pagination-controls pagination-id="UserWiseLogPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                    </dir-pagination-controls>
                                </div>
                            </footer>
                            <footer class="main-footer">
                                <div class="text-right control-btns">
                                    <button type="button" class="btn btn-default" ng-click="">Reset</button>
                                    <button type="button" class="btn btn-primary" ng-click="">Save</button>
                                </div>
                            </footer>

                        </div>
                    </div>

                </div>

            </section>
            <!-- /.row -->
        </div>
        <!--/. container-fluid -->
    </section>

    <!-- Add ReportTemplates Modal Dailog -->
    <div class="modal fade bd-example-modal-xl sales-invoice-page-modal" id="FrmPrintReport" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenter2Title" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Report Viewer</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <iframe id="frmRpt" style='width: 100%; height: 600px; background-color: white; visibility:visible;' frameborder='0' scrolling='yes'></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>


</div>