@{

    ViewBag.Title = "";
    Layout = null;
}

@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/setup/AllowUserWiseBranch.js?v=20220916"></script>
<div ng-app="myApp" ng-controller="userWiseBranchController" ng-class="{waiting: loadingstatus=='running'}" ng-init="LoadData()">
    <div class="container-fluid">

        <div class="tab-content">
            <div class="card p-2">
                <div class="row">
                    <div class="col-sm-5">
                        <div class="form-group d-flex">
                            <label>Select User:</label>
                            <select class="form-control form-control-sm select2 ml-2" ng-model="newUserWiseBranch.UserId" ng-change="GetAllowEntityList()" style="width:75%;" data-placeholder="**Select User**">
                                <option ng-value="cl.UserId" ng-repeat="cl in UserList">{{cl.UserName}}</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <form class="form-inline float-right">
                            <button type="button"
                                    class="btn btn-md btn-primary mr-2"
                                    style="min-width: 90px; padding-top: 3px; padding-bottom: 3px;" ng-click="SaveUpdateAllowBranch()">
                                <i class="fas fa-database w-t"></i>Update Data
                            </button>
                            <div class="input-group input-group-sm table-search-filed">
                                <input class="form-control form-control-navbar"
                                       type="search"
                                       placeholder="Search"
                                       aria-label="Search" ng-model="searchData.AllowEntity"/>
                                <div class="input-group-append">
                                    <button class="btn btn-default border-left-0"
                                            type="submit">
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class="card p-2">
                <div class="table-scroll-x-y table-scroll mt-2" style="height: calc(100vh - 100px);">
                    <table id="maintable" class="table table-bordered table-hover table-sm">
                        <thead>
                            <tr>
                                <th class="text-center" style="width: 15%; z-index: 3; background-color: #ececec !important">SN.</th>
                                <th style="width: 50%; z-index: 3; background-color: #ececec !important">Branch Name</th>
                                <th class="text-center" style="width: 20%; z-index: 3; background-color: #ececec !important">Allow <input type="checkbox"   class="ml-2" sstyle="width:15px;height:15px;" ng-model="newUserWiseBranch.IsAllow" ng-change="CheckAll()" /></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr ng-repeat="el in AllowBranchList |filter:searchData.AllowEntity">
                                <td class="text-center">{{$index+1}}.</td>
                                <td>{{el.Name}}</td>
                                <td class="text-center"><input type="checkbox"  sstyle="width:15px;height:15px;" ng-model="el.IsAllow" /></td>
                            </tr>
                          
                        </tbody>

                    </table>
                </div>



            </div>
        </div>

    </div>


</div>