@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<style>
    .person-photo-attachment-wrap .img-wrap {
        background-color: #fff;
        border: 1px solid #bbb;
        position: relative;
        overflow: hidden;
        margin-bottom: 1rem;
        width: 100px;
        height: 100px;
    }
</style>


<script src="~/jslib/Setup/UserName.js"></script>
<div ng-app="myApp" ng-controller="UserName" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllUserName()">


        <div class="content">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">User Name</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.UserName">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.UserName">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.UserName">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file" title="Download File">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'debtorcreditortypes'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'pdf',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image"> PDF</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'doc',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image"> Word</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'json',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image"> JSON</a>
                                            </div>
                                            <a print-tbl table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait"
                                               title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>

                                            <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                               data-toggle="modal" data-target="#itemAllocationForModal" data-placement="bottom" title="Filter">
                                                <i class="fas fa-filter"></i>
                                            </a>
                                        </div>


                                    </div>
                                </header>
                                <div class="search-toolbar mt-2">

                                    <div class="table-responsive">
                                        <table class="main-table table table-bordered table-hover table-sm" id="datatable">
                                            <thead>
                                                <tr>
                                                    <th style="text-align: center;  width: 90px;">
                                                        S.No
                                                        <span class="glyphicon sort-icon" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th ng-click="sort('Name')" style="text-align:left;width: 150px ;">
                                                        UserName
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Name'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th ng-click="sort('Alias')" style="text-align: left; width: 120px; ">
                                                        Designation
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Alias'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('Code')" style="text-align:left;width: 120px;">

                                                        Address
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Code'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th style="text-align: center;  width:90px;" class="no-print">Action</th>

                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="beData in UserNameColl | orderBy:sortKey:reverse | filter:searchData.UserName | itemsPerPage:perPage.UserName" current-page="currentPages.UserName" pagination-id="UserNamePagination">

                                                    <td style="text-align:center;">
                                                        {{$index+1}}
                                                    </td>
                                                    <td style="text-align:left;">
                                                        {{beData.UserName}}
                                                    </td>

                                                    <td style="text-align:left;">
                                                        {{beData.Designation}}
                                                    </td>
                                                    <td style="text-align:left;">
                                                        {{beData.Address}}
                                                    </td>
                                                    <td class="project-actions no-print" style="text-align:center;">
                                                        <div class="btn-group-sm">
                                                            <a href="#" class="btn btn-info" ng-click="getUserNameById(beData)"><i class="fas fa-pencil-alt"></i></a>
                                                            <a href="#" class="btn btn-danger" ng-click="deleteUserName(beData,$index)"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>

                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="UserNamePagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                                <div class="">  
                                            <form>
                                                <div class="row border-bottom">
                                                    <div class="col-sm-10">
                                                        <div class="row justify-content-between">
                                                            <div class="col-sm-4">
                                                                <div class="form-group">
                                                                    <label for="exampleFormControlSelect1">User Group</label>
                                                                    <select class="form-control form-control-sm" ng-model="beData.UserId"
                                                                            id="exampleFormControlSelect1">
                                                                        <option ng-value="cl.UserId" ng-repeat="cl in UserGroupList" ng-selected="cl.UserId==beData.UserId">{{cl.GroupName}}</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4">
                                                                <div class="form-group">
                                                                    <label>First Name</label>
                                                                    <input type="text" class="form-control form-control-sm"
                                                                           ng-model="beData.FirstName ">
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4">
                                                                <div class="form-group">
                                                                    <label>Last Name</label>
                                                                    <input type="text" class="form-control form-control-sm"
                                                                           ng-model="beData.LastName">
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="row justify-content-between">
                                                            <div class="col-sm-4 col-md-4">
                                                                <div class="form-group">
                                                                    <label>Designation</label>
                                                                    <input type="text" class="form-control form-control-sm"
                                                                           ng-model="beData.Designation ">
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4 ">
                                                                <div class="form-group">
                                                                    <label>User Name</label>
                                                                    <input type="text" class="form-control form-control-sm"
                                                                           ng-model="beData.UserName">
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4">
                                                                <div class="form-group">
                                                                    <label>Address</label>
                                                                    <input type="text" class="form-control form-control-sm"
                                                                           ng-model="beData.Address ">
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="row justify-content-between">
                                                            <div class="col-sm-4 col-md-4">
                                                                <div class="form-group">
                                                                    <label>Password</label>
                                                                    <input type="password" class="form-control form-control-sm"
                                                                           ng-model="beData.Passoword ">
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4 ">
                                                                <div class="form-group">
                                                                    <label>Re-Password</label>
                                                                    <input type="password" class="form-control form-control-sm"
                                                                           ng-model="beData.RePassword">
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-4 col-md-4 ">
                                                                <div class="form-group">
                                                                    <label>Branch</label>
                                                                    <select class="form-control form-control-sm"
                                                                            id="exampleFormControlSelect1">
                                                                        <option ng-value="cl.BranchId" ng-repeat="cl in BranchList" ng-selected="cl.BranchId==UserName.BranchId">{{cl.Name}}</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="row justify-content-between">
                                                            <div class="col-sm-6 col-md-6">
                                                                <div class="form-group">
                                                                    <label>Mobile</label>
                                                                    <input type="text" class="form-control form-control-sm"
                                                                           ng-model="beData.MobileNO ">
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-6 col-md-6 ">
                                                                <div class="form-group">
                                                                    <label>Email-id</label>
                                                                    <input type="text" class="form-control form-control-sm"
                                                                           ng-model="beData.EMailID">
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-2">
                                                        <label for="" class="invisible">Photo</label>

                                                        <div class="person-photo-attachment-wrap text-center">
                                                            <div class="img-wrap mx-auto">
                                                                <img src="~/wwwroot/dynamic/images/avatar-img.jpg" alt="" class="img-fluid">
                                                            </div>
                                                            <label for="choose-file" type="button" class="btn btn-outline-primary btn-sm"><i class="fas fa-camera w-t"></i> Upload Photo</label>
                                                            <input id="choose-file" type="file" accept=".jpg,.jpeg,.png" style="display: none;" file-model ng-model="newCompanyDetails.CompanyLogoPhoto_TMP" @*after-selected="AddStudentPhoto()"*@ fileread="newCompanyDetails.CompanylogoPhotoData" />

                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row mt-1">
                                                    <div class="col-sm-12 ">
                                                        <h5>User Config</h5>
                                                        <div class="row">
                                                            <div class="col-sm-4 mt-2">
                                                                <div class="form-group d-flex">
                                                                    <label>DeActive After:</label>
                                                                    <input type="text" class="form-control form-control-sm ml-1"
                                                                           style="width: 35%;">
                                                                </div>
                                                                <div class="form-group d-flex mt-3">
                                                                    <label>Start Date:</label>
                                                                    <input type="text" class="form-control form-control-sm ml-4"
                                                                           style="width: 35%;">
                                                                </div>
                                                                <div class="mt-3">
                                                                    <label>Status:</label>
                                                                    <input type="radio" id="active" name="active_deactive"
                                                                           value="active">
                                                                    <label for="active">Active</label>
                                                                    <input type="radio" id="deactive" name="active_deactive"
                                                                           value="deactive">
                                                                    <label for="deactive">Deactive</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-4 mt-2">
                                                                <div class="form-group d-flex">
                                                                    <label>Autoclose Time:</label>
                                                                    <input type="text" class="form-control form-control-sm ml-2"
                                                                           style="width: 35%;" placeholder="5min">
                                                                </div>
                                                                <div class="form-group d-flex mt-3">
                                                                    <label>End Date:</label>
                                                                    <input type="text" class="form-control form-control-sm ml-5"
                                                                           style="width: 35%;">
                                                                </div>
                                                                <div class="mt-3">
                                                                    <label>Logon Hours:</label>
                                                                    <input type="radio" id="active" name="active_deactive"
                                                                           value="active">
                                                                    <label for="active">selected</label>
                                                                    <input type="radio" id="deactive" name="active_deactive"
                                                                           value="deactive">
                                                                    <label for="deactive">non-selected</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-4">
                                                                <div class="form-check ">
                                                                    <input type="checkbox" id="purcase" name="purchaseac">
                                                                    <label for="changepw">User never expire </label>
                                                                </div>
                                                                <div class="form-check ">
                                                                    <input type="checkbox" id="purcase" name="purchaseac">
                                                                    <label for="changepw">User cannot change password</label>
                                                                </div>
                                                                <div class="form-check ">
                                                                    <input type="checkbox" id="purcase" name="purchaseac">
                                                                    <label for="changepw">Change password  first time</label>
                                                                </div>
                                                                <div class="form-check ">
                                                                    <input type="checkbox" id="purcase" name="purchaseac">
                                                                    <label for="changepw">Userwise security</label>
                                                                </div>
                                                                <div class="form-check ">
                                                                    <input type="checkbox" id="purcase" name="purchaseac">
                                                                    <label for="changepw">Userwise Autopost Transaction</label>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="row mt-3">
                                                            <div class="col-sm-6">
                                                                <div class="form-group d-flex">
                                                                    <label>Mac Address:</label>
                                                                    <input type="text" class="form-control form-control-sm ml-3"
                                                                           style="width: 70%;">
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-6">
                                                                <div class="form-group d-flex">
                                                                    <label>Public IP:</label>
                                                                    <input type="text" class="form-control form-control-sm ml-3"
                                                                           style="width: 70%;">
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
