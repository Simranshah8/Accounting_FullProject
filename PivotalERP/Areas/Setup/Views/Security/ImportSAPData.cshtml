@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/setup/ImportSAP.js"></script>
<div ng-app="myApp" ng-controller="importSAPServiceCntrl" ng-class="{waiting: loadingstatus=='running'}">
    <div class="content">
        <div class="container-fluid">
            <div class="pt-1"></div>
            <div class="row">
                <div class="col-md-6">
                    <div class="card p-2">
                        <div class="row">
                            <div class="col-md-10">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label>Import Customer</label>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group clearfix">
                                            <div class="icheck-primary d-inline">
                                                <input type="radio" id="radioPrimary1" name="r1" ng-value="2" ng-model="beData.ForDate1">
                                                <label for="radioPrimary1">
                                                    Yesterday
                                                </label>
                                            </div>
                                            <div class="icheck-primary d-inline ml-3">
                                                <input type="radio" id="radioPrimary2" name="r1" ng-value="1" ng-model="beData.ForDate1">
                                                <label for="radioPrimary2">
                                                    Today
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <button class="btn btn-sm btn-primary load float-right" ng-click="importUpdateSAP(1)">Import</button>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card p-2">
                        <div class="row">
                            <div class="col-md-10">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label>General Ledger</label>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group clearfix">
                                            <div class="icheck-primary d-inline">
                                                <input type="radio" id="radioPrimary3" name="r2" ng-value="2" ng-model="beData.ForDate2">
                                                <label for="radioPrimary3">
                                                    Yesterday
                                                </label>
                                            </div>
                                            <div class="icheck-primary d-inline ml-3">
                                                <input type="radio" id="radioPrimary4" name="r2" ng-value="1" ng-model="beData.ForDate2">
                                                <label for="radioPrimary4">
                                                    Today
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                            <div class="col-md-2">
                                <button class="btn btn-sm btn-primary load float-right" ng-click="importUpdateSAP(2)">Import</button>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card p-2">
                        <div class="row">
                            <div class="col-md-9">
                                <div class="row">
                                    <div class="col-md-4">
                                        <label>Product </label>
                                    </div>
                                    <div class="col-md-8">
                                        <div class="form-group clearfix">
                                            <div class="icheck-primary d-inline">
                                                <input type="radio" id="radioPrimary5" name="r3" ng-value="2" ng-model="beData.ForDate3">
                                                <label for="radioPrimary5">
                                                    Yesterday
                                                </label>
                                            </div>
                                            <div class="icheck-primary d-inline ml-3">
                                                <input type="radio" id="radioPrimary6" name="r3" ng-value="1" ng-model="beData.ForDate3">
                                                <label for="radioPrimary6">
                                                    Today
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-sm btn-primary load float-right" ng-click="importUpdateSAP(3)">Import</button>
                            </div>
                        </div>

                    </div>
                </div>
                    
        
            </div>
        </div>
        <!-- /.container-fluid -->
    </div>
</div>