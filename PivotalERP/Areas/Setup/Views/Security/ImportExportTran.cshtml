@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/setup/TranImportExport.js"></script> 
<div ng-app="myApp" ng-controller="TranImportExportCtrl" ng-class="{waiting: loadingstatus=='running'}">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-6">
                <div class="card ">
                    <div class="card-header py-1">
                        <h5 class="mb-0">Export Data</h5>
                    </div>
                    <div class="card-body p-2">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group d-flex">
                                    <label class="mt-1 mr-2" style="width:155px;">Select Entity Name</label>
                                    <select class="form-control form-control-sm select2" style="width:100%" ng-model="exportPara.EntityId"  data-placeholder="**Select Entity**">
                                        <option ng-value="er.id" ng-repeat="er in EntityColl">{{er.text}}</option>                                        
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label>Period From</label>
                                    </div>
                                    <div class="col-md-6">
                                        <input type="text"
                                               class="form-control form-control-sm" date-picker ng-model="exportPara.DateFrom_TMP" date-detail="exportPara.DateFromDet">
                                    </div>
                                </div>

                            </div>
                            <div class="col-md-6">

                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="float-right">To</label>
                                    </div>
                                    <div class="col-md-6">
                                        <input type="text"
                                               class="form-control form-control-sm" date-picker ng-model="exportPara.DateTo_TMP" date-detail="exportPara.DateToDet">
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mt-2">
                                    <div class="col-md-6">
                                        <label>Voucher No From</label>
                                    </div>
                                    <div class="col-md-6">
                                        <input type="number" class="form-control form-control-sm"  ng-model="exportPara.FromNo"/>
                                    </div>
                                </div>

                            </div>
                            <div class="col-md-6">
                                <div class="row mt-2">
                                    <div class="col-md-6">
                                        <label class="float-right">To</label>
                                    </div>
                                    <div class="col-md-6">
                                        <input type="number" class="form-control form-control-sm" ng-model="exportPara.ToNo"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <button class="btn load btn-primary mt-2" style="width:120px;" ng-click="GetAllDataForExport()">Get Data</button>
                            </div>
                            <div class="col-md-6">
                                <a  class="btn load btn-primary mt-2 float-right" style="width:120px;" download="{{exportPara.ExportData.ResponseId}}" href="~/Setup/Security/DownloadReportTemplates?fpath={{exportPara.ExportData.ResponseMSG}}">Download </a>                
                            </div>
                        </div>
                        <label class="mt-3">No of Data : {{exportPara.ExportData.Count}}</label>
                    </div>
                    <!-- /.card -->
                </div>
            </div>
            <div class="col-md-6">
                <div class="card ">
                    <div class="card-header py-1">
                        <h5 class="mb-0">Import Data</h5>
                    </div>
                    <div class="card-body p-2">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="form-group d-flex">
                                    <label class="mt-1 mr-2" style="width:190px;">Select Entity Name</label>
                                    <select class="form-control form-control-sm select2" style="width:100%" ng-model="importPara.EntityId" data-placeholder="**Select Entity**">
                                        <option ng-value="er.id" ng-repeat="er in EntityColl">{{er.text}}</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4"> 
                                <input type="file" class="form-control-file border p-1"  file-model ng-model="importPara.Document_TMP" fileread="importPara.DocumentData">
                            </div>
                        </div>
                        <div class="row mt-2">

                            @*<div class="col-md-8">
                                <select class="form-control form-control-sm select2" style="width:100%">
                                    <option></option>
                                    <option value="1">Type 1</option>
                                    <option value="2">Type 2</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <button class="btn load btn-default float-right">Show Not Found List</button>
                            </div>*@
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <button class="btn load btn-primary mt-2" style="width:120px;">Reset Data</button>
                            </div>
                            <div class="col-md-6">
                                <button class="btn load btn-primary mt-2 float-right" style="width:120px;" ng-click="UploadJSONDataForImport()">Import Data</button>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-4">
                                <div class="custom-control custom-checkbox">
                                    <input class="custom-control-input" type="checkbox"
                                           id="customCheckbox1" ng-value="true" ng-model="importPara.CreateNonExistsMaster">
                                    <label for="customCheckbox1"
                                           class="custom-control-label">
                                        Create Non Exists Master
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="custom-control custom-checkbox float-right">
                                    <input class="custom-control-input" type="checkbox"
                                           id="customCheckbox2" ng-value="true" ng-model="importPara.OverideExistData">
                                    <label for="customCheckbox2"
                                           class="custom-control-label">
                                        Overide Existing Voucher
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="custom-control custom-checkbox float-right">
                                    <input class="custom-control-input" type="checkbox"
                                           id="customCheckbox4" ng-value="true" ng-model="importPara.ContinueOnError">
                                    <label for="customCheckbox4"
                                           class="custom-control-label">
                                        Continue On Error
                                    </label>
                                </div>
                            </div>
                        </div>

                    </div>
                    <!-- /.card -->
                </div>
            </div>
        </div>

        <div class="card p-2">
            @*<div id="datatable" style="height: calc(100vh - 16rem);width: 100%;" class="ag-theme-alpine"></div>*@
        </div>
    </div>
</div>

