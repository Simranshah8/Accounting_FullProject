@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/Setup/PurchaseFeatures.js"></script>
<div ng-app="myApp" ng-controller="PurchaseFeatures"  ng-class="{waiting: loadingstatus=='running'}">

    <div class="container-fluid">

        <div class="tab-content">

            <div class="card">
                <div class="card-header header-corner-triangle">
                    <h3 class="card-title">Purchase Features</h3>
                </div>

                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label>Allow Quotation</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary25" name="r13" ng-model="beData.AllowQuotation">
                                            <label for="radioPrimary25">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary26" name="r13" ng-model="beData.AllowQuotation">
                                            <label for="radioPrimary26">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label class="mr-5">Allow Order</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary27" name="r15" value="Yes" ng-model="beData.AllowOrder"/>
                                            <label for="radioPrimary27">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary28" name="r15" value="No" ng-model="beData.AllowOrder">
                                            <label for="radioPrimary28">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label>Allow ReceiptNote</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary29" name="r18" value="Yes" ng-model="beData.AllowReceiptNote">
                                            <label for="radioPrimary29">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary30" name="r18" value="No" ng-model="beData.AllowReceiptNote">
                                            <label for="radioPrimary30">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label>SalesRate PurchaseInvoice</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary31" name="r19" value="Yes" ng-model="beData.AllowSalesRateInPurchaseInvoice">
                                            <label for="radioPrimary31">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary32" name="r19" value="No" ng-model="beData.AllowSalesRateInPurchaseInvoice">
                                            <label for="radioPrimary32">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label>Allow IndentForm</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary33" name="r21" value="Yes" ng-model="beData.AllowIndent">
                                            <label for="radioPrimary33">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary34" name="r21" value="No" ng-model="beData.AllowIndent">
                                            <label for="radioPrimary34">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label>Allow IncomingGoods(IG)</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary35" name="r22" value="Yes" ng-model="beData.AllowIG">
                                            <label for="radioPrimary35">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary36" name="r22" value="No" ng-model="beData.AllowIG">
                                            <label for="radioPrimary36">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label>Allow AutoTDSOnInvoice</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary40" name="r23" value="Yes" ng-model="beData.AllowAutoTDS">
                                            <label for="radioPrimary40">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary38" name="r23" value="No" ng-model="beData.AllowAutoTDS">
                                            <label for="radioPrimary38">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label>LedgerAllocation ReceiptNote</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary41" name="r24" value="Yes" ng-model="beData.AllowLedAllocationReceiptNote">
                                            <label for="radioPrimary41">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary42" name="r24" value="No" ng-model="beData.AllowLedAllocationReceiptNote">
                                            <label for="radioPrimary42">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label>ProductWise PurchaseLedger</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary43" name="r25" value="Yes" ng-model="beData.ProductWisePurchaseLedger">
                                            <label for="radioPrimary43">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary44" name="r25" value="No" ng-model="beData.ProductWisePurchaseLedger">
                                            <label for="radioPrimary44">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label>Show ProductWiseLedger</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary45" name="r26" value="Yes" ng-model="beData.ShowProductLedger">
                                            <label for="radioPrimary45">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary46" name="r26" value="No" ng-model="beData.ShowProductLedger">
                                            <label for="radioPrimary46">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label>ProductWise AdditionalCost</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary47" name="r27" value="Yes" ng-model="beData.ProductWiseAditinalCost">
                                            <label for="radioPrimary47">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary48" name="r27" value="No" ng-model="beData.ProductWiseAditinalCost">
                                            <label for="radioPrimary48">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-5">
                                    <label>ProductRate DetailsInInvoice</label>
                                </div>
                                <div class="col-md-7">
                                    <div class="clearfix">
                                        <div class="icheck-primary d-inline">
                                            <input type="radio" id="radioPrimary49" name="r28" value="Yes" ng-model="beData.ProductWiseAID">
                                            <label for="radioPrimary49">Yes</label>
                                        </div>
                                        <div class="icheck-primary d-inline ml-3">
                                            <input type="radio" id="radioPrimary50" name="r28" value="No" ng-model="beData.ProductWiseAID">
                                            <label for="radioPrimary50">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <footer class="main-footer">
                    <div class="text-right control-btns">
                        <button type="button" class="btn btn-default" ng-click="ClearFields()">Reset</button>
                        <button type="button" class="btn btn-primary" ng-click="AddNewPurchaseFeatures()">Save</button>
                    </div>
                </footer>
            </div>
        </div>

    </div>


</div>