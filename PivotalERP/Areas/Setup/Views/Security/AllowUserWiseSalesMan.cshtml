@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>
<div ng-app="myApp" ng-controller="AllowUserWiseSalesMan">

    <div class="container-fluid">

        <div class="tab-content">
            <div class="card p-2">
                <div class="row">
                    <div class="col-sm-5">
                        <div class="form-group d-flex">
                            <label class="mt-1">Select User Name</label>
                            <select class="form-control form-control-sm select2 ml-2" style="width:50%">
                                <option>Admin</option>
                                <option>adminuat</option>
                                <option>HRAPI</option>

                            </select>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <form class="form-inline float-right">
                            <button type="button"
                                    class="btn btn-md btn-primary mr-2"
                                    style="min-width: 90px; padding-top: 3px; padding-bottom: 3px;">
                                <i class="fas fa-database w-t"></i>Update Data
                            </button>
                            <div class="input-group input-group-sm table-search-filed">
                                <input class="form-control form-control-navbar"
                                       type="search"
                                       placeholder="Search"
                                       aria-label="Search" />
                                <div class="input-group-append">
                                    <button class="btn btn-default border-left-0"
                                            type="submit">
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>

                </div>
            </div>
            <div class="card p-2">               
                <div class="table-scroll-x-y table-scroll mt-2" style="height: calc(100vh - 100px);">
                    <table id="maintable" class="table table-bordered table-hover table-sm">
                        <thead>
                            <tr>
                                <th class="text-center" style="width: 5%; z-index: 3; background-color: #ececec !important">SN.</th>
                                <th style="width: 10%; z-index: 3; background-color: #ececec !important">Code</th>
                                <th style="width: 40%; z-index: 3; background-color: #ececec !important">Name</th>
                                <th style="width: 10%; z-index: 3; background-color: #ececec !important">Mobile No</th>
                                <th style="width: 10%; z-index: 3; background-color: #ececec !important">Allow Salesman <input type="checkbox" ng-checked="true" class="ml-2" style="width:15px;height:15px;" /></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-center">1</td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td class="text-center"><input type="checkbox" ng-checked="true" style="width:15px;height:15px;" /></td>
                            </tr>
                        </tbody>                     
                        
                    </table>
                </div>

              
            </div>
        </div>

    </div>


</div>