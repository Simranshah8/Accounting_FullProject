@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/setup/security.js"></script>

<div ng-app="myApp" ng-controller="oneSignalSetupCtrl" ng-class="{waiting: loadingstatus=='running'}">
     
    <div class="content">
        <div class="container-fluid">

            <div class="card">
                <div class="card-header header-corner-triangle">
                    <h3 class="card-title">OneSignal Setup For Notification</h3>
                </div>
                <div class="card-body px-5 pb-5 pt-4">
                    <form>
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>APP Id</label>
                                    <input type="text" class="form-control" ng-model="beData.ApiId">
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>API Key</label>
                                    <input type="text" class="form-control" ng-model="beData.ApiKey">
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>SMS User</label>
                                    <select class="form-control form-control-sm select2 ml-2" active-select2 ng-model="beData.UserId">                                  
                                        <option ng-value="cl.UserId" ng-repeat="cl in UserList" ng-selected="beData.UserId==cl.UserId">{{cl.UserName}}</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>SMS Api</label>
                                    <input type="text" class="form-control" ng-model="beData.SmsAPI">
                                </div>
                            </div>
                        </div>
                    </form>
                    <footer class="main-footer">
                        <div class="text-right control-btns">
                            @*<button type="button" class="btn btn-default">Cancel</button>*@
                            <button type="button" class="btn btn-primary" ng-click="UpdateOneSignalSetup()" ng-disabled="loadingstatus=='running'">Save</button>
                        </div>

                    </footer>
                </div>
            </div>

        </div>
        <!-- /.container-fluid -->
    </div>
</div>