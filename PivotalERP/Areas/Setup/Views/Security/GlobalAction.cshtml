@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>
<script src="~/jslib/Setup/importData.js?v=1"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="GlobalActionController" ng-init="LoadData()">
    <!-- Main content -->
    @RenderPage("~/Views/Global/_WaitDialog.cshtml")
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="tab-content">
                    <!-- form area starts -->
                    <div id="allow-branch-form">
                        <div class="card card-default">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-3">
                                                <div class="form-group">
                                                    <label for="">Action </label>
                                                    <select class="form-control form-control-sm select2" ng-model="beData.ActionType">
                                                        <option ng-value="cl.id" ng-repeat="cl in ActionTypeColl">{{cl.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-3" ng-show="beData.ActionType==26">
                                                <div class="form-group">
                                                    <label>Voucher Type<span style="color:red">*</span></label>
                                                    <select class="form-control form-control-sm" style="width: 100%;" ng-model="beData.VoucherType" data-placeholder="**Select Voucher Type**">
                                                        <option ng-repeat="vt in VoucherTypeList" ng-value="vt.id">{{vt.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-3" ng-show="beData.ActionType==45">
                                                <div class="form-group">
                                                    <label>For Year<span style="color:red">*</span></label>
                                                    <select class="form-control form-control-sm" style="width: 100%;" ng-model="beData.CostClassId" data-placeholder="**For Year**">
                                                        <option ng-repeat="vt in CostClassColl" ng-value="vt.CostClassId">{{vt.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-3" ng-show="beData.ActionType==45">
                                                <div class="form-group">
                                                    <label>For Year<span style="color:red">*</span></label>
                                                    <select class="form-control form-control-sm" style="width: 100%;" ng-model="beData.BranchId" data-placeholder="**Select Branch**">
                                                        <option ng-repeat="vt in BranchColl" ng-value="vt.BranchId">{{vt.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group">
                                                    <label for="">Email Id </label>
                                                    <input type="email" class="form-control form-control-sm" ng-model="beData.EmailId" />
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label for="">OTP</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.OTP" maxlength="10" />
                                                </div>
                                            </div>
                                            <div class="col-md-2 mt-4">
                                                <button type="button" class="btn  btn-success" style="min-width: 90px;" ng-click="GenerateOTP()">Send OTP</button>
                                                <button type="button" class="btn  btn-success" style="min-width: 90px;" ng-click="PerformAction()">Perform Action</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- /.row -->
        </div>
        <!--/. container-fluid -->
    </section>
    <!-- /.content -->
    <!-- model form for table input -->
    <div class="modal fade"
         id="AddNewExcel"
         tabindex="-1"
         role="dialog"
         aria-labelledby="exampleModalLabel"
         aria-hidden="true"
         style="margin-top:0px;margin-left: 60px;">
        <div class="modal-dialog modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">
                        Import Data
                    </h5>
                    <button type="button"
                            class="close"
                            data-dismiss="modal"
                            aria-label="Close">
                        <div aria-hidden="true">&times;</div>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label class="control-label">
                                Select Sheet Name <span id="ErrName" style="color:red;"></span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-addon"><i class="fa fa-info"></i></span>
                                <select ng-model="SelectedSheet" class="form-control input-sm" ng-change="LoadProperties()">
                                    <option ng-repeat="ttl in SheetColl" value="{{ttl}}">{{ttl}}</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12" id="tblPart">
                        <div class="box-body scroller">
                            <div class="table-scroll-x-y table-scroll" style="max-height:360px!important;">
                                <table cellpadding="12" class="table table-bordered table-hover enquiry-table" id="clientTable">
                                    <thead>
                                        <tr>
                                            <td class="col2">S.No.</td>
                                            <td class="col1">Target Fields Name</td>
                                            <td class="col3">Source Fields Name</td>
                                            <td class="col4">Default Value</td>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr id="tablerow0" ng-repeat="newBeData in PropertiesColl ">
                                            <td class="col1">
                                                {{$index+1}}
                                            </td>
                                            <td class="col3">
                                                {{newBeData.PropertyName}}
                                            </td>
                                            <td class="col4">
                                                <select ng-model="newBeData.Id" class="form-control input-sm">
                                                    <option ng-repeat="cl in ColumnColl track by cl.Id" value="{{cl.Id}}">
                                                        {{cl.Name}}
                                                    </option>
                                                </select>
                                            </td>
                                            <td>
                                                <input type="text" class="form-control input-sm" ng-model="newBeData.DefaultValue" />
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="time-label">
                    <span class="d-block border-0 p-3 text-center">
                        <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="ImportDataExcel()">ImportData</button>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <!-- modal form for table input close -->
    <!-- model form for table input -->
    <div class="modal fade"
         id="UpdateNewExcel"
         tabindex="-1"
         role="dialog"
         aria-labelledby="exampleModalLabel"
         aria-hidden="true"
         style="margin-top:0px;margin-left: 60px;">
        <div class="modal-dialog modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">
                        Update Data
                    </h5>
                    <button type="button"
                            class="close"
                            data-dismiss="modal"
                            aria-label="Close">
                        <div aria-hidden="true">&times;</div>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label class="control-label">
                                Select Sheet Name <span id="ErrName" style="color:red;"></span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-addon"><i class="fa fa-info"></i></span>
                                <select ng-model="SelectedSheet" class="form-control input-sm" ng-change="LoadProperties()">
                                    <option ng-repeat="ttl in SheetColl" value="{{ttl}}">{{ttl}}</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12" id="tblPart">
                        <div class="box-body scroller">
                            <div class="table-scroll-x-y table-scroll" style="max-height:360px!important;">
                                <table cellpadding="12" class="table table-bordered table-hover enquiry-table" id="clientTable">
                                    <thead>
                                        <tr>
                                            <td class="col2">S.No.</td>
                                            <td class="col1">Target Fields Name</td>
                                            <td class="col3">Source Fields Name</td>
                                            <td class="col4">Default Value</td>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr id="tablerow0" ng-repeat="newBeData in SelectedPropertiesColl ">
                                            <td class="col1">
                                                <label class="col-sm-12">
                                                    {{$index+1}}
                                                </label>
                                            </td>
                                            <td class="col3">
                                                <div class="editor-field">
                                                    <select ng-model="newBeData.PropertyName" class="form-control input-sm">
                                                        <option ng-repeat="et in PropertiesColl" value="{{et.PropertyName}}">
                                                            {{et.PropertyName}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </td>
                                            <td class="col4">
                                                <select ng-model="newBeData.Id" class="form-control input-sm">
                                                    <option ng-repeat="cl in ColumnColl track by cl.Id" value="{{cl.Id}}">
                                                        {{cl.Name}}
                                                    </option>
                                                </select>
                                            </td>
                                            <td>
                                                <a class="btn btn-default btn-xs" ng-click="addrow($index)"><i class="fa fa-plus"></i></a>
                                                <a class="btn btn-default btn-xs" ng-click="delete($index)"><i class="fa fa-trash"></i></a>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="time-label">
                    <span class="d-block border-0 p-3 text-center">
                        <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="UpdateDataExcel()">ImportData</button>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <!-- modal form for table input close -->
</div>