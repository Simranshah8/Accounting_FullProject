@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>
<script src="~/jslib/Setup/Job Card/JobAssign.js"></script>
<div ng-app="myApp" ng-controller="JobAssign" ng-class="{waiting: loadingstatus=='running'}" ng-init="Loaddata()">
    <div class="box-body">
        <div class="pt-1"></div>
        <div class="content">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group d-flex">
                            <label class="mt-1 text-nowrap" style="width:120px">Job No.</label>
                            <input type="text" class="form-control form-control-sm" ng-model="beData.JobNo" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group d-flex">
                            <label class="mt-1 text-nowrap" style="width:150px">Mechanic</label>
                            <input type="text" class="form-control form-control-sm" readonly ng-model="beData.Mechanic"/>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group d-flex">
                            <label class="mt-1 text-nowrap"  style="min-width:90px">Assign Date</label>
                            <input type="text" date-picker class="form-control form-control-sm" ng-model="beData.AssignDate" date-details="AssignDateDet"/>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group d-flex">                            
                            <input type="time" class="form-control form-control-sm" ng-model="beData.AssignTime"/>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header py-1 header-primary" style="background-color: #068abf; color: #ffffff;">
                        <h5 class="mb-0">Job Card Details</h5>
                    </div>
                    <div class="card-body p-2">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="min-width:120px!important">Engine No</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.EngineNo" />
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="width:120px">Ch.Srl.No.</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.ChSrlNo" />
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="min-width:90px">Regd. No.</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.RegdNo" />
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="width:120px">Party</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.Party" />
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="min-width:120px!important">Service Engineer</label>
                                    <select class="form-control form-control-sm select2" readonly ng-model="beData.ServiceEngineerId">
                                        <option></option>
                                        <option>1</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="min-width:90px">Arrival Date</label>
                                    <input type="text" date-picker class="form-control form-control-sm" ng-model="beData.ArrivalDate" date-details="ArrivalDateDet" />
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group d-flex">
                                    <input type="time" class="form-control form-control-sm" ng-model="beData.ArrivalTime" />
                                </div>
                            </div>

                            <div class="col-md-12">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="min-width:120px!important">Remarks</label>
                                    <textarea class="form-control form-control-sm" id="exampleFormControlTextarea1" rows="1" ng-model="beData.Remarks"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <footer class="main-footer">
                    <div class="text-right control-btns">
                        <button type="button" class="btn btn-default btn" ng-click="ClearjobAssign()"> <span class="glyphicon glyphicon-remove"></span>Clear</button>
                        <button type="button" class="btn btn-primary btn" ng-click="AddJobAssign()" ng-disabled="loadingstatus=='running'"><span class="glyphicon glyphicon-save"></span>Accept</button>
                    </div>
                </footer>
            </div>
        </div>
    </div>
</div>