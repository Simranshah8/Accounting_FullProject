@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/Setup/Job Card/ServiceMembers.js"></script>
<div ng-app="myApp" ng-controller="ServiceMembers" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllServiceMembers()">
    <div class="box-body">
        <div class="pt-1"></div>
        <div class="content">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">                    
                    <div class="card-body">
                        <div class="p-2">
                            <form>
                                <div class="row">
                                    <div class="col-sm-6">
                                        <div class="form-group">
                                            <label>Name</label>
                                            <input type="text" class="form-control form-control-sm" ng-model="beData.Name">
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="form-group">
                                            <label>Address</label>
                                            <input type="text" class="form-control form-control-sm" ng-model="beData.Address">
                                        </div>
                                    </div>

                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Mobile No</label>
                                            <input type="text" class="form-control form-control-sm" ng-model="beData.Mobile">
                                        </div>
                                    </div>
                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Email Id</label>
                                            <input type="text" class="form-control form-control-sm" ng-model="beData.Email">
                                        </div>
                                    </div>
                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Job Title</label>
                                            <select class="form-control form-control-sm select2" disabled ng-model="beData.JobTitle">
                                                <option></option>
                                                <option>1</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Branch</label>
                                           <select class="form-control form-control-sm select2" disabled ng-model="beData.BranchId">
                                               <option></option>
                                               <option>1</option>
                                           </select>
                                        </div>
                                    </div>

                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>User</label>
                                            <select class="form-control form-control-sm select2" ng-model="beData.UserId">
                                                <option></option>
                                                <option>1</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </form>
                            <footer class="main-footer">
                                <div class="text-right control-btns">
                                    <button type="button" class="btn btn-default btn" ng-click="ClearFields()"> <span class="glyphicon glyphicon-remove"></span>Clear</button>
                                    <button type="button" class="btn btn-primary btn" ng-click="SaveUpdateServiceMembers()" ng-disabled="loadingstatus=='running'"><span class="glyphicon glyphicon-save"></span>Accept</button>
                                </div>
                            </footer>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->
        </div>
    </div>
</div>
