@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>

<script src="~/jslib/Setup/Job Card/PartsDemandList.js"></script>
<div ng-app="myApp" ng-controller="PartsDemandList" ng-class="{waiting: loadingstatus=='running'}" ng-init="LoadData()">
    <div class="box-body">
        <div class="pt-1"></div>
        <div class="content">
            <div class="container-fluid">
                <div class="row">

                    <div class="col-md-3">
                        <div class="form-group d-flex">
                            <label class="mt-1 text-nowrap" style="width:100px">Job No.</label>
                            <input type="text" class="form-control form-control-sm" ng-model="beData.JobNo" />
                        </div>
                    </div>

                </div>

                <div class="card">
                    <div class="card-header py-1 header-primary" style="background-color: #068abf; color: #ffffff;">
                        <h5 class="mb-0">Job Card Details</h5>
                    </div>
                    <div class="card-body p-2">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="width:120px">Engine No</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.EngineNo" />
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="width:120px">Ch.Srl.No.</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.ChassisNo" />
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="width:120px">Regd. No.</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.RegdNo" />
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="width:120px">Party</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.Party" />
                                </div>
                            </div>
                        </div>

                        <div class="table-scroll-x-y table-scroll mt-2" style="max-height: calc(100vh - 202px);">
                            <table id="maintable" class="table table-bordered table-hover table-sm">
                                <thead>
                                    <tr>
                                        <th style="width:200px; z-index: 3; background-color: #ececec !important">Product</th>
                                        <th style="width:200px; z-index: 3; background-color: #ececec !important">Remarks</th>
                                        <th class="text-center" style="width:120px; z-index: 3; background-color: #ececec !important">Demand Date</th>
                                        <th class="text-center" style="width: 100px; z-index: 3; background-color: #ececec !important">Demand Qty</th>
                                        <th class="text-center" style="width: 90px; z-index: 3; background-color: #ececec !important">Issue Qty</th>
                                        <th class="text-center" style="width: 90px; z-index: 3; background-color: #ececec !important">Return Qty</th>
                                        <th class="text-center" style="width: 100px; z-index: 3; background-color: #ececec !important">Balanced Qty</th>
                                        <th class="text-center" style="width: 90px; z-index: 3; background-color: #ececec !important">Rate</th>
                                        <th class="text-center" style="width: 100px; z-index: 3; background-color: #ececec !important">Amount</th>
                                        <th class="text-center" style="width: 80px; z-index: 3; background-color: #ececec !important">Action</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <tr ng-repeat="pd in beData.PartsDemandColl">
                                        <td>
                                            <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-product ng-model="sp.ProductId" id="cboProduct"
                                                    placeholder=" Select Product  " showdetails="true" product-detail="sp.productDetail" side-bar-data="sp.sideBarData">
                                            </select>
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" ng-model="pd.Remarks">
                                        </td>
                                        <td>
                                            <input type="text" date-picker class="form-control form-control-sm" ng-model="pd.DemandDate" date-details="DemandDateDet">
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="pd.DemandQty" onfocus="this.select()" style="text-align: right">
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="pd.IssueQty" onfocus="this.select()" style="text-align: right">
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="pd.ReturnQty" onfocus="this.select()" style="text-align: right">
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="pd.BalancedQty" onfocus="this.select()" style="text-align: right">
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="pd.Rate" onfocus="this.select()" style="text-align: right">
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="pd.Amount" onfocus="this.select()" style="text-align: right">
                                        </td>
                                        <td class="text-center">
                                            <div>
                                                <a class="p-1" ng-click="AddPartsDemandListDet()" data-original-title="View doc">
                                                    <i class="fas fa-plus text-secondary"></i>
                                                </a>

                                                <a class="p-1" ng-click="delPartsDemandListDet($index)">
                                                    <i class="fas fa-trash-alt text-danger"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>

                            </table>
                        </div>

                    </div>
                </div>
                <footer class="main-footer">
                    <div class="text-right control-btns">
                        <button type="button" class="btn btn-default btn" ng-click="ClearDemandList()"> <span class="glyphicon glyphicon-remove"></span>Clear</button>
                        <button type="button" class="btn btn-primary btn" ng-click="SaveUpdatePartsDemandList()" ng-disabled="loadingstatus=='running'"><span class="glyphicon glyphicon-save"></span>Accept</button>
                    </div>
                </footer>
            </div>
        </div>
    </div>
</div>