
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/Appointment/Transaction/QuickAppointment.js"></script>
<style>
    .alert-pink {
        background-color: #fdecea;
        color: #b71c1c;
        border-color: #f5c6cb;
    }
</style>
<div id="ActionDiv" ng-app="myApp" ng-controller="QuickAppointment" ng-init="LoadData()">
    <div class="content">
        <div class="container-fluid">
            <div class="card">
                <div class="card-header p-0 border-bottom-0">
                    <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false" ng-click="ClearFields()">Quick Appointment</a>
                        </li>
                    </ul>
                </div>
                <div class="p-2">
                    <div class="tab-content" id="custom-tabs-four-tabContent">
                        <div class="tab-pane fade  show active" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                            <div class=" mb-1">
                                <div class=" py-1">
                                    <div class="row align-items-center">
                                        <div class="col-md-4">
                                            <label class=" mb-1">Search Patient</label>
                                            <div class="input-group-prepend">
                                                <select class="form-control select2 form-control-sm"
                                                        ng-model="searchData.QuickAppointment"
                                                        data-placeholder="** Search By Patient Name **">
                                                    <option></option>
                                                    <option>Test</option>
                                                </select>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="table-scroll-x-y mb-3 mt-2" style="height:auto!important;max-height:calc(100vh - 10rem)!important">
                                <table cellpadding="12" class="main-table table mb-2 mt-2 table-bordered table-hover table-sm" id="datatable">
                                    <thead>
                                        <tr>
                                            <th style="width: 50px;" class="text-center">S.No</th>
                                            <th style="width: 202px;">Patient Reg.No</th>
                                            <th style="width: 150px ;">Name</th>
                                            <th style="width: 150px ;">Age/Sex</th>
                                            <th style="width: 150px;">Contact No</th>
                                            <th style="width: 150px ;">Nationality</th>
                                            <th style="width: 209px;">Blood Group</th>
                                            <th style="width: 150px ;">Patient Id</th>
                                            <th style="width: 150px ;">Visit Date</th>
                                            <th style="width: 150px ;">Days Since Visit </th>
                                            <th style="width: 150px ;">Address</th>
                                            <th style="text-align:center" class="no-print " width="145px">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td class="text-center">1</td>
                                            <td>121212</td>
                                            <td>Rahul</td>
                                            <td>24Y/Male</td>
                                            <td>928554385093</td>
                                            <td>Nepali</td>
                                            <td>A+</td>
                                            <td>298349028</td>
                                            <td>2080/01/23</td>
                                            <td>78 days</td>
                                            <td>Kathmandu</td>
                                            <td></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>