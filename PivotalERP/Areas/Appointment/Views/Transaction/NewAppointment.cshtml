
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/Appointment/Transaction/NewAppointment.js"></script>
<div id="ActionDiv" ng-app="myApp" ng-controller="NewAppointment" ng-init="LoadData()">
    <div class="content">
        <div class="container-fluid">
            <div class="card">
                <div class="card-header p-0 border-bottom-0">
                    <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false" ng-click="ClearFields()">New Appointment</a>
                        </li>
                    </ul>
                </div>
                <div class="p-2">
                    <div class="tab-content" id="custom-tabs-four-tabContent">
                        <div class="tab-pane fade  show active" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab" ng-show="NewAppointmentForm">
                            <div>
                                <form>
                                    <div class="row">
                                        <div class=" row col-md-10">
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>First Name</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="NewAppointment.FirstName">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Last Name</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="NewAppointment.LastName">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Gender</label>
                                                    <select class="form-control form-control-sm form-select" ng-model="NewAppointment.GenderId">
                                                        <option ng-value="G.id" ng-repeat="G in GenderColl" ng-selected="G.id == NewAppointment.GenderId">{{ G.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>DOB</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="NewAppointment.DOB_TMP" date-detail="NewAppointment.DOBDet" />
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Age (yy-mm-dd)</label>
                                                    <div class="d-flex gap-1">
                                                        <input type="number" class="form-control form-control-sm" placeholder="2020" ng-model="NewAppointment.AgeYear">
                                                        <input type="number" class="form-control form-control-sm" placeholder="1" ng-model="NewAppointment.AgeMonth">
                                                        <input type="number" class="form-control form-control-sm" placeholder="1" ng-model="NewAppointment.AgeDay">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Blood Group</label>
                                                    <select class="form-control form-control-sm select2"
                                                            ng-model="NewAppointment.BloodGroupId">
                                                        <option ng-repeat="bg in BloodGroupList"
                                                                ng-value="bg"
                                                                ng-selected="bg == NewAppointment.BloodGroup">
                                                            {{bg}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Ethnicity</label>
                                                    <select class="form-control form-control-sm select2" ng-model="NewAppointment.EthnicityId">
                                                        <option ng-value="E.EthnicityId" ng-repeat="E in EthnicityList" ng-selected="E.EthnicityId == NewAppointment.EthnicityId">{{ E.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Marital Status</label>
                                                    <select class="form-control form-control-sm form-select" ng-model="NewAppointment.MaritalStatusId">
                                                        <option ng-value="G.id" ng-repeat="G in MaritalStatusColl" ng-selected="G.id == NewAppointment.MaritalStatusId">{{ G.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Spouse Name</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="NewAppointment.SpouseName">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Occupation</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="NewAppointment.Occupation">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Nationality</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="NewAppointment.Nationality">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Contact Number</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="NewAppointment.Contact">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Email Id</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="NewAppointment.Email">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>ID Type</label>
                                                    <select class="form-control form-control-sm form-select" ng-model="NewAppointment.DocumentTypeId">
                                                        <option ng-value="D.DocumentTypeId" ng-repeat="D in DocumentTypeList" ng-selected="D.DocumentTypeId == NewAppointment.DocumentTypeId">{{D.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>ID No</label>
                                                    <div class="row">
                                                        <div class="col-md-5 pr-0">
                                                            <div class="form-group">
                                                                <input type="text"
                                                                       class="form-control form-control-sm"
                                                                       ng-model="NewAppointment.IDNo">
                                                            </div>
                                                        </div>

                                                        <div class="col-md-7 pl-0">
                                                            <div class="form-group d-flex align-items-center">
                                                                <input type="file" id="flMoreFiles" accept="image/*"
                                                                       file-model ng-model="attachFile" style="display: none">

                                                                <label for="flMoreFiles"
                                                                       class="btn btn-default btn-sm d-flex align-items-center justify-content-center mb-0"
                                                                       title="Attach document"
                                                                       style="width:25px; height:28px;">
                                                                    <i class="fas fa-paperclip"></i>
                                                                </label>

                                                                <a class="p-1 d-flex align-items-center justify-content-center"
                                                                   href="#"
                                                                   ng-click="ShowPersonalImg(NewAppointment.Document)"
                                                                   data-toggle="tooltip"
                                                                   title="View doc">
                                                                    <i class="fas fa-eye text-secondary" ng-show="attachFile"></i>
                                                                </a>

                                                                <span class="ml-2 text-truncate">
                                                                    {{ NewAppointment.Document.Name || "No File" }}
                                                                </span>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Province</label>
                                                    <select class="form-control form-control-sm form-select select2" ng-model="NewAppointment.ProvinceId">
                                                        <option ng-repeat="cl in ProvinceColl" ng-value="cl.id" ng-selected="cl.id== NewAppointment.ProvinceId">
                                                            {{cl.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> District</label>
                                                    <select class="form-control form-control-sm form-select select2" ng-model="NewAppointment.DistrictId">
                                                        <option ng-repeat="tdc in DistrictColl | filter: { stateId: NewAppointment.ProvinceId }:true" ng-value="tdc.id" ng-selected="tdc.id==NewAppointment.DistrictId">
                                                            {{tdc.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Local Level</label>
                                                    <select class="form-control form-control-sm form-select select2" ng-model="NewAppointment.LocalLevelId">
                                                        <option ng-repeat="tdc in VDCColl| filter: { districtId: NewAppointment.DistrictId }:true" ng-value="tdc.id" ng-selected="tdc.id==NewAppointment.LocalLevelId">
                                                            {{tdc.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Full Address</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="NewAppointment.PatientAddress">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-2">
                                            <div class="person-photo-attachment-wrap text-center">
                                                <div class="img-wrap mx-auto">
                                                    <img ng-src="{{NewAppointment.PhotoData || NewAppointment.Photo }}" class="img-fluid" alt="" id="Photo" style="height:130px; width:165px; border:1px solid #ccc">
                                                </div>
                                                <label for="choose-sfile" type="button" class="btn btn-default mt-1 mb-0"><i class="fa fa-image"></i>Upload Image</label>
                                                <input id="choose-sfile" type="file" accept="image/*" style="display: none;" file-model ng-model="NewAppointment.Photo_TMP" fileread="NewAppointment.PhotoData" />
                                                <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                                <div class="text-left control-btns">
                                    <button type="button" class="btn btn-primary btn text-right" ng-click=" AddNewAppointment()"> <span class="glyphicon glyphicon-remove"></span> <i class="fas fa-plus"></i>  Add Appointment</button>
                                </div>
                            </div>
                        </div>

                        <div class="container-fluid" ng-show="ShowPatient">
                            <div class=" mb-1">
                                <!-- Patient Info -->
                                <div class="card p-1 my-2 px-2">
                                    <div class="row info-row mb-2">
                                        <div class="col-md-10">
                                            <div class="row">
                                                <div class="col-md-4 py-2">
                                                    <i class="fas fa-id-card"></i>
                                                    Patient Reg.No : 12345
                                                </div>
                                                <div class="col-md-4 py-2">
                                                    <i class="fas fa-user"></i>
                                                    Name : {{NewAppointment.FirstName}} {{NewAppointment.LastName}}
                                                </div>

                                                <div class="col-md-4 py-2">
                                                    <i class="fas fa-venus-mars"></i>
                                                    Age/Sex : {{NewAppointment.AgeYear}}Y / {{NewAppointment.GenderName}}
                                                </div>
                                                <div class="col-md-4 py-2">
                                                    <i class="fas fa-phone"></i>
                                                    Contact No : {{NewAppointment.Contact}}
                                                </div>
                                                <div class="col-md-4 py-2">
                                                    <i class="fas fa-envelope"></i>
                                                    Email : {{NewAppointment.Email}}
                                                </div>
                                                <div class="col-md-4 py-2">
                                                    <i class="fas fa-flag"></i>
                                                    Nationality : {{NewAppointment.Nationality}}
                                                </div>
                                                <div class="col-md-4 py-2">
                                                    <i class="fas fa-tint"></i>
                                                    Blood Group : {{NewAppointment.BloodGroupName}}
                                                </div>
                                                <div class="col-md-4 py-2">
                                                    <i class="fas fa-hashtag"></i>
                                                    Patient Id : {{NewAppointment.PatientId}}
                                                </div>
                                                <div class="col-md-4 py-2">
                                                    <i class="fas fa-calendar-alt"></i>
                                                    Visit Date : {{NewAppointment.VisitMitti}}
                                                </div>
                                                <div class="col-md-4 py-2">
                                                    <i class="fas fa-hourglass-half"></i>
                                                    Day Since Visit : {{NewAppointment.DaySinceVisit}} days
                                                </div>
                                                <div class="col-md-4 py-2">
                                                    <i class="fas fa-map-marker-alt"></i>
                                                    Full Address : {{NewAppointment.Address}}
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-2">
                                            <div class="person-photo-attachment-wrap text-center">
                                                <div class="img-wrap mx-auto">
                                                    <img ng-src="{{NewAppointment.PhotoData || NewAppointment.Photo }}" class="img-fluid" alt="" id="Photo" style="height:130px; width:165px; border:1px solid #ccc">
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Department</label>
                                            <select class="form-control form-control-sm select2" ng-model="NewAppointment.DepartmentId">
                                                <option ng-value="T.CostCenterDepartmentId" ng-repeat="T in DepartmentList" ng-selected="T.CostCenterDepartmentId==NewAppointment.DepartmentId">{{T.Name}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label> Doctor</label>
                                            <select class="form-control form-control-sm form-select select2" ng-model="NewAppointment.DoctorId">
                                                <option ng-repeat="D in DoctorList" ng-value="D.DoctorId" ng-selected="D.DoctorId== NewAppointment.DoctorId">
                                                    {{D.Name}}
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                    <!--<div class="col-md-12">
                                    <div class="search-toolbar mb-3 mt-2">
                                        <table cellpadding="12" class=" main-table table table-bordered table-striped table-hover table-sm" id="datatable">
                                            <thead>
                                                <tr>
                                                    <th style="width: 50px;">S.No</th>
                                                    <th style="width: 202px;">Session</th>
                                                    <th style="width: 150px ;">Time</th>
                                                    <th style="width: 150px ;">Quota</th>
                                                    <th style="width: 150px;">Available</th>
                                                    <th style="width: 150px ;">Book</th>
                                                    <th style="text-align:center" class="no-print " width="145px">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>-->
                                    @*<tr ng-repeat="beData in PatientList">*@
                                    <!--<tr>
                                    <td>-->
                                    @*{{$index + 1}}*@
                                    <!--</td>
                                        <td>Morning OPD</td>
                                        <td>8AM-11AM</td>
                                        <td></td>
                                        <td></td>
                                        <td>
                                            <div class="col-md-3">
                                                <div class="custom-control custom-checkbox">
                                                    <input class="custom-control-input" type="checkbox" id="IsReturnable">
                                                    <label for="IsReturnable" class="custom-control-label" ng-model="NewAppointment.IsReturnable"></label>
                                                </div>
                                            </div>
                                        </td>
                                        <td></td>
                                    </tr>
                                    <tr>
                                        <td>-->
                                    @*{{$index + 1}}*@
                                    <!--</td>
                                                        <td>Evening OPD</td>
                                                        <td>2PM-6PM</td>
                                                        <td></td>
                                                        <td></td>
                                                        <td>
                                                            <div class="col-md-3">
                                                                <div class="custom-control custom-checkbox">
                                                                    <input class="custom-control-input" type="checkbox" id="IsReturnable">
                                                                    <label for="IsReturnable" class="custom-control-label" ng-model="NewAppointment.IsReturnable"></label>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td></td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>-->
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label> Appointment Type</label>
                                            <select class="form-control form-control-sm form-select select2" ng-model="NewAppointment.AppointmentTypeId">
                                                <option ng-repeat="A in AppointmentTypeList" ng-value="A.AppointmentTypeId" ng-selected="A.AppointmentTypeId== NewAppointment.AppointmentTypeId">
                                                    {{A.Name}}
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label> Booking Channel</label>
                                            <select class="form-control form-control-sm form-select select2" ng-model="NewAppointment.AppointmentTypeId">
                                                <option ng-repeat="B in BookingChannelList" ng-value="B.BookingChannelId" ng-selected="B.BookingChannelId== NewAppointment.BookingChannelId">
                                                    {{B.Name}}
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Refered By</label>
                                            <input class="form-control form-control-sm" ng-model="NewAppointment.ReferedBy" />
                                        </div>
                                    </div>
                                    <div class="col-md-9">
                                        <div class="form-group">
                                            <label>Patient Remarks</label>
                                            <textarea rows="1" class="form-control form-control-sm" ng-model="NewAppointment.PatientRemarks"></textarea>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-right ">
                                    <button type="button" class="btn btn-default" ng-click="BackToList()"> <span class="glyphicon glyphicon-remove"></span>   Back </button>
                                </div>
                            </div>
                        </div>
                        <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
                            <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
                                <div class="modal-content">
                                    <div class="modal-body d-flex justify-content-center align-items-center p-2" style="min-height: 80vh;">
                                        <img ng-show="viewImg.FileType === 'image'" ng-src="{{viewImg.ContentPath}}" alt="" style="max-width: 100%; max-height: 80vh; object-fit: contain" id="imgPreviewAdd">
                                    </div>
                                    <div class="modal-footer p-2">
                                        <div><a href="{{viewImg.ContentPath}}" download class="btn btn-primary btn-sm dynamic-uiux-sm-btn">Download</a></div>
                                        <button class="btn btn-secondary btn-sm dynamic-uiux-sm-btn" data-dismiss="modal" type="button" style="min-width: 70px;">Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
