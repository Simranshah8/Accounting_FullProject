@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script>

    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.PDC)";
</script>
<script src="~/jslib/account/creation/PDCDetails.js?v=20250701"></script>
<div ng-app="myApp" ng-controller="PDCDetails" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllPDCDetails()" ng-cloak>
    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">Post Dated Cheque Details</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body px-2">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.PDCDetails">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.PDCDetails">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.PDCDetails">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file" title="Download File">
                                            <a class="btn btn-secondary btn-light btn-sm wait"
                                               title="Refresh" ng-click="GetAllPDCDetails()">
                                                <i class="fas fa-sync-alt"></i>
                                            </a>
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'PDC'" report-name="'List Of PDC'" ignore-column="'5'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'PDC',ignoreColumn:'5' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl report-name="'List Of P.D.C.'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait"
                                               title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>

                                        </div>


                                    </div>
                                </header>
                                <div class="search-toolbar mt-2">

                                    <div class="">

                                        <table cellpadding="12" class="table table-bordered table-striped table-hover table-sm" id="datatable">
                                            <thead>
                                                <tr>
                                                    <th ng-click="sort('TranId')" style="text-align: center; width: 5%;">

                                                        S.No
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='TranId'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('TypeOfPDC')" style="width: 12% ; text-align:left">
                                                        Type
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='TypeOfPDC'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('VoucherDate')" style="width: 10% ; text-align:left">
                                                        Entry Date
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='VoucherDate'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('Party')" style="width: 20% ; text-align:left">
                                                        Party
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Name'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th ng-click="sort('BankName')" style="width: 15% ; text-align:left">
                                                        BankName
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='BankName'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('BankBranch')" style="width: 15%;text-align:left">

                                                        BankBranch
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Code'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('ChequeDate')" style="width: 10% ; text-align:left">
                                                        Cheque Date
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='ChequeDate'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('ChequeNo')" style="width: 22%;text-align:left">
                                                        Cheque No.
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Code'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('ValidDays')" style="width: 8%;text-align:left">
                                                        V.Days
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Code'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('BankBranch')" style="width: 25%;text-align:left">

                                                        Amount
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Code'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th style="text-align:center;width: 15%;">Action</th>

                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="beData in PDCColl | orderBy:sortKey:reverse | filter:searchData.PDCDetails | itemsPerPage:perPage.PDCDetails" current-page="currentPages.PDCDetails" pagination-id="PDCDetailsPagination">
                                                    <td style="text-align:center;margin:auto">
                                                        {{$index+1}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.TypeOfPDCName}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.VoucherDate | dateFormat}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.LedgerName}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.BankName}}
                                                    </td>

                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.BankBranch}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.ChequeDate| dateFormat}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.ChequeNo}}
                                                    </td>
                                                    <td style="margin:auto;text-align:center">
                                                        {{beData.ValidDays}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.Amount |number:2}}
                                                    </td>
                                                    <td class="project-actions text-center" style="text-align:center">
                                                        <div class="btn-group-sm">
                                                            <a href="#" class="btn btn-info" ng-click="getPDCById(beData)" style="font-size:xx-small"><i class="fas fa-pencil-alt"></i></a>
                                                            <a href="#" class="btn btn-danger" ng-click="deletePDC(beData,$index)" style="font-size:xx-small"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="PDCDetailsPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>

                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                                <div class="row">
                                    <div class="col-md-2" ng-hide="EPDet.TypeOfPDC.ShowHide==2">
                                        <div class="form-group">
                                            <label for="name">Type</label>
                                            <select class="form-control form-control-sm select2" ng-model="beData.TypeOfPDC" data-placeholder="**select Salesman**" title="{{beData.TranId>0 ? beData.TranId : ''}}" ng-disabled="EPDet.TypeOfPDC.ShowHide==3">
                                                <option ng-value="pp.id" ng-repeat="pp in TypeOfPDCColl" ng-selected="beData.TypeOfPDC==pp.id">{{pp.text}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-5" ng-hide="EPDet.LedgerId.ShowHide==2">
                                        <div class="form-group">
                                            <label>Party:<span style="color:red">*</span></label>
                                            <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="beData.LedgerId" id="cboParty" style="width:95%" ledgertype="13"
                                                    placeholder="** Select Party Name **" showdetails="true" confirm-action="PartySelectionChange(beData)" ledger-detail="beData.PartyLedger" side-bar-data="beData.partySideBarData" ng-disabled="EPDet.LedgerId.ShowHide==3"></select>
                                        </div>
                                    </div>
                                    <div class="col-md-3" ng-hide="EPDet.VoucherDate.ShowHide==2">
                                        <div class="form-group">
                                            <label for="name">Date:</label>
                                            <div class="d-inline-block">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text">BS:</span>
                                                    </div>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="ChangeDate('VoucherDate',2)" title="{{beData.VoucherDateDet.dateAD |dateFormat}}" date-style="2" ng-disabled="EPDet.VoucherDate.ShowHide==3">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text">AD:</span>
                                                    </div>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.VoucherDateAD_TMP" date-detail="beData.VoucherDateADDet" confirm-action="ChangeDate('VoucherDate',1)" title="{{ beData.VoucherDateADDet.dateBS }}" date-style="1" ng-disabled="EPDet.VoucherDate.ShowHide==3">
                                                </div>
                                            </div>

                                            @*<input type="text" class="form-control form-control-sm" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" ng-disabled="EPDet.VoucherDate.ShowHide==3">*@
                                        </div>
                                    </div>
                                    <div class="col-md-5" ng-hide="EPDet.AgentId.ShowHide==2">
                                        <div class="form-group">
                                            <label for="name">Salesman:</label>
                                            <select class="form-control form-control-sm select2" ng-model="beData.AgentId" data-placeholder="**select Salesman**" ng-disabled="EPDet.AgentId.ShowHide==3">
                                                <option ng-value="pp.AgentId" ng-repeat="pp in AgentList" ng-selected="beData.AgentId==pp.AgentId">{{pp.Name}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-7" ng-show="beData.TypeOfPDC==2">
                                        <div class="form-group">
                                            <label>Bank Name<span style="color:red">*</span></label>
                                            <select class="form-control form-control-sm select2" ng-model="beData.BankName" data-placeholder="**select Bank**" ng-disabled="EPDet.BankName.ShowHide==3">
                                                <option ng-value="pp.Name" ng-repeat="pp in BankColl" ng-selected="beData.BankName==pp.Name">{{pp.Name}}</option>
                                            </select>

                                        </div>
                                    </div>

                                    <div class="col-md-7" ng-show="beData.TypeOfPDC==1">
                                        <div class="form-group">
                                            <label>Bank Name<span style="color:red">*</span></label>
                                            <input type="text" class="form-control form-control-sm" data-ng-model="beData.BankName" list="lstBank" ng-disabled="EPDet.BankName.ShowHide==3">
                                            <datalist id="lstBank">
                                                <option data-ng-repeat="ttl in BankColl" value="{{ttl.Name}}">
                                            </datalist>
                                        </div>
                                    </div>

                                    <div class="col-md-5" ng-hide="EPDet.BankBranch.ShowHide==2">
                                        <div class="form-group">
                                            <label>Branch Name<span style="color:red">*</span></label>
                                            <input type="text" class="form-control form-control-sm" ng-model="beData.BankBranch" ng-disabled="EPDet.BankBranch.ShowHide==3">
                                        </div>
                                    </div>
                                    <div class="col-md-2" ng-hide="EPDet.ChequeNo.ShowHide==2">
                                        <div class="form-group">
                                            <label>ChequeNo<span style="color:red">*</span></label>
                                            <input type="text" class="form-control form-control-sm" ng-model="beData.ChequeNo" ng-disabled="EPDet.ChequeNo.ShowHide==3">
                                        </div>
                                    </div>
                                    <div class="col-sm-3" ng-hide="EPDet.ChequeDate.ShowHide==2">
                                        <div class="form-group">
                                            <label for="name">Cheque Date:<span style="color:red">*</span></label>
                                            <div class="d-inline-block">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text">BS:</span>
                                                    </div>
                                                    <input type="text" class="form-control form-control-sm" date-picker model-name="beData.ChequeDate" ng-model="beData.ChequeDate_TMP" date-detail="beData.ChequeDateDet" confirm-action="ChangeDate('ChequeDate',2)" title="{{beData.ChequeDateDet.dateAD |dateFormat}}" date-style="2" ng-disabled="EPDet.ChequeDate.ShowHide==3">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text">AD:</span>
                                                    </div>
                                                    <input type="text" class="form-control form-control-sm" date-picker model-name="beData.ChequeDate" ng-model="beData.ChequeDateAD_TMP" date-detail="beData.ChequeDateADDet" confirm-action="ChangeDate('ChequeDate',1)" title="{{ beData.ChequeDateADDet.dateBS }}" date-style="1" ng-disabled="EPDet.ChequeDate.ShowHide==3">
                                                </div>
                                            </div>
                                            @*<input type="text" class="form-control form-control-sm" date-picker ng-model="beData.ChequeDate" date-detail="beData.ChequeDateDet" ng-disabled="EPDet.ChequeDate.ShowHide==3">*@
                                        </div>
                                    </div>
                                    <div class="col-md-2" ng-hide="EPDet.Amount.ShowHide==2">
                                        <div class="form-group">
                                            <label>Amount<span style="color:red">*</span></label>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="beData.Amount" ng-disabled="EPDet.Amount.ShowHide==3">
                                        </div>
                                    </div>
                                    <div class="col-md-7" ng-hide="EPDet.Notes.ShowHide==2">
                                        <div class="form-group">
                                            <label for="exampleFormControlTextarea1" class="form-label">Notes</label>
                                            <textarea class="form-control form-control-sm" id="exampleFormControlTextarea1" rows="1" ng-model="beData.Notes" ng-disabled="EPDet.Notes.ShowHide==3"></textarea>
                                        </div>
                                    </div>
                                    <div class="col-md-2" ng-hide="EPDet.ValidDays.ShowHide==2">
                                        <div class="form-group">
                                            <label for="exampleFormControlTextarea1" class="form-label">Valid Days</label>
                                            <input type="number" class="form-control form-control-sm" ng-model="beData.ValidDays" ng-disabled="EPDet.ValidDays.ShowHide==3">
                                        </div>
                                    </div>
                                    <div class="col-md-10" ng-hide="EPDet.Against.ShowHide==2">
                                        <div class="form-group">
                                            <label for="exampleFormControlTextarea1" class="form-label">Against</label>
                                            <textarea class="form-control form-control-sm" rows="1" ng-model="beData.Against" ng-disabled="EPDet.Against.ShowHide==3"></textarea>
                                        </div>
                                    </div>
                                    <div class="col-md-2 my-2">
                                        <div class="custom-control custom-checkbox">
                                            <input class="custom-control-input" type="checkbox"
                                                   id="chkGenerateVoucher" value="option" ng-model="beData.GenerateVoucher">
                                            <label for="chkGenerateVoucher"
                                                   class="custom-control-label">
                                                Generate Voucher
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                <label><b>Document Attachment</b></label>
                                <div class="row">
                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Type Of Document</label>
                                            <select class="form-control form-control-sm" ng-model="CurDocument.DocumentTypeId">
                                                <option ng-value="dt.DocumentTypeId" ng-repeat="dt in DocumentTypeList" ng-selected="CurDocument.DocumentTypeId==dt.DocumentTypeId">{{dt.Name}}</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-sm-9">
                                        <div class="row">
                                            <div class="col-sm-8">
                                                <div class="form-group">
                                                    <label>Attach Doc.</label>
                                                    <div class="form-group">
                                                        <input type="file" accept=".jpg,.jpeg,.png,.pdf" class="form-control form-control-sm p-0" id="flMoreFiles" file-model ng-model="CurDocument.Document_TMP" fileread="CurDocument.DocumentData">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-4">
                                                <div class="d-flex">
                                                    <div>
                                                        <label class="invisible d-block">for height</label>
                                                        <button type="button" class="btn btn-sm load btn-secondary" ng-click="AddMoreFiles()"><i class="fas fa-plus"></i> Add More</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="pb-3" style="margin-bottom:60px">
                                    <div class="table-responsive">
                                        <table class="table table-sm table-hover border">
                                            <thead>
                                                <tr>
                                                    <th scope="col" style="width: 20px">SN.</th>
                                                    <th scope="col" style="width: 40%">Doc. Type</th>
                                                    <th scope="col">Name</th>
                                                    <th scope="col" style="width: 130px">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr ng-repeat="dcc in beData.DocumentColl">
                                                    <th scope="row">{{$index+1}}</th>
                                                    <td>{{dcc.DocumentTypeName}}</td>
                                                    <td>{{dcc.Name}}</td>
                                                    <td>
                                                        <div class="btn-group btn-group-sm">
                                                            <a href="{{dcc.DocumentData || dcc.DocPath}}" class="btn btn-warning" data-toggle="tooltip" data-placement="top" title="" data-original-title="Download doc." download="{{dcc.Name}}"><i class="fas fa-download"></i></a>
                                                            <a  class="btn btn-info" data-toggle="tooltip" data-placement="top" title="" data-original-title="View doc" ng-click="ShowPersonalImg(dcc)"><i class="fas fa-eye"></i></a>
                                                            <a  class="btn btn-danger" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete doc." ng-click="delAttachmentFiles($index)"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <footer class="main-footer">
                                    <div class="text-right">
                                        <div class=" control-btns">
                                            <button type="button" class="btn btn-outline-secondary" ng-click="ClearFields()"
                                                    style="font-size: 15px;">
                                                Reset
                                            </button>

                                            <button type="button" class="btn btn-primary" ng-click="AddPDC()"
                                                    style="font-size: 15px;">
                                                Save
                                            </button>
                                        </div>
                                    </div>

                                </footer>

                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card -->
            </div>
            <!-- /.card -->
        </div>
        <!-- /.container-fluid -->
    </div>


    @*<div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-body mb-0 p-0">
                    <img ng-src="{{viewImg.FileData || viewImg.ContentPath}}" alt="" style="width:100%; height: 70vh;">
                </div>
                <div class="modal-footer">
                    <div><a href="{{viewImg.FileData || viewImg.ContentPath}}" download>Download</a></div>
                    <button class="btn btn-success btn-rounded btn-sm ml-4 text-center" data-dismiss="modal" type="button" style="min-width: 90px;">Close</button>
                </div>
            </div>
        </div>
    </div>*@


    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
        <div class="modal-dialog modal-lg" role="document" style="margin-top: 0; width: auto; max-width: 90vw; padding: 3px; display: flex; justify-content: center; align-items: center;">
            <div class="modal-content" style="width: auto; display: inline-block; padding: 5px;">
                <div class="modal-body mb-0 p-2">
                    <iframe ng-hide="viewImg.FileType === 'image'" id="pdfViewer"  style="width: 90vw; height: calc(100vh - 6rem); border: none;"></iframe>
                    <img ng-show="viewImg.FileType === 'image'" ng-src="{{viewImg.ContentPath}}" alt=""style="display: block; width: 100%; height: auto; max-height: 70vh; object-fit: contain;" id="imgPreviewAdd">
                </div>
                <div class="modal-footer p-2">
                    <div><a href="{{viewImg.ContentPath}}" download>Download</a></div>
                    <button class="btn btn-success btn-rounded btn-sm ml-4 btn-add text-center" data-dismiss="modal" type="button" style="min-width: 70px;">Close</button>
                </div>
            </div>
        </div>
    </div>

    @RenderPage("~/Views/Global/_IsValidMaster.cshtml")

