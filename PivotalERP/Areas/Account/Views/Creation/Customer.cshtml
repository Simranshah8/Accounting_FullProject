@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/account/creation/Customer.js?v=@Dynamic.BusinessEntity.Global.AppVer.Ver"></script>
<script>
    var TranId =@ViewBag.TranId;
    var LedgerEntity =@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Ledger);
     var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Customer)";
</script>
<script src="~/jslib/export/tableExport.js"></script>
<script src="~/jslib/export/jquery.base64.js"></script>

<script src="~/jslib/export/jspdf/libs/sprintf.js"></script>
<script src="~/jslib/export/jspdf/jspdf.js"></script>
<script src="~/jslib/export/jspdf/libs/base64.js"></script>

<style>
    .resp-vtabs .resp-tabs-list li {
        padding: 0.1rem 1rem 0.1rem 1.5rem !important;
    }

    label {
        margin-bottom: 0.1rem !important;
        font-size: 13px;
    }

    .form-group {
        margin-bottom: 0.1rem !important;
    }
</style>
<div ng-app="myApp" ng-controller="Ledger" ng-init="LoadData()" ng-cloak>
    <div class="container-fluid">
        <div class="content">
            <div class="card">
                <div class="card-header header-corner-triangle p-1">
                    <h3 class="card-title">Customer </h3>
                    <button class="btn btn-primary btn-light btn-sm  float-right" type="button"
                            title="Create Multiple Data" ng-click="ShowMultipleModal()">
                        Create Multiple
                    </button>
                </div>
                <!--Vertical Tab-->
                <div class="cstm-vertical-nav-tabs">
                    <div id="parentVerticalTab">
                        <div class="row no-gutters">
                            <div class="col-md-4 col-lg-3">
                                <div class="left-side-wrap">
                                    <ul class="resp-tabs-list hor_1 mt-0">
                                        <li id="tab-1st-active">Basic Info</li>
                                        <li id="tab-2st-active" ng-hide="EPDet.Contact_Panel.ShowHide==2">Contact Details</li>
                                        <li id="tab-5st-active">Bill To Details</li>
                                        <li id="tab-6st-active">Ship To Details</li>
                                        <li id="tab-3st-active" ng-hide="EPDet.Other_Panel.ShowHide==2">Other Details</li>
                                        <li id="tab-4st-active" ng-hide="EPDet.Doc_Panel.ShowHide==2">Doc. Attach</li>
                                    </ul>
                                    <div class="bottom-content-wrap py-0" ng-hide="EPDet.Side_Panel.ShowHide==2" style="padding-bottom: 70px!important;">
                                        <div class="form-group" ng-hide="EPDet.Status.ShowHide==2">
                                            <label>{{GetLabel('Status')}}</label>
                                            <div class="row">
                                                <div class="col-12">
                                                    <div class="clearfix">
                                                        <div class="icheck-primary d-inline">
                                                            <input type="radio" id="radioPrimary1" name="r1" checked="" ng-model="newLedger.Status" ng-value="true">
                                                            <label for="radioPrimary1">Active</label>
                                                        </div>
                                                        <div class="icheck-primary d-inline ml-3">
                                                            <input type="radio" id="radioPrimary2" name="r1" ng-model="newLedger.Status" ng-value="false">
                                                            <label for="radioPrimary2">De-Active</label>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>

                                        <div class="form-group" ng-hide="EPDet.ActiveSMS.ShowHide==2">
                                            <label>{{GetLabel('ActiveSMS')}}</label>
                                            <div class="row">
                                                <div class="col-12">
                                                    <div class="clearfix">
                                                        <div class="icheck-primary d-inline">
                                                            <input type="radio" id="rboSMS1" name="rboSMS" checked="" ng-model="newLedger.ActiveSMS" ng-value="true">
                                                            <label for="rboSMS1">Active</label>
                                                        </div>
                                                        <div class="icheck-primary d-inline ml-3">
                                                            <input type="radio" id="rboSMS2" name="rboSMS" ng-model="newLedger.ActiveSMS" ng-value="false">
                                                            <label for="rboSMS2">De-Active</label>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>

                                        <div class="form-group" ng-hide="EPDet.ActiveEmail.ShowHide==2">
                                            <label>{{GetLabel('ActiveEmail')}}</label>
                                            <div class="row">
                                                <div class="col-12">
                                                    <div class="clearfix">
                                                        <div class="icheck-primary d-inline">
                                                            <input type="radio" id="rboEmail1" name="rboEmail" checked="" ng-model="newLedger.ActiveEmail" ng-value="true">
                                                            <label for="rboEmail1">Active</label>
                                                        </div>
                                                        <div class="icheck-primary d-inline ml-3">
                                                            <input type="radio" id="rboEmail2" name="rboEmail" ng-model="newLedger.ActiveEmail" ng-value="false">
                                                            <label for="rboEmail2">De-Active</label>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>

                                        <div class="form-group" ng-hide="EPDet.ActiveNotification.ShowHide==2">
                                            <label>{{GetLabel('ActiveNotification')}}</label>
                                            <div class="row">
                                                <div class="col-12">
                                                    <div class="clearfix">
                                                        <div class="icheck-primary d-inline">
                                                            <input type="radio" id="rboNotification1" name="rboNotification" checked="" ng-model="newLedger.ActiveNotification" ng-value="true">
                                                            <label for="rboNotification1">Active</label>
                                                        </div>
                                                        <div class="icheck-primary d-inline ml-3">
                                                            <input type="radio" id="rboNotification2" name="rboNotification" ng-model="newLedger.ActiveNotification" ng-value="false">
                                                            <label for="rboNotification2">De-Active</label>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @*Basic Information *@
                            <div class="col-md-8 col-lg-9">
                                <div class="resp-tabs-container hor_1 " style="height:100%!important;margin-bottom:60px!important">
                                    <div>
                                        <div class="row">

                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label title="{{newLedger.LedgerId>0 ? newLedger.LedgerId : ''}}">{{GetLabel('Name')}}<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newLedger.Name" ng-blur="GenerateCode()" title="{{newLedger.LedgerId>0 ? newLedger.LedgerId : ''}}">
                                                </div>
                                            </div>

                                            <div class="col-sm-3" ng-hide="EPDet.Alias.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('Alias')}}</label>
                                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newLedger.Alias">
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-hide="EPDet.DebtorTypeId.ShowHide==2 || DebtorTypeList.length==0">
                                                <div class="form-group">
                                                    <label>{{GetLabel('DebtorTypeId')}}</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.DebtorTypeId" data-placeholder="** Select Type **" ng-change="ChangeDebtorType()">
                                                        <option ng-value="cl.DebtorTypeId" ng-repeat="cl in DebtorTypeList" ng-selected="cl.DebtorTypeId==newLedger.DebtorTypeId">{{cl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label>Pan/Vat No.</label>
                                                    @*<input type="text" formatnumber="false" number-input positive="true" integer="true" class="form-control form-control-sm" placeholder="" ng-model="newLedger.StatutoryDetail.PanVatNo" maxlength="9" ng-blur="IsValidPANVat(newLedger.LedgerId,newLedger.StatutoryDetail.PanVatNo)">*@

                                                    <!--search button starts-->
                                                    <div class="input-group input-group-sm table-search-filed">
                                                        <input class="form-control form-control-navbar" formatnumber="false" number-input positive="true" integer="true" ng-model="newLedger.StatutoryDetail.PanVatNo" maxlength="9" @*ng-blur="IsValidPANVat(newLedger.LedgerId,newLedger.StatutoryDetail.PanVatNo)"*@>
                                                        <div class="input-group-append">
                                                            <button class="btn btn-default border-left-0" type="button" ng-click="IsValidPANVat(newLedger.LedgerId,newLedger.StatutoryDetail.PanVatNo)">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <!--Ends-->
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.LedgerGroupId.ShowHide==2 || DebtorGroupList.length==1">
                                                <div class="form-group">
                                                    <label>{{GetLabel('LedgerGroupId')}}<span style="color:red">*</span></label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.LedgerGroupId" data-placeholder="** Select Group **" ng-blur="GenerateCode()">
                                                        <option ng-value="pl.LedgerGroupId" ng-repeat="pl in DebtorGroupList" ng-selected="pl.LedgerGroupId==newLedger.LedgerGroupId">{{pl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-hide="EPDet.Code.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('Code')}}</label>
                                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newLedger.Code" disabled>
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-show="newLedger.TypeOfDutyTax==30">
                                                <div class="form-group">
                                                    <label>Opening Credit Points</label>
                                                    <input type="text" number-input positive="true" class="form-control form-control-sm" placeholder="" ng-model="newLedger.OpeningPoint">
                                                </div>
                                            </div>
                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label>Country</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.Country" data-placeholder="** Country **" ng-change="ChangeCountry(newLedger)">
                                                        <option ng-value="cl.Name" ng-repeat="cl in CountryColl" ng-selected="cl.Name==newLedger.Country">{{cl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-3">
                                                @*<div class="form-group">
                                                        <label>Mobile No.</label>
                                                        <input type="text" formatnumber="false" number-input positive="true" integer="true" class="form-control form-control-sm" placeholder="" ng-model="newLedger.CompanyContactNo" maxlength="10">
                                                    </div>*@
                                                <label>Mobile No.</label>
                                                <div class="input-group input-group-sm">
                                                    <input type="text" formatnumber="false" title="Country Code" positive="true" integer="true" class="form-control form-control-sm" placeholder="C.Code" ng-model="newLedger.CountryCode" maxlength="10" style="flex: 0 0 35%; max-width: 35%;">
                                                    <input type="text" formatnumber="false" number-input positive="true" integer="true" class="form-control form-control-sm" placeholder="" ng-model="newLedger.CompanyContactNo" maxlength="10" style="flex: 0 0 65%; max-width: 65%;" ng-blur="GenerateCode()">
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.Address.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('Address')}}</label>
                                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newLedger.Address">
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.CreditLimit.ShowHide==2">
                                                <div class="row">
                                                    <div class="col-6">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('CreditLimitAmount')}}</label>
                                                            <input type="text" number-input class="form-control form-control-sm" placeholder="" ng-model="newLedger.CreditLimitAmount">
                                                        </div>
                                                    </div>
                                                    <div class="col-3">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('CreditLimitDays')}}</label>
                                                            <input type="text" number-input class="form-control form-control-sm" placeholder="" ng-model="newLedger.CreditLimitDays">
                                                        </div>
                                                    </div>
                                                    <div class="col-3">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('CreditLimitAs')}}</label>
                                                            <select class="form-control form-control-sm " data-placeholder="**Select Rule**" ng-model="newLedger.CreditLimitAs">
                                                                <option ng-value="r.id" ng-repeat="r in CreditRuleTypeList" ng-selected="r.id==newLedger.CreditLimitAs">{{r.text}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-sm-6" ng-show="CurrencyList.length>1">
                                                <div class="form-group">
                                                    <label>{{GetLabel('CurrencyId')}}</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.CurrencyId" data-placeholder="** Select Currency **">
                                                        <option ng-value="c.CurrencyId" ng-repeat="c in CurrencyList" ng-selected="c.CurrencyId==newLedger.CurrencyId">{{c.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label>Payment Type</label>
                                                    <select class="form-control form-control-sm" style="width: 100%;" ng-model="newLedger.PaymentType">
                                                        <option ng-value="0">**select PaymentType**</option>
                                                        <option ng-value="cl.id" ng-repeat="cl in PaymentTypeColl" ng-selected="cl.id==newLedger.PaymentType">{{cl.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.AgentId.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('AgentId')}}</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.TmpAgentIdColl" data-placeholder="** Select Salesman **" multiple id="cboAgent">
                                                        <option value="{{cl.id}}" ng-repeat="cl in SalesManList" @*ng-selected="cl.id==newLedger.AgentId"*@>{{cl.text}}-{{cl.Mobile}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.AreaId.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('AreaId')}}</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.AreaId" data-placeholder="** Select Area **" ng-change="ChangeAreaSelection(newLedger.AreaId)">
                                                        <option ng-value="pl.AreaId" ng-repeat="pl in AreaList" ng-selected="pl.AreaId==newLedger.AreaId">{{pl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>


                                            <div class="col-sm-6" ng-show="IsDealer(newLedger.DebtorTypeId)==true">
                                                <div class="form-group">
                                                    <label>Dealer/Distributor</label>
                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="newLedger.ParentLedgerId" ledgertype="15" fortransaction="true"
                                                            placeholder="** Select Dealer/Distrubutor **" showdetails="false" confirm-action="ChangeCashBankLedger(beData)" ledger-detail="newLedger.ParentLedgerDetails" side-bar-data="newLedger.partySideBarData"></select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.DebtorRouteId.ShowHide==2">
                                                <div class="form-group">
                                                    @*<label>Customer Group</label>*@
                                                    <label>{{GetLabel('DebtorRouteId')}}</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.DebtorRouteId" data-placeholder="** Select DebtorCreditorType **">

                                                        <option ng-value="cl.DebtorRouteId" ng-repeat="cl in RouteList" ng-selected="cl.DebtorRouteId==newLedger.DebtorRouteId">{{cl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.PriceId.ShowHide==2 || PriceColl.length==0">
                                                <div class="form-group">
                                                    <label>{{GetLabel('PriceId')}}</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.PriceId" data-placeholder="** Select Price **">
                                                        <option ng-value="cl.PriceId" ng-repeat="cl in PriceColl" ng-selected="cl.PriceId==newLedger.PriceId">{{cl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-{{vUF.ColWidth}}" ng-repeat="uf in UDFFeildsColl | filter: { FieldAfter: 1 }:true">
                                                <div class="form-group">
                                                    <label>{{uf.Name}} <span style="color:red" ng-show="uf.IsMandatory==true">*</span></label>
                                                    <udf-field udf="uf" change-event="ChangeUDFField(uf.NameId)"></udf-field>
                                                </div>
                                            </div>
                                            <div class="col-sm-12" ng-hide="EPDet.Notes.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('Notes')}}</label>
                                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newLedger.Notes">
                                                </div>
                                            </div>

                                        </div>
                                        <!-- row -->
                                    </div>
                                    <div>
                                        <div class="row">
                                            <div class="col-md-10">
                                                <div class="row">
                                                    <div class="col-sm-6">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('ContactPersons.Name')}}</label>
                                                            <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newContactDetails.Name">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-6" ng-hide="EPDet['ContactPersons.Post'].ShowHide==2">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('ContactPersons.Post')}}</label>
                                                            <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newContactDetails.Post">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-6" ng-hide="EPDet['ContactPersons.CountryId'].ShowHide==2">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('ContactPersons.CountryId')}}</label>
                                                            <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newContactDetails.Country" data-placeholder="** Country **" ng-change="ChangeCountry(newContactDetails)">
                                                                <option ng-value="cl.Name" ng-repeat="cl in CountryColl" ng-selected="cl.Name==newContactDetails.Country">{{cl.Name}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-6" ng-hide="EPDet['ContactPersons.Address'].ShowHide==2">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('ContactPersons.Address')}}</label>
                                                            <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newContactDetails.Address">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-6" ng-hide="EPDet['ContactPersons.EmailId'].ShowHide==2">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('ContactPersons.EmailId')}}</label>
                                                            <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newContactDetails.EmailId">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-6" ng-hide="EPDet['ContactPersons.CitizenShipNo'].ShowHide==2">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('ContactPersons.CitizenShipNo')}}</label>
                                                            <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newContactDetails.CitizenShipNo">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-6" ng-hide="EPDet['ContactPersons.MobileNo1'].ShowHide==2">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('ContactPersons.MobileNo1')}}</label>
                                                            <div class="input-group input-group-sm">
                                                                <input type="text" title="Country Code" class="form-control form-control-sm" placeholder="C.Code" ng-model="newContactDetails.CountryCode" style="flex: 0 0 30%; max-width: 30%;">
                                                                <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newContactDetails.MobileNo1" style="flex: 0 0 70%; max-width: 70%;">
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-6" ng-hide="EPDet['ContactPersons.MobileNo2'].ShowHide==2">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('ContactPersons.MobileNo2')}}</label>
                                                            <div class="input-group input-group-sm">
                                                                <input type="text" title="Country Code" class="form-control form-control-sm" placeholder="C.Code" ng-model="newContactDetails.CountryCode2" style="flex: 0 0 30%; max-width: 30%;">
                                                                <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newContactDetails.MobileNo2" style="flex: 0 0 70%; max-width: 70%;">
                                                            </div>

                                                        </div>
                                                    </div>
                                                    <div class="col-sm-6" ng-hide="EPDet['ContactPersons.TelNo1'].ShowHide==2">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('ContactPersons.TelNo1')}}</label>
                                                            <div class="input-group input-group-sm">
                                                                <input type="text" title="Country Code" class="form-control form-control-sm" placeholder="C.Code" ng-model="newContactDetails.TelCountrCode1" style="flex: 0 0 30%; max-width: 30%;">
                                                                <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newContactDetails.TelNo1" style="flex: 0 0 70%; max-width: 70%;">
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-6" ng-hide="EPDet['ContactPersons.TelNo2'].ShowHide==2">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('ContactPersons.TelNo2')}}</label>

                                                            <div class="input-group input-group-sm">
                                                                <input type="text" title="Country Code" class="form-control form-control-sm" placeholder="C.Code" ng-model="newContactDetails.TelCountrCode2" style="flex: 0 0 30%; max-width: 30%;">
                                                                <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newContactDetails.TelNo2" style="flex: 0 0 70%; max-width: 70%;">
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-6">
                                                        <div class="form-group text-right">
                                                            <label class="d-block invisible">Add more btn</label>
                                                            <button type="button" class="btn btn-outline-primary btn-sm py-1" ng-click="AddNewContactPerson()"><i class="fas fa-plus"></i> Add New Member</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- col-md-9 -->
                                        </div>
                                        <div class="table-responsive mt-4">
                                            <table class="table table-sm table-hover border">
                                                <thead>
                                                    <tr>
                                                        <th style="width: 60px">SN.</th>
                                                        <th style="width:180px">{{GetLabel('ContactPersons.Name')}}</th>
                                                        <th style="width:140px">{{GetLabel('ContactPersons.Post')}}</th>
                                                        <th style="width:180px">{{GetLabel('ContactPersons.Address')}}</th>
                                                        <th style="width:130px">{{GetLabel('ContactPersons.CitizenShipNo')}}</th>
                                                        <th style="width: 120px">Contact No.</th>
                                                        <th style="width: 90px">Action</th>
                                                    </tr>
                                                </thead>
