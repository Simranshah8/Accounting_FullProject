@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/export/tableExport.js"></script>
<script src="~/jslib/export/jquery.base64.js"></script>

<script src="~/jslib/export/jspdf/libs/sprintf.js"></script>
<script src="~/jslib/export/jspdf/jspdf.js"></script>
<script src="~/jslib/export/jspdf/libs/base64.js"></script>


<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.DebtorRoute)";
</script>
<script src="~/jslib/account/creation/DebtorsCreditorsRoute.js?v=1"></script>
<div ng-app="myApp" ng-controller="DebtorsCreditorsRoute" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllDebtorsCreditorsRoutes()" ng-cloak>


    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">Debtors Creditors Route</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.DebtorsCreditorsRoute">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.DebtorsCreditorsRoute">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.DebtorsCreditorsRoute">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="switch-field ml-1 mr-2">
                                            <input type="radio" id="all" ng-model="newFilter.Status" name="statuschoose" ng-value="1" ng-change="GetAllDebtorsCreditorsRoutes()" />
                                            <label class="px-1" for="all">Active</label>
                                            <input type="radio" id="open" ng-model="newFilter.Status" name="statuschoose" ng-value="0" ng-change="GetAllDebtorsCreditorsRoutes()" />
                                            <label class="px-1" for="open">Inactive</label>
                                        </div>
                                        <div class="dropdown dnld-file">


                                            <a class="btn btn-secondary btn-light btn-sm wait"
                                               title="Refresh" ng-click="GetAllDebtorsCreditorsRoutes()">
                                                <i class="fas fa-sync-alt"></i>
                                            </a>
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    title="Create Multiple Data" ng-click="ShowMultipleModal()">
                                                <i class="fas fa-file-import"></i>
                                            </button>
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'Route'" report-name="'List Of Route'" ignore-column="'7'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'Route',ignoreColumn:'7' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl report-name="'List Of Route'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait">
                                                <i class="fas fa-print"></i>
                                            </a>
                                        </div>


                                    </div>
                                </header>
                                <div class="search-toolbar mb-3 mt-2">

                                    <div class="">
                                        <table cellpadding="12" class="main-table table table-bordered table-striped table-hover table-sm" id="datatable">
                                            <thead>
                                                <tr>
                                                    <th style="text-align: center;  width: 90px;">
                                                        S.No
                                                        <span class="glyphicon sort-icon" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th ng-click="sort('Name')" style="text-align:left;width: 200px ;">
                                                        Name
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Name'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th ng-click="sort('Alias')" style="text-align: left; width: 120px; ">
                                                        Alias
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Alias'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('Code')" style="text-align:left;width: 120px;">

                                                        Code
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Code'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('Agent')" style="text-align:left;width: 120px;">

                                                        Salesman
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Agent'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('NoOfCustomer')" style="text-align:center;width: 120px;">

                                                        No. Of Customer
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='NoOfCustomer'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('DayName')" style="text-align:center;width: 120px;">
                                                        Day
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='DayName'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th style="text-align: center;  width:90px;" class="no-print">Action</th>

                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="beData in DebtorsCreditorsRouteColl | orderBy:sortKey:reverse | filter:searchData.DebtorsCreditorsRoute | itemsPerPage:perPage.DebtorsCreditorsRoute" current-page="currentPages.DebtorsCreditorsRoute" pagination-id="DebtorsCreditorsRoutePagination">

                                                    <td style="text-align:center;">
                                                        {{$index+1}}
                                                    </td>
                                                    <td style="text-align:left;">
                                                        {{beData.Name}}
                                                    </td>

                                                    <td style="text-align:left;">
                                                        {{beData.Alias}}
                                                    </td>
                                                    <td style="text-align:left;">
                                                        {{beData.Code}}
                                                    </td>
                                                    <td style="text-align:left;">
                                                        {{beData.Agent}}
                                                    </td>
                                                    <td style="text-align:center;">
                                                        {{beData.NoOfCustomer}}
                                                    </td>
                                                    <td style="text-align:center;">
                                                        {{beData.DayName}}
                                                    </td>
                                                    <td class="project-actions no-print" style="text-align:center;">
                                                        <div class="btn-group-sm">
                                                            <a href="#" class="btn btn-sm btn-info" ng-click="getDebtorsCreditorsRouteById(beData)"><i class="fas fa-pencil-alt"></i></a>
                                                            <a href="#" class="btn btn-danger" ng-click="deleteDebtorsCreditorsRoute(beData,$index)"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>

                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="DebtorsCreditorsRoutePagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">


                                <form>
                                    <div class="row">
                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Name<span style="color:red">*</span></label>
                                                <input type="text" class="form-control form-control-sm" ng-model="beData.Name">
                                            </div>
                                        </div>
                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>Alias</label>
                                                <input type="text" class="form-control form-control-sm" ng-model="beData.Alias">
                                            </div>
                                        </div>

                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>Code</label>
                                                <input type="text" class="form-control form-control-sm" ng-model="beData.Code">
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Salesman</label>
                                                <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="beData.TmpAgentIdColl" data-placeholder="** Select Salesman **" id="cboAgent" multiple>
                                                    <option value="{{cl.id}}" ng-repeat="cl in SalesManList" @*ng-selected="cl.id==beData.AgentId"*@>{{cl.text}}-{{cl.Mobile}}</option>
                                                </select>

                                            </div>
                                        </div>

                                        <div class="col-md-3 my-2">
                                            <div class="custom-control custom-checkbox">
                                                <input class="custom-control-input" type="checkbox"
                                                       id="chkIsActive" ng-model="beData.IsActive">
                                                <label for="chkIsActive"
                                                       class="custom-control-label">
                                                    Is Active
                                                </label>
                                            </div>
                                        </div>
                                        @*<div class="col-sm-6">
            <div class="form-group">
                <label>Type</label>
                <div class="form-group clearfix">
                    <div class="icheck-primary d-inline">
                        <input type="radio" id="radioPrimary7" name="r4" checked="" ng-model="beData.IsActive" ng-value="true">
                        <label for="radioPrimary7">Debtors</label>
                    </div>
                    <div class="icheck-primary d-inline ml-3">
                        <input type="radio" id="radioPrimary8" name="r4" ng-model="beData.IsActive" ng-value="false">
                        <label for="radioPrimary8">Creditors</label>
                    </div>
                </div>
            </div>
        </div>*@
                                    </div>

                                </form>
                                <footer class="main-footer">
                                    <div class="text-right control-btns">
                                        <button type="button" class="btn btn-default" ng-click="ClearFields()"> <span class="glyphicon glyphicon-remove"></span>Clear</button>
                                        <button type="button" class="btn btn-primary" ng-click="AddNewDebtorsCreditorsRoute()" ng-disabled="loadingstatus=='running'"><span class="glyphicon glyphicon-save"></span>Accept</button>
                                    </div>

                                </footer>
                            </div>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->
        </div>
    </div>

    @RenderPage("~/Views/Global/_ImportMultiple.cshtml")

</div>
<style>

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>