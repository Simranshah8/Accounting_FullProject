@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")



<script src="~/jslib/account/creation/BankGaurantee.js?v=1"></script>
<div ng-app="myApp" ng-controller="BankGaurantee" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllBankGuarantee()" ng-cloak>
    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">BankGaurantee</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.BankGaurantee">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.BankGaurantee">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.BankGaurantee">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file" title="Download File">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'BG'" report-name="'List Of BG'" ignore-column="'4'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'BG',ignoreColumn:'4' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl report-name="'List Of B.G.'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait"
                                               title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>

                                        </div>


                                    </div>
                                </header>
                                <div class="search-toolbar mt-2">

                                    <div class="">

                                        <table cellpadding="12" class="table table-bordered table-striped table-hover table-sm" id="datatable">
                                            <thead>
                                                <tr>
                                                    <th ng-click="sort('TranId')" style="text-align: center; width: 10%;">

                                                        S.No
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='LedgerGroupId'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th ng-click="sort('BankName')" style="width: 30% ; text-align:left">
                                                        BankName
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='BankName'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>


                                                    <th ng-click="sort('BranchName')" style="width: 20%;text-align:left">

                                                        BranchName
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='BranchName'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('Amount')" style="width: 15%;text-align:center">

                                                        Amount
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Amount'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th style="text-align:center;width: 15%;">Action</th>

                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="beData in BankGauranteeColl | orderBy:sortKey:reverse | filter:searchData.BankGaurantee | itemsPerPage:perPage.BankGaurantee" current-page="currentPages.BankGaurantee" pagination-id="BankGauranteePagination">
                                                    <td style="text-align:center;margin:auto">
                                                        {{$index+1}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.BankName}}
                                                    </td>

                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.BranchName}}
                                                    </td>
                                                    <td style="margin:auto;text-align:center">
                                                        {{beData.Amount}}
                                                    </td>
                                                    <td class="project-actions text-center" style="text-align:center">
                                                        <div class="btn-group-sm">
                                                            <a href="#" class="btn btn-info" ng-click="getBankGuaranteeById(beData)" style="font-size:xx-small"><i class="fas fa-pencil-alt"></i></a>
                                                            <a href="#" class="btn btn-danger" ng-click="deleteBankGuarantee(beData,$index)" style="font-size:xx-small"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        
                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="BankGauranteePagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>

                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                                <form>
                                    <div class="row">
                                        <div class="col-sm-6">
                                            <label>Party<span style="color:red">*</span></label>
                                            <div class="input-group-prepend">
                                                <select class="input-group-text dropdown-toggle p-0" style="outline: none; border-top-right-radius: unset; border-bottom-right-radius: unset;margin-right: -3px;z-index: 1;" ng-model="beData.FromTo">
                                                    <option ng-value="ft.id" ng-repeat="ft in FromToColl" ng-selected="ft.id==beData.FromTo">{{ft.text}} </option>
                                                </select>
                                                <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="beData.LedgerId" id="cboParty" style="width:95%" ledgertype="13"
                                                        placeholder="** Select Party Name **" showdetails="true" confirm-action="PartySelectionChange(beData)" ledger-detail="beData.PartyLedger" side-bar-data="beData.partySideBarData"></select>
                                            </div>
                                        </div>
                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>B.G.No.<span style="color:red">*</span></label>
                                                <input type="text" class="form-control form-control-sm" ng-model="beData.BGNo">

                                            </div>
                                        </div>
                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>Amount<span style="color:red">*</span></label>
                                                <input type="text" number-input class="form-control form-control-sm" ng-model="beData.Amount">
                                            </div>
                                        </div>
                                        <div class="col-sm-2" ng-show="beData.FromTo==2">
                                            <div class="form-group">
                                                <label>Margin Hold<span style="color:red">*</span></label>
                                                <input type="text" number-input class="form-control form-control-sm" ng-model="beData.MarginHoldAmt">
                                            </div>
                                        </div>
                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>Status<span style="color:red">*</span></label>
                                                <div class="form-group clearfix">
                                                    <div class="icheck-primary d-inline">
                                                        <input type="radio" id="radioPrimary7" name="r4" ng-checked="true" ng-model="beData.Status">
                                                        <label for="radioPrimary7">Yes</label>
                                                    </div>
                                                    <div class="icheck-primary d-inline ml-3">
                                                        <input type="radio" id="radioPrimary8" name="r4" ng-model="beData.Status">
                                                        <label for="radioPrimary8">No</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>Bank Name<span style="color:red">*</span></label>
                                                <select class="form-control form-control-sm select2" ng-model="beData.BankName" data-placeholder="**select Bank**">
                                                    <option ng-value="pp.Name" ng-repeat="pp in BankColl" ng-selected="beData.BankName==pp.Name">{{pp.Name}}</option>
                                                </select>
                                                @*<input type="text" class="form-control form-control-sm" data-ng-model="beData.BankName" list="lstBank">
        <datalist id="lstBank">
            <option data-ng-repeat="ttl in BankColl" value="{{ttl.Name}}">
        </datalist>*@
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>Branch Name</label>
                                                <input type="text" class="form-control form-control-sm" ng-model="beData.BranchName">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <div class="form-group">
                                                <label>Issue Date<span style="color:red">*</span></label>
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">BS:</span>
                                                        </div>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.IssuesDate_TMP" date-detail="beData.IssuesDateDet" confirm-action="ChangeDate('IssuesDate',2)" title="{{beData.IssuesDateDet.dateAD |dateFormat}}" date-style="2" >
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">AD:</span>
                                                        </div>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.IssuesDateAD_TMP" date-detail="beData.IssuesDateADDet" confirm-action="ChangeDate('IssuesDate',1)" title="{{ beData.IssuesDateADDet.dateBS }}" date-style="1">
                                                    </div>
                                                </div>
                                                @*<input type="text" class="form-control form-control-sm" date-picker ng-model="beData.IssuesDate_TMP" date-detail="beData.IssuesDateDet">*@
                                            </div>
                                        </div>
                                        <div class="col-sm-3">
                                            <div class="form-group">
                                                <label>Expire Date<span style="color:red">*</span></label>
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">BS:</span>
                                                        </div>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.ExpiredDate_TMP" date-detail="beData.ExpiredDateDet" confirm-action="ChangeDate('ExpiredDate',2)" title="{{beData.ExpiredDateDet.dateAD |dateFormat}}" date-style="2">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">AD:</span>
                                                        </div>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.ExpiredDateAD_TMP" date-detail="beData.ExpiredDateADDet" confirm-action="ChangeDate('ExpiredDate',1)" title="{{ beData.ExpiredDateADDet.dateBS }}" date-style="1">
                                                    </div>
                                                </div>
                                                @*<input type="text" class="form-control form-control-sm" date-picker ng-model="beData.ExpiredDate_TMP" date-detail="beData.ExpiredDateDet">*@
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>Remarks</label>
                                                <input type="text" class="form-control form-control-sm" ng-model="beData.Remarks">
                                            </div>
                                        </div>
                                    </div>
                                    <label><b>Document Attachment</b></label>
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <div class="form-group">
                                                <label>Type Of Document</label>
                                                <select class="custom-select" ng-model="CurDocument.DocumentTypeId">
                                                    <option ng-value="dt.DocumentTypeId" ng-repeat="dt in DocumentTypeList" ng-selected="CurDocument.DocumentTypeId==dt.DocumentTypeId">{{dt.Name}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-9">
                                            <div class="row">
                                                <div class="col-sm-8">
                                                    <div class="form-group">
                                                        <label>Attach Doc.</label>
                                                        <div class="form-group">
                                                            <input type="file" class="form-control-file border p-1" id="flMoreFiles" file-model ng-model="CurDocument.Document_TMP" fileread="CurDocument.DocumentData">
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-sm-4">
                                                    <div class="d-flex">
                                                        <div>
                                                            <label class="invisible d-block">for height</label>
                                                            <button type="button" class="btn btn-secondary" ng-click="AddMoreFiles()"><i class="fas fa-plus"></i> Add More</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="pb-3">
                                        <div class="table-responsive">
                                            <table class="table table-hover border">
                                                <thead>
                                                    <tr>
                                                        <th scope="col" style="width: 20px">SN.</th>
                                                        <th scope="col" style="width: 40%">Doc. Type</th>
                                                        <th scope="col">Name</th>
                                                        <th scope="col" style="width: 130px">Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr ng-repeat="dcc in beData.DocumentColl">
                                                        <th scope="row">{{$index+1}}</th>
                                                        <td>{{dcc.DocumentTypeName}}</td>
                                                        <td>{{dcc.Name}}</td>
                                                        <td>
                                                            <div class="btn-group btn-group-sm">
                                                                <a href="{{dcc.DocumentData || dcc.DocPath}}" class="btn btn-warning" data-toggle="tooltip" data-placement="top" title="" data-original-title="Download doc." download><i class="fas fa-download"></i></a>
                                                                <a href="#" class="btn btn-info" data-toggle="tooltip" data-placement="top" title="" data-original-title="View doc" ng-click="ShowPersonalImg(dcc)"><i class="fas fa-eye"></i></a>
                                                                <a href="#" class="btn btn-danger" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete doc." ng-click="delAttachmentFiles($index)"><i class="fas fa-trash"></i></a>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>




                                </form>



                            </div>
                            <footer class="main-footer">
                                <div class="text-right control-btns">


                                    <button type="button" class="btn btn-default" ng-click="ClearFields()">Reset</button>

                                    <button type="button" class="btn btn-primary" ng-click="AddBankGaurantee()">Save</button>
                                </div>

                            </footer>


                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->
        </div>
    </div>

    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-body mb-0 p-0">
                    <img ng-src="{{viewImg.FileData || viewImg.ContentPath}}" alt="" style="width:100%; height: 70vh;">
                </div>
                <div class="modal-footer">
                    <div><a href="{{viewImg.FileData || viewImg.ContentPath}}" download>Download</a></div>
                    <button class="btn btn-success btn-rounded btn-sm ml-4 text-center" data-dismiss="modal" type="button" style="min-width: 90px;">Close</button>
                </div>
            </div>
        </div>
    </div>

</div>


<style>

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>