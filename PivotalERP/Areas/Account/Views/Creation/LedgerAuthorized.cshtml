@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/global/math.min.js"></script>
<script src="~/jslib/account/creation/LedgerAuthorized.js"></script>


<div ng-app="myApp" ng-controller="LedgerAuthorized" ng-init="LoadData()" ng-cloak>
    <div class="container-fluid">
        <div class="content" style="min-height:650px!important;">
            <div class="card pt-2">
                <div class="p-2">
                    <div class="row">
                        @*<div class="col-sm-4">
            <label>Expenses Ledger</label>
            <div class="form-group">
                <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="beData.LedgerId" id="cboCashBank" ledgertype="10" fortransaction="true"
                        placeholder="** Select Expenses  Name **" showdetails="true" confirm-action="GetLederWiseAuthorized(beData)" ledger-detail="beData.LedgerDetails" side-bar-data="beData.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="4"></select>
            </div>
        </div>*@
                        <div class="col-sm-3">
                            <label>User</label>
                            <div class="form-group">
                                <select class="form-control form-control-sm select2" ng-model="beData.UserId">
                                    <option ng-value="0">**Select User**</option>
                                    <option ng-value="cl.UserId" ng-repeat="cl in UserList">{{cl.UserName}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <label>Branch</label>
                            <div class="form-group">
                                <select class="form-control form-control-sm select2" ng-model="beData.BranchId">
                                    <option ng-value="0">**Select Branch**</option>
                                    <option ng-value="cl.BranchId" ng-repeat="cl in BranchList" ng-selected="Cl.BranchId=beData.BranchId">{{cl.Name}}</option>
                                </select>
                            </div>
                        </div>

                    </div>
                    <div>

                        <div class="table-scroll-x-y table-scroll" style="height:auto!important;max-height: calc(100vh - 8rem);">
                            <table id="main-table"
                                   class="main-table table table-sm table-bordered bg-white">
                                <thead>
                                    <tr>
                                        <th class="text-center align-middle" style="width: 50px;">S.No</th>
                                        <th class="align-middle" style="width: 300px;">Ledger</th>
                                       
                                        <th class="align-middle" style="width: 120px; ">Limit Amt.</th>
                                        <th class="align-middle" style="width: 120px; ">Used Amt.</th>
                                        <th class="align-middle" style="width: 150px; ">Balance Amt.</th>
                                        <th class="align-middle" style="width: 150px; ">Limit Amt Monthly </th>
                                        <th class="align-middle" style="width: 150px;">Used Amt Monthly </th>
                                        <th class="align-middle" style="width: 150px;">Balance Amt Monthly </th>
                                        <th class="text-center align-middle cstm-sticky" style="background-color: #e9ecef !important; width: 80px; right: 0; z-index: 3;">Action</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="pDet in beData.LedgerAuthorizedColl">
                                        <td class="text-center">{{$index+1}}</td>
                                        <td>
                                            <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="pDet.LedgerId" id="cboCashBank" ledgertype="10" fortransaction="true"
                                                    placeholder="** Select Expenses  Name **" showdetails="true" @*confirm-action="GetLederWiseAuthorized(beData)"*@ ledger-detail="pDet.LedgerDetails" side-bar-data="beData.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="4"></select>
                                        </td>
                                       
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-model="pDet.LimitAmt">
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-model="pDet.UsedAmt" disabled>
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-model="pDet.BalanceAmt" disabled>
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-model="pDet.LimitAmt_Monthly">
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-model="pDet.UsedAmt_Monthly" disabled>
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-model="pDet.BalanceAmt_Monthly" disabled>

                                        </td>
                                        <td style="text-align: center; width: 150px; position: sticky; right: 0; background: #fff; z-index: 9;">
                                            <a class="p-1" href="#" ng-click="AddData($index)">
                                                <i class="fas fa-plus text-info"></i>
                                            </a>
                                            <a class="p-1" href="#" ng-click="DelData($index)">
                                                <i class="fas fa-trash-alt text-danger"></i>
                                            </a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <!-- table end -->
                    </div>


                </div>

                <footer class="main-footer">
                    <div class="text-right control-btns">
                        <button type="button" class="btn btn-default btn" ng-click="resetLedgerAuthorized()"> <span class="glyphicon glyphicon-remove"></span> Clear</button>
                        <button type="button" class="btn btn-primary btn" ng-click="SaveUpdateLedgerAuthorized()"><span class="glyphicon glyphicon-save"></span> Save</button>
                    </div>
                </footer>
            </div>
        </div>
    </div>
</div>