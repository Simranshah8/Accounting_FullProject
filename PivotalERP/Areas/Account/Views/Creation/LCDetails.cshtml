@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script src="~/jslib/account/creation/LCDetails.js"></script>
<div ng-app="myApp" ng-controller="LCDetails" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllLCDetails()" ng-cloak>
    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">LCDetails</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body p-2">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.LCDetails">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.LCDetails">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.LCDetails">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file" title="Download File">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'BG'" report-name="'List Of BG'" ignore-column="'4'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'LC',ignoreColumn:'4' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl report-name="'List Of LC'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait"
                                               title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>

                                        </div>


                                    </div>
                                </header>
                                <div class="search-toolbar mt-2">

                                    <div class="">

                                        <table cellpadding="12" class="table table-bordered table-striped table-hover table-sm" id="datatable">
                                            <thead>
                                                <tr>
                                                    <th ng-click="sort('TranId')" style="text-align: center; width: 10%;">

                                                        S.No
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='LedgerGroupId'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th ng-click="sort('BankName')" style="width: 30% ; text-align:left">
                                                        BankName
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='BankName'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>


                                                    <th ng-click="sort('BranchName')" style="width: 20%;text-align:left">

                                                        BranchName
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='BranchName'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th> 
                                                 
                                                    <th ng-click="sort('Amount')" style="width: 15%;text-align:center">

                                                        Amount
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Amount'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th style="text-align:center;width: 15%;">Action</th>

                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="beData in LCDetailsColl | orderBy:sortKey:reverse | filter:searchData.LCDetails | itemsPerPage:perPage.LCDetails" current-page="currentPages.LCDetails" pagination-id="LCDetailsPagination">
                                                    <td style="text-align:center;margin:auto">
                                                        {{$index+1}}
                                                    </td>
                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.BankName}}
                                                    </td>

                                                    <td style="margin:auto;text-align:left">
                                                        {{beData.BranchName}}
                                                    </td>
                                                   
                                                    <td style="margin:auto;text-align:center">
                                                        {{beData.Amount}}
                                                    </td>
                                                    <td class="project-actions text-center" style="text-align:center">
                                                        <div class="btn-group-sm">
                                                            <a href="#" class="btn btn-info" ng-click="getLCDetailsById(beData)" style="font-size:xx-small"><i class="fas fa-pencil-alt"></i></a>
                                                            <a href="#" class="btn btn-danger" ng-click="deleteLCDetails(beData,$index)" style="font-size:xx-small"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="LCDetailsPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>

                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                                <form>
                                    <div class="row">
                                        <div class="col-sm-6">
                                            <label>Party<span style="color:red">*</span></label>
                                            <div class="input-group-prepend">
                                                <select class="input-group-text dropdown-toggle p-0" style="outline: none; border-top-right-radius: unset; border-bottom-right-radius: unset;margin-right: -3px;z-index: 1;" ng-model="newDet.FromTo">
                                                    <option ng-value="ft.id" ng-repeat="ft in FromToColl" ng-selected="ft.id==newDet.FromTo">{{ft.text}} </option>
                                                </select>
                                                <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="newDet.LedgerId" id="cboParty" style="width:95%" ledgertype="13"
                                                        placeholder="** Select Party Name **" showdetails="false" confirm-action="PartySelectionChange(newDet)" ledger-detail="newDet.PartyLedger" side-bar-data="newDet.partySideBarData"></select>
                                            </div>
                                        </div>
                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>LC No.<span style="color:red">*</span></label>
                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.LCNo">

                                            </div>
                                        </div>
                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>Amount<span style="color:red">*</span></label>
                                                <input type="text" number-input class="form-control form-control-sm float-right" ng-model="newDet.Amount">
                                            </div>
                                        </div>
                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>Tolerance<span style="color:red">*</span></label>
                                                <input type="text" number-input class="form-control form-control-sm" ng-model="newDet.Tolerance">
                                            </div>
                                        </div>

                                        <div class="col-sm-3">
                                            <div class="form-group">
                                                <label>Total Amount<span style="color:red">*</span></label>
                                                <input type="text" number-input class="form-control form-control-sm text-right" ng-model="newDet.TAmount">
                                            </div>
                                        </div>
                                        <div class="col-sm-3" ng-show="newDet.FromTo==2">
                                            <div class="form-group">
                                                <label>Margin Hold<span style="color:red">*</span></label>
                                                <input type="text" number-input class="form-control form-control-sm" ng-model="newDet.MarginHoldAmt">
                                            </div>
                                        </div>
                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>Status<span style="color:red">*</span></label>
                                                <div class="form-group clearfix">
                                                    <div class="icheck-primary d-inline">
                                                        <input type="radio" id="radioPrimary7" name="r4" ng-checked="true" ng-model="newDet.Status">
                                                        <label for="radioPrimary7">Yes</label>
                                                    </div>
                                                    <div class="icheck-primary d-inline ml-3">
                                                        <input type="radio" id="radioPrimary8" name="r4" ng-model="newDet.Status">
                                                        <label for="radioPrimary8">No</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Bank Name<span style="color:red">*</span></label>
                                                <input type="text" number-input class="form-control form-control-sm" ng-model="newDet.BankName">

                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Branch Name</label>
                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.BranchName">
                                            </div>
                                        </div>

                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>Payment Terms In Days</label>
                                                <input type="text" number-input class="form-control form-control-sm" ng-model="newDet.PaymentTermsInDays">

                                            </div>
                                        </div>

                                      
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Issue Date<span style="color:red">*</span></label>
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">BS:</span>
                                                        </div>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.IssuesDate_TMP" date-detail="newDet.IssuesDateDet" confirm-action="ChangeDate('IssuesDate',2)" title="{{newDet.IssuesDateDet.dateAD |dateFormat}}" date-style="2">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">AD:</span>
                                                        </div>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.IssuesDateAD_TMP" date-detail="newDet.IssuesDateADDet" confirm-action="ChangeDate('IssuesDate',1)" title="{{ newDet.IssuesDateADDet.dateBS }}" date-style="1">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Expire Date<span style="color:red">*</span></label>
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">BS:</span>
                                                        </div>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.ExpiredDate_TMP" date-detail="newDet.ExpiredDateDet" confirm-action="ChangeDate('ExpiredDate',2)" title="{{newDet.ExpiredDateDet.dateAD |dateFormat}}" date-style="2">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">AD:</span>
                                                        </div>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.ExpiredDateAD_TMP" date-detail="newDet.ExpiredDateADDet" confirm-action="ChangeDate('ExpiredDate',1)" title="{{ newDet.ExpiredDateADDet.dateBS }}" date-style="1">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Last Date of Shipment<span style="color:red">*</span></label>
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">BS:</span>
                                                        </div>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.LastDateOfShipment_TMP" date-detail="newDet.LastDateOfShipmentDet" confirm-action="ChangeDate('LastDateOfShipment',2)" title="{{newDet.LastDateOfShipmentDet.dateAD |dateFormat}}" date-style="2">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">AD:</span>
                                                        </div>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.LastDateOfShipmentAD_TMP" date-detail="newDet.LastDateOfShipmentADDet" confirm-action="ChangeDate('LastDateOfShipment',1)" title="{{ newDet.LastDateOfShipmentADDet.dateBS }}" date-style="1">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-8">
                                            <div class="form-group">
                                                <label>Remarks</label>
                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.Remarks">
                                            </div>
                                        </div>
                                    </div>

                                    <label><b>Document Attachment</b></label>
                                    <div>
                                        <div class="timeline-item">
                                            <div class="pb-2 add-more-than-one-form-block">
                                                <div class="row">
                                                    <div class="col-sm-2">
                                                        <div class="form-group">
                                                            <label>Type Of Document</label>
                                                            <select class="form-control form-control-sm select2" ng-model="docType">
                                                                <option ng-value="dc" ng-repeat="dc in DocumentTypeList">{{dc.Name}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-10">
                                                        <div class="row">
                                                            <div class="col-sm-4">
                                                                <div class="form-group">
                                                                    <label>Attach Document</label>
                                                                    <div class="form-group">
                                                                        <input type="file" id="flMoreFiles" class="form-control-file form-control form-control-sm border bg-white p-0" file-model ng-model="attachFile">
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <div class="form-group">
                                                                    <label>Description</label>
                                                                    <input type="text" class="form-control form-control-sm"
                                                                           ng-model="docDescription"
                                                                           placeholder="">
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-2">
                                                                <div class="d-flex">
                                                                    <div>
                                                                        <label class="invisible d-block">for height</label>
                                                                        <button type="button" class="btn btn-secondary" ng-click="AddMoreFiles(attachFile,docType,docDescription)" style="height: 28px;  align-items: center; justify-content: center; display: flex;"><i class="fas fa-plus"></i> Add More</button>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="pb-3">
                                                <div class="table-responsive">
                                                    <table class="table table-hover border bg-white">
                                                        <thead>
                                                            <tr>
                                                                <th scope="col" style="width: 20px">S.No.</th>
                                                                <th scope="col" style="width: 40%">Document Type</th>
                                                                <th scope="col">Attachment</th>
                                                                <th scope="col">Description</th>
                                                                <th scope="col" style="width: 100px">Action</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <tr ng-repeat="ac in newDet.DocumentColl">
                                                                <th scope="row">{{$index+1}}</th>
                                                                <td>{{(DocumentTypeList | filter:{DocumentTypeId: ac.DocumentTypeId})[0].Name}}</td>
                                                                <td>{{ac.Name}}</td>
                                                                <td>{{ac.Description}}</td>
                                                                <td>

                                                                    <div>
                                                                        <a class="p-1" href="" data-toggle="tooltip" data-placement="top" title="" ng-click="ShowPersonalImg(ac)" data-original-title="View doc">
                                                                            <i class="fas fa-eye text-secondary"></i>
                                                                        </a>
                                                                        <a ng-hide="ac.DocPath==null" class="p-1" href="{{ac.DocPath}}" download="" data-toggle="tooltip" data-placement="top" title="" data-original-title="Download doc.">
                                                                            <i class="fas fa-download  text-info"></i>
                                                                        </a>
                                                                        <a class="p-1" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete doc." ng-click="delAttachmentFiles($index)">
                                                                            <i class="fas fa-trash-alt text-danger"></i>
                                                                        </a>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                        @* modal- for View----------- *@
                                        <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="ImgDocView" role="dialog" tabindex="-1">
                                            <div class="modal-dialog modal-lg" role="document">
                                                <div class="modal-content">
                                                    <div class="modal-body mb-0 p-2">
                                                        <iframe ng-hide="viewImg.FileType === 'image'" id="pdfViewer" style="width: 100%; height: 700px; border: none;"></iframe>
                                                        <img ng-show="viewImg.FileType === 'image'" ng-src="{{viewImg.ContentPath}}" alt="" style="width: 100%; height: auto;" id="imgPreviewAdd">
                                                    </div>
                                                    <div class="modal-footer p-2">
                                                        <div><a href="{{viewImg.ContentPath}}" download>Download</a></div>
                                                        <button class="btn btn-success btn-rounded btn-sm ml-4 btn-add text-center" data-dismiss="modal" type="button" style="min-width: 70px;">Close</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                            <footer class="main-footer">
                                <div class="text-right control-btns">
                                    <button type="button" class="btn btn-default" ng-click="ClearFields()">Reset</button>
                                    <button type="button" class="btn btn-primary" ng-click="AddLCDetails()">Save</button>
                                </div>
                            </footer>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->
        </div>
    </div>

    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-body mb-0 p-0">
                    <img ng-src="{{viewImg.FileData || viewImg.ContentPath}}" alt="" style="width:100%; height: 70vh;">
                </div>
                <div class="modal-footer">
                    <div><a href="{{viewImg.FileData || viewImg.ContentPath}}" download>Download</a></div>
                    <button class="btn btn-success btn-rounded btn-sm ml-4 text-center" data-dismiss="modal" type="button" style="min-width: 90px;">Close</button>
                </div>
            </div>
        </div>
    </div>
</div>


<style>

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>