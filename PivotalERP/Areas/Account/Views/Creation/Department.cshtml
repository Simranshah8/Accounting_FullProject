@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/export/tableExport.js"></script>
<script src="~/jslib/export/jquery.base64.js"></script>

<script src="~/jslib/export/jspdf/libs/sprintf.js"></script>
<script src="~/jslib/export/jspdf/jspdf.js"></script>
<script src="~/jslib/export/jspdf/libs/base64.js"></script>


<script src="~/jslib/account/creation/CostCenterDepartment.js"></script>
<div ng-app="myApp" ng-controller="ControllCostCenterDepartment" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllCostCenterDepartment()" ng-cloak>

    <div class="box-body1 ">
        <div class="content">
            <div class="container-fluid p-1">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">Department</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body p-2">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.CostCenterDepartment">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.CostCenterDepartment">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.CostCenterDepartment">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'CostCenterDepartment'" report-name="'List Of CostCenterDepartment'" ignore-column="'6'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'CostCenterDepartment',ignoreColumn:'6' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl report-name="'List Of Department'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait">
                                                <i class="fas fa-print"></i>
                                            </a>
                                        </div>


                                    </div>
                                </header>
                                <div class="search-toolbar mt-2">

                                    <div class="">
                                        <table cellpadding="12" class="main-table table table-bordered table-striped table-hover table-sm" id="datatable">
                                            <thead>
                                                <tr>
                                                    <th style="text-align: center; width: 10%;">
                                                        S.No.
                                                        <span class="glyphicon sort-icon" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('Name')" style="text-align:left;width: 20% ;">
                                                        Name
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Name'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th ng-click="sort('Code')" style="text-align:left;width:10%;">
                                                        Code
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Code'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('Alias')" style="text-align:left;width:10%;">
                                                        Alias
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Alias'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    @*<th style="text-align:left;width:10%;">Ledger</th>*@
                                                    <th style="text-align:center;width: 10%;" class="no-print">Action</th>

                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="beData in CostCenterDepartmentColl | orderBy:sortKey:reverse | filter:searchData.CostCenterDepartment | itemsPerPage:perPage.CostCenterDepartment" current-page="currentPages.CostCenterDepartment" pagination-id="CostCenterDepartmentPagination">
                                                    <td style="text-align:center;">{{$index+1}}</td>
                                                    <td style="text-align:left">{{beData.Name}}</td>
                                                    <td style="text-align:left">{{beData.Code}} </td>
                                                    <td style="text-align:left"> {{beData.Alias}}  </td>
                                                    @*<td style="text-align:left"> {{beData.LedgerName}} </td>*@
                                                    <td class="project-actions no-print text-center">
                                                        <div class="btn-group-sm">
                                                            <a href="#" class="btn btn-sm btn-info" ng-click="getCostCenterDepartmentById(beData)"><i class="fas fa-pencil-alt"></i></a>
                                                            <a href="#" class="btn btn-sm btn-danger" ng-click="deleteCostCenterDepartment(beData,$index)"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>

                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="CostCenterDepartmentPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                                <div>
                                    <form>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label>Name<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.Name">
                                                </div>
                                            </div>
                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label>Code<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.Code">
                                                </div>
                                            </div>
                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label>Alias</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.Alias">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="mt-2">
                                                    <!-- table input start  -->
                                                    <div class="table-responsive">
                                                        <div class="card table-scroll-x-y" style="height: auto !important; max-height: calc(100Vh - 18rem) !important;">
                                                            <table id="main-table" cellpadding="12" class="main-table table table-sm table-bordered">
                                                                <thead>
                                                                    <tr>
                                                                        <th style="width: 56px; background-color: #ececec !important;">SNo.</th>
                                                                        <th style="width: 200px; background-color: #ececec !important;">Pay Heading</th>
                                                                        <th style="width: 200px; background-color: #ececec !important;">Pay Head Type</th>
                                                                        <th style="width: 200px; background-color: #ececec !important; z-index:2;"> Ledger </th>
                                                                        <th style="width: 180px; background-color: #ececec !important;">Ledger Group</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    <tr ng-repeat="E in PayHeadList">
                                                                        <td>{{$index+1}}</td>
                                                                        <td>{{E.Name}}</td>
                                                                        <td>{{E.PayHeadType}}</td>
                                                                        <td style="z-index: 3;">
                                                                            <select class="form-control form-control-sm select2" all-ledger ng-model="E.LedgerId" ledgertype="1"
                                                                                    placeholder="** Select  Ledger **" showdetails="false" confirm-action="PartySelectionChange(E)" ledger-detail="E.PartyLedger" side-bar-data="E.partySideBarData">
                                                                            </select>
                                                                        </td>
                                                                        <td>{{E.LedgerGroup}}</td>
                                                                    </tr>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- tabel input end -->
                                        </div>

                                    </form>
                                    <footer class="main-footer">
                                        <div class="text-right control-btns">
                                            <button type="button" class="btn btn-default btn" ng-click="ClearFields()"> <span class="glyphicon glyphicon-remove"></span>Clear</button>
                                            <button type="button" class="btn btn-primary btn" ng-click="AddNewCostCenterDepartment()" ng-disabled="loadingstatus=='running'"><span class="glyphicon glyphicon-save"></span>Accept</button>
                                        </div>
                                    </footer>

                                </div>


                            </div>

                        </div>
                    </div>
                    <!-- /.card -->

                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->

        </div>


    </div>

    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-body mb-0 p-0">
                    <img ng-src="{{viewImg.ContentPath}}" alt="" style="width:100%; height: 70vh;">
                </div>
                <div class="modal-footer">
                    <div><a href="{{viewImg.ContentPath}}" download>Download</a></div>
                    <button class="btn btn-success btn-rounded btn-sm ml-4 text-center" data-dismiss="modal" type="button" style="min-width: 90px;">Close</button>
                </div>
            </div>
        </div>
    </div>

</div>


<style>

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>