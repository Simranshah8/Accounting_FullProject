
@{ ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<style>
    .select2-container--default .select2-selection--multiple .select2-selection__choice {
        background-color: #049bdb;
    }
    .select2-container--default .select2-selection--multiple .select2-selection__choice__remove {
        color: #ffffff;
    }
</style>
<script src="~/jslib/account/creation/Price.js"></script>

<div ng-app="myApp" ng-controller="PriceController" @*ng-class="{waiting: loadingstatus=='running'}"*@ ng-init="LoadData()" ng-cloak>
    <div class="box-body">
        <div class="content">
            <div class="p-1"></div>
            <div class="container-fluid">
                <div class="tab-content" id="device-section">
                    <div class="card card-primary card-outline card-outline-tabs">
                        <div class="card-header p-0 border-bottom-0">
                            <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                                <li class="nav-item">
                                    <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">Price</a>
                                </li>
                            </ul>
                        </div>
                        <div class="card-body">
                            <div class="tab-content" id="custom-tabs-four-tabContent ">
                                <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                    <header class="row">
                                        <div class="col-md-8">
                                            <div class="clearfix">
                                                <form class="form-inline">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text cstm">Show</span>
                                                        </div>
                                                        <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.Price">
                                                            <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.Price">{{pp.text}}</option>
                                                        </select>
                                                        <div class="input-group-append">
                                                            <span class="input-group-text bg-white"><small>entries</small></span>
                                                        </div>
                                                    </div>
                                                    <div class="input-group input-group-sm table-search-filed">
                                                        <input class="form-control form-control-navbar" type="search" placeholder="Search" aria-label="Search" ng-model="searchData.Price">
                                                        <div class="input-group-append">
                                                            <button class="btn btn-default border-left-0" type="submit">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                        @*table starts*@
                                        <div class="col-md-4 text-right">
                                            <div class="dropdown dnld-file" data-placement="top" title="Download File">
                                                <a class="btn btn-secondary btn-light btn-sm wait"
                                                   title="Refresh" ng-click="GetAllPriceList()">
                                                    <i class="fas fa-sync-alt"></i>
                                                </a>
                                                <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    <i class="fas fa-download"></i>
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                                    <span class="dropdown-item">Choose an option:</span>
                                                    <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'debtorcreditortypes'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                    <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>

                                                </div>
                                                <a print-tbl table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait" title="Print">
                                                    <i class="fas fa-print"></i>
                                                </a>
                                            </div>

                                        </div>
                                    </header>
                                    <div class="search-toolbar mb-3 mt-2" style="margin-bottom:50px;">
                                        <table cellpadding="12" class="table table-bordered table-striped table-hover table-sm" id="datatable">
                                            <tr>
                                                <th style="text-align: center; width: 10%;">

                                                    S.No
                                                    <span class="glyphicon sort-icon" ng-show="sortKey=='CostCategoryId'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                </th>

                                                <th ng-click="sort('Name')" style="text-align: left; width: 40%;">
                                                    Name
                                                    <span class="glyphicon sort-icon" ng-show="sortKey=='Name'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                </th>

                                                <th ng-click="sort('Alias')" style="text-align: left; width: 15%;">
                                                    Factor
                                                    <span class="glyphicon sort-icon" ng-show="sortKey=='Alias'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                </th>
                                                <th ng-click="sort('Code')" style="text-align: left; width: 15%;">

                                                    Valid-From
                                                    <span class="glyphicon sort-icon" ng-show="sortKey=='Code'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                </th>
                                                <th ng-click="sort('Code')" style="text-align: left; width: 15%;">

                                                    Valid-To
                                                    <span class="glyphicon sort-icon" ng-show="sortKey=='Code'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                </th>

                                                <th style="text-align: center; width: 10%;">Action</th>

                                            </tr>
                                            <tr dir-paginate="P in PriceList|filter:searchData.Price|itemsPerPage:perPage.Price" current-page="currentPages.Price" pagination-id="PricePagination">


                                                <td style="text-align:center;margin:auto">
                                                    {{$index+1}}
                                                </td>
                                                <td style="text-align: left; margin: auto">
                                                    {{P.Name}}
                                                </td>

                                                <td style="text-align: left; margin: auto">
                                                    {{P.Factor}}
                                                </td>
                                                <td style="text-align: left; margin: auto">
                                                    {{P.ValidFromMiti}}
                                                </td>
                                                <td style="text-align: left; margin: auto">
                                                    {{P.ValidToMiti}}
                                                </td>
                                                <td class="project-actions" style="text-align:center">
                                                    <div class="btn-group-sm">
                                                        <a href="#" class="btn btn-info" ng-click="GetPriceById(P)"><i class="fas fa-pencil-alt"></i></a>
                                                        <a href="#" class="btn btn-danger" ng-click="DelPriceById(P)"><i class="fas fa-trash"></i></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="PricePagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                                    <div class="p-2">
                                        <form>
                                            <div class="row">

                                                <div class="col-sm-3">
                                                    <div class="form-group">
                                                        <label>Name</label>
                                                        <input type="text" class="form-control form-control-sm" ng-model="newPrice.Name">
                                                    </div>
                                                </div>

                                                <div class="col-sm-3">
                                                    <div class="form-group">
                                                        <label>Factor</label>                                                        
                                                        <input type="text" number-input class="form-control form-control-sm" ng-model="newPrice.Factor" positive="true">
                                                    </div>
                                                </div>

                                                <div class="col-sm-3">
                                                    <div class="form-group">
                                                        <label>Default Base Price</label>
                                                        <select class="form-control form-control-sm" style="width: 100%;" ng-model="newPrice.DefaultBasePriceList" >
                                                            <option ng-value="pg.id" ng-repeat="pg in DefaultBasePriceColl" ng-selected="pg.id==newPrice.DefaultBasePriceList">{{pg.text}}</option>

                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-sm-3">
                                                    <div class="form-group">
                                                        <label class="form-label">Active</label>
                                                        <div class="d-flex" style="gap:1rem;">
                                                            <div class="form-check">
                                                                <label class="form-check-label form-label">
                                                                    <input type="radio" ng-value="true" ng-model="newPrice.Active" name="Active" class="form-check-input form-check-sm" />Yes
                                                                </label>
                                                            </div>
                                                            <div class="form-check">
                                                                <label class="form-check-label form-label" style="font-size:0.95rem;">
                                                                    <input type="radio" ng-value="false" ng-model="newPrice.Active" name="Active" class="form-check-input form-check-sm" />No
                                                                </label>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-sm-3">
                                                    <div class="form-group">
                                                        <label>Rounding Method</label>
                                                        <select class="form-control form-control-sm" style="width: 100%;" ng-model="newPrice.RoundingMethod">
                                                            <option ng-value="pg.id" ng-repeat="pg in RoundingMethodList" ng-selected="pg.id==newPrice.RoundingMethod">{{pg.text}}</option>

                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-sm-3">
                                                    <div class="form-group">
                                                        <label for="ValidFrom" class="form-label">Valid From</label>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="newPrice.ValidFrom_TMP" date-detail="newPrice.ValidFromDet">
                                                    </div>
                                                </div>  <div class="col-md-3">
                                                    <div class="form-group">
                                                        <label for="ValidTo" class="form-label">Valid To</label>
                                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="newPrice.ValidTo_TMP" date-detail="newPrice.ValidToDet">
                                                    </div>
                                                </div>


                                                <div class="col-sm-3">
                                                    <div class="form-group">
                                                        <label>For Debtor Type</label>                                                        
                                                        <multi-select-option ng-model="newPrice.ForDebtorTypeId" data="DebtorTypeList" label="Name" value="DebtorTypeId"></multi-select-option>
                                                    </div>
                                                </div>

                                                <div class="col-sm-3">
                                                    <div class="form-group">
                                                        <label>For Ledger Group</label>                                                        
                                                        <multi-select-option ng-model="newPrice.ForLedgerGroupId" data="LedgerGroupList" label="Name" value="LedgerGroupId"></multi-select-option>
                                                    </div>
                                                </div>
                                                <div class="col-sm-3">
                                                    <div class="form-group">
                                                        <label>For Area</label>                                                        
                                                        <multi-select-option ng-model="newPrice.ForAreaId" data="AreaList" label="Name" value="AreaMasterId"></multi-select-option>
                                                    </div>
                                                </div>
                                                <div class="col-sm-3">
                                                    <div class="form-group">
                                                        <label>For Province</label>                                                       
                                                        <select class="form-control form-control-sm select2" id="cboProvincePer" style="width: 100%;" ng-model="newPrice.ForProvinceColl" multiple  data-placeholder="* select province *">
                                                            <option ng-repeat="cl in ProvinceColl" ng-value="cl.text" ng-selected="cl.text==newPrice.ForProvinceColl">
                                                                {{cl.text}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-sm-3">
                                                    <div class="form-group">
                                                        <label>For District</label>
                                                        <select class="form-control form-control-sm select2" id="cboDistrictPer" style="width: 100%;" ng-model="newPrice.ForDistrictColl" multiple data-placeholder="* select district *" >
                                                            <option ng-repeat="tdc in DistrictColl" ng-value="tdc.text" ng-selected="tdc.text==newPrice.ForDistrictColl">
                                                                {{tdc.text}}
                                                            </option>
                                                        </select>

                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    </div>


                                    <footer class="main-footer">
                                        <div class="text-right control-btns">
                                            <button type="button" class="btn btn-default" ng-click="ClearDetails()">Cancel</button>
                                            <button type="button" class="btn btn-primary" ng-click="SaveUpdatePrice()">Save</button>
                                        </div>

                                    </footer>
                                </div>
                            </div>
                        </div>
                    </div>


                </div>
            </div>
            <!-- /.container-fluid -->
        </div>
    </div>
    <!-- /.container-fluid -->
</div>