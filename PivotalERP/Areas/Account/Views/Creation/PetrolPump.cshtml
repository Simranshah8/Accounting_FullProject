@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .bg-olive {
        background-color: #068abf !important;
    }

    .form-qty {
        font-weight: 700 !important;
        text-align: end !important;
        font-size: 16px;
    }

    bg-olive.btn:not(:disabled):not(.disabled):active, .bg-olive.btn:not(:disabled):not(.disabled).active, .bg-olive.btn:active, .bg-olive.btn.active {
        background-color: #7abe5a !important;
        border-color: #7abe5a !important;
        color: #ffffff;
    }
</style>
<script src="~/jslib/account/creation/petrolPump.js"></script>

<div ng-app="myApp" ng-controller="PetrolPump" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllSalesMan()">
    <div class="container-fluid">
        <div class="content">
            <div class="card">
                <div class="card-header header-corner-triangle">
                    <h3 class="card-title">Petrol Pump</h3>
                </div>
                <div class="card-body">
                    <form>
                        <div class="row">

                            <div class="col-md-2 col-sm-6">
                                <div class="form-group">
                                    <label>Coupon No</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="beData.CouponNo">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>Buyer Name</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="beData.BuyerName">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>Address</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="beData.Address">
                                </div>
                            </div>
                            <div class="col-md-2 col-sm-6">
                                <div class="form-group">
                                    <label>Sales Miti</label>
                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.SalesMiti_TMP" date-detail="beData.SalesMitiDet">
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>Contact No</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="beData.ContactNo">
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>PanVatNo</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="beData.PanVat">
                                </div>
                            </div>

                            <div class="col-md-2 col-sm-6">
                                <div class="form-group">
                                    <label>Vehicle No</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="beData.VehicleNo">
                                </div>
                            </div>

                            @*<div class="col-md-2 col-sm-6">
                                    <div class="form-group">
                                        <label>Product Id</label>
                                        <input type="text" class="form-control form-control-sm" ng-model="beData.ProductId">
                                    </div>
                                </div>
                            *@


                        </div>

                        <div class=" btn-group-toggle" data-toggle="buttons">
                            <label class="btn bg-olive  mr-2 mb-1">
                                <input type="radio" name="options" id="option_b1" autocomplete="off"> Petrol
                            </label>
                            <label class="btn bg-olive active mr-2 mb-1">
                                <input type="radio" name="options" id="option_b2" autocomplete="off"> Diesel
                            </label>
                            <label class="btn bg-olive mr-2 mb-1">
                                <input type="radio" name="options" id="option_b3" autocomplete="off"> Keroscene
                            </label>
                        </div>

                        <div class="row mt-2">
                            <div class="col-md-4">
                                <div class="card p-2" style="background-color: #2dce523d">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="form-group d-flex">
                                                <label class="mr-2" style="width:90px"><b>Quantity</b></label>
                                                <input type="text" class="form-control form-qty" ng-model="beData.Qty">
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group d-flex">
                                                <label class="mr-2" style="width:90px"><b>Rate</b></label>
                                                <input type="text" class="form-control form-qty" ng-model="beData.Rate">
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group d-flex">
                                                <label class="mr-2" style="width:90px"><b>Amount</b></label>
                                                <input type="text" class="form-control form-qty" ng-model="beData.Amount">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                    <footer class="main-footer">
                        <div class="text-right control-btns">
                            <button type="button" class="btn btn-default" ng-click="ClearFields()">Cancel</button>
                            <button type="button" class="btn btn-primary" ng-click="AddPetrolPump()">Save</button>
                        </div>

                    </footer>
                </div>
            </div>

        </div>
        <!-- /.container-fluid -->
    </div>
</div>