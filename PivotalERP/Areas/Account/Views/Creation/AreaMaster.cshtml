@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/account/creation/AreaMaster.js"></script>
<div ng-app="myApp" ng-controller="AreaMaster" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllAreaMaster()" ng-cloak>

    <div class="container-fluid">

        <div class="card card-primary card-outline card-outline-tabs">
            <div class="card-header p-0 border-bottom-0">
                <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">Area Master</a>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <div class="tab-content" id="custom-tabs-four-tabContent">
                    <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                        <header class="row">
                            <div class="col-md-8">
                                <div class="clearfix">
                                    <form class="form-inline">
                                        <div class="input-group input-group-sm">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text cstm">Show</span>
                                            </div>
                                            <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.AreaMaster" >
                                                <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.AreaMaster">{{pp.text}}</option>
                                            </select>
                                            <div class="input-group-append">
                                                <span class="input-group-text bg-white"><small>entries</small></span>
                                            </div>
                                        </div>
                                        <div class="input-group input-group-sm table-search-filed">
                                            <input class="form-control form-control-navbar" type="search"
                                                   placeholder="Search" aria-label="Search" ng-model="searchData.AreaMaster">
                                            <div class="input-group-append">
                                                <button class="btn btn-default border-left-0" type="submit">
                                                    <i class="fas fa-search"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                            <!-- end col-md-8 -->
                            <div class="col-md-4 text-right">
                                <div class="dropdown dnld-file" title="Download File">
                                    <a class="btn btn-secondary btn-light btn-sm wait"
                                       title="Refresh" ng-click="GetAllAreaMaster()">
                                        <i class="fas fa-sync-alt"></i>
                                    </a>
                                    <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                            id="dropdownMenuButton" data-toggle="dropdown"
                                            aria-haspopup="true" aria-expanded="false">
                                        <i class="fas fa-download"></i>
                                    </button>
                                    <div class="dropdown-menu dropdown-menu-right"
                                         aria-labelledby="dropdownMenuButton">
                                        <span class="dropdown-item">Choose an option:</span>
                                        <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'Area'" report-name="'List Of Area'" ignore-column="'5'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'Area',ignoreColumn:'5' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                    </div>
                                    <a print-tbl report-name="'List Of Area'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait"
                                       title="Print">
                                        <i class="fas fa-print"></i>
                                    </a>
                                </div>


                            </div>
                        </header>
                        <div class="search-toolbar mt-2">
                            <div class="">

                                <table cellpadding="12" class="table table-bordered table-striped table-hover table-sm" id="datatable">
                                    <thead>
                                        <tr>
                                            <th style="text-align: center; width: 90px;">
                                                S.No
                                                <span class="glyphicon sort-icon" ng-show="sortKey=='AreaMasterId'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                            </th>

                                            <th ng-click="sort('Name')" style="text-align: left; width: 200px;">
                                                Name
                                                <span class="glyphicon sort-icon" ng-show="sortKey=='Name'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                            </th>

                                            <th ng-click="sort('Code')" style="text-align: left; width: 130px;">
                                                Code
                                                <span class="glyphicon sort-icon" ng-show="sortKey=='Code'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                            </th>
                                            <th ng-click="sort('Alias')" style="text-align: left; width: 130px;">
                                                Alias
                                                <span class="glyphicon sort-icon" ng-show="sortKey=='Alias'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                            </th>

                                            <th ng-click="sort('District')" style="text-align: left; width: 130px;">

                                                District
                                                <span class="glyphicon sort-icon" ng-show="sortKey=='District'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                            </th>

                                            <th style="text-align: center; width: 100px;">Action</th>

                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr dir-paginate="beData in AreaColl|orderBy:sortKey:reverse|filter:searchData.AreaMaster|itemsPerPage:perPage.AreaMaster" current-page="currentPages.AreaMaster" pagination-id="AreaMasterPagination">

                                            <td style="text-align:center;margin:auto">
                                                {{$index+1}}
                                            </td>
                                            <td style="margin: auto; text-align: left">
                                                {{beData.Name}}
                                            </td>

                                            <td style="margin:auto;text-align:left">
                                                {{beData.Code}}
                                            </td>
                                            <td style="margin:auto;text-align:left">
                                                {{beData.Alias}}
                                            </td>
                                            <td style="margin:auto;text-align:left">
                                                {{beData.District}}
                                            </td>
                                            <td class="project-actions text-center" style="text-align:center">
                                                <div class="btn-group-sm">
                                                    <a href="#" class="btn btn-info" ng-click="getAreaMasterById(beData)"><i class="fas fa-pencil-alt"></i></a>
                                                    <a href="#" class="btn btn-danger" ng-click="deleteAreaMaster(beData,$index)"><i class="fas fa-trash"></i></a>
                                                </div>
                                            </td>
                                        </tr>
                                    </tbody>
                                  
                                </table>
                                <div class="col-md-12">
                                    <dir-pagination-controls pagination-id="AreaMasterPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                    </dir-pagination-controls>
                                </div>

                            </div>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                        <div class="p-3">
                            <form>
                                <div class="row">
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Name<span style="color:red">*</span></label>
                                            <input type="text" class="form-control form-control-sm" ng-model="beData.Name" title="{{beData.AreaMasterId>0 ? beData.AreaMasterId : ''}}">
                                        </div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Alias</label>
                                            <input type="text" class="form-control form-control-sm" ng-model="beData.Alias">
                                        </div>
                                    </div>

                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Code</label>
                                            <input type="text" class="form-control form-control-sm" ng-model="beData.Code">
                                        </div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Province</label> 
                                            <select class="form-control form-control-sm select2" id="cboProvince" data-placeholder="** select province **"
                                                    style="width: 100%;" ng-model="beData.ProvinceId1">
                                                <option ng-repeat="cl in ProvinceColl" ng-value="cl.id" ng-selected="cl.id==beData.ProvinceId1">
                                                    {{cl.text}}
                                                </option>
                                            </select>                                          
                                        </div>
                                    </div> 
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>District</label> 
                                            <select class="form-control form-control-sm select2" id="cboDistrict"
                                                    style="width: 100%;" ng-model="beData.DistrictId1" data-placeholder="** select district **">
                                                <option ng-repeat="tdc in DistrictColl | filter: { stateId: beData.ProvinceId1 }:true" ng-value="tdc.id" ng-selected="tdc.id==beData.DistrictId1">
                                                    {{tdc.text}}
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Area</label>                                            
                                            <select class="form-control form-control-sm select2" id="cboArea"
                                                    style="width: 100%;" ng-model="beData.CityId1"   data-placeholder="** select area **">
                                                <option ng-repeat="tdc in VDCColl| filter: { districtId: beData.DistrictId1 }:true" ng-value="tdc.id" ng-selected="tdc.id==beData.CityId1">
                                                    {{tdc.text}}
                                                </option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Area Type<span style="color:red">*</span></label>
                                            <select class="select2 form-control form-control-sm" style="width: 100%;" ng-model="beData.AreaType">
                                                <option ng-value="at.id" ng-repeat="at in AreaTypeList" ng-selected="at.id==beData.AreaType">{{at.text}}</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Is Active</label>
                                            <div class="form-group clearfix">
                                                <div class="icheck-primary d-inline">
                                                    <input type="radio" id="radioPrimary7" name="r4" checked="" ng-model="beData.IsActive" ng-value="true">
                                                    <label for="radioPrimary7">Yes</label>
                                                </div>
                                                <div class="icheck-primary d-inline ml-3">
                                                    <input type="radio" id="radioPrimary8" name="r4" ng-model="beData.IsActive" ng-value="false">
                                                    <label for="radioPrimary8">No</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </form>
                            <footer class="main-footer">
                                <div class="text-right control-btns">
                                    <button type="button" class="btn btn-default" ng-click="ClearFields()">Reset</button> 
                                    <button type="button" class="btn btn-primary" ng-click="AddAreaMaster()">Save</button>
                                </div>

                            </footer>
                        </div>
                    </div>
                </div>
            </div>
            <!-- /.card -->
        </div>

    </div>
</div>

