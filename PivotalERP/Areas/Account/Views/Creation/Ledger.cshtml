@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/global/math.min.js"></script>
<script src="~/jslib/account/creation/Ledger.js?v=@Dynamic.BusinessEntity.Global.AppVer.Ver"></script>
<script>
    var TranId =@ViewBag.TranId;
    var LedgerEntity =@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Ledger);
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Ledger)";
</script>
<script src="~/jslib/export/tableExport.js"></script>
<script src="~/jslib/export/jquery.base64.js"></script>

<script src="~/jslib/export/jspdf/libs/sprintf.js"></script>
<script src="~/jslib/export/jspdf/jspdf.js"></script>
<script src="~/jslib/export/jspdf/libs/base64.js"></script>
<style>
    .resp-vtabs .resp-tabs-list li {
        padding: 0.1rem 1rem 0.1rem 1.5rem !important;
    }

    label {
        margin-bottom: 0.1rem !important;
        font-size: 13px;
    }

    .form-group {
        margin-bottom: 0.1rem !important;
    }
</style>

<div ng-app="myApp" ng-controller="Ledger" ng-init="LoadData()" ng-cloak>
    <div class="container-fluid">
        <div class="content" style="min-height:650px!important;">
            <div class="card">
                <div class="card-header header-corner-triangle p-1">
                    <h3 class="card-title">Ledger </h3>
                    <button class="btn btn-primary btn-light btn-sm float-right" type="button"
                            title="Create Multiple Data" ng-click="ShowMultipleModal()">
                        Create Multiple
                    </button>
                </div>
                <!--Vertical Tab-->
                <div class="cstm-vertical-nav-tabs p-0" style="margin-bottom:60px!important">
                    <div id="parentVerticalTab">
                        <div class="row no-gutters">
                            <div class="col-md-3 col-lg-3">
                                <div class="left-side-wrap">
                                    <ul class="resp-tabs-list hor_1 mt-0">
                                        <li id="tab-1st-active">Basic Info</li>
                                        <li id="tab-2st-active" ng-hide="EPDet.Contact_Panel.ShowHide==2">Contact Details</li>
                                        <li id="tab-3st-active" ng-hide="EPDet.Other_Panel.ShowHide==2">Other Details</li>
                                        <li id="tab-4st-active" ng-hide="EPDet.Doc_Panel.ShowHide==2">Doc. Attach</li>
                                        <!--New Field Added-->
                                        <li id="tab-5st-active" @*ng-hide="EPDet.Product_UDF.ShowHide==2" *@>Ledger Wise UDF</li>
                                        <!--Ends-->
                                    </ul>
                                    <div class="bottom-content-wrap py-0 px-2" ng-hide="EPDet.Side_Panel.ShowHide==2" style="padding-bottom: 60px!important;">
                                        <div class="form-group" ng-hide="EPDet.Status.ShowHide==2">
                                            <label>{{GetLabel('Status')}}</label>
                                            <div class="row">
                                                <div class="col-12">
                                                    <div class="clearfix">
                                                        <div class="icheck-primary d-inline">
                                                            <input type="radio" id="radioPrimary1" name="r1" checked="" ng-model="newLedger.Status" ng-value="true">
                                                            <label for="radioPrimary1">Active</label>
                                                        </div>
                                                        <div class="icheck-primary d-inline ml-3">
                                                            <input type="radio" id="radioPrimary2" name="r1" ng-model="newLedger.Status" ng-value="false">
                                                            <label for="radioPrimary2">De-Active</label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="" ng-hide="EPDet.BillWiseAdjustment.ShowHide==2">
                                            <div class="form-group">
                                                <label>{{GetLabel('BillWiseAdjustment')}}</label>
                                                <div class="form-group clearfix">
                                                    <div class="icheck-primary d-inline">
                                                        <input type="radio" id="radioPrimary3" name="r2" checked="" ng-model="newLedger.BillWiseAdjustment" ng-value="true">
                                                        <label for="radioPrimary3">Active</label>
                                                    </div>
                                                    <div class="icheck-primary d-inline ml-3">
                                                        <input type="radio" id="radioPrimary4" name="r2" ng-model="newLedger.BillWiseAdjustment" ng-value="false">
                                                        <label for="radioPrimary4">De-Active</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="" ng-hide="EPDet.InventoryValuesAreAffected.ShowHide==2">
                                            <div class="form-group">
                                                <label>{{GetLabel('InventoryValuesAreAffected')}}</label>
                                                <div class="form-group clearfix">
                                                    <div class="icheck-primary d-inline">
                                                        <input type="radio" id="radioPrimary5" name="r3" checked="" ng-model="newLedger.InventoryValuesAreAffected" ng-value="true">
                                                        <label for="radioPrimary5">Active</label>
                                                    </div>
                                                    <div class="icheck-primary d-inline ml-3">
                                                        <input type="radio" id="radioPrimary6" name="r3" ng-model="newLedger.InventoryValuesAreAffected" ng-value="false">
                                                        <label for="radioPrimary6">De-Active</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="" ng-hide="EPDet.CostCentersAreApplied.ShowHide==2">
                                            <div class="form-group">
                                                <label>{{GetLabel('CostCentersAreApplied')}}</label>
                                                <div class="form-group clearfix">
                                                    <div class="icheck-primary d-inline">
                                                        <input type="radio" id="radioPrimary7" name="r4" checked="" ng-model="newLedger.CostCentersAreApplied" ng-value="true">
                                                        <label for="radioPrimary7">Active</label>
                                                    </div>
                                                    <div class="icheck-primary d-inline ml-3">
                                                        <input type="radio" id="radioPrimary8" name="r4" ng-model="newLedger.CostCentersAreApplied" ng-value="false">
                                                        <label for="radioPrimary8">De-Active</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="" ng-hide="EPDet.ActiveInterestCalculation.ShowHide==2">
                                            <label>{{GetLabel('ActiveInterestCalculation')}}</label>
                                            <div class="form-group clearfix">
                                                <div class="icheck-primary d-inline">
                                                    <input type="radio" id="rb-interest-calc-yes" name="r5" ng-model="newLedger.ActiveInterestCalculation" ng-value="true">
                                                    <label for="rb-interest-calc-yes">Active</label>
                                                </div>
                                                <div class="icheck-primary d-inline ml-3">
                                                    <input type="radio" id="rb-interest-cal-no" name="r5" ng-model="newLedger.ActiveInterestCalculation" ng-value="false">
                                                    <label for="rb-interest-cal-no">De-Active</label>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group clearfix" ng-hide="EPDet.ActiveChequeDetails.ShowHide==2">
                                            <div class="icheck-primary d-inline">
                                                <input type="checkbox" id="checkboxPrimary5" checked="" ng-model="newLedger.ActiveChequeDetails">
                                                <label for="checkboxPrimary5">{{GetLabel('ActiveChequeDetails')}}</label>
                                            </div>
                                        </div>
                                        <div class="form-group clearfix" ng-show="newLedger.TypeOfDutyTax==1 || newLedger.TypeOfDutyTax==5">
                                            <div class="icheck-primary d-inline">
                                                <input type="checkbox" id="checkboxPrimary1t" checked="" ng-model="newLedger.IsTDS">
                                                <label for="checkboxPrimary1t">{{GetLabel('IsTDS')}}</label>
                                            </div>
                                            <div class="icheck-primary d-inline ml-3">
                                                <input type="checkbox" id="checkboxPrimary2v" ng-model="newLedger.IsVat">
                                                <label for="checkboxPrimary2v">{{GetLabel('IsVat')}}</label>
                                            </div>
                                        </div>
                                        <div class="form-group clearfix" ng-hide="EPDet.IsImportExportLedger.ShowHide==2">
                                            <div class="icheck-primary d-inline">
                                                <input type="checkbox" id="checkboxPrimary6" checked="" ng-model="newLedger.IsImportExportLedger">
                                                <label for="checkboxPrimary6">{{GetLabel('IsImportExportLedger')}}</label>
                                            </div>
                                        </div>
                                        <div class="form-group clearfix" ng-hide="EPDet.IsFundTransfer.ShowHide==2">
                                            <div class="icheck-primary d-inline">
                                                <input type="checkbox" id="chkIsFundTransfer" checked="" ng-model="newLedger.IsFundTransfer">
                                                <label for="chkIsFundTransfer">{{GetLabel('IsFundTransfer')}}</label>
                                            </div>
                                        </div>

                                        <div class="form-group" ng-hide="EPDet.ActiveSMS.ShowHide==2">
                                            <label>{{GetLabel('ActiveSMS')}}</label>
                                            <div class="row">
                                                <div class="col-12">
                                                    <div class="clearfix">
                                                        <div class="icheck-primary d-inline">
                                                            <input type="radio" id="rboSMS1" name="rboSMS" checked="" ng-model="newLedger.ActiveSMS" ng-value="true">
                                                            <label for="rboSMS1">Active</label>
                                                        </div>
                                                        <div class="icheck-primary d-inline ml-3">
                                                            <input type="radio" id="rboSMS2" name="rboSMS" ng-model="newLedger.ActiveSMS" ng-value="false">
                                                            <label for="rboSMS2">De-Active</label>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>

                                        <div class="form-group" ng-hide="EPDet.ActiveEmail.ShowHide==2">
                                            <label>{{GetLabel('ActiveEmail')}}</label>
                                            <div class="row">
                                                <div class="col-12">
                                                    <div class="clearfix">
                                                        <div class="icheck-primary d-inline">
                                                            <input type="radio" id="rboEmail1" name="rboEmail" checked="" ng-model="newLedger.ActiveEmail" ng-value="true">
                                                            <label for="rboEmail1">Active</label>
                                                        </div>
                                                        <div class="icheck-primary d-inline ml-3">
                                                            <input type="radio" id="rboEmail2" name="rboEmail" ng-model="newLedger.ActiveEmail" ng-value="false">
                                                            <label for="rboEmail2">De-Active</label>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>

                                        <div class="form-group" ng-hide="EPDet.ActiveNotification.ShowHide==2">
                                            <label>{{GetLabel('ActiveNotification')}}</label>
                                            <div class="row">
                                                <div class="col-12">
                                                    <div class="clearfix">
                                                        <div class="icheck-primary d-inline">
                                                            <input type="radio" id="rboNotification1" name="rboNotification" checked="" ng-model="newLedger.ActiveNotification" ng-value="true">
                                                            <label for="rboNotification1">Active</label>
                                                        </div>
                                                        <div class="icheck-primary d-inline ml-3">
                                                            <input type="radio" id="rboNotification2" name="rboNotification" ng-model="newLedger.ActiveNotification" ng-value="false">
                                                            <label for="rboNotification2">De-Active</label>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                        <div class="">
                                            <div class="form-group">
                                                <label>Is Taxable</label>
                                                <div class="form-group clearfix">
                                                    <div class="icheck-primary d-inline">
                                                        <input type="radio" id="rboIsTaxableYes" name="rboIsTaxable" checked="" ng-model="newLedger.IsTaxable" ng-value="true">
                                                        <label for="rboIsTaxableYes">Yes</label>
                                                    </div>
                                                    <div class="icheck-primary d-inline ml-3">
                                                        <input type="radio" id="rboIsTaxableNo" name="rboIsTaxable" ng-model="newLedger.IsTaxable" ng-value="false">
                                                        <label for="rboIsTaxableNo">No</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @*Basic Information *@
                            <div class="col-md-9 col-lg-9">
                                <div class="resp-tabs-container hor_1" style="height:100%!important;">
                                    <div class="p-2">
                                        <div class="row">

                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label title="{{newLedger.LedgerId>0 ? newLedger.LedgerId : ''}}">{{GetLabel('Name')}}<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newLedger.Name" ng-blur="GenerateCode()" ng-change="ChangePanrentFields(1)" title="{{beData.LedgerId>0 ? beData.LedgerId : ''}}">
                                                </div>
                                            </div>

                                            <div class="col-sm-3" ng-hide="EPDet.Alias.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('Alias')}}</label>
                                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newLedger.Alias">
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-hide="EPDet.DebtorTypeId.ShowHide==2 || DebtorTypeList.length==0">
                                                <div class="form-group">
                                                    <label>{{GetLabel('DebtorTypeId')}}</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.DebtorTypeId" data-placeholder="** Select DebtorCreditorType **" ng-change="ChangeDebtorType()">
                                                        <option ng-value="cl.DebtorTypeId" ng-repeat="cl in DebtorTypeList" ng-selected="cl.DebtorTypeId==newLedger.DebtorTypeId">{{cl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.LedgerGroupId.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('LedgerGroupId')}}<span style="color:red">*</span></label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.LedgerGroupId" data-placeholder="** Select Group **" ng-blur="GenerateCode()" ng-change="ChangeGroup(1,newLedger.LedgerGroupId)">
                                                        <option ng-value="pl.LedgerGroupId" ng-repeat="pl in LedgerGroupList" ng-selected="pl.LedgerGroupId==newLedger.LedgerGroupId">{{pl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-show="SubGroupColl1.length>0 && EPDet.LedgerGroupId.ShowHide!=2">
                                                <div class="form-group">
                                                    <label>Sub Group 1<span style="color:red">*</span></label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.SubGroup1" data-placeholder="** Select SubGroup **" ng-change="ChangeGroup(2,newLedger.SubGroup1)">
                                                        <option ng-value="pl.LedgerGroupId" ng-repeat="pl in SubGroupColl1" ng-selected="pl.LedgerGroupId==newLedger.SubGroup1">{{pl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-show="SubGroupColl2.length>0 && EPDet.LedgerGroupId.ShowHide!=2">
                                                <div class="form-group">
                                                    <label>Sub Group 2<span style="color:red">*</span></label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.SubGroup2" data-placeholder="** Select SubGroup **" ng-change="ChangeGroup(3,newLedger.SubGroup2)">
                                                        <option ng-value="pl.LedgerGroupId" ng-repeat="pl in SubGroupColl2" ng-selected="pl.LedgerGroupId==newLedger.SubGroup2">{{pl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-show="SubGroupColl3.length>0 && EPDet.LedgerGroupId.ShowHide!=2">
                                                <div class="form-group">
                                                    <label>Sub Group 3<span style="color:red">*</span></label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.SubGroup3" data-placeholder="** Select SubGroup **" ng-change="ChangeGroup(4,newLedger.SubGroup3)">
                                                        <option ng-value="pl.LedgerGroupId" ng-repeat="pl in SubGroupColl3" ng-selected="pl.LedgerGroupId==newLedger.SubGroup3">{{pl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-show="SubGroupColl4.length>0 && EPDet.LedgerGroupId.ShowHide!=2">
                                                <div class="form-group">
                                                    <label>Sub Group 4<span style="color:red">*</span></label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.SubGroup4" data-placeholder="** Select SubGroup **" ng-change="ChangeGroup(5,newLedger.SubGroup4)">
                                                        <option ng-value="pl.LedgerGroupId" ng-repeat="pl in SubGroupColl4" ng-selected="pl.LedgerGroupId==newLedger.SubGroup4">{{pl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-hide="EPDet.Code.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('Code')}}</label>
                                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newLedger.Code">
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-show="newLedger.TypeOfDutyTax==30">
                                                <div class="form-group">
                                                    <label>Opening Credit Points</label>
                                                    <input type="text" number-input positive="true" class="form-control form-control-sm" placeholder="" ng-model="newLedger.OpeningPoint">
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label>Pan/Vat No.</label>
                                                    @*<input type="text" formatnumber="false" number-input positive="true" integer="true" class="form-control form-control-sm" placeholder="" ng-model="newLedger.StatutoryDetail.PanVatNo" maxlength="9" ng-blur="IsValidPANVat(newLedger.LedgerId,newLedger.StatutoryDetail.PanVatNo)">*@

                                                    <!--search button starts-->
                                                    <div class="input-group input-group-sm table-search-filed">
                                                        <input class="form-control form-control-navbar" formatnumber="false" number-input positive="true" integer="true" ng-model="newLedger.StatutoryDetail.PanVatNo" maxlength="9" @*ng-blur="IsValidPANVat(newLedger.LedgerId,newLedger.StatutoryDetail.PanVatNo)" *@>
                                                        <div class="input-group-append">
                                                            <button class="btn btn-default border-left-0" type="button" ng-click="IsValidPANVat(newLedger.LedgerId,newLedger.StatutoryDetail.PanVatNo)">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <!--Ends-->
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.Address.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('Address')}}</label>
                                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newLedger.Address" ng-change="ChangePanrentFields(2)">
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.CreditLimit.ShowHide==2">
                                                <div class="row">
                                                    <div class="col-6">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('CreditLimitAmount')}}</label>
                                                            <input type="text" number-input class="form-control form-control-sm" placeholder="" ng-model="newLedger.CreditLimitAmount">
                                                        </div>
                                                    </div>
                                                    <div class="col-3">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('CreditLimitDays')}}</label>
                                                            <input type="text" number-input class="form-control form-control-sm" placeholder="" ng-model="newLedger.CreditLimitDays">
                                                        </div>
                                                    </div>
                                                    <div class="col-3">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('CreditLimitAs')}}</label>
                                                            <select class="form-control form-control-sm " data-placeholder="**Select Rule**" ng-model="newLedger.CreditLimitAs">
                                                                <option ng-value="r.id" ng-repeat="r in CreditRuleTypeList" ng-selected="r.id==newLedger.CreditLimitAs">{{r.text}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-sm-6" ng-hide="EPDet.Opening.ShowHide==2">
                                                <div class="row">
                                                    <div class="col-6">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('OpeningAmount')}}</label>
                                                            <div class="input-group mb-3">
                                                                <input type="text" number-input class="form-control form-control-sm" ng-model="newLedger.OpeningAmount" positive="true">
                                                                <div class="input-group-append">
                                                                    <select id="inputState" class="form-control form-control-sm rounded-0" ng-model="newLedger.DrCr">
                                                                        <option ng-value="d.id" ng-repeat="d in DrCrList" ng-selected="d.id==newLeddger.DrCr">{{d.text}}</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-6">
                                                        <div class="form-group">
                                                            <label>{{GetLabel('DuesFrom')}}</label>
                                                            <input type="text" class="form-control form-control-sm float-right serial hideSideBar" name="duesFrom" date-picker ng-model="newLedger.DuesFrom_TMP" date-detail="newLedger.DuesFromDet" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-sm-6" ng-hide="EPDet.CurrencyId.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('CurrencyId')}}</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.CurrencyId" data-placeholder="** Select Currency **">
                                                        <option ng-value="c.CurrencyId" ng-repeat="c in CurrencyList" ng-selected="c.CurrencyId==newLedger.CurrencyId">{{c.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.AgentId.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('AgentId')}}</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.TmpAgentIdColl" data-placeholder="** Select Salesman **" multiple id="cboAgent">
                                                        <option value="{{cl.id}}" ng-repeat="cl in SalesManList" @*ng-selected="cl.id==newLedger.AgentId" *@>{{cl.text}}-{{cl.Mobile}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.AreaId.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('AreaId')}}</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.AreaId" data-placeholder="** Select Area **" ng-change="ChangeAreaSelection(newLedger.AreaId)">
                                                        <option ng-value="pl.AreaId" ng-repeat="pl in AreaList" ng-selected="pl.AreaId==newLedger.AreaId">{{pl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-sm-6" ng-hide="EPDet.DebtorRouteId.ShowHide==2">
                                                <div class="form-group">
                                                    <label>{{GetLabel('DebtorRouteId')}}</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.DebtorRouteId" data-placeholder="** Select DebtorCreditorType **">

                                                        <option ng-value="cl.DebtorRouteId" ng-repeat="cl in RouteList" ng-selected="cl.DebtorRouteId==newLedger.DebtorRouteId">{{cl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-hide="EPDet.PriceId.ShowHide==2 || PriceColl.length==0">
                                                <div class="form-group">
