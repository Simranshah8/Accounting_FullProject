@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/export/tableExport.js"></script>
<script src="~/jslib/export/jquery.base64.js"></script>

<script src="~/jslib/export/jspdf/libs/sprintf.js"></script>
<script src="~/jslib/export/jspdf/jspdf.js"></script>
<script src="~/jslib/export/jspdf/libs/base64.js"></script>
<script src="~/jslib/account/creation/Currency.js"></script>
<div ng-app="myApp" ng-controller="currencyController" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllCurrencys()" ng-cloak>

    <div class="box-body1 ">
        <div class="content1">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">Currency</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.Currency">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.Currency">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.Currency">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file">
                                            <a class="btn btn-secondary btn-light btn-sm wait"
                                               title="Refresh" ng-click="GetAllCurrencys()">
                                                <i class="fas fa-sync-alt"></i>
                                            </a>
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'Currency'" report-name="'List Of Currency'" ignore-column="'5'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'Currency',ignoreColumn:'5' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl report-name="'List Of Currency'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait">
                                                <i class="fas fa-print"></i>
                                            </a>
                                        </div>


                                    </div>
                                </header>
                                <div class="search-toolbar mt-2">

                                    <div class="">
                                        <table cellpadding="12" class="main-table table table-bordered table-striped table-hover table-sm" id="datatable">
                                            <thead>
                                                <tr>
                                                    <th style="text-align: center; width: 10%;">
                                                        S.No
                                                        <span class="glyphicon sort-icon" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th ng-click="sort('Name')" style="text-align:left;width: 30% ;">
                                                        Name
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Name'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>

                                                    <th ng-click="sort('Unit')" style="text-align:left;width:20%;">
                                                        Unit
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Unit'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('Code')" style="text-align:left;width: 15%;">

                                                        Symbol
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='Code'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th ng-click="sort('CanEditRate')" style="text-align:left;width: 15%;">

                                                        Can Edit
                                                        <span class="glyphicon sort-icon" ng-show="sortKey=='CanEditRate'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                    </th>
                                                    <th style="text-align:center;width: 10%;" class="no-print">Action</th>

                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="beData in CurrencyColl | orderBy:sortKey:reverse | filter:searchData.Currency | itemsPerPage:perPage.Currency" current-page="currentPages.Currency" pagination-id="CurrencyPagination">

                                                    <td style="text-align:center;">
                                                        {{$index+1}}
                                                    </td>
                                                    <td style="text-align:left">
                                                        {{beData.Name}}
                                                    </td>

                                                    <td style="text-align:left">
                                                        {{beData.Unit}}
                                                    </td>
                                                    <td style="text-align:left">
                                                        {{beData.Code}}
                                                    </td>
                                                    <td style="text-align:left">
                                                        {{beData.CanEditRate}}
                                                    </td>
                                                    <td class="project-actions no-print text-center">
                                                        <div class="btn-group-sm">
                                                            <a href="#" class="btn btn-sm btn-info" ng-click="getCurrencyById(beData)"><i class="fas fa-pencil-alt"></i></a>
                                                            <a href="#" class="btn btn-sm btn-danger" ng-click="deleteCurrency(beData,$index)"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>

                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="CurrencyPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                                <div>
                                    <form>
                                        <div class="row">
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label>Name<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.Name" title="{{beData.CurrencyId>0 ? beData.CurrencyId : ''}}">
                                                </div>
                                            </div>
                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label>Unit</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.Unit">
                                                </div>
                                            </div>

                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label>Symbol</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.Code">
                                                </div>
                                            </div>
                                            <div class="col-sm-2">
                                                <div class="form-group">
                                                    <label>No Of Decimal</label>
                                                    <input type="number" class="form-control form-control-sm" ng-model="beData.NoOfDecimal">
                                                </div>
                                            </div>
                                            <div class="col-sm-2">
                                                <div class="form-group mt-4">
                                                    <div class="icheck-primary d-inline ml-3">
                                                        <input type="checkbox" id="chkCanEditRate" name="chkCanEditRate" ng-model="beData.CanEditRate" >
                                                        <label for="chkCanEditRate">
                                                            CAN EDIT RATE
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>
                                            @*<div class="col-sm-6">
            <div class="form-group">
                <label>Type</label>
                <div class="form-group clearfix">
                    <div class="icheck-primary d-inline">
                        <input type="radio" id="radioPrimary7" name="r4" ng-value="true" ng-model="beData.IsActive">
                        <label for="radioPrimary7">Debtors</label>
                    </div>
                    <div class="icheck-primary d-inline ml-3">
                        <input type="radio" id="radioPrimary8" name="r4" ng-value="false" ng-model="beData.IsActive">
                        <label for="radioPrimary8">Creditors</label>
                    </div>
                </div>
            </div>
        </div>*@
                                        </div>

                                    </form>
                                    <footer class="main-footer">
                                        <div class="text-right control-btns">
                                            <button type="button" class="btn btn-default btn" ng-click="ClearFields()"> <span class="glyphicon glyphicon-remove"></span>Clear</button>
                                            <button type="button" class="btn btn-primary btn" ng-click="AddNewCurrency()" ng-disabled="loadingstatus=='running'"><span class="glyphicon glyphicon-save"></span>Accept</button>
                                        </div>
                                    </footer>

                                </div>


                            </div>

                        </div>
                    </div>
                    <!-- /.card -->

                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->

        </div>




    </div>

</div>


<style>

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>