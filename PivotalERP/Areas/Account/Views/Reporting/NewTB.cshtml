<script src="~/jslib/misreporting/NewTB.js"></script>

<div class="hold-transition layout-navbar-fixed" ng-app="myApp" ng-controller="NewTBController">
    <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
        <div class="overflow-hidden">
            <nav id="sidebarzz" class="order-last float-right active">
                <div class="custom-menu">
                    <button type="button" id="ctmRightSidebarCollapse" class="btn btn-primary"></button>
                </div>
                <div class="" id="firstpanel">
                    <div class="right-box-wrap">
                        <!--Add the required Contents of sidebar-->
                        <div class="d-xl-block" style="height: 200px;">
                            @*<div class="form-group">
                                    <label class="mr-2 mt-1">Branch</label>
                                    <select class="form-control form-control-sm hideSideBar" active-select2 ng-model="newFilter.BranchId" placeholder="*select branch*">
                                        <option ng-repeat="vt in BranchList track by vt.BranchId" ng-value="vt.BranchId">
                                            {{vt.Name}}
                                        </option>
                                    </select>
                                </div>*@

                        </div>
                    </div>
                </div>
            </nav>
            <!-- Main content -->
            <div class="content-wrapper-new">
                <section class="">
                    <div class="container-fluid">
                        <section class="iframe-content-starts-here">
                            <div class="tab-content">
                                <div id="day-book-section">
                                    <div class="card p-2">
                                        <div class="row">
                                            <div class="col-sm-3">
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">From:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" date-picker ng-model="newFilter.DateFrom_TMP" style="max-width:100px" date-detail="newFilter.DateFromDet" />
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">To:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" date-picker ng-model="newFilter.DateTo_TMP" style="max-width:100px" date-detail="newFilter.DateToDet" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex">
                                                    <label class="mr-2 mt-1" style="width: 100px;">Report Type</label>
                                                    <select class="form-control form-control-sm select2" style="width: 80%;" ng-model="newFilter.ReportTypeId" data-placeholder="**Select Report Type**">
                                                        <option ng-value="cl.id" ng-repeat="cl in ReportTypeColl" ng-selected="cl.id==newFilter.ReportTypeId">{{cl.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-3">
                                                <div class="form-group d-flex">
                                                    <label class="mr-2 mt-1">Group</label>
                                                    <select class="form-control form-control-sm select2" active-select2 style="width: 70%;" ng-model="newFilter.LedgerGroupId" placeholder="*select Group*">
                                                        <option ng-repeat="vt in LedgerGroupList track by vt.LedgerGroupId" ng-value="vt.LedgerGroupId">
                                                            {{vt.GroupName}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-2" ng-show="BranchList.length>1">
                                                <div class="form-group d-flex">
                                                    <label class="mr-2 mt-1">Branch</label>
                                                    <multi-select-option ng-model="newFilter.BranchId" data="BranchList" label="Name" value="BranchId"></multi-select-option>
                                                </div>
                                            </div>

                                            <div class="col-sm-1 text-right">
                                                <button type="button" class="btn btn-primary btn-sm load" ng-click="GetAllNewTB()" ng-disabled="loadingstatus=='running'"><i class="fas fa-download"> &nbsp;</i>Load</button>
                                            </div>


                                        </div>

                                    </div>
                                    <div class="card p-2 ">
                                        <header class="row">
                                            <div class="col-md-5 col-sm-5">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm mr-sm-2">
                                                            <div class="input-group-prepend">
                                                                <span class="input-group-text cstm">Find:</span>
                                                            </div>
                                                            <!-- <input type="text" class="form-control border-left-0" placeholder=""> -->
                                                            <select class="form-control pr-0"
                                                                    id="exampleFormControlSelect1">
                                                                <option>Contain</option>
                                                                <option>Prefix</option>
                                                            </select>
                                                        </div>
                                                        <div class="input-group input-group-sm" style="width: 150px;">
                                                            <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">

                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-default">
                                                                    <i class="fas fa-search"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>

                                            <div class="col-md-7 col-sm-7 text-right">
                                                <form class="form-inline  float-right">

                                                    <div class="dropdown dnld-file ml-2">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right"
                                                             aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                     class="img-fluid exports-icon" alt="Excel image">
                                                                Excel
                                                            </a>
                                                            <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                     class="img-fluid exports-icon">
                                                                CSV
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       title="Print" ng-click="Print()">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       data-toggle="modal" data-target="#itemAllocationForModal" data-placement="bottom" title="Filter">
                                                        <i class="fas fa-filter"></i>
                                                    </a>
                                                </form>
                                            </div>
                                        </header>
                                        <div id="datatable" style="height: calc(100vh - 11rem); width: 100%;" class="ag-theme-alpine" ag-grid="gridOptions"></div>
                                        <div id="myGridBottom" style="height: 50px;" class="ag-theme-alpine"></div>
                                    </div>

                                </div>

                            </div>

                        </section>
                        <!-- /.row -->
                    </div>
                    <!--/. container-fluid -->
                </section>
                <!-- /.content -->

            </div>
        </div>
    </div>
	
	@RenderPage("~/Views/Global/_RptContentMenu.cshtml")
</div>
<script>
    (function ($) {
        "use strict";
        var fullHeight = function () {
            $('.js-fullheight').css('height', $(window).height());
            $(window).resize(function () {
                $('.js-fullheight').css('height', $(window).height());
            });

        };
        fullHeight();
        $('#ctmRightSidebarCollapse').on('click', function () {
            $('#sidebarzz').toggleClass('active');
        });

    })(jQuery);
</script>

