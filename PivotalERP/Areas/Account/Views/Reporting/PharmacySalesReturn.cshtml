@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/inventory/transaction/PharmacySalesReturn.js"></script>
<script>
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
</script>
<style>
    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }

    .table-scroll-x-y {
        height: auto!important;
    }
</style>
<div ng-app="myApp" ng-controller="PharmacySalesReturnController">
    <div class="sale-page-wrap1">
        <div class="overflow-hidden">           
            <!-- Page Content  -->
            <div class="container-fluid">
                <div class="card mt-2">                  
                    <div class="card-body py-2">
                        <div class="row">
                            <div class="col-sm-3">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-sm-4">Invoice No.<span style="color:red">*</span></label>
                                    <div class="col-sm-8 col-md-8">
                                        <input type="text" class="form-control form-control-sm serial">
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-3">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-sm-4">Patient Id</label>
                                    <div class="col-sm-8 col-md-8">
                                        <input type="text" class="form-control form-control-sm serial hideSideBar" id="txtPatientId" placeholder="" ng-model="beData.RefNo" ng-blur="GetPatientById()" onfocus="this.select();">
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-sm-4">Bill No</label>
