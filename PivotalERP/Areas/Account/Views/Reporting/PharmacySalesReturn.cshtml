                                        <input type="text" class="form-control form-control-sm" ng-model="beData.PharmacySalesReturnDetail.Address" onfocus="this.select();">
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-lg-4">Phone No.</label>
