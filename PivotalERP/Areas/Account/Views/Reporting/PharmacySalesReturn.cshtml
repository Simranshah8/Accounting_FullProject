                                            <option ng-value="x1.id" ng-repeat="x1 in PaymentTermColl" ng-selected="beData.PharmacySalesReturnDetail.PaymentTermsId==x1.id">{{x1.Name}}</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
