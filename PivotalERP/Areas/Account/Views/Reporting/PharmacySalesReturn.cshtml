                                    <label for="inputEmail3" class="col-sm-5">SSF Code</label>
                                    <div class="col-sm-6 col-md-6">
                                        <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.PharmacySalesReturnDetail.OtherRefereces" ng-blur="SSFCodeLostFocus()">
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" ng-click="ShowSSFDetails()"> :: </button>
                                </div>
                            </div>
                        </div>

                        <div class="table-scroll-x-y" style="height:calc(100vh-22rem)!important;">
                            <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                <thead class="text-center">
                                    <tr>
                                        <th style="width: 50px;">S.No.</th>
                                        <th style="width: 90px;">Bill Date</th>
                                        <th style="width: 80px;">Bill No</th>
                                        <th style="width: 80px;">Bill Type</th>
                                        <th style="width: 170px;">Item Name</th>
                                        <th style="width: 90px;">Batch</th>
                                        <th style="width: 85px;">Expiry </th>                                        
                                        <th style="width: 90px;">Sales Qty</th>
                                        <th style="width: 80px;">Return Qty</th>
                                        <th style="width: 80px;">Rate</th>
                                        <th style="width: 80px;">Discount</th>
                                        <th style="width: 80px;">Vat</th>
                                        <th style="width: 100px;">Total</th>
                                        <th style="width: 70px;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>1</td>
                                        <td>12-12-2020</td>
                                        <td>2132</td>
                                        <td>Credit</td>
                                        <td>qweqe</td>
                                        <td>23123</td>
                                        <td>yyyy-mm</td>
                                        <td style="text-align:center">121321</td>
                                        <td><input type="text" class="form-control form-control-sm" style="text-align:right" /></td>
                                        <td><input type="text" class="form-control form-control-sm" style="text-align:right" /></td>
                                        <td><input type="text" class="form-control form-control-sm" style="text-align:right" /></td>
                                        <td><input type="text" class="form-control form-control-sm" style="text-align:right" /></td>
                                        <td><input type="text" class="form-control form-control-sm" style="text-align:right" /></td>
                                        <td class="text-center">
                                            <a class="p-1" href="#">
                                                <i class="fas fa-plus text-info"></i>
                                            </a>
                                            <a class="p-1" href="#">
                                                <i class="fas fa-trash-alt text-danger"></i>
                                            </a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
