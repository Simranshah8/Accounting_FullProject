
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.RptFormsEntity.CostCenterVoucher)";
</script>
<script src="~/jslib/account/reporting/CostCenterVoucher.js?v=2"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="costCenterVoucherCntrl" ng-init="LoadData()">
    <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
        <div class="overflow-hidden">
            <nav id="sidebarzz" class="order-last float-right active active">
                <div class="custom-menu">
                    <button type="button" id="ctmRightSidebarCollapse" class="btn btn-primary"></button>
                </div>
                <div class="" id="firstpanel">
                    <div class="right-box-wrap px-3">
                        <div class="form-group">
                            <label for="name">Branch</label>
                            <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="costCenterVoucher.BranchId" data-placeholder="* Select Branch *">
                                <option ng-value="cl.BranchId" ng-repeat="cl in BranchList" ng-selected="cl.BranchId==costCenterVoucher.BranchId">{{cl.Name}}</option>
                            </select>
                        </div>
                        <div class="d-xl-block" style="height: 200px;"></div>
                    </div>
                </div>
            </nav>


            <div class="content-wrapper-new">
                <section class="">
                    <div class="container-fluid">
                        <section class="iframe-content-starts-here">
                            <div class="tab-content">
                                <div id="day-book-section">
                                    <div class="card p-2">
                                        <div class="row">
                                            <div class="col-sm-3">
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">From:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" id="dtDateFrom" date-picker ng-model="costCenterVoucher.DateFrom_TMP" style="max-width:100px" date-detail="costCenterVoucher.DateFromDet" />
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">To:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" id="dtDateTo" date-picker ng-model="costCenterVoucher.DateTo_TMP" style="max-width:100px" date-detail="costCenterVoucher.DateToDet" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label class="mt-1 mr-2">Ledger</label>
                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="costCenterVoucher.LedgerId" id="cboLedger" @*style="width:95%"*@ ledgertype="1"
                                                            placeholder="* Select Ledger Name *" showdetails="true" confirm-action="GetCostCenterVoucher()" ledger-detail="costCenterVoucher.LedgerDetails" side-bar-data="costCenterVoucher.partySideBarData"></select>

                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex">
                                                    <label class="mr-2 mt-1">CostCenter</label>
                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-cost-center ng-model="costCenterVoucher.CostCenterId"
                                                            placeholder="* Select CostCeter Name *" showdetails="true" confirm-action="ChangeParticularCostCenter(costCenterVoucher)" costcenter-detail="costCenterVoucher.CostCenterDetails" side-bar-data="costCenterVoucher.partySideBarData"></select>

                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <a href="#" class="btn btn-primary px-1 load" style="float: right; min-width: 75px" data-toggle="tooltip" data-placement="top" title="" data-original-title="Load" ng-click="GetCostCenterVoucher()" ng-disabled="loadingstatus=='running'"><i class="fas fa-download"> &nbsp;&nbsp;Load</i></a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card p-2 ">
                                        <header class="row">
                                            <div class="col-md-5 col-sm-5">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm mr-sm-2">
                                                            <div class="input-group-prepend">
                                                                <span class="input-group-text cstm">Find:</span>
                                                            </div>
                                                            <select class="form-control pr-0"
                                                                    id="exampleFormControlSelect1">
                                                                <option>Contain</option>
                                                                <option>Prefix</option>
                                                            </select>
                                                        </div>
                                                        <div class="input-group input-group-sm" style="width: 150px;">
                                                            <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">

                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-default">
                                                                    <i class="fas fa-search"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                            <div class="col-md-7 col-sm-7 text-right">
                                                <form class="form-inline  float-right">
                                                    <div class="input-group input-group-sm mr-sm-2">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text cstm">Search By:</span>
                                                        </div>
                                                        <select class="form-control pr-0" id="exampleFormControlSelect1">
                                                            <option ng-value="cl.field" ng-repeat="cl in columnDefs">{{cl.headerName}}</option>
                                                        </select>
                                                    </div>
                                                    <div class="input-group input-group-sm" style="width: 200px;">
                                                        <input type="text" name="table_search" class="form-control float-right" placeholder="Search">

                                                        <div class="input-group-append">
                                                            <button type="button" class="btn btn-default">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <div class="dropdown dnld-file ml-2">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right"
                                                             aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                     class="img-fluid exports-icon" alt="Excel image">
                                                                Excel
                                                            </a>
                                                            <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                     class="img-fluid exports-icon">
                                                                CSV
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       title="Print" ng-click="Print()">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                    @*<a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
           data-toggle="modal" data-target="#itemAllocationForModal" data-placement="bottom" title="Filter">
            <i class="fas fa-filter"></i>
        </a>*@
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       data-placement="bottom" title="Save List State" ng-click="saveRptListState()">
                                                        <i class="fas fa-save"></i>
                                                    </a>
                                                </form>
                                            </div>
                                        </header>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <div id="datatable" style="height: calc(100vh - 14.5rem);width:100%;" class="ag-theme-alpine" ag-grid="gridOptions"></div>
                                                <div id="myGridBottom" style="height: 115px;" class="ag-theme-alpine"></div>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                        <!-- /.row -->
                    </div>
                    <!--/. container-fluid -->
                </section>
                <!-- /.content -->
            </div>
            <!-- Add ReportTemplates Modal Dailog -->
            <div class="modal fade bd-example-modal-xl sales-invoice-page-modal" id="FrmPrintReport" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenter2Title" aria-hidden="true">
                <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-xl" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h6 class="modal-title" id="exampleModalCenterTitle">Report Viewer</h6>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <div class="row">
                                <iframe id="frmRpt" style='width: 100%; height: 600px; background-color: white; visibility:visible;' frameborder='0' scrolling='yes'></iframe>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal fade" id="modal-showDocument">
                <div class="modal-dialog modal-md">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h6 class="modal-title" id="exampleModalCenterTitle">{{SelectedTran.VoucherName}}-{{SelectedTran.AutoManualNo}}</h6>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <div class="row">
                                <div class="table-responsive">
                                    <table class="table table-hover border">
                                        <thead>
                                            <tr>
                                                <th scope="col" style="width: 20px">SN.</th>
                                                <th scope="col" style="width:150px">Name</th>
                                                <th scope="col" style="width: 130px">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="dcc in SelectedTran.DocumentColl">
                                                <th scope="row">{{$index+1}}</th>
                                                <td>{{dcc.Name}}</td>
                                                <td>
                                                    <div class="btn-group btn-group-sm">
                                                        <a href="{{dcc.DocPath}}" class="btn btn-warning" data-toggle="tooltip" data-placement="top" title="" data-original-title="Download doc." download="{{dcc.Name}}"><i class="fas fa-download"></i></a>
                                                        <a href="#" class="btn btn-info" data-toggle="tooltip" data-placement="top" title="" data-original-title="View doc" ng-click="ShowPersonalImg(dcc)"><i class="fas fa-eye"></i></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="time-label">
                            <span class="d-block border-0 p-3 text-center">
                                <button type="button" class="btn btn-sm btn-danger" data-dismiss="modal" style="min-width: 90px;">Close</button>
                            </span>
                        </div>
                    </div>
                </div>
                <!-- /.modal-content -->
            </div>
            <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
                <div class="modal-dialog modal-lg" role="document">
                    <div class="modal-content">
                        <div class="modal-body mb-0 p-2">
                            <iframe class="responsive-iframe" ng-hide="viewImg.FileType === 'image'" id="pdfViewer" style="width: 100%; height: 700px; border: none;"></iframe>
                            <img ng-show="viewImg.FileType === 'image'" ng-src="{{viewImg.ContentPath}}" alt="" style="width: 100%; height: auto;" id="imgPreviewAdd">
                        </div>
                        <div class="modal-footer p-2">
                            <div><a href="{{viewImg.ContentPath}}" download>Download</a></div>
                            <button class="btn btn-success btn-rounded btn-sm ml-4 btn-add text-center" data-dismiss="modal" type="button" style="min-width: 70px;">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
	
	@RenderPage("~/Views/Global/_RptContentMenu.cshtml")
	
</div>

<script>
    (function ($) {

        "use strict";

        var fullHeight = function () {

            $('.js-fullheight').css('height', $(window).height());
            $(window).resize(function () {
                $('.js-fullheight').css('height', $(window).height());
            });

        };
        fullHeight();

        $('#ctmRightSidebarCollapse').on('click', function () {
            $('#sidebarzz').toggleClass('active');
        });


    })(jQuery);
</script>