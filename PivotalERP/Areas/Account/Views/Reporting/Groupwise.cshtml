
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.RptFormsEntity.TrailBalanceLedgerGroupWise)";
</script>
<script src="~/jslib/account/reporting/Groupwise.js?v=20250701"></script>
<div class="hold-transition layout-navbar-fixed" ng-app="myApp" ng-controller="GroupwiseTBController">
    <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
        <div class="overflow-hidden">
            <nav id="sidebarzz" class="order-last float-right active">
                <div class="custom-menu">
                    <button type="button" id="ctmRightSidebarCollapse" class="btn btn-primary"></button>
                </div>
                <div class="" id="firstpanel">
                    <div class="right-box-wrap">
                        <!--Add the required Contents of sidebar-->
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <div class="form-group">
                                    <div class="icheck-primary d-inline ml-3">
                                        <input type="checkbox" id="rboShowZeroBal" name="rboShowZeroBal" ng-model="Groupwise.ShowZeroBalance">
                                        <label for="rboShowZeroBal">
                                            SHOW ZERO BALANCE
                                        </label>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="form-group">
                                    <div class="icheck-primary d-inline ml-3">
                                        <input type="checkbox" id="cboShowPDC" name="ShowPDC" ng-model="Groupwise.ShowPDC" ng-change="ShowPDC(Groupwise.ShowPDC)">
                                        <label for="cboShowPDC">
                                            SHOW PDC
                                        </label>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="form-group">
                                    <div class="icheck-primary d-inline ml-3">
                                        <input type="checkbox" id="rboShowDetails" name="rboShowDetails" ng-model="Groupwise.ShowDetails" ng-change="ShowDetails(Groupwise.ShowDetails)">
                                        <label for="rboShowDetails">
                                            SHOW DETAILS
                                        </label>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="form-group">
                                    <div class="icheck-primary d-inline ml-3">
                                        <input type="checkbox" id="rboShowCostCenter" name="rboShowCostCenter" ng-model="Groupwise.ShowCostCenter">
                                        <label for="rboShowCostCenter">
                                            SHOW COSTCENTER
                                        </label>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="form-group">
                                    <div class="icheck-primary d-inline ml-3">
                                        <input type="checkbox" id="rboShowAsList" name="rboShowAsList" ng-model="Groupwise.ShowAsList" ng-change="GetGroupwise()">
                                        <label for="rboShowAsList">
                                            SHOW AS LIST
                                        </label>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="form-group">
                                    <div class="icheck-primary d-inline ml-3">
                                        <input type="checkbox" id="rboShowDebtorCreditor" name="ShowDebtorCreditor" ng-model="Groupwise.ShowDebtorCreditor" ng-change="GetGroupwise()">
                                        <label for="rboShowDebtorCreditor">
                                            SHOW DEBTOR AND CREDITORS
                                        </label>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="form-group">
                                    <div class="icheck-primary d-inline ml-3">
                                        <input type="checkbox" id="rboShowMonthWise" name="ShowMonthWise" ng-model="Groupwise.MonthWise" ng-change="GetGroupwise()">
                                        <label for="rboShowMonthWise">
                                            SHOW MONTH WISE
                                        </label>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="form-group">
                                    <label class="mr-2 mt-1">Sub Ledger As</label>
                                    <select class="form-control form-control-sm select2 ml-2" style="width: 80%;" ng-model="Groupwise.ReportType" data-placeholder="**Select SubLedger As**">
                                        <option ng-value="cl.id" ng-repeat="cl in ReportTypes">{{cl.text}}</option>
                                    </select>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="form-group">
                                    <label class="mr-2 mt-1">Brand</label>
                                    <select class="form-control form-control-sm select2 ml-2" style="width: 80%;" ng-model="Groupwise.BrandId" data-placeholder="**Select Brand **">
                                        <option ng-value="cl.ProductBrandId" ng-repeat="cl in ProductBrandList">{{cl.Name}}</option>
                                    </select>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="form-group">
                                    <div class="icheck-primary d-inline ml-3">
                                        <input type="checkbox" id="rboShowOpeningClosingDrCr" name="ShowOpeningClosingDrCr" ng-model="Groupwise.ShowOpeningClosingDrCr" ng-change="ShowDetailsDrCr(Groupwise.ShowOpeningClosingDrCr)">
                                        <label for="rboShowOpeningClosingDrCr">
                                            Show Opening/Closing DrCr
                                        </label>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="form-group">
                                    <label class="mr-2 mt-1">Project</label>
                                    <multi-select-option ng-model="Groupwise.ProjectIdColl" data="ProjectColl" label="Name" value="ProjectId" confirm-action="GetGroupwise()"></multi-select-option>
                                </div>
                            </li>
                        </ul>

                        <div class="d-xl-block" style="height: 200px;"></div>
                    </div>
                </div>
            </nav>
            <div class="content-wrapper-new">
                <section class="">
                    <div class="container-fluid">
                        <section class="iframe-content-starts-here">
                            <div class="tab-content">
                                <div id="day-book-section">
                                    <div class="card pt-2 pb-0 px-2">
                                        <div class="row">
                                            <div class="col-sm-3">
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">From:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" date-picker ng-model="Groupwise.DateFrom_TMP" style="max-width:100px" date-detail="Groupwise.DateFromDet" />
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">To:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" date-picker ng-model="Groupwise.DateTo_TMP" style="max-width:100px" date-detail="Groupwise.DateToDet" />
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-3">
                                                <div class="form-group d-flex" ng-show="BranchList.length>1">
                                                    <label class="mr-2 mt-1">Branch</label>
                                                    <multi-select-option ng-model="Groupwise.BranchId" data="BranchList" label="Name" value="BranchId"></multi-select-option>
                                                    @*<select class="form-control form-control-sm select2 ml-2" style="width: 80%;" ng-model="Groupwise.BranchId" data-placeholder="**Select Branch**" multiple>
            <option ng-value="cl.BranchId" ng-repeat="cl in BranchList">{{cl.Name}}</option>
        </select>*@
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label class="mr-2 mt-1">Group</label>
                                                    <select class="form-control form-control-sm select2 ml-2" style="width: 80%;" ng-model="Groupwise.LedgerGroupId" data-placeholder="**Select Group**">
                                                        <option ng-value="cl.LedgerGroupId" ng-repeat="cl in LedgerGroupList">{{cl.Name}}</option>
                                                    </select>

                                                </div>
                                            </div>
                                            <div class="col-md-2 ">
                                                <div class="form-group">
                                                    <a href="#" class="btn btn-primary load px-1" style="float: right; min-width: 80px" data-toggle="tooltip" data-placement="top" title="" data-original-title="Load" ng-click="GetGroupwise()" ng-disabled="loadingstatus=='running'"><i class="fas fa-download"> &nbsp;&nbsp;Load</i></a>
                                                </div>
                                            </div>

                                        </div>

                                    </div>
                                    <div class="card p-2 ">
                                        <header class="row">
                                            <div class="col-md-5 col-sm-5">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm mr-sm-2">
                                                            <div class="input-group-prepend">
                                                                <span class="input-group-text cstm">Find:</span>
                                                            </div>
                                                            <!-- <input type="text" class="form-control border-left-0" placeholder=""> -->
                                                            <select class="form-control pr-0"
                                                                    id="exampleFormControlSelect1">
                                                                <option>Contain</option>
                                                                <option>Prefix</option>
                                                            </select>
                                                        </div>
                                                        <div class="input-group input-group-sm" style="width: 150px;">
                                                            <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">

                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-default">
                                                                    <i class="fas fa-search"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>

                                            <div class="col-md-7 col-sm-7 text-right">
                                                <form class="form-inline  float-right">
                                                    <div class="input-group input-group-sm mr-sm-2">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text cstm">Search By:</span>
                                                        </div>
                                                        <div class="input-group-prepend">
                                                            <select class="form-control form-control-sm select2bs4" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                                <option ng-value="asp" ng-repeat="asp in columnDefs">{{asp.headerName}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="input-group input-group-sm" style="width: 150px;">
                                                        <input type="text" name="table_search" class="form-control float-right" placeholder="Search">

                                                        <div class="input-group-append">
                                                            <button type="submit" class="btn btn-default">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <div class="input-group input-group-sm mx-3">
                                                        <div class="custom-control custom-checkbox">
                                                            <input class="custom-control-input" type="checkbox"
                                                                   id="customCheckbox1" value="option1" ng-model="Groupwise.ExpandCollapse" ng-change="toggleExpandCollapse()">
                                                            <label for="customCheckbox1"
                                                                   class="custom-control-label">
                                                                {{Groupwise.ExpandCollapse==true ? 'Collapse': 'Expand' }}
                                                            </label>
                                                        </div>
                                                    </div>
                                                    <div class="dropdown dnld-file ml-2">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right"
                                                             aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                     class="img-fluid exports-icon" alt="Excel image">
                                                                Excel
                                                            </a>
                                                            <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                     class="img-fluid exports-icon">
                                                                CSV
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       title="Print" ng-click="Print()">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       data-placement="bottom" title="Save List State" ng-click="saveRptListState()">
                                                        <i class="fas fa-save"></i>
                                                    </a>
                                                </form>

                                            </div>

                                        </header>
                                        <div id="datatable" style="height: calc(100vh - 8rem); width: 100%;" class="ag-theme-alpine" ag-grid="gridOptions"></div>
                                    </div>

                                </div>

                            </div>

                        </section>
                        <!-- /.row -->
                    </div>
                    <!--/. container-fluid -->
                </section>
            </div>
            <!-- /.content -->
            <!-- Add ReportTemplates Modal Dailog -->
            <div class="modal fade bd-example-modal-xl sales-invoice-page-modal" id="FrmPrintReport" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenter2Title" aria-hidden="true">
                <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-xl" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h6 class="modal-title" id="exampleModalCenterTitle">Report Viewer</h6>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <div class="row">
                                <iframe id="frmRpt" style='width: 100%; height: 600px; background-color: white; visibility:visible;' frameborder='0' scrolling='yes'></iframe>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



    @RenderPage("~/Views/Global/_EditTran.cshtml")
	@RenderPage("~/Views/Global/_RptContentMenu.cshtml")
</div>
    <script>
        (function ($) {
            "use strict";
            var fullHeight = function () {
                $('.js-fullheight').css('height', $(window).height());
                $(window).resize(function () {
                    $('.js-fullheight').css('height', $(window).height());
                });

            };
            fullHeight();
            $('#ctmRightSidebarCollapse').on('click', function () {
                $('#sidebarzz').toggleClass('active');
            });

        })(jQuery);
    </script>
