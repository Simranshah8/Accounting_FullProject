
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/account/reporting/BudgetReporting.js"></script>
<div class="hold-transition layout-navbar-fixed" ng-app="myApp" ng-controller="BudgetReportingController">
    <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
        <div class="overflow-hidden">
            <nav id="sidebarzz" class="order-last float-right active">
                <div class="custom-menu">
                    <button type="button" id="ctmRightSidebarCollapse" class="btn btn-primary"></button>
                </div>
                <div class="" id="firstpanel">
                    <div class="right-box-wrap">
                        <!--Add the required Contents of sidebar-->
                        <div class="d-xl-block" style="height: 200px;"></div>
                    </div>
                </div>
            </nav>
            <div class="content-wrapper-new">
                <section class="">
                    <div class="container-fluid">
                        <section class="iframe-content-starts-here">
                            <div class="tab-content">
                                <div id="day-book-section">
                                    <div class="card p-2">
                                        <div class="row">
                                            <div class="col-sm-4">
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">Branch</span>
                                                        </div>
                                                        <div>
                                                            <select class="form-control form-control-sm select2 text-dark" style="width:100% !important" ng-model="BudgetReporting.BranchId" multiple placeholder="*select branch*">
                                                                <option ng-value="poc.BranchId" ng-repeat="poc in BranchList">{{poc.Name}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-3">
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">Fiscal Year</span>
                                                        </div>
                                                        <div>
                                                            <select class="form-control form-control-sm select2" ng-model="BudgetReporting.CostClassId" placeholder="**Select All**" style="width:150px!important">
                                                                <option ng-value="c.CostClassId" ng-repeat="c in CostClassList" ng-selected="c.CostClassId==BudgetReporting.CostClassId">{{c.Name}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-sm-3">
                                                <div class="form-group row" ng-show="BranchList.length>1">
                                                    <label for="inputEmail3" class="col-lg-3">Branch</label>
                                                    <div class="col-lg-9">
                                                        <select class="form-control form-control-sm hideSideBar" active-select2 style="width: 100%;" ng-model="BudgetReporting.BranchId" ng-change="GetBudgetReporting()" placeholder="*select branch*">
                                                            <option ng-repeat="vt in BranchList track by vt.BranchId" ng-value="vt.BranchId">
                                                                {{vt.Name}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-1">
                                                <button type="button" class="btn btn-primary load px-1 float-right" style="min-width: 75px;" ng-click="GetBudgetReporting()"><i class="fas fa-download"> &nbsp;&nbsp;Load</i></button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card p-2 ">
                                        <header class="row">
                                            <div class="col-md-5 col-sm-5">
                                                <div class="clearfix">
                                                    <form class="form-inline">                                                          
                                                        <div class="input-group input-group-sm" style="width: 250px;">
                                                            <input type="text" name="table_search" class="form-control float-right" placeholder="Search"ng-model="search" ng-change="onFilterTextBoxChanged()">
                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-default">
                                                                    <i class="fas fa-search"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>

                                            <div class="col-md-7 col-sm-7 text-right">
                                                <form class="form-inline  float-right">
                                                    <div class="dropdown dnld-file ml-2">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right"
                                                             aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                <img src="/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                     class="img-fluid exports-icon" alt="Excel image">
                                                                Excel
                                                            </a>
                                                            <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                                <img src="/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                     class="img-fluid exports-icon">
                                                                CSV
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       title="Print" ng-click="Print()">
                                                        <i class="fas fa-print"></i>
                                                    </a>                                                  
                                                </form>
                                            </div>
                                        </header>
                                        <div>
                                            <div id="datatable" style="height: calc(100vh - 10rem); width: 100%;" class="ag-theme-alpine"></div>
                                            <div id="myGridBottom" style="height:50px;" class="ag-theme-alpine"></div>
                                        </div>                                    
                                    </div>
                                </div>

                            </div>

                        </section>
                        <!-- /.row -->
                    </div>
                    <!--/. container-fluid -->
                </section>
            </div>
            <!-- /.content -->
            <!-- Add ReportTemplates Modal Dailog -->
            <div class="modal fade bd-example-modal-xl sales-invoice-page-modal" id="FrmPrintReport" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenter2Title" aria-hidden="true">
                <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-xl" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h6 class="modal-title" id="exampleModalCenterTitle">Report Viewer</h6>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <div class="row">
                                <iframe id="frmRpt" style='width: 100%; height: 600px; background-color: white; visibility:visible;' frameborder='0' scrolling='yes'></iframe>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

         

        </div>
    </div>
</div>
<script>
    (function ($) {
        "use strict";
        var fullHeight = function () {
            $('.js-fullheight').css('height', $(window).height());
            $(window).resize(function () {
                $('.js-fullheight').css('height', $(window).height());
            });

        };
        fullHeight();
        $('#ctmRightSidebarCollapse').on('click', function () {
            $('#sidebarzz').toggleClass('active');
        });

    })(jQuery);
</script>