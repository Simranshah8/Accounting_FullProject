                {
                    label: "Stock",
                    data: [10, 20, 30, 40, 50, 40, 30, 20, 10],
                    backgroundColor: "#69A643", // Light blue
                    borderRadius: 20, // Add rounded corners to bars
                    barThickness: 35,
                }
            ],
        };

        const options = {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,

                    title: {
                        display: true,
                        text: "Stock unit",
                    },
                },
            },
            plugins: {
                legend: {
                    display: false,
                    position: "bottom",
                    labels: {
                        usePointStyle: true,
                    },
                },

            },
        };

        new Chart(ctx5, {
            type: "bar",
            data: data,
            options: options,
        });
    });

</script>

