<script>
    const ctx7 = document.getElementById('AnnualStockAnalysys').getContext('2d');

    // Create gradient for online sales (blue)
    const gradientBlue7 = ctx7.createLinearGradient(0, 0, 0, 400);
    gradientBlue7.addColorStop(0, '#FF0000');
    gradientBlue7.addColorStop(1, 'rgba(74, 144, 226, 0.01)');

    // Create gradient for offline sales (orange)
    const gradientOrange7 = ctx7.createLinearGradient(0, 0, 0, 400);
    gradientOrange7.addColorStop(0, '#55B11B');
    gradientOrange7.addColorStop(1, 'rgba(169, 223, 216, 0.01)');

    new Chart(ctx7, {
        type: 'line',
        data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
            datasets: [
                {
                    label: 'Online Sales',
                    data: [20, 30, 40, 60, 80, 70, 90, 75, 50, 45, 65, 85],
                    borderColor: '#007bff',
                    backgroundColor: gradientBlue7,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 3,
                    pointBackgroundColor: '#007bff',
                },
                {
                    label: 'Offline Sales',
                    data: [30, 40, 50, 70, 90, 80, 100, 85, 60, 55, 75, 95],
                    borderColor: '#ffa500',
                    backgroundColor: gradientOrange7,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 3,
                    pointBackgroundColor: '#ffa500',
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: {
                    beginAtZero: true,
                    title: {
                        display: true,
                        text: 'Monthly Stock Unit',
                    },
                },
                x: {
                    title: {
                        display: true,
                        text: 'Months',
                    },
                },
            },
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        usePointStyle: true, // Use point style for legend markers
                        pointStyle: 'circle', // Set the point style to circle
                    },
                },
            },
        },
    });
</script>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const ctx5 = document.getElementById("categorywisestock").getContext("2d");

        const data = {
            labels: ["Cat1", "Cat2", "Cat3", "Cat4", "Cat5", "Cat6", "Cat7", "Cat8", "Cat9"],
