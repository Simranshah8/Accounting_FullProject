                                    <th>Amount</th>
                                    <th>Voucher</th>
                                    <th>CostClass</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr dir-paginate="sd in PurchaseDataColl |orderBy:sortKey:reverse|itemsPerPage:paginationOptions.pageSize" total-items="paginationOptions.TotalRows">
                                    <td align="center">
                                        <input class="custom-control-input"
                                               type="checkbox" id="chk-p-{{$index}}" ng-model="sd.IsSelected" ng-change="SelectPurchaseInvoice(sd)">
                                        <label for="chk-p-{{$index}}"
                                               class="custom-control-label">
                                            {{sd.VoucherDate |dateFormat}}
                                        </label>
                                    </td>
                                    <td align="center">{{sd.VoucherMiti}}</td>
                                    <td align="center">{{sd.Days}}</td>
                                    <td align="center">{{sd.VoucherNo}}</td>
                                    <td>{{sd.RefNo}}</td>
                                    <td>{{sd.PartyLedger}}</td>
                                    <td align="right">
                                        {{sd.Amount |number:2}}
                                    </td>
                                    <td>{{sd.VoucherName}}</td>
                                    <td>{{sd.CostClass}}</td>
                                </tr>
                            </tbody>

                        </table>
                        <dir-pagination-controls max-size="paginationOptions.pageSize" direction-links="true" boundary-links="true"
                                                 on-page-change="ReSearchPurchaseData(newPageNumber)">
                        </dir-pagination-controls>
                    </div>

                </div>
                <!-- end modal body -->
                <div class="modal-footer justify-content-between align-items-center py-2">
                    <h6 class="mb-0">Total Record: {{paginationOptions.TotalRows}}</h6>
                    <div class="">
                        <button type="button" class="btn btn-sm btn-outline-secondary" ng-click="AfterPurchaseInvoiceSelected()">Ok</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @RenderPage("~/Global/_ReportTemplates.cshtml");
    @RenderPage("~/Views/Global/_IsValidTran.cshtml")
</div>


