
<script>
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
    var TranId =@ViewBag.TranId;
    var PurchaseVoucherType=@Convert.ToInt32(Dynamic.BusinessEntity.Account.VoucherTypes.PurchaseInvoice);
</script>
<script src="~/jslib/account/transaction/AdditionalJournal.js"></script>
<div ng-app="myApp" ng-controller="AdditionalJournalController" ng-init="LoadData()" ng-cloak>
    <div class="sale-page-wrap">
        <div class="overflow-hidden">
            @RenderPage("~/Views/Global/_WaitDialog.cshtml")
            @RenderPage("~/Views/Global/_LedgerDetails.cshtml")

            <!-- Page Content  -->
            <div class="content-wrapper-new">

                <div class="card">
                    <div class="card-header header-corner-triangle overflow-hidden">
                        <div class="row">
                            <h3 class="card-title">Additional Journal</h3>
                            <div class="col-sm-4" ng-hide="HideShow.VoucherType==true">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-sm-4 col-form-label">Voucher</label>
                                    <div class="col-sm-8">
                                        <select class="form-control  hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()">
                                            <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" value="{{vt.VoucherId}}" ng-selected="vt.VoucherId == beData.VoucherId">
                                                {{vt.VoucherName}}
                                            </option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4" ng-hide="HideShow.CostClass==true">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-sm-4 col-form-label">For Year</label>
                                    <div class="col-sm-8">
                                        <select class="form-control  hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()">
                                            <option ng-repeat="cc in CostClassColl track by cc.CostClassId" value="{{cc.CostClassId}}" ng-selected="cc.CostClassId == beData.CostClassId">
                                                {{cc.Name}}
                                            </option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <form action="">
                            <div class="row">
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Voucher No.</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                            <input type="text" class="form-control serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-4 col-form-label">Ref. No.</label>
                                        <div class="col-sm-8">
                                            <div class="d-flex">
                                                <div class="input-group">
                                                    <input type="text" class="form-control serial hideSideBar" placeholder="" ng-model="beData.RefNo" readonly>
                                                </div>
                                                <button type="button" class="btn btn-default ml-2" ng-click="SearchPurchaseData()">
                                                    <i class="fas fa-bars"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Voucher Date</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial hideSideBar" name="VoucherDate" date-picker ng-model="beData.VoucherDate" date-detail="beData.VoucherDateDet" />
                                            @*<input type="text" class="form-control float-right serial hideSideBar" name="VoucherDate" voucher-date ng-model="beData.VoucherDate" readonly />*@
                                        </div>
                                    </div>
                                </div>


                                <div class="col-sm-6" ng-hide="HideShow.Currency==true">
                                    <div class="row">
                                        <label for="inputEmail3" class="col-sm-4 col-form-label">Currency</label>
                                        <div class="col-sm-8">
                                            <div class="row">
                                                <div class="col-sm-6">
                                                    <select autoShowHide="true" class="select2 serial" all-currency ng-model="beData.CurrencyId" id="cboCurrency" style="width:95%"
                                                            placeholder="** Select Currency **" showdetails="true" confirm-action="ShowSideBar(beData.currencySideBarData)" currency-detail="beData.CurrencyDet" side-bar-data="beData.currencySideBarData"></select>
                                                </div>
                                                <div class="col-sm-6">
                                                    <div class="form-group row">
                                                        <label for="inputEmail3" class="col-sm-4 col-form-label">Rate</label>
                                                        <div class="col-sm-8">
                                                            <input type="number" class="form-control serial" placeholder="" ng-model="beData.CurRate" onfocus="this.select();">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- row -->
                        </form>
                    </div>
                    <!-- end form fiels -->
                    <div class="card-body pt-0">
                        <div class="table-scroll-x-y">
                            <table id="main-table" class="main-table table table-sm table-bordered">
                                <thead class="text-center">
                                    <tr>
                                        <th style="width: 50px">S.No.</th>
                                        <th style="width: 60px">DR/CR</th>
                                        <th style="width: 200px">Particulars</th>
                                        <th style="width: 150px">Current Bal.</th>
                                        <th style="width: 120px">Dr.Amount</th>
                                        <th style="width: 120px">Cr.Amount</th>
                                        <th ng-show="SelectedVoucher.EachNarrationEntry==true" style="width: 150px">Narration</th>
                                        <th class="text-center align-middle" style="width: 60px;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="ledAllocation in beData.LedgerAllocationColl">
                                        <td align="center">{{$index+1}}</td>
                                        <td>
                                            <select class="form-control form-control-sm rounded-0" ng-model="ledAllocation.DrCr" ng-change="ChangeDrCr(ledAllocation)">
                                                <option ng-value="d.id" ng-repeat="d in DrCrList" ng-selected="d.id==ledAllocation.DrCr">{{d.text}}</option>
                                            </select>
                                        </td>
                                        <td>
                                            <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="ledAllocation.LedgerId" ledgertype="1"
                                                    placeholder="** Select Ledger Name **" showdetails="true" confirm-action="ChangeParticularLedger(ledAllocation)" ledger-detail="ledAllocation.LedgerDetails" side-bar-data="ledAllocation.partySideBarData"></select>
                                        </td>
                                        <td>{{ledAllocation.CurrentBal |accountFormat}}</td>
                                        <td><input type="text" number-input style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="ledAllocation.DrAmount" ng-blur="AddRowInLedgerAllocation($index,true)" ng-change="ChangeDrCrAmount()" ng-disabled="ledAllocation.DrCr==2"></td>
                                        <td><input type="text" number-input style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="ledAllocation.CrAmount" ng-blur="AddRowInLedgerAllocation($index,true)" ng-change="ChangeDrCrAmount()" ng-disabled="ledAllocation.DrCr==1"></td>
                                        <td ng-show="SelectedVoucher.EachNarrationEntry==true"><input type="text" onfocus="this.select();" class="form-control form-control-sm" ng-model="ledAllocation.Narration"></td>
                                        <td>
                                            <a class="p-1" href="#" data-original-title="Add Row" ng-click="AddRowInLedgerAllocation($index)">
                                                <i class="fas fa-plus text-info"></i>
                                            </a>
                                            <a class="p-1" href="#" data-original-title="Delete Row." ng-click="delRowLedgerAllocation($index)">
                                                <i class="fas fa-trash-alt text-danger"></i>
                                            </a>

                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </div>


                    <!-- /.card body -->
                </div>
                <div style="height: 30px"></div>
            </div>
        </div>
        <!-- /.container-fluid -->
    </div>

    <footer class="main-footer control-btns pt-0">
        <div class="secondary-footer mb-2 mt-2" style="padding-left: 27px; padding-right: 40px;">
            <div class="row">
                <div class="col-md-8 col-xl-9">
                    <input type="text" list="lstNarration" class="form-control hideSideBar" name="" id="" rows="3" placeholder="Narration" ng-model="beData.Narration">
                    <datalist id="lstNarration">
                        <option ng-repeat="x1 in NarrationList track by $index" value="{{x1}}">
                    </datalist>
                </div>
                <div class="col-md-4 col-xl-3">
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-5 col-sm-6 col-form-label font-weight-bold text-dark text-right">Total:</label>
                        <div class="col-7 col-sm-6 col-md-6">
                            <input type="text" number-input class="form-control hideSideBar" style="text-align:right;" placeholder="" readonly ng-model="beData.TotalAmount">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-4">
                @*<button type="button" class="btn btn-default" data-toggle="modal" data-target="#aditionalCostModal">
                        Aditional Cost
                    </button>*@
                <button type="button" class="btn btn-default" data-toggle="modal" data-target="#documentAttachModal">
                    Document Attach ({{beData.AttechFiles.length}} )
                </button>
            </div>
            <div class="col-sm-8">
                <form class="form-inline justify-content-end">
                    <button type="button" class="btn btn-default ml-1" ng-click="SearchData()">Search</button>
                    <button type="button" class="btn btn-default ml-1" ng-click="Print()">Re-Print</button>
                    <button type="button" class="btn btn-default ml-1" ng-click="Clear()">Reset</button>
                    @*<button type="button" class="btn btn-secondary ml-1" ng-click="SaveSalesInvoice()">Save & Close</button>*@
                    <button type="button" class="btn btn-primary ml-1" ng-click="SaveJournal()">Save</button>
                </form>
            </div>
        </div>
    </footer>




    <div class="modal fade bd-example-modal-xl sales-invoice-page-modal" id="frmCostCentersModel" role="dialog" aria-labelledby="exampleModalCenter2Title" aria-hidden="true" style="margin-top:20px">
