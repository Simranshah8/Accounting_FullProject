
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.0/FileSaver.min.js" integrity="sha512-csNcFYJniKjJxRWRV1R7fvnXrycHP6qDR21mgz1ZP55xY5d+aHLfo9/FcGDQLfn2IfngbAHd8LdfsagcCqgTcQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="~/jslib/global/WebSocketEx.js"></script>
@*<script src="~/jslib/inventory/transaction/SalesInvoiceHulas.js"></script>*@
<script src="~/jslib/inventory/transaction/SalesInvoice.js?v=20240220"></script>
<script>
    var RecVoucherType = "@Convert.ToInt32(Dynamic.BusinessEntity.Account.VoucherTypes.Receipt)";
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
    var EntityDE="@ViewBag.EntityDE";
</script>
<style>
    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .sale-page-wrap .content-wrapper-new {
        padding-left: 0px;
    }
    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }

    #ndp-nepali-box {
        left: calc(92% - 9rem) !important;
    }
</style>

<style>
    .table-scroll-x-y table thead th {
        background-color: #e8eef4 !important;
    }
</style>
<script src="~/jslib/inventory/transaction/CounterSales.js"></script>

<div ng-app="myApp" ng-controller="CounterSalesController" ng-init="LoadData()">
    <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
        <div class="overflow-hidden">
            <!-- Page Content  -->
            <div class="content-wrapper-new1 px-2">
                <div class="card mt-1 bodypart1">
                    <div class="demo-container1">
                        <div class="demo-header">
                            <div class="card-body px-3 py-2">
                                <div class="row">
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <div class="d-flex">
                                                <label for="inputEmail3" style="min-width: 120px;">Product</label>

                                                <div data-barcode-scanner="barcodeScanned"></div>
                                                <input type="text" class="form-control form-control-sm" data-ng-model="beData.ProductBarCode" id="txtBarcode" name="txtBarcode" onfocus="this.select();" autocomplete="off" />

                                                @*<select autoShowHide="true" class="form-control form-control-sm select2 serial" all-product ng-model="beData.ProductId" style="width:100%" ng-paste="PasteData('product',0)" onpaste="return false"
                                                    placeholder="** Select Product  **" showdetails="true" confirm-action="ProductSelectionChange(itemDet,$index)" product-detail="beData.productDetail" side-bar-data="beData.sideBarData" voucher-id="SelectedVoucher.VoucherId" ledger-id="beData.PartyLedgerId" company-id="beData.ProductCompanyId" vouchertype="14" ng-disabled="itemDet.ReadOnlyQty==true" godown-id="itemDet.GodownId" godown-change="GodownChange" rate-type="beData.RateTypeId"></select>*@

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-3">
                                        <div class="form-group d-flex">
                                            <label for="inputEmail3" style="min-width:120px;">Bill No.</label>
                                            <input type="text" class="form-control form-control-sm float-right" ng-model="beData.AutoManualNo" disabled />
                                        </div>
                                    </div>
                                    <div class="col-sm-3">
                                        <div class="form-group d-flex">
                                            <label for="inputEmail3" style="min-width:120px;">Ref No.</label>
                                            <input type="text" class="form-control form-control-sm float-right" ng-model="beData.RefNo" />
                                        </div>
                                    </div>

                                    <div class="col-sm-3">
                                        <div class="form-group d-flex">
                                            <label for="inputEmail3" style="min-width: 100px;">Invoice Date</label>
                                            <input type="text" class="form-control form-control-sm float-right serial hideSideBar" name="VoucherDate" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" disabled confirm-action="getVoucherNoOnly()" title="{{(beData.VoucherDateDet.dateAD |dateFormat)}}" />
                                        </div>
                                    </div>
                                    <div class="col-sm-3">
                                        <div class="form-group d-flex">
                                            <label for="inputEmail3" style="min-width:120px;">Customer</label>
                                            <select autoShowHide="true" class="select2 serial form-control form-control-sm" all-ledger ng-model="beData.PartyLedgerId" id="cboParty1" style="width:95%" ledgertype="3" fortransaction="true"
                                                    placeholder="** Select Party Name **" showdetails="true" confirm-action="PartySelectionChange(beData)" ledger-detail="beData.PartyLedger" side-bar-data="beData.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="14"></select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- end form fiels -->
                        <div class="row">
                            <div class="col-sm-9">
                                <div class="table-scroll-x-y mb-1 table-container" style="height: calc(100vh - 10rem)!important;">
                                    <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                        <thead>
                                            <tr>
                                                <th rowspan="2" class="text-center align-middle cstm-sticky" style="width: 40px;left:0;z-index:3">S.No</th>
                                                <th rowspan="2" class="align-middle cstm-sticky" style="width: 250px;left:40px;z-index:3">Particulars</th>
                                                <th rowspan="2" class="align-middle" style="width: 95px;">Closing Stock</th>
                                                <th colspan="2" class="text-center" style="width: 125px;">Quantity</th>
                                                <th rowspan="2" class="text-center align-middle" style="width: 80px;">Free Qty</th>
                                                <th rowspan="2" class="text-center align-middle" style="width: 70px;">Rate</th>
                                                <th colspan="2" class="text-center" style="width: 140px;">Discount</th>
                                                <th rowspan="2" class="text-center align-middle" style="width: 80px;">Amount</th>
                                                <th rowspan="2" class="text-center align-middle" style="width: 53px;">Action</th>
                                            </tr>
                                            <tr>
                                                <th scope="col" class="text-center cstm-sticky" style="top: 29px">Actual</th>
                                                <th scope="col" class="text-center cstm-sticky" style="top: 29px">Unit</th>
                                                <th scope="col" class="text-center cstm-sticky" style="top: 29px">Per(%)</th>
                                                <th scope="col" class="text-center cstm-sticky" style="top: 29px">Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="itemDet in beData.ItemDetailsColl  | filter: { RowType: 'P' } track by $index">
                                                <td class="text-center cstm-sticky" style="width: 40px;left:0;z-index:2;background-color:#ffffff!important"><b>{{$index+1}}</b></td>
                                                <td class="cstm-sticky" style="width: 250px; left: 40px; z-index: 2; background-color: #ffffff !important" ng-show="1==2">
                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-product ng-model="itemDet.ProductId" style="width:100%" ng-paste="PasteData('product',0)" onpaste="return false"
                                                            placeholder="** Select Product  **" showdetails="true" confirm-action="ProductSelectionChange(itemDet,$index)" product-detail="itemDet.productDetail" side-bar-data="itemDet.sideBarData" voucher-id="SelectedVoucher.VoucherId" ledger-id="beData.PartyLedgerId" company-id="beData.ProductCompanyId" vouchertype="14" ng-disabled="itemDet.ReadOnlyQty==true" godown-id="itemDet.GodownId" godown-change="GodownChange" rate-type="beData.RateTypeId"></select>
                                                </td>
                                                <td class="cstm-sticky" style="width: 250px; left: 40px; z-index: 2; background-color: #ffffff !important">
                                                    <b>{{itemDet.productDetail.Name}}</b>
                                                </td>
                                                <td align="center"><b>{{itemDet.ClosingQty}}</b></td>
                                                <td class="text-center"><b>{{itemDet.ActualQty |number:2}}</b></td>
                                                <td class="text-center"><b>{{itemDet.UnitName}}</b></td>
                                                <td class="text-center"><b>{{itemDet.FreeQty |number:2}}</b></td>
                                                <td class="text-center"><b>{{itemDet.Rate |number:2}}</b></td>
                                                <td class="text-center"><b>{{itemDet.DiscountPer |number:3}}</b></td>
                                                <td class="text-center"><b>{{itemDet.DiscountAmt |number:2}}</b></td>
                                                <td class="text-right"><b>{{itemDet.Amount |number:3}}</b></td>
                                                <td class="project-actions no-print text-center">
                                                    <div class="btn-group-sm">
                                                        <a class="btn btn-danger" ng-click="delRowFromItemDetails($index)"><i class="fas fa-trash"></i></a>
                                                    </div>
                                                </td>
                                            </tr>

                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div style="height: calc(100vh - 10rem)!important;overflow-y:auto!important;overflow-x:hidden">
                                    <div class="row">
                                        <div class="col-sm-12">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width:100px;">Buyer Name</label>
                                                <input type="text" class="form-control form-control-sm" data-ng-model="beData.SalesInvoiceDetail.Buyes" list="lstBuyers" ng-change="ChangeBuyerSelection()" onfocus="this.select();" ng-readonly="IsRefPartyDet==true || SelectedVoucher.EditablePartyDetail==false">
                                                <datalist id="lstBuyers">
                                                    <option data-ng-repeat="ttl in CashPartyColl" value="{{ttl.Buyes}}">
                                                </datalist>
                                            </div>
                                        </div>

                                        <div class="col-sm-12">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width:100px;">Address</label>
                                                <input type="text" class="form-control form-control-sm float-right" name="Address" ng-model="beData.SalesInvoiceDetail.Address" />
                                            </div>
                                        </div>
                                        <div class="col-sm-12">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width:100px;">PAN No.</label>
                                                <input type="text" class="form-control form-control-sm float-right" name="PanNo" ng-model="beData.SalesInvoiceDetail.SalesTaxNo" />
                                            </div>
                                        </div>
                                        <div class="col-sm-12">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width:100px;">Mobile No</label>
                                                <input type="text" class="form-control form-control-sm float-right" name="MobileNo" ng-model="beData.SalesInvoiceDetail.PhoneNo" />
                                            </div>
                                        </div>
                                        <div class="col-sm-12">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width:100px;">Remarks</label>
                                                <input type="text" list="lstNarration" class="form-control hideSideBar" rows="3" placeholder="Remarks" ng-model="beData.Narration">
                                                <datalist id="lstNarration">
                                                    <option ng-repeat="x1 in NarrationList track by $index" value="{{x1}}">
                                                </datalist>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width:100px; font-size:22px;font-weight:700;font-size:16px">SUB TOTAL :</label>
                                                <input type="text" number-input class="form-control px-1" style="text-align: right; font-size: 28px; font-weight: 700;" placeholder="" ng-model="beData.ItemSubTotal" noofdecimal="2" disabled>
                                            </div>
                                        </div>
                                        <div class="col-md-12" ng-repeat="acc in beData.ItemDetailsColl  | filter: { RowType: 'L' } track by $index">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width:100px; font-size:22px;font-weight:700;font-size:16px">{{acc.costLedgerDetail.Name}}:</label>
                                                <input type="text" number-input class="form-control px-1" style="text-align: right; font-size: 28px; font-weight: 700;" placeholder="" ng-model="acc.Amount" noofdecimal="2" disabled>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group  d-flex">
                                                <label for="inputEmail3" style="min-width:100px; font-size:22px;font-weight:700;font-size:16px">Grand Total:</label>
                                                <input type="text" number-input class="form-control px-1" style="text-align: right; font-size: 29px; font-weight: 700;height:36px;color:green;" placeholder="" ng-model="beData.TotalAmount" noofdecimal="2" disabled>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group  d-flex">
                                                <label for="inputEmail3" style="min-width:100px; font-size:22px;font-weight:700;font-size:16px">Tender:</label>
                                                <input type="text" number-input class="form-control px-1" style="text-align: right; font-size: 28px; font-weight: 700;" placeholder="" ng-model="beData.ReceivedAmount" ng-change="ChangeTenderAmt()" noofdecimal="2">
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group  d-flex">
                                                <label for="inputEmail3" style="min-width:100px; font-size:22px;font-weight:700;font-size:16px">Change:</label>
                                                <input type="text" number-input class="form-control px-1" style="text-align: right; font-size: 29px; font-weight: 700; height: 36px; color: red;" placeholder="" ng-model="beData.ChangeAmt" noofdecimal="2" disabled>
                                            </div>
                                        </div>

                                    </div>

                                </div>
                                </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
        <!-- /.container-fluid -->
    </div>

    <footer class="main-footer control-btns py-0">
        <div class="secondary-footer mt-2 ">

            <div class="row pb-3 pt-2" style="background-color: #c2e0fb">

                <div class="col-md-12 text-right">
                    <button type="button" class="btn btn-default" data-toggle="modal" data-target="#documentPaymentTerm">
                        Receipt As
                    </button>
                    <button type="button" class="btn btn-default ml-1" ng-click="SearchData()">Search</button>
                    <button type="button" class="btn btn-default ml-1" ng-click="Print()" ng-show="lastTranId>0 && lastVoucherId>0">Re-Print</button>
                    <button type="button" class="btn btn-default ml-1" ng-click="Clear()">Reset</button>
                    <button type="button" class="btn btn-primary ml-1" ng-click="SaveSalesInvoice()" ng-hide="loadingstatus=='running'">Save</button>
                </div>
            </div>
        </div>
    </footer>

    <!--  Search Voucher right button Modal demo -->
    <div class="modal fade sales-invoice-page-modal document-attach-modal" id="searVoucherRightBtn" tabindex="-1" role="dialog" aria-labelledby="partyAccRightBtn" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Search Sales Invoice Voucher</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group row">
                                <label for="" class="col-sm-2 col-form-label col-form-label-sm text-center">Search By</label>
                                <div class="col-sm-10">
                                    <div class="input-group input-group-sm mb-3">
                                        <div class="input-group-prepend">
                                            <select class="form-control form-control-sm" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                <option ng-value="asp" ng-repeat="asp in VoucherSearchOptions">{{asp.text}}</option>
                                            </select>
                                        </div>
                                        <input type="text" class="form-control" placeholder="" ng-model="paginationOptions.SearchVal" ng-change="ReSearchData(-1)">
                                        <div class="input-group-append">
                                            <div class="input-group-text">
                                                <span class="fas fa-search" ng-click="ReSearchData(-1)"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <form class="float-right">
                                <div class="form-row align-items-center">
                                    <div class="d-flex align-items-center">
                                        <label class="mr-sm-2 mb-0" for="inlineFormCustomSelect">Show</label>
                                        <input type="text" ng-model="paginationOptions.pageSize" class="form-control input-sm" placeholder="NoOfRows" @*ng-blur="ReSearchData(-2)"*@>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                    <div class="">
                        <table id="main-table" class="main-table table table-sm table-striped table-bordered text-nowrap" style="table-layout: auto;">
                            <thead>
                                <tr>
                                    <th class="cstm-sticky">Invoice</th>
                                    <th>Date</th>
                                    <th>Miti</th>
                                    <th>Days</th>
                                    <th>Ref. No.</th>
                                    <th>Party Ledger</th>
                                    <th>Amount</th>
                                    <th>Voucher</th>
                                    <th>CostClass</th>
                                    <th class="cstm-sticky">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr dir-paginate="sd in SearchDataColl |orderBy:sortKey:reverse|itemsPerPage:paginationOptions.pageSize" total-items="paginationOptions.TotalRows">
                                    <td class="cstm-sticky" align="center">{{sd.VoucherNo}}</td>
                                    <td align="center">{{sd.VoucherDate |dateFormat}}</td>
                                    <td align="center">{{sd.VoucherMiti}}</td>
                                    <td align="center">{{sd.Days}}</td>
                                    <td>{{sd.RefNo}}</td>
                                    <td>{{sd.PartyLedger}}</td>
                                    <td align="right">
                                        {{sd.Amount |number:2}}
                                    </td>
                                    <td>{{sd.VoucherName}}</td>
                                    <td>{{sd.CostClass}}</td>
                                    <td class="cstm-sticky">

                                        <a class="p-1" href="#" ng-click="PrintVoucher(sd.TranId,sd.VoucherId)">
                                            <i class="fas fa-print text-primary"></i>
                                        </a>
                                    </td>
                                </tr>
                            </tbody>

                        </table>
                        <dir-pagination-controls max-size="paginationOptions.pageSize" direction-links="true" boundary-links="true"
                                                 on-page-change="ReSearchData(newPageNumber)">
                        </dir-pagination-controls>
                    </div>

                </div>
                <!-- end modal body -->
                <div class="modal-footer justify-content-between align-items-center py-2">
                    <h6 class="mb-0">Total Record: {{paginationOptions.TotalRows}}</h6>
                    <div class="">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade bd-example-modal-xl sales-invoice-page-modal" id="documentPaymentTerm" role="dialog" aria-labelledby="exampleModalCenter2Title" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-xl" role="document" style="max-width: 700px !important;">
            <div class="modal-content">
                <div class="modal-header" style="padding: 1.5px; padding-left: 12px;">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Payment  Details</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="row" ng-show="RecVoucherTypeColl.length>0">
                        <div class="col-sm-8">
                            <div class="form-group row">
                                <label class="col-lg-5 col-form-label">Receipt Voucher</label>
                                <div class="col-lg-7">
                                    <select class="form-control form-control-sm  hideSideBar" style="width: 100%;" ng-model="beData.SalesInvoiceDetail.ReceiptVoucherId">
                                        <option ng-repeat="vt in RecVoucherTypeColl track by vt.VoucherId" ng-value="vt.VoucherId" ng-selected="vt.VoucherId == beData.SalesInvoiceDetail.ReceiptVoucherId">
                                            {{vt.VoucherName}}
                                        </option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group row">
                                <label class="form-control form-control-sm">Challan Amount:<b>  {{beData.TotalAmount |number:2}}</b> </label>
                            </div>
                        </div>
                    </div>
                    <div class="row" style="margin-top: -10px">
                        <div class="table-responsive">
                            <div class="table-scroll-x-y mt-1" style="height: 350px!important">
                                <table id="main-table" class="main-table table table-head-fixed table-sm table-bordered bg-white">
                                    <thead class="text-center">
                                        <tr>
                                            <th style="width: 50px;  z-index: 3; background-color: #fff !important; ">S.No.</th>
                                            <th style="width: 200px;  z-index: 3; background-color: #fff !important;">Particular's</th>
                                            <th style="width: 120px;  z-index: 3; background-color: #fff !important;">Amount</th>
                                            <th style="width: 160px;   z-index: 3; background-color: #fff !important;">Remarks</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr ng-repeat="pt in beData.PaymentTermColl">
                                            <td align="center">{{$index+1}}</td>
                                            <td>
                                                {{pt.Name}}
                                            </td>
                                            <td><input type="text" number-input noofdecimal="SelectedVoucher.NoOfDecimalPlaces" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="pt.Amount"></td>
                                            <td><input type="text" onfocus="this.select();" class="form-control form-control-sm" ng-model="pt.Remarks"></td>
                                        </tr>                                       
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td align="center" colspan="2">TOTAL :- </td>
                                            <td align="right">
                                                <h4>
                                                    {{(beData.PaymentTermColl | sumOfValue:'Amount') |number:2}}
                                                </h4>
                                            </td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer" style="padding: 3px; ">
                    <button type="button" class="btn btn-sm btn-success" data-dismiss="modal" style="min-width:90px">Ok</button>
                    @*<button type="button" class="btn btn-sm btn-success" ng-click="OkCostCenterModal()" style="min-width:90px">Ok</button>*@
                </div>
            </div>
        </div>
    </div>
</div>

