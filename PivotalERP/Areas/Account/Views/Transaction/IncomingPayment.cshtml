<script>
    document.querySelector('.responsive-iframe').onload = function () {
        const iframeDocument = this.contentDocument || this.contentWindow.document;
        const img = iframeDocument.querySelector('img');
        if (img) {
            img.style.width = '100%';
            img.style.height = 'auto';
        }
    };
</script>

<script>
    function toggleAccordion(button) {
        var collapse = document.getElementById('collapseOne');
        var icon = button.querySelector('.arrow-icon');

        if (collapse.style.display === "none" || collapse.style.display === "") {
            collapse.style.display = "block"; // Show
            icon.classList.remove('fa-angle-down');
            icon.classList.add('fa-angle-up');
        } else {
            collapse.style.display = "none"; // Hide
            icon.classList.remove('fa-angle-up');
            icon.classList.add('fa-angle-down');
        }
    }
</script>
