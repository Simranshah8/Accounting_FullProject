
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script>
      var VoucherType = "@ViewBag.VoucherType";
      var EntityId = "@ViewBag.EntityId";
      var TranId=@ViewBag.TranId;
    var DefaultKeyValues = "@ViewBag.DefaultKeyValues";
    var EntityId1 = "@ViewBag.EntityId1";
</script>
<style>
    .receipttbl {
        height: auto !important;
    }
</style>
<script src="~/jslib/account/transaction/IncomingPayment.js"></script>
 
<div ng-app="myApp" ng-controller="IncomingPaymentController" ng-init="LoadData()" ng-cloak>
    <!-- Main content -->
    <div class="container-fluid">
        <div class="sale-page-wrap">
            <div class="overflow-hidden">
                @RenderPage("~/Views/Global/_WaitDialog.cshtml")
                @RenderPage("~/Views/Global/_LedgerDetails.cshtml")
                <!-- Page Content  -->
                <div class="content-wrapper-new">
                    <div class="card mt-2 bodypart">
                        <div class="demo-container">
                            <div class="demo-header">
                                <div class="card-header header-corner-triangle overflow-hidden py-1">
                                    <div class="row">
                                        <h3 class="card-title mr-4">{{SelectedVoucher && SelectedVoucher.VoucherName ? SelectedVoucher.VoucherName : 'Receipt'}}</h3>
                                        <div class="col-md-3" ng-hide="HideShow.VoucherType==true">
                                            <div class="form-group row">
                                                <label class="col-md-4">Voucher Type</label>
                                                <div class="col-md-8">
                                                    <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                        <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" ng-value="vt.VoucherId" ng-selected="vt.VoucherId == beData.VoucherId">
                                                            {{vt.VoucherName}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-sm-3" ng-hide="HideShow.CostClass==true">
                                            <div class="form-group row">
                                                <label for="" class="col-sm-4 col-form-label">Fiscal Year</label>
                                                <div class="col-sm-8">
                                                    <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                        <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == beData.CostClassId">
                                                            {{cc.Name}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-sm-3" ng-show="SelectedVoucher.ActiveProject==true">
                                            <div class="form-group row">
                                                <label for="" class="col-sm-4 col-form-label text-nowrap">Project</label>
                                                <div class="col-sm-8">
                                                    <select class="form-control form-control-sm hideSideBar" active-select2 style="width: 100%;" ng-model="beData.ProjectId" data-placeholder="** select project **">
                                                        <option ng-repeat="cc in ProjectColl track by cc.ProjectId" ng-value="cc.ProjectId" ng-selected="cc.ProjectId == beData.ProjectId">
                                                            {{cc.Name}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card-body px-2 py-1">
                                    <div class="row">
                                        <div class="col-md-3">
                                            <div class="form-group mb-2 row">
                                                <label for="" class="col-md-6">Receipt No.</label>
                                                <div class="col-md-6">
                                                    <input type="text" class="form-control form-control-sm serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                    <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group mb-2 row">
                                                <label for="" class="col-md-4">{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}</label>
                                                <div class="col-md-8">
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.RefNo" />
                                                </div>

                                            </div>
                                        </div>
                                        <div class="col-sm-3">
                                            <div class="row" ng-show="SelectedVoucher.AllowMultipleCurrency==true && CurrencyColl.length>1">
                                                <div class="col-sm-8">
                                                    <div class="form-group d-flex">
                                                        <label for="inputEmail3" style="min-width: 120px;">Currency</label>
                                                        <select class=" form-control form-control-sm" style="width: 100%;" ng-model="beData.CurrencyId" ng-change="ChangeCurrency()">
                                                            <option ng-repeat="curC in CurrencyColl" ng-value="curC.CurrencyId" ng-selected="curC.CurrencyId == beData.CurrencyId">
                                                                {{curC.Name}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-sm-4">
                                                    <div class="form-group d-flex">
                                                        <label for="inputEmail3" class="mr-2">Rate</label>
                                                        <input type="number" class="form-control form-control-sm serial" placeholder="" ng-model="beData.CurRate" onfocus="this.select();">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group mb-2 row">
                                                <label for="" class="col-md-5">Voucher Date</label>
                                                <div class="col-md-7" @*ng-hide="SelectedVoucher.DateStyle==1"*@ id="dvDTVoucher">
                                                    <input type="text"
                                                           class="form-control form-control-sm" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">
                                                </div>

                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-5">
                                            <div class="form-group mb-2 row">
                                                @*<label for="" class="col-md-2">Select Cash/Bank</label>*@
                                                <!--Added By Suresh on 15 baishakh 2082-->
                                                <div class="col-md-2">
                                                    <select class="form-control form-control-sm" ng-model="beData.ForCV">
                                                        <option ng-repeat="cv in ForCustomerVendor" ng-selected="cv.id==beData.ForCV" ng-value="cv.id">{{cv.text}}</option>
                                                    </select>
                                                </div>
                                                <!--Ends-->
                                                <div class="col-md-8" ng-show="beData.ForCV==1">
                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="beData.PartyLedgerId" ledgertype="3" fortransaction="true"
                                                            placeholder="** Select Customer **" showdetails="true" confirm-action="ChangePartyLedger(beData)" ledger-detail="beData.PartyLedgerDetails" side-bar-data="beData.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="1"></select>
                                                </div>
                                                <div class="col-md-8" ng-show="beData.ForCV==2">
                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="beData.PartyLedgerId" ledgertype="2" fortransaction="true"
                                                            placeholder="** Select Vendor **" showdetails="true" confirm-action="ChangePartyLedger(beData)" ledger-detail="beData.PartyLedgerDetails" side-bar-data="beData.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="1"></select>
                                                </div>

                                                <div class="col-md-2">
                                                    <span>
                                                        <b>
                                                            {{beData.PartyLedgerDetails.Closing | formatNumberAC}}
                                                        </b>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group row">
                                                <label for="" class="col-sm-4 col-form-label text-nowrap">Cash/Bank</label>
                                                <div class="col-sm-8">
                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="beData.CashBankLedgerId" ledgertype="8" fortransaction="true"
                                                            placeholder="** Select Cash/Bank **" showdetails="true" confirm-action="ChangeCashBankLedger(beData)" ledger-detail="beData.LedgerDetails" side-bar-data="beData.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="1"></select>
                                                </div>
                                            </div>
                                            @*<div class="form-group row">
                                                    <label for="" class="col-sm-4 col-form-label text-nowrap">Income</label>
                                                    <div class="col-sm-8">
                                                        <select class="form-control form-control-sm select2bs4" active-select2 style="width: 100%; background-color: #fff" ng-model="beData.IECostCenterId" data-placeholder="**Select Income**">
                                                            <option ng-repeat="cc in AllCostCenterColl| filter: { DimensionId: 8 }:true track by cc.CostCenterId" ng-value="cc.CostCenterId" ng-selected="cc.CostCenterId == beData.IECostCenterId">
                                                                {{cc.Name}}-{{cc.Code}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>*@
                                        </div>
                                        <div class="col-md-4" ng-show="SelectedVoucher.ActiveBranch==true">
                                            <div class="form-group mb-2 row">
                                                <label for="" class="col-md-5">For Branch</label>
                                                <div class="col-md-7">
                                                    <select class="form-control form-control-sm select2" style="width: 100%; background-color: #fff" ng-model="beData.ForBranchId" data-placeholder="**For Branch**">
                                                        <option ng-repeat="cc in BranchColl track by cc.BranchId" ng-value="cc.BranchId" ng-selected="cc.BranchId == beData.ForBranchId">
                                                            {{cc.Name}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4" ng-show="SelectedVoucher.ActiveReceiptNo==true">
                                            <div class="form-group mb-2 row">
                                                <label for="" class="col-md-5">Received No.</label>
                                                <div class="col-md-7">
                                                    <select class="form-control form-control-sm" active-select2 style="width: 100%;" ng-model="beData.ReceiptId">
                                                        <option ng-repeat="vt in PendingReceiptColl" ng-value="{{vt.ReceiptId}}" ng-selected="vt.ReceiptId == beData.ReceiptId">
                                                            {{vt.DisplayReceiptNo}}-{{vt.AccountNo}}
                                                        </option>
                                                    </select>
                                                </div>

                                            </div>

                                        </div>
                                    </div>

                                    <div class="row" ng-show="SelectedVoucher.ActiveUDF==true">
                                        <div class="col-sm-3" ng-repeat="uf in beData.UDFFeildsColl | filter: { FieldAfter: 4 }:true">
                                            <div class="form-group d-flex">
                                                <label style="min-width: 120px;">{{uf.Name}} <span style="color:red" ng-show="uf.IsMandatory==true">*</span></label>
                                                <udf-field udf="uf" voucher="SelectedVoucher" change-event="ChangeUDFField(uf.NameId)"></udf-field>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!--new Panel  added by suresh on 15 baishakh 2082 starts-->
                            <div class="accordion" id="billDetailsAccordion">
                                <div class="card">
                                    <div class="card-header text-center p-0" id="headingOne">
                                        <h2 class="mb-0 position-relative">
                                            <button class="btn btn-link w-100 py-1  collapsed"
                                                    type="button"
                                                    onclick="toggleAccordion(this)"
                                                    style="background-color: #049bdb26; text-decoration: none;">
                                                <b>Show Bill Details</b>
                                                <i class="fas fa-angle-down arrow-icon ml-2"></i> <!-- FontAwesome arrow -->
                                            </button>
                                        </h2>
                                    </div>

                                    <div class="collapse" id="collapseOne" style="display: none;">
                                        <div class="card-body p-0">

                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width: 80px;">
                                                    Total Dues
                                                </label>
                                                <div class="col-sm-3 col-md-3">
                                                    <label type="text" class="form-control form-control-sm">
                                                        {{(CurBillRefColl | sumOfValue:'Amount') |number:2}}
                                                    </label>
                                                </div>
                                                <label style="min-width: 80px;">
                                                    Search
                                                </label>
                                                <div class="col-sm-3 col-md-3">
                                                    <input type="text" class="form-control form-control-sm" data-ng-model="BillSearchData" onfocus="this.select();" autocomplete="off" />
                                                </div>
                                                <label style="min-width: 80px;" class="mt-1">
                                                    No Bill Ref. <input type="checkbox" ng-model="beData.NoBillRef" />
                                                </label>
                                            </div>

                                            <div class="table-scroll-x-y table-scroll" style="height:300px !important; overflow-y:auto">
                                                <table id="main-table" class="main-table table-head-fixed table table-sm table-bordered bg-white">
                                                    <thead>
                                                        <tr>
                                                            <th class="cstm-sticky" style="left:0px;width: 60px;z-index:3; background-color:#eee!important">S.No.</th>
                                                            <th class="cstm-sticky" style="left: 60px; width: 130px; z-index: 3;background-color:#eee!important">Invoice No.</th>
                                                            <th style="width: 120px; z-index: 2">Miti(Days)</th>
                                                            <th style="width: 150px; z-index: 2">Dues Amt.</th>
                                                            <th style="width: 150px; z-index: 2">Paid Amt.</th>
                                                            <th style="width: 160px; z-index: 2">Voucher</th>
                                                            <th style="width: 140px; z-index: 2">Branch</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr dir-paginate="curItemA in CurBillRefColl  | filter:BillSearchData | orderBy:sortKey:reverse | itemsPerPage:perPage.PendingBill" current-page="currentPages.PendingBill" pagination-id="PendingBillPagination">
                                                            <td align="center">
                                                                {{$index+1}}
                                                            </td>
                                                            <td class="cstm-sticky" style="left: 0px; width: 60px; z-index: 2;background-color:#fff!important">
                                                                {{curItemA.InvoiceNo}}
                                                            </td>
                                                            <td class="cstm-sticky" style="left: 60px; width: 130px; z-index: 2; background-color: #fff !important">
                                                                {{curItemA.VoucherDateBS}} ({{curItemA.Days}})
                                                            </td>
                                                            <td align="right">
                                                                {{curItemA.Amount |number:2}}
                                                            </td>
                                                            <td>
                                                                <input type="text" number-input class="form-control form-control-sm serial" onfocus="this.select();" ng-model="curItemA.PaidAmt" ng-change="ChangeBillWiseAmt('paidAmt')" positive="true" />
                                                            </td>
                                                            <td>
                                                                {{curItemA.VoucherName}}
                                                            </td>
                                                            <td>
                                                                {{curItemA.Branch}}
                                                            </td>
                                                        </tr>

                                                    </tbody>
                                                </table>
                                                <div class="col-md-12">
                                                    <dir-pagination-controls pagination-id="PendingBillPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                                    </dir-pagination-controls>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!--Ends-->

                            <div class="table-scroll-x-y mb-1 table-container">
                                <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                    <thead class="text-center">
                                        <tr>
                                            <th style="width: 50px;background-color:#ececec!important">S.No.</th>
                                            <th style="width: 60px; background-color: #ececec !important;z-index:3">DrCr</th>
                                            <th style="width: 200px;background-color:#ececec!important;z-index:3">Particulars</th>
                                            <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 1 }:true" rowspan="2" class="text-center align-middle" style="width: 120px;background-color:#ececec!important;">{{ud.Label}}</th>
                                            <th ng-show="SelectedVoucher.ActiveBranch==true" style="width: 150px;background-color:#ececec!important">For Branch</th>
                                            <th style="width: 150px;background-color:#ececec!important">Current Bal.</th>
                                            <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 5 }:true" rowspan="2" class="text-center align-middle" style="width: 120px;background-color:#ececec!important;">{{ud.Label}}</th>
                                            <th style="width: 180px; background-color: #ececec !important" ng-show="SelectedVoucher.UseSubLedger==true">Sub Ledger</th>
                                            <th style="width: 180px; background-color: #ececec !important" ng-show="SelectedVoucher.ActiveMultipleReceiptNo==true">Received No.</th>
                                            <th style="width: 150px;background-color:#ececec!important">Amount</th>
                                            <th style="width: 350px; background-color: #ececec !important" ng-show="SelectedVoucher.ProfitCenter1==true">{{AllDimensionColl[0].Description}}</th>
                                            <th style="width: 350px; background-color: #ececec !important" ng-show="SelectedVoucher.ProfitCenter2==true">{{AllDimensionColl[1].Description}}</th>
                                            <th style="width: 350px; background-color: #ececec !important" ng-show="SelectedVoucher.ProfitCenter3==true">{{AllDimensionColl[2].Description}}</th>
                                            <th style="width: 350px; background-color: #ececec !important" ng-show="SelectedVoucher.ProfitCenter4==true">{{AllDimensionColl[3].Description}}</th>
                                            <th style="width: 350px; background-color: #ececec !important" ng-show="SelectedVoucher.ProfitCenter5==true">{{AllDimensionColl[4].Description}}</th>
                                            <th ng-show="SelectedVoucher.EachNarrationEntry==true" style="width: 150px;background-color:#ececec!important">Narration</th>
                                            <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 0 }:true" rowspan="2" class="text-center align-middle" style="width: 120px;background-color:#ececec!important;">{{ud.Label}}</th>
                                            <th class="text-center align-middle" style="width: 70px;background-color:#ececec!important">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr ng-repeat="ledAllocation in beData.LedgerAllocationColl">
                                            <td align="center">{{$index+1}}</td>
                                            <td>
                                                <select class="form-control form-control-sm rounded-0" ng-model="ledAllocation.DrCr" ng-change="ChangeDrCr(ledAllocation)">
                                                    <option ng-value="d.id" ng-repeat="d in DrCrList" ng-selected="d.id==ledAllocation.DrCr">{{d.text}}</option>
                                                </select>
                                            </td>
                                            <td ng-show="ledAllocation.DrCr==1">
                                                <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="ledAllocation.LedgerId" ledgertype="1" fortransaction="true"
                                                        placeholder="** Select Cash/Bank **" showdetails="true" confirm-action="ChangeParticularLedger(ledAllocation)" ledger-detail="ledAllocation.LedgerDetails" side-bar-data="ledAllocation.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="2"></select>

                                            </td>
                                            <td ng-show="ledAllocation.DrCr==2">
                                                <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="ledAllocation.LedgerId" ledgertype="1" fortransaction="true"
                                                        placeholder="** Select Income **" showdetails="true" confirm-action="ChangeParticularLedger(ledAllocation)" ledger-detail="ledAllocation.LedgerDetails" side-bar-data="ledAllocation.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="2"></select>

                                            </td>
                                            <td ng-repeat="uf in ledAllocation.UDFFeildsColl | filter: { FieldAfter: 1 }:true ">
                                                <udf-field udf="uf" voucher="SelectedVoucher"></udf-field>
                                            </td>
                                            <td ng-show="SelectedVoucher.ActiveBranch==true">
                                                <select class="form-control form-control-sm select2" style="width: 100%; background-color: #fff" ng-model="ledAllocation.ForBranchId" data-placeholder="**For Branch**">
                                                    <option ng-repeat="cc in BranchColl track by cc.BranchId" ng-value="cc.BranchId" ng-selected="cc.BranchId == ledAllocation.ForBranchId">
                                                        {{cc.Name}}
                                                    </option>
                                                </select>
                                            </td>
                                            <td><h5> {{ledAllocation.CurrentBal |accountFormat}}</h5></td>
                                            <td ng-repeat="uf in ledAllocation.UDFFeildsColl | filter: { FieldAfter: 5 }:true ">
                                                <udf-field udf="uf" voucher="SelectedVoucher"></udf-field>
                                            </td>
                                            <td ng-show="SelectedVoucher.UseSubLedger==true">
                                                <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-cost-center ng-model="ledAllocation.SubLedgerId" fortransaction="true"
                                                        placeholder="** Select Sub Ledger **" showdetails="false" costcenter-detail="ledAllocation.SubLedgerDetails" side-bar-data="ledAllocation.subLedgerSideBarData" ledger-id="ledgerAllocation.LedgerId"></select>
                                            </td>
                                            <td ng-show="SelectedVoucher.ActiveMultipleReceiptNo==true">
                                                <select class="form-control form-control-sm" active-select2 style="width: 100%;" ng-model="ledAllocation.ReceiptId">
                                                    <option ng-repeat="vt in PendingReceiptColl" ng-value="{{vt.ReceiptId}}" ng-selected="vt.ReceiptId == ledAllocation.ReceiptId">
                                                        {{vt.DisplayReceiptNo}}-{{vt.AccountNo}}
                                                    </option>
                                                </select>
                                            </td>
                                            <td ng-show="ledAllocation.DrCr==1">
                                                <input type="text" number-input noofdecimal="SelectedVoucher.NoOfDecimalPlaces" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="ledAllocation.DrAmount" ng-blur="AddRowInLedgerAllocation($index,true)" ng-change="ChangeCrAmount(ledAllocation)" positive="true" ng-style="ledAllocation.IsNegativeBudget==true && { 'color' : 'red' }">
                                            </td>
                                            <td ng-show="ledAllocation.DrCr==2">
                                                <input type="text" number-input noofdecimal="SelectedVoucher.NoOfDecimalPlaces" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="ledAllocation.CrAmount" ng-blur="AddRowInLedgerAllocation($index,true)" ng-change="ChangeCrAmount(ledAllocation)" positive="true" ng-style="ledAllocation.IsNegativeBudget==true && { 'color' : 'red' }">
                                            </td>

                                            <td ng-show="SelectedVoucher.ProfitCenter1==true">
                                                <select class="form-control form-control-sm select2bs4" active-select2 style="width: 100%; background-color: #fff" ng-model="ledAllocation.Dimension1" data-placeholder="**Select**">
                                                    <option ng-repeat="cc in AllCostCenterColl| filter: { DimensionId: 1 }:true track by cc.CostCenterId" ng-value="cc.CostCenterId" ng-selected="cc.CostCenterId == ledAllocation.Dimension1">
                                                        {{cc.Name}}-{{cc.Code}}
                                                    </option>
                                                </select>
                                            </td>
                                            <td ng-show="SelectedVoucher.ProfitCenter2==true">
                                                <select class="form-control form-control-sm select2bs4" active-select2 style="width: 100%; background-color: #fff" ng-model="ledAllocation.Dimension2" data-placeholder="**Select**">
                                                    <option ng-repeat="cc in AllCostCenterColl| filter: { DimensionId:2 }:true track by cc.CostCenterId" ng-value="cc.CostCenterId" ng-selected="cc.CostCenterId == ledAllocation.Dimension2">
                                                        {{cc.Name}}-{{cc.Code}}
                                                    </option>
                                                </select>
                                            </td>
                                            <td ng-show="SelectedVoucher.ProfitCenter3==true">
