                                                                                        <td>
                                                                                            <input type="text" noofdecimal="3" class="form-control form-control-sm" style="text-align:right" number-input max-value="itemDet.Amount" ng-model="itemDet.Paid" ng-change="ChangePaidAmt(pv,itemDet,'paid',$index)" positive="true">
                                                                                        </td>
                                                                                        <td align="center">{{itemDet.Days}}</td>
                                                                                        <td>{{itemDet.Branch}}</td>
                                                                                        <td></td>
                                                                                    </tr>
                                                                                </tbody>
                                                                            </table>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>

                                            <!-- Custom Pagination Controls -->
                                            <div class="col-md-12 mt-3">
