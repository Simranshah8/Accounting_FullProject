                                                            </td>
                                                            <td>
                                                                <select class="form-control form-control-sm" active-select2 style="width: 100%;" ng-model="pv.ChequeId" ng-change="ChequeNoSelect(pv)">
                                                                    <option ng-repeat="vt in pv.PendingChequeColl" ng-value="{{vt.ChequeId}}" ng-selected="vt.ChequeId == pv.ChequeId">
                                                                        {{vt.DisplayChequeNo}}-{{vt.BranchName}}
