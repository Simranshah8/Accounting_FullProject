                                            <td>{{sd.NoOfPayment}}</td>
                                            <td align="center">{{sd.LogDateTime |dateFormat}}</td>
                                            <td align="center">{{sd.LogMiti}}</td>
                                            <td align="right">{{sd.Amount |number:3}}</td>
                                            <td class="text-center cstm-sticky" style="z-index: 3; right: 0; background-color: white !important;">
                                                <a class="p-1" title="Print Payment List" href="#" ng-click="Print(sd.UniqueId)">
                                                    <i class="fas fa-print text-primary"></i>
                                                </a>
                                                <a class="p-1" title="Print Voucher" href="#" ng-click="PrintVoucher(sd.ReceiptTranId)">
                                                    <i class="fas fa-print text-primary"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    </tbody>

                                </table>

                            </div>

                        </div>
                        <!-- end modal body -->
                        <div class="modal-footer justify-content-between align-items-center py-2">
                            <h6 class="mb-0">Total Record: {{SearchDataColl.length}}</h6>
                            <div class="">
                                <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Close</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
