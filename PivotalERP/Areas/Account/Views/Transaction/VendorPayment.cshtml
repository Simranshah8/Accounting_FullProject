                                                                                        <th class="py-0" style="width: 120px; background-color: #ececec !important; text-align: center">Paid</th>
                                                                                        <th class="py-0" style="width: 50px; background-color: #ececec !important; text-align: center">Days</th>
                                                                                        <th class="py-0" style="width: 140px; background-color: #ececec !important; text-align: center">Branch</th>
                                                                                        <th style="text-align: center; width: 80px; background-color: #ececec !important;">Action</th>
                                                                                    </tr>
                                                                                </thead>
                                                                                <tbody>
                                                                                    <tr ng-repeat="itemDet in pv.ChieldColl">
                                                                                        <td class="text-center">{{$index+1}}</td>
                                                                                        <td>
                                                                                            <input type="checkbox" ng-change="ChangeSelectionCH(pv,itemDet)" ng-model="itemDet.IsSelected" id="chkPVI{{pv.LedgerId}}-{{$index}}">
                                                                                        </td>
                                                                                        <td align="center">
                                                                                            <label for="chkPVI{{pv.LedgerId}}-{{$index}}">{{itemDet.InvoiceNo}}</label>
                                                                                        </td>
