
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script>
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
    var TranId=@ViewBag.TranId;
</script>
<script src="~/jslib/account/transaction/CashDeposite.js"></script>
<div ng-app="myApp" ng-controller="CashDepositeController" ng-init="LoadData()" ng-cloak>
    <!-- Main content -->
    <div class="container-fluid">
        <div class="sale-page-wrap">
            <div class="overflow-hidden">
                @RenderPage("~/Views/Global/_WaitDialog.cshtml")
                @RenderPage("~/Views/Global/_LedgerDetails.cshtml")
                <!-- Page Content  -->
                <div class="content-wrapper-new">
                    <div class="row">
                        <div class="col-md-4" ng-hide="HideShow.VoucherType==true">
                            <div class="form-group row">
                                <label class="col-md-4">Voucher</label>
                                <div class="col-md-8">
                                    <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()">
                                        <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" value="{{vt.VoucherId}}" ng-selected="vt.VoucherId == beData.VoucherId">
                                            {{vt.VoucherName}}
                                        </option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4" ng-hide="HideShow.CostClass==true">
                            <div class="form-group row">
                                <label for="" class="col-sm-4 col-form-label">Cost Class</label>
                                <div class="col-sm-8">
                                    <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()">
                                        <option ng-repeat="cc in CostClassColl track by cc.CostClassId" value="{{cc.CostClassId}}" ng-selected="cc.CostClassId == beData.CostClassId">
                                            {{cc.Name}}
                                        </option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card p-2 mt-2">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group row">
                                    <label for="" class="col-md-6">Receipt No.</label>
                                    <div class="col-md-6">
                                        <input type="text" class="form-control form-control-sm serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true">
                                        <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false">
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-sm-4">Patient Id</label>
                                    <div class="col-sm-8 col-md-8">
                                        <input type="text" class="form-control form-control-sm serial hideSideBar" id="txtPatientId" placeholder="" ng-model="beData.RefNo" ng-blur="GetPatientById()" onfocus="this.select();">
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group row">
                                    <label for="" class="col-md-4">Voucher Date</label>
                                    <div class="col-md-8">
                                        <input type="text"
                                               class="form-control form-control-sm" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" disabled>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-lg-4">Patient Name<span style="color:red">*</span></label>
                                    <div class="col-lg-8">
                                        <input type="text" class="form-control form-control-sm" ng-model="beData.LedgerAllocationColl[1].PatientName" onfocus="this.select();" disabled>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-lg-4">Address<span style="color:red">*</span></label>
                                    <div class="col-lg-8">
                                        <input type="text" class="form-control form-control-sm" ng-model="beData.LedgerAllocationColl[1].PatientAddress" onfocus="this.select();" disabled>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-lg-4">Phone No.</label>
                                    <div class="col-lg-8">
                                        <input type="text" class="form-control form-control-sm float-right"  ng-model="beData.LedgerAllocationColl[1].Narration" onfocus="this.select();" disabled />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-lg-4">Recived Amount</label>
                                    <div class="col-lg-8">
                                        <input type="text" number-input class="form-control form-control-sm serial hideSideBar" name="LossWeight" style="text-align:right" onfocus="this.select();" positive="true" noofdecimal="2" ng-model="beData.LedgerAllocationColl[0].DrAmount">
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-lg-4">Remarks</label>
                                    <div class="col-lg-8">
                                        <input type="text" class="form-control form-control-sm float-right" name="VoucherDate" ng-model="beData.Narration" onfocus="this.select();"  />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group row">
                                    <label for="" class="col-md-4">Select Cash/Bank</label>
                                    <div class="col-md-8">
                                        <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="beData.LedgerAllocationColl[0].LedgerId" id="cboCashBank" @*style="width:95%"*@ ledgertype="8"
                                                placeholder="** Select Party Name **" showdetails="true" confirm-action="PartySelectionChange(beData)" ledger-detail="beData.PartyLedger" side-bar-data="beData.partySideBarData"></select>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        <footer class="main-footer control-btns pt-0">
            <div class="secondary-footer mb-2 mt-2">
                
                <div class="row ">

                    <div class="col-md-4 mt-2">
                        <button type="button" class="btn btn-default" data-toggle="modal" data-target="#documentAttachModal">
                            Document Attach ({{beData.AttechFiles.length}} )
                        </button>

                    </div>
                    <div class="col-md-8 mt-2">
                        <span class="d-block text-right">
                            <button type="button" class="btn btn-default" style="min-width: 90px;" ng-click="SearchData()">Search</button>
                            <button type="button" class="btn btn-default ml-1" ng-click="Print()" ng-show="lastTranId>0 && lastVoucherId>0">Re-Print</button>
                            <button type="button" class="btn btn-default" style="min-width: 90px;" ng-click="Clear()">Reset</button>
                            <button type="button" class="btn btn-primary" style="min-width: 90px;" ng-click="SaveReceipt()">{{beData.Mode}}</button>
                        </span>
                    </div>
                </div>

            </div>
        </footer>

        <div class="modal fade sales-quotation-page-modal document-attach-modal" id="searVoucherRightBtn" tabindex="-1" role="dialog" aria-labelledby="partyAccRightBtn" aria-hidden="true">
            <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-lg" role="document" style="min-width:1100px">
                <div class="modal-content">
                    <div class="modal-header">
                        <h6 class="modal-title" id="exampleModalCenterTitle">Search Receipt</h6>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body gradient-bg">
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group row">
                                    <label for="" class="col-sm-2 col-form-label col-form-label-sm text-center">Search By</label>
                                    <div class="col-sm-10">
                                        <div class="input-group input-group-sm mb-3">
                                            <div class="input-group-prepend">
                                                <select class="form-control form-control-sm" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                    <option ng-value="asp" ng-repeat="asp in VoucherSearchOptions">{{asp.text}}</option>
                                                </select>
                                            </div>
                                            <input type="text" class="form-control" placeholder="" ng-model="paginationOptions.SearchVal"  ng-change="ReSearchData(-1)">
                                            <div class="input-group-append">
                                                <div class="input-group-text">
                                                    <span class="fas fa-search" ng-click="ReSearchData(-1)"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <form class="float-right">
                                    <div class="form-row align-items-center">
                                        <div class="d-flex align-items-center">
                                            <label class="mr-sm-2 mb-0" for="inlineFormCustomSelect">Show</label>
                                            <input type="text" ng-model="paginationOptions.pageSize" class="form-control input-sm" placeholder="NoOfRows" @*ng-blur="ReSearchData(-2)"*@>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="">
                            <table id="main-table" class="main-table table table-sm table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>Voucher No</th>
                                        <th>RefNo</th>
                                        <th>Voucher Date</th>
                                        <th>Voucher Name</th>
                                        <th>CostClass</th>
                                        <th>Ledger</th>
                                        <th>Amount</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr dir-paginate="sd in SearchDataColl |orderBy:sortKey:reverse|itemsPerPage:paginationOptions.pageSize" total-items="paginationOptions.TotalRows" ng-class="{'bg-red': sd.IsCancel === true}">
                                        <td align="center">{{sd.VoucherNo}}</td>

                                        <td>{{sd.RefNo}}</td>
                                        <td align="center">{{sd.VoucherDate |dateFormat}}</td>
                                        <td>{{sd.VoucherName}}</td>
                                        <td>{{sd.CostClass}}</td>
                                        <td>{{sd.Ledger}}</td>
                                        <td>{{sd.Amount}}</td>
                                        <td>                                            
                                            <a class="p-1" href="#" ng-click="PrintVoucher(sd.TranId,sd.VoucherId)">
                                                <i class="fas fa-print text-primary"></i>
                                            </a>
                                        </td>
                                    </tr>
                                </tbody>

                            </table>
                            <dir-pagination-controls max-size="paginationOptions.pageSize" direction-links="true" boundary-links="true"
                                                     on-page-change="ReSearchData(newPageNumber)">
                            </dir-pagination-controls>
                        </div>

                    </div>
                    <!-- end modal body -->
                    <div class="modal-footer justify-content-between align-items-center py-2">
                        <h6 class="mb-0">Total Record: {{paginationOptions.TotalRows}}</h6>
                        <div class="">
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>


        <!-- /.row -->
        @*file-upload modal*@
        <div class="modal fade sales-invoice-page-modal document-attach-modal" id="documentAttachModal" tabindex="-1" role="dialog" aria-labelledby="documentAttachModalTitle" aria-hidden="true">
            <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h6 class="modal-title" id="exampleModalCenterTitle">Document Attach</h6>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body gradient-bg">
                        <div class="input-group" ng-repeat="fl in beData.AttechFiles">
                            <a href="#">{{$index+1}}  -  {{fl.name}}</a>
                        </div>
                        <div class="input-group">
                            <div class="custom-file">
                                <input type="file" class="custom-file-input" id="exampleInputFile" multiple file-model="beData.AttechFiles" ng-model="beData.AttechFiles">
                                <label class="custom-file-label" for="exampleInputFile">Choose file ({{beData.AttechFiles.length}} )</label>
                            </div>
                        </div>
                    </div>
                    <!-- end modal body -->
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Ok</button>
                        @*<button type="button" class="btn btn-sm btn-primary">Ok</button>*@
                    </div>
                </div>
            </div>
        </div>

        <!-- Add ReportTemplates Modal Dailog -->
        <div class="modal fade bd-example-modal-xl sales-invoice-page-modal" id="FrmPrintReport" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenter2Title" aria-hidden="true">
            <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-xl" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h6 class="modal-title" id="exampleModalCenterTitle">Report Viewer</h6>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <iframe id="frmRpt" style='width: 100%; height: 600px; background-color: white; visibility:visible;' frameborder='0' scrolling='yes'></iframe>
                        </div>
                    </div>
                </div>
            </div>
        </div>


        <div class="modal fade bd-example-modal-xl sales-invoice-page-modal" id="frmCostCentersModel" role="dialog" aria-labelledby="exampleModalCenter2Title" aria-hidden="true" style="margin-top:20px">
            <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-xl" role="document">
                <div class="modal-content">
                    <div class="modal-header" style="padding: 1.5px; padding-left: 12px;">
                        <h6 class="modal-title" id="exampleModalCenterTitle">Cost Center Details</h6>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body gradient-bg">
                        <div class="row" style="margin-top: -10px">
                            <div class="table-responsive">
                                <div class="table-scroll-x-y mt-1" style="height: 330px">
                                    <table id="main-table" class="main-table table table-head-fixed table-sm table-bordered bg-white">
                                        <thead class="text-center">
                                            <tr>
                                                <th style="width: 50px">S.No.</th>
                                                <th style="width: 200px">CostCenter</th>
                                                <th style="width: 150px">Current Bal.</th>
                                                <th style="width: 150px">Amount</th>
                                                <th class="text-center align-middle" style="width: 70px;">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="costAllocation in CurLedgerAllocation.CostCenterColl">
                                                <td align="center">{{$index+1}}</td>
                                                <td>
                                                    <select parentId="frmCostCentersModel" autoShowHide="true" class="form-control form-control-sm select2 serial" all-cost-center ng-model="costAllocation.CostCenterId"
                                                            placeholder="** Select CostCeter Name **" showdetails="true" confirm-action="ChangeParticularCostCenter(costAllocation)" costcenter-detail="costAllocation.CostCenterDetails" side-bar-data="costAllocation.partySideBarData"></select>
                                                </td>
                                                <td><h5> {{costAllocation.CurrentBal |number:2}}</h5></td>
                                                <td><input type="text" number-input noofdecimal="SelectedVoucher.NoOfDecimalPlaces" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="costAllocation.CrAmount" ng-blur="AddRowInCostCenterAllocation($index,true)" ng-change="ChangeCostCenterAmount()"></td>
                                                <td>
                                                    <a class="p-1" href="#" data-original-title="Add Row" ng-click="AddRowInCostCenterAllocation($index)">
                                                        <i class="fas fa-plus text-info"></i>
                                                    </a>
                                                    <a class="p-1" href="#" data-original-title="Delete Row." ng-click="delRowCostCenterAllocation($index)">
                                                        <i class="fas fa-trash-alt text-danger"></i>
                                                    </a>

                                                </td>
                                            </tr>

                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="modal-footer" style="padding: 3px; margin-top: -20px; ">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal" style="min-width:90px">Cancel</button>
                        <button type="button" class="btn btn-sm btn-success" ng-click="OkCostCenterModal()" style="min-width:90px">Ok</button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
<script>

    $(function () {
        $("#wrapper").toggleClass("toggled");
        $("#sidebar-wrapper").css("overflow-y", "hidden");


        $("#menu-toggle").click(function (e) {
            e.preventDefault();
            $("#wrapper").toggleClass("toggled");
            $("#sidebar-wrapper").css("overflow-y", "auto");
        });


    });

</script>
<script>
    (function ($) {
        "use strict";
        var fullHeight = function () {
            $('.js-fullheight').css('height', $(window).height());
            $(window).resize(function () {
                $('.js-fullheight').css('height', $(window).height());
            });
        };
        fullHeight();

        $('#ctmRightSidebarCollapse').on('click', function () {
            $('#sidebarzz').toggleClass('active');
        });

    })(jQuery);
</script>

<script>

    $(document).ready(function () {
        $(document).on('keyup', '.serial', function (e) {
            if (e.which == 13) {
                //var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                //if (key == 13) {
                //    e.preventDefault();
                //    var inputs = $(this).closest('form').find(':input:visible');
                //    inputs.eq(inputs.index(this) + 1).focus();
                //}

                var index = $('.serial').index(this) + 1;
                $('.serial').eq(index).focus();
            }
        });
    });
</script>