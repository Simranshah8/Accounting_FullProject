@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>
<script src="~/jslib/service/transaction/SparePartsReturn.js?v=1"></script>
<div ng-app="myApp" ng-controller="SparePartsReturn" ng-class="{waiting: loadingstatus=='running'}" ng-init="LoadData()">
    <div class="box-body">
        <div class="pt-1"></div>
        <div class="content">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-sm-3" ng-hide="HideShow.Branch==true">
                        <div class="form-group row">
                            <label for="inputEmail3" class="col-sm-4 col-form-label">Branch<span style="color:red">*</span></label>
                            <div class="col-sm-8">
                                <select class="form-control form-control-sm  hideSideBar" style="width: 100%;" ng-model="beData.BranchId" ng-change="getVoucherNo()">
                                    <option ng-repeat="vt in BranchList track by vt.BranchId" ng-value="vt.BranchId" ng-selected="vt.BranchId == beData.BranchId">
                                        {{vt.Name}}
                                    </option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-3" ng-hide="HideShow.CostClass==true">
                        <div class="form-group row">
                            <label for="inputEmail3" class="col-sm-4 col-form-label">For Year<span style="color:red">*</span></label>
                            <div class="col-sm-8">
                                <select class="form-control  form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()">
                                    <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == beData.CostClassId">
                                        {{cc.Name}}
                                    </option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group d-flex">
                            <label class="mt-1 text-nowrap" style="min-width: 120px!important">Job No.</label>
                            <input type="text" class="form-control form-control-sm" ng-model="beData.JobNo" ng-blur="getJobCardDetails()" />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group d-flex">
                            <label class="mt-1 text-nowrap" style="width:120px">Entry Date</label>
                            <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.EntryDateTime_TMP" date-detail="beData.EntryDateTimeDet" />
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header py-1 header-primary" style="background-color: #068abf; color: #ffffff;" ng-click="ShowVehicleHistory(beData.VehicleEntryId)">
                        <h5 class="mb-0">Job Card Details</h5>
                    </div>
                    <div class="card-body p-2">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="width:120px">Engine No</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.EngineNo" />
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="width:120px">Ch.Srl.No.</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.ChassisNo" />
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="width:120px">Regd. No.</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.RegdNo" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="min-width:90px">Vin No.</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.VinNo" />
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="min-width:90px">Model</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.VehicleModelName" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="min-width:90px">Type</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.VehicleTypeName" />
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group d-flex">
                                    <label class="mt-1 text-nowrap" style="width:120px">Party</label>
                                    <input type="text" class="form-control form-control-sm" readonly ng-model="beData.Party" />
                                </div>
                            </div>
                        </div>

                        <div class="table-scroll-x-y table-scroll mt-2" style="max-height: calc(100vh - 205px);">
                            <table id="maintable" class="table table-bordered table-hover table-sm">
                                <thead>
                                    <tr>
                                        <th style="width:200px; z-index: 3; background-color: #ececec !important">Product</th>
                                        <th style="width:200px; z-index: 3; background-color: #ececec !important">Alternate Product</th>
                                        <th class="text-center" style="width:110px; z-index: 3; background-color: #ececec !important">Demand Date</th>
                                        <th class="text-center" style="width: 110px; z-index: 3; background-color: #ececec !important">Demand Qty</th>
                                        <th class="text-center" style="width: 90px; z-index: 3; background-color: #ececec !important">Issue Qty</th>
                                        <th class="text-center" style="width: 90px; z-index: 3; background-color: #ececec !important">Return Qty</th>
                                        <th class="text-center" style="width: 100px; z-index: 3; background-color: #ececec !important">Remarks<span style="color:red">*</span></th>
                                        <th class="text-center" style="width: 90px; z-index: 3; background-color: #ececec !important">Rate</th>
                                        <th class="text-center" style="width: 100px; z-index: 3; background-color: #ececec !important">Amount</th>
                                        @*<th class="text-center" style="width: 80px; z-index: 3; background-color: #ececec !important">Action</th>*@
                                    </tr>
                                </thead>

                                <tbody>
                                    <tr ng-repeat="pr in beData.SparePartsColl">
                                        <td>
                                            <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-product ng-model="pr.ProductId" style="width:100%"
                                                    placeholder="** Select Product  **" showdetails="true" confirm-action="ProductSelectionChange(pr,$index)" product-detail="pr.productDetail" side-bar-data="pr.sideBarData" disabled></select>
                                        </td>
                                        <td>
                                            <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-product ng-model="pr.AlternateProductId"
                                                    placeholder=" Select Product  " showdetails="true" product-detail="pr.productDetail" side-bar-data="pr.sideBarData" disabled>
                                            </select>
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" ng-model="pr.DemandDateBSStr" onfocus="this.select()" style="text-align: right" disabled>
                                        </td>

                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="pr.DemandQty" onfocus="this.select()" style="text-align: right" disabled>
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="pr.TotalIssueQty" onfocus="this.select()" style="text-align: right" disabled>
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="pr.ReturnQty" onfocus="this.select()" style="text-align: right">
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" ng-model="pr.ReturnRemarks" onfocus="this.select()">
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="pr.Rate" onfocus="this.select()" style="text-align: right" disabled>
                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm" ng-model="pr.Amount" onfocus="this.select()" style="text-align: right" disabled>
                                        </td>
                                        @*<td class="text-center">
                                                <div>
                                                    <a class="p-1" ng-click="AddSparePartsReturnDet()" data-original-title="View doc">
                                                        <i class="fas fa-plus text-secondary"></i>
                                                    </a>

                                                    <a class="p-1" ng-click="delSparePartsReturnDet($index)">
                                                        <i class="fas fa-trash-alt text-danger"></i>
                                                    </a>
                                                </div>
                                            </td>*@
                                    </tr>

                                </tbody>

                            </table>
                        </div>

                    </div>
                </div>
                <footer class="main-footer">
                    <div class="text-right control-btns">
                        <button type="button" class="btn btn-default btn" ng-click="ClearSpareParts()"> <span class="glyphicon glyphicon-remove"></span>Clear</button>
                        <button type="button" class="btn btn-primary btn" ng-click="SaveUpdateSparePartsReturn()" ng-disabled="loadingstatus=='running'"><span class="glyphicon glyphicon-save"></span>Accept</button>
                    </div>
                </footer>
            </div>
        </div>
    </div>

    @RenderPage("~/Views/Global/_EditTran.cshtml")
</div>