                                    <td colspan="9"><b>Status : </b>Open({{dayBook.OpenColl.length}})</td>
                                </tr>
                                <tr id="tblrow" ng-repeat="o in dayBook.OpenColl">
                                    <td><a href="" ng-click="ShowCurTicket(o)">{{o.Branch}}</a> </td>
                                    <td align="center">{{o.TotalDays}}</td>
                                    <td>{{o.Category}}</td>
                                    <td align="center">{{o.TicketSNo}}</td>
                                    <td>{{o.LogMiti}} {{o.LogDateTime |timeFormat}}</td>
                                    <td>{{o.PartyName}}</td>
                                    <td>{{o.MobileNo}}</td>
                                    <td>{{o.AppointmentType}}</td>
                                    <td>{{o.Remarks}}</td>
                                </tr>
                                <tr>
                                    <td colspan="9"><b>Status : </b>Closed({{dayBook.ClosedColl.length}})</td>
                                </tr>
                                <tr id="tblrow" ng-repeat="o in dayBook.ClosedColl">
