                                                        Active Population ({{ DB.C23 }})
                                                    </div>
                                                    <ul>
                                                        <li>
                                                            <div class="yellow clickcur" ng-click="getJobCardCallingRpt(20)">Under Warranty ({{DB.C20}})</div>
                                                        </li>
                                                        <li>
                                                            <div class="yellow clickcur" ng-click="getJobCardCallingRpt(21)">Out Of Warranty ({{DB.C21}})</div>
                                                        </li>
                                                    </ul>
                                                </li>
                                                <li>
                                                    <div class="green clickcur" ng-click="getJobCardCallingRpt(24)">
                                                        Pulled MHPL ({{ DB.C24 }})
