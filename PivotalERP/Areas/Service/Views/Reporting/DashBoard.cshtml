                                                            <div class="blue">
                                                                6th call non retained Pending
                                                                ({{DB.C3}})
                                                            </div>
                                                        </li>
                                                        <li class="clickcur" ng-click="getJobCardCallingRpt(4)">
                                                            <div class="blue">
                                                                Potential Customer Pending
                                                                ({{DB.C4}})
                                                            </div>
                                                        </li>
                                                        <li class="clickcur" ng-click="getJobCardCallingRpt(6)">
                                                            <div class="blue">
                                                                6th Call Retained Pending
                                                                ({{DB.C6}})
                                                            </div>
                                                        </li>
                                                    </ul>
                                                </li>
                                                <li>
                                                    <div class="sidebar-dark-pink clickcur" ng-click="getJobCardCallingRpt(8)">
                                                        Feedback Call Pending
                                                        ({{ DB.C8 }})
                                                    </div>
                                                </li>
                                                <li>
                                                    <div class="sidebar-dark-pink clickcur">
                                                        Birthday Celebration
                                                        ({{ DB.C18 }})
                                                    </div>
                                                </li>
                                                <li>
                                                    <div class="sidebar-dark-pink clickcur" ng-click="getJobCardCallingRpt(7)">
                                                        Open JobCard
                                                        ({{ DB.C18 }})
                                                    </div>
                                                </li>
                                            </ul>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                    </div>
                    <!--Ends-->
                </div>
                <div class="row mt-4">
                 
                    <div class="col-md-2 text-center clickcur" ng-click="getJobCardCallingRpt(5)">
                        <div class="paper foldtl">
                            <div class="">
                                <p class="py-3">Pending Installation</p>
                            </div>
                            <div class="card-body text-white" style="background-color: #33B8FF;">
                                {{DB.C5}}
                            </div>
                        </div>
                    </div>
                    
               
                    <div class="col-md-2 text-center clickcur" ng-click="getJobCardCallingRpt(8)">
                        <div class="paper foldtl">
                            <div class="">
                                <p class="py-3">Pending Service Reminder</p>
                            </div>
                            <div class="card-body text-white" style="background-color: #87CEEB;">
                                {{DB.C8}}
                            </div>
                        </div>
                    </div>
                    
                    
                </div>
                <div class="row mt-4">
                    <div class="col-md-12">
                        <div id="datatable" style="height: calc(100vh - 255px);width: 100%;" class="ag-theme-alpine" ag-grid="gridOptions"></div>
                    </div>
                </div>


            </section>
            <!-- /.row -->
        </div>
    </div>
    <!-- Main content -->
    <!--Forth Call Modal starts-->
    <div class="modal fade sales-invoice-page-modal document-attach-modal" id="fourthcall" tabindex="-1" role="dialog" aria-labelledby="documentAttachModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="row p-2" style="background-color: #7abe5a; color: #fff;">
                    <h6 class="modal-title text-center col-md-11" id="exampleModalCenterTitle">Feedback for 4th Week Call</h6>
                    <button type="button" class="close col-md-1" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="px-2 py-1 text-center" style="background-color: #068abf; color: #fff;">
                    <h6 class="modal-title">{{CurCall.PartyName}}({{CurCall.Address}})</h6>
                </div>
                <div class="px-2 py-1">
                    <div class="row" style="">
                        <div class="col-md-12 text-center">
                            <h6 class="modal-title">Date Of Sale: <b>{{CurCall.InvoiceDate | dateFormat}} (A.D.) - {{CurCall.InvoiceMiti}} (B.S.)</b></h6>
                        </div>
                    </div>
                </div>
                <div class="px-2 py-1">
                    <div class="row" style="">
                        <div class="col-md-12 text-center">
                            <h6 class="modal-title">Branch: <b>{{CurCall.Branch}}</b></h6>
                        </div>
                    </div>
                </div>
                <div class="px-2 py-1">
                    <div class="row" style="">
                        <div class="col-md-9 text-center">
                            <h6 class="modal-title">Mobile No: <b>{{CurCall.MobileNo}}</b> (Model-{{CurCall.Model}})</h6>
                        </div>
                        <div class="col-md-3">
                            <div class="float-right">
                                <button class="btn btn-success" style="padding:2px 4px;" ng-click="ClickOnFailedCall()">Failed Call</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-body gradient-bg" style="border-top: 1px solid #068abf;">
                    <div id="forthcallsuccess" ng-show="CurCall.IsFailed==false">
                        <div class="row">
                            <div class="col-md-7" style="text-align: right;">
                                <label><b>Is it your repeat Purchase?</b></label>
                            </div>
                            <div class="col-md-5">
                                <div class="text-center">
                                    <div class="switch-field">
                                        <input type="radio" id="purchase_yes" name="switch_3" ng-value="true" @*onclick="myFunction1()"*@ ng-model="CurCall.IsRepeatPurchase" />
                                        <label for="purchase_yes">Yes</label>
                                        <input type="radio" id="purchase_no" name="switch_3" ng-value="false" @*onclick="myFunction1()"*@ ng-model="CurCall.IsRepeatPurchase" />
                                        <label for="purchase_no">No</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row text-center">
                            <div class="col-md-7" style="text-align: right;">
                                <label><b>Is Installation Done?</b></label>
                            </div>
                            <div class="col-md-5">
                                <div class="switch-field">
                                    <input type="radio" id="switch_left" name="switch_2" ng-value="true" @*onclick="myFunction()"*@ ng-model="CurCall.IsInstallationDone" />
                                    <label for="switch_left">Yes</label>
                                    <input type="radio" id="switch_right" name="switch_2" ng-value="false" @*onclick="myFunction()"*@ ng-model="CurCall.IsInstallationDone" />
                                    <label for="switch_right">No</label>
                                </div>
                            </div>
                        </div>
                        <div id="installation" ng-show="CurCall.IsInstallationDone==true">
                            <div class="row form-group text-center">
                                <div class="col-md-7" style="text-align: right;">
                                    <label><b>Which implement has been used for installation?</b></label>
                                </div>
                                <div class="col-md-5">
                                    <select class="form-control form-control-sm select2" ng-model="CurCall.VehicleImplementId">
                                        <option ng-value="0">**Select Implement**</option>
                                        <option ng-repeat="il in VehicleImplementsList" ng-value="il.id" ng-selected="il.id==CurCall.VehicleImplementId">{{il.text}}</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-7" style="text-align: right;">
                                    <label><b>Are you satisfied with delivery and Installation Process?</b></label>
                                </div>
                                <div class="col-md-5">
                                    <div class="switch-field text-center">
                                        <input type="radio" id="satisfy_yes" name="switch_4" ng-value="true" @*onclick="myFunction3()"*@ ng-model="CurCall.AreYouSatisfied" />
                                        <label for="satisfy_yes">Yes</label>
                                        <input type="radio" id="satisfy_no" name="switch_4" ng-value="false" @*onclick="myFunction3()"*@ ng-model="CurCall.AreYouSatisfied" />
                                        <label for="satisfy_no">No</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="noninstallation" ng-show="CurCall.IsInstallationDone==false">
                            <div class="row form-group text-center">
                                <div class="col-md-12" style="background-color: lightgreen;">
                                    <label><b>Ticket will be raised against non-installation</b></label>
                                </div>
                            </div>
                            <div class="form-group">
                                <label><b>Comment on Non Installation</b></label>
                                <textarea class="form-control" id="exampleFormControlTextarea1" rows="2" ng-model="CurCall.SatisfiedYes"></textarea>
                            </div>
                        </div>
                        <div id="commentdiv" ng-show="CurCall.AreYouSatisfied==false">
                            <div class="form-group">
                                <label><b>Comment(Not Satisfied)</b></label>
                                <textarea class="form-control" id="exampleFormControlTextarea1" rows="2" ng-model="CurCall.SatisfiedNo"></textarea>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-7">
                                <label><b>Do you have any open Complaints?</b></label>
                            </div>
                            <div class="col-md-5">
                                <div class="switch-field text-center">
                                    <input type="radio" id="complaints_yes_4P" name="switch_4PO" ng-value="true" ng-model="CurCall.AnyComplaints" />
                                    <label for="complaints_yes_4P">Yes</label>
                                    <input type="radio" id="complaints_no_4P" name="switch_4PO" ng-value="false" ng-model="CurCall.AnyComplaints" />
                                    <label for="complaints_no_4P">No</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div ng-show="CurCall.IsFailed==true">
                        <div class="row">
                            <div class="col-md-4 px-0">
                                <label><b>Reason for Failure</b></label>
                            </div>
                            <div class="col-md-8 px-0">
                                <select class="form-control form-control-sm select2" ng-model="CurCall.CallFailedReasonId">
                                    <option ng-value="0">**select reason**</option>
                                    <option ng-repeat="cr in FailedReasonList" ng-value="cr.id" ng-selected="cr.id==CurCall.CallFailedReasonId">{{cr.text}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="row my-2">
                            <div class="col-md-4 px-0">
                                <label><b>Comment on Failure</b></label>
                            </div>
                            <div class="col-md-8 px-0">
                                <textarea class="form-control" id="exampleFormControlTextarea1" rows="2" ng-model="CurCall.CallFailedComment"></textarea>
                            </div>
                        </div>
                    </div>
                    <div ng-show="CurCall.AnyComplaints==true">
                        <div class="row form-group text-center">
                            <div class="col-md-12" style="background-color: lightgreen;">
                                <label><b>Complaint Ticket No <b>TKCXXXXXXXXXXX</b></b></label>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Complaint Type</label>
                            </div>
                            <div class="col-md-9">
                                <div class="row">
                                    <div class="col-md-6" ng-repeat="ct in ComplainTypeList">
                                        <div class="form-group">
                                            <div class="icheck-primary d-inline">
                                                <input type="checkbox" id="Service{{$index}}" ng-model="ct.IsSelected">
                                                <label for="Service{{$index}}">{{ct.text}}</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Comments</label>
                            </div>
                            <div class="col-md-9">
                                <textarea class="form-control" id="exampleFormControlTextarea1" rows="1" ng-model="CurCall.Comments"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="text-center mt-1">
                        <button type="button" class="btn btn-success"
                                style="min-width: 50px;padding:2px 4px;" ng-click="CallSaveUpdateFourthCall()">
                            Save
                        </button>
                        <button type="button" class="btn btn-danger" data-dismiss="modal" aria-label="Close"
                                style="min-width: 50px;padding:2px 4px;">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--Fifth Call Modal starts-->
    <div class="modal fade sales-invoice-page-modal document-attach-modal" id="fifthcall" tabindex="-1" role="dialog" aria-labelledby="documentAttachModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="row p-2" style="background-color: #7abe5a; color: #fff;">

                    <h6 class="modal-title text-center col-md-11" id="exampleModalCenterTitle">Feedback for 5th Week Call</h6>
                    <button type="button" class="close col-md-1" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="px-2 py-1 text-center" style="background-color: #068abf; color: #fff;">
                    <h6 class="modal-title">{{CurCall.PartyName}}({{CurCall.Address}})</h6>
                </div>
                <div class="px-2 py-1">
                    <div class="row" style="">
                        <div class="col-md-12 text-center">
                            <h6 class="modal-title">Date Of Sale: <b>{{CurCall.InvoiceDate | dateFormat}} (A.D.) - {{CurCall.InvoiceMiti}} (B.S.)</b></h6>
                        </div>
                    </div>
                </div>
                <div class="px-2 py-1">
                    <div class="row" style="">
                        <div class="col-md-12 text-center">
                            <h6 class="modal-title">Branch: <b>{{CurCall.Branch}}</b></h6>
                        </div>
                    </div>
                </div>
                <div class="px-2 py-1">
                    <div class="row" style="">
                        <div class="col-md-9 text-center">
                            <h6 class="modal-title">Mobile No: <b>{{CurCall.MobileNo}}</b> (Model-{{CurCall.Model}})</h6>
                        </div>
                        <div class="col-md-3">
                            <div class="float-right">
                                <button class="btn btn-success" style="padding:2px 4px;" ng-click="ClickOnFailedCall()">Failed Call</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-body gradient-bg" style="border-top: 1px solid #068abf;">
                    <div ng-show="CurCall.IsFailed==false">
                        <label><b>How would you rate the quality of Dealer Service Experience?</b></label>
                        <div class="text-center">
                            <div class="switch-field">
                                <input type="radio" id="detractor" name="rate1" ng-value="1" ng-model="CurCall.ServiceQualityRate" />
                                <label for="detractor" style="width:100px">0-6 Detractor</label>
                                <input type="radio" id="neutral" name="rate1" ng-value="2" ng-model="CurCall.ServiceQualityRate" />
                                <label for="neutral" style="width:100px">7-8 Neutral</label>
                                <input type="radio" id="promotor" name="rate1" ng-value="3" ng-model="CurCall.ServiceQualityRate" />
                                <label for="promotor" style="width:100px">9-10 Promotor</label>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-md-3">
                                <label><b>Comments</b></label>
                            </div>
                            <div class="col-md-9">
                                <textarea class="form-control ml-2" id="exampleFormControlTextarea1" rows="1" ng-model="CurCall.ServiceComment"></textarea>
                            </div>
                        </div>

                        <label><b>How likely are you to recommend this product?</b></label>
                        <div class="text-center">
                            <div class="switch-field">
                                <input type="radio" id="rdetractor" name="rate2" ng-value="1" ng-model="CurCall.RecommendRate" />
                                <label for="rdetractor" style="width:100px">0-6 Detractor</label>
                                <input type="radio" id="rneutral" name="rate2" ng-value="2" ng-model="CurCall.RecommendRate" />
                                <label for="rneutral" style="width:100px">7-8 Neutral</label>
                                <input type="radio" id="rpromotor" name="rate2" ng-value="3" ng-model="CurCall.RecommendRate" />
                                <label for="rpromotor" style="width:100px">9-10 Promotor</label>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-md-3">
                                <label><b>Comments</b></label>
                            </div>
                            <div class="col-md-9">
                                <textarea class="form-control ml-2" id="exampleFormControlTextarea1" rows="1" ng-model="CurCall.RecommendComment"></textarea>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-7">
