                                    <td>{{id.Name}}</td>
                                    <td>{{id.Code}}</td>
                                    <td class="text-center">{{id.Qty |number:2}} {{id.Unit}}</td>
                                    <td style="text-align:right">{{id.Rate |number:2}}</td>
                                    <td style="text-align:right">{{id.Amount |number:2}}</td>
                                    <td class="text-center">{{id.IsUnderWarrency}}</td>
                                    <td>{{id.Remarks}}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <!--Job Closed Modal Ends-->

</div>
