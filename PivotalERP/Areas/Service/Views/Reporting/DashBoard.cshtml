                                                </li>
                                                <li>
                                                    <div class="green clickcur" ng-click="getJobCardCallingRpt(27)">
                                                        TO BE SOLD ({{ DB.C27 }})
                                                    </div>
                                                </li>
                                            </ul>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="col-md-6 card p-2">
                                <div class="text-center">
                                    <ul class="heirarchy vertical">
                                        <li>
                                            <div class="blue clickcur" ng-click="getJobCardCallingRpt(9)">
                                                Retention
                                                <b>({{DB.C9 |number:0}})</b>
                                            </div>
                                            <ul>
                                                <li>
                                                    <div class="green clickcur" ng-click="getJobCardCallingRpt(15)">
                                                        Repair Retention
                                                        ({{ DB.C15 |number:0}})
                                                    </div>
                                                    <ul>
                                                        <li>
                                                            <div class="yellow clickcur" ng-click="getJobCardCallingRpt(16)">Under Warranty ({{DB.C16 |number:0}})</div>
                                                        </li>
                                                        <li>
                                                            <div class="yellow clickcur" ng-click="getJobCardCallingRpt(17)">Out Of Warranty ({{DB.C17 |number:0}})</div>
                                                        </li>
                                                    </ul>
                                                </li>
                                                <li>
                                                    <div class="green clickcur" ng-click="getJobCardCallingRpt(12)">
                                                        Service Retention ({{ DB.C12 |number:0 }})
                                                    </div>
                                                    <ul>
                                                        <li>
                                                            <div class="yellow clickcur" ng-click="getJobCardCallingRpt(13)">Under Warranty ({{DB.C13 |number:0}})</div>
                                                        </li>
                                                        <li>
                                                            <div class="yellow clickcur" ng-click="getJobCardCallingRpt(14)">Out Of Warranty ({{DB.C14 |number:0}})</div>
                                                        </li>
                                                    </ul>
                                                </li>
                                                <li>
                                                    <div class="green clickcur" ng-click="getJobCardCallingRpt(10)">
                                                        UW Retention
                                                        ({{ DB.C10 |number:0 }})
                                                    </div>
                                                </li>
                                                <li>
                                                    <div class="green clickcur" ng-click="getJobCardCallingRpt(11)">
                                                        OW retention
                                                        ({{ DB.C11 |number:0 }})
                                                    </div>
                                                </li>

                                            </ul>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="col-md-12 card p-2">
                                <div class="text-center">
                                    <ul class="heirarchy vertical">
                                        <li>
                                            <div class="red">
                                                CRO’S Calling 
                                            </div>
                                            <ul>
                                                <li class="clickcur" ng-click="getJobCardCallingRpt(1)">
                                                    <div class="sidebar-dark-pink">
                                                        4th Call Pending
                                                        ({{ DB.C1 }})
                                                    </div>
                                                </li>
                                                <li class="clickcur" ng-click="getJobCardCallingRpt(2)">
                                                    <div class="sidebar-dark-pink">
                                                        5th Call Pending
                                                        ({{ DB.C2 }})
                                                    </div>
                                                </li>
                                                <li>
                                                    <div class="sidebar-dark-pink">
                                                        6th Call Pending
                                                    </div>
                                                    <ul>
