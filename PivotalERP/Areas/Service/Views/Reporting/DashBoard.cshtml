@{

    ViewBag.Title = "";
    Layout = null;
}
<link href="~/wwwroot/dynamic-erp/css/treeview.css" rel="stylesheet" />

@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .card-body {
        overflow-x: auto;
        overflow: hidden;
        padding: 8px;
    }

    .paper {
        background: #fff;
        box-shadow: 2px 2px 1px rgb(199, 196, 196);
    }

    .foldtl {
        position: relative;
    }

        .foldtl:before {
            content: "";
            position: absolute;
            top: 0%;
            left: 0%;
            width: 0px;
            height: 0px;
            border-bottom: 20px solid #eee;
            border-left: 25px solid transparent;
        }

        .foldtl:after {
            content: "";
            position: absolute;
            top: 0%;
            left: 0%;
            width: 0px;
            height: 0px;
            border-top: 20px solid #f4f6f9;
            border-right: 25px solid #bcc3c9;
        }
</style>
<style type="text/css" media="all">
    .clickcur {
        cursor: pointer !important;
    }
</style>
<script src="~/jslib/service/reporting/Dashboard.js?v=1"></script>
<div ng-app="myApp" ng-controller="serviceDashboardCtrl" ng-class="{waiting: loadingstatus=='running'}" ng-init="LoadData()">

    <div class="content  third-level-scroll-only">
        <div class="container-fluid">

            <section class="iframe-content-starts-here">

                <div class="row">
                    <div class="col-sm-6">
                        <div class="d-inline-block">
