                                    <span class="input-group-text">From:</span>
                                </div>
                                <input class="form-control text-dark input-sm" type="text" date-picker ng-model="para.DateFrom_TMP" style="max-width:100px" date-detail="para.DateFromDet" />
                                <div class="input-group-prepend">
                                    <span class="input-group-text">To:</span>
                                </div>
                                <input class="form-control text-dark input-sm" type="text" date-picker ng-model="para.DateTo_TMP" style="max-width:100px" date-detail="para.DateToDet" />
                                <div class="input-group-prepend">
                                    <span class="input-group-text" ng-click="GetData()">Load</span>
                                </div>

                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <a href="#" class="btn btn-secondary btn-light btn-sm ml-2" ng-click="onBtExportCSV()">
                            Export
