
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/service/Creation/JobTypeMapping.js"></script>
<div ng-app="myApp" ng-controller="JobTypeMappingController" ng-init="LoadData()">

    <div class="box-body">
        <div class="content">
            <div class="p-1"></div>
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-body p-2" style="margin-bottom:55px;">
                        <div class="tab-content">
                            <div id="JobTypeMapping-section">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.JobTypeMapping">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.JobTypeMapping">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.JobTypeMapping">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file"
                                             data-placement="top" title="Download File">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#JobTypeMapping'" sheet-name="'JobTypeMappingDetails'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#JobTypeMapping').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>

                                            </div>
                                            <a print-tbl table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait"
                                               title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>
                                            <button type="button"
                                                    class="btn btn-sm btn-primary load"
                                                    id="add-JobTypeMapping-details" style="min-width: 110px;" ng-click="ClearJobTypeMapping()">
                                                <i class="fas fa-plus w-t"></i> Add JobTypeMapping
                                            </button>
                                        </div>


                                    </div>
                                </header>
                                <div class="search-toolbar mb-3">
                                    <table cellpadding="12" class="table table-bordered table-striped table-hover table-sm" id="datatable">
                                        <thead>
                                            <tr>
                                                <th style="text-align: center; width: 60px; ">
                                                    S.No
                                                </th>
                                                <th style="width: 200px; ">
                                                    Vehicle Type
                                                </th>
                                                <th style="width: 200px; ">
                                                    Vehicle Model
                                                </th>
                                                <th style="width: 250px; ">
                                                    Description
                                                </th>

                                                <th style="text-align: center; width: 80px;">Action</th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr dir-paginate="C in JobTypeMappingList | filter:searchData.JobTypeMapping | itemsPerPage: perPage.JobTypeMapping" current-page="currentPages.JobTypeMapping" pagination-id="JobTypeMappingPagination">
                                                <td style="text-align:center;margin:auto">
                                                    {{$index+1}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{C.VehicleTypeName}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{C.VehicleModelName}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{C.Description}}
                                                </td>

                                                <td class="project-actions" style="text-align:center">
                                                    <div class="btn-group-sm">
                                                        <a class="btn btn-info" ng-click="getJobTypeMappingById(C, $index)"><i class="fas fa-pencil-alt text-white"></i></a>
                                                        <a class="btn btn-danger" ng-click="DelJobTypeMappingById(C)"><i class="fas fa-trash text-white"></i></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>

                                    </table>
                                    <div class="col-md-12">
                                        <dir-pagination-controls pagination-id="JobTypeMappingPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                        </dir-pagination-controls>
                                    </div>
                                </div>
                            </div>



                            <div id="JobTypeMapping-form">
                                <form>
                                    <div class="row">
                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>Vehicle Type</label>
                                                <select class="form-control form-control-sm select2" ng-model="newDet.VehicleTypeId">
                                                    <option ng-repeat="V in VehicleTypeList" ng-value="V.VehicleTypeId" ng-selected="newDet.VehicleTypeId==V.VehicleTypeId">{{V.Name}}</option>
                                                </select>
                                              
                                            </div>
                                        </div>
                                        <div class="col-sm-2">
                                            <div class="form-group">
                                                <label>Vehicle Model</label>
                                                <select class="form-control form-control-sm select2" ng-model="newDet.VehicleModelId">
                                                    <option ng-repeat="V in VehicleModelList" ng-value="V.VehicleModelId" ng-selected="newDet.VehicleModelId==V.VehicleModelId">{{V.Name}}</option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="col-sm-8">
                                            <div class="form-group">
                                                <label>Description</label>
                                                <textarea class="form-control form-control-sm" rows="1" ng-model="newDet.Description"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </form>

                                <div class="table-scroll-x-y  table-scroll" style="height:auto!important;max-height:400px!important;">
                                    <table class="main-table table table-sm table-bordered bg-white">
                                        <thead>
                                            <tr>
                                                <th class="text-center" style="width: 90px;background-color:#e1e1e1e1!important">S.No.</th>
                                                <th style="width: 200px;background-color:#e1e1e1e1!important">JobCard type</th>
                                                <th style="width: 140px;background-color:#e1e1e1e1!important">Kilometers Upto</th>
                                                <th style="width: 150px;background-color:#e1e1e1e1!important">Hours Upto</th>
                                                <th style="width: 200px;background-color:#e1e1e1e1!important">Days Upto(With Sales Date)</th>
                                                <th class="text-center" style="width: 100px;background-color:#e1e1e1e1!important">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="A in newDet.JobTypeMappingDetColl">
                                                <td class="text-center">{{$index+1}}</td>
                                                <td>
                                                    <select class="form-control form-control-sm select2" active-select2  ng-model="A.JobCardTypeId">
                                                        <option ng-repeat="J in JobCardTypeList" ng-value="J.id" ng-selected="J.id==A.J.JobCardTypeId">{{J.text}}</option>
                                                    </select>
                                                </td>
                                                <td>  <input type="number" class="form-control form-control-sm" ng-model="A.KmUpto"></td>
                                                <td>  <input type="number" class="form-control form-control-sm" ng-model="A.HourUpto"></td>
                                                <td>  <input type="number" class="form-control form-control-sm" ng-model="A.DayUpto"></td>
                                                <td class="text-center">
                                                    <a class="p-1" href="#" ng-click="AddDetail($index)">
                                                        <i class="fas fa-plus text-info"></i>
                                                    </a>
                                                    <a class="p-1" href="#" ng-click="delDetail($index)">
                                                        <i class="fas fa-trash-alt text-danger"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <footer class="main-footer">
                                    <div class="text-right control-btns">
                                        @*<button type="button" class="btn btn-default" ng-click="ClearJobTypeMapping()">Cancel</button>*@
                                        <button type="button" class="btn btn-secondary" id="back-to-JobTypeMapping-list">Back to List</button>

                                        <button type="button" class="btn btn-primary" ng-click="SaveJobTypeMapping()">{{newDet.Mode}}</button>
                                    </div>

                                </footer>
                            </div>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->
        </div>




    </div>
</div>

<style>

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>
