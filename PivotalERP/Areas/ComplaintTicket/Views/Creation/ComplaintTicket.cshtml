                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:150px">STPL Entry Time</label>
                                                    <input type="time" class="form-control form-control-sm" ng-model="newcomplaintTicket.STPLEntryTime_TMP" />
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
