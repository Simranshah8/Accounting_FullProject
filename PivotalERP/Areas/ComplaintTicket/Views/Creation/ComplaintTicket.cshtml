                                                        </div>
                                                        <div class="card-tools">
                                                            <button type="button" class="mt-1 btn btn-tool" data-card-widget="collapse"
                                                                    data-toggle="tooltip" title="Click to expand it">
                                                                <i class="fas fa-plus text-info"></i>
                                                            </button>

                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            <div class="card-body p-0 expand">
                                <div class="row p-2 px-2">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:140px">Document No</label>
                                                    <div class="input-group input-group-sm">
                                                        <input class="form-control form-control-sm" disabled ng-model="newcomplaintTicket.AutoVoucherNo">
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:90px">Ticket For</label>
                                                    <div class="input-group input-group-sm">
                                                        <select class="form-control form-control-sm" ng-model="newcomplaintTicket.TicketForId">
                                                            <option ng-repeat="T in TicketForList" ng-value="T.TicketForId" ng-selected="newcomplaintTicket.TicketForId==H.TicketForId">
                                                                {{T.Name}}
                                                            </option>
                                                        </select>                                                       
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:90px">Entry Date</label>
                                                    <input  class="form-control form-control-sm" type="text" date-picker ng-model="newcomplaintTicket.VoucherDate_TMP"  date-detail="newcomplaintTicket.VoucherDateDet" />                                                  
                                                </div>
                                            </div>

                                            <div class="col-md-8">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:140px">Customer Name</label>
                                                    <div class="input-group input-group-sm">
                                                        <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="newcomplaintTicket.LedgerId" id="cboParty1" style="width:95%" ledgertype="3" fortransaction="true"
                                                                placeholder="** Select Customer **" showdetails="true" confirm-action="CustmerChange()" ledger-detail="newcomplaintTicket.PartyLedger" side-bar-data="newcomplaintTicket.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="14"></select>

                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:90px">Phone No.</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newcomplaintTicket.PhoneNo" />
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:140px">Customer Address</label>
                                                    <input type="text" class="form-control form-control-sm"  ng-model="newcomplaintTicket.CustomerAddress" />
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:90px">Source</label>
                                                    <div class="input-group input-group-sm">
                                                        <select class="form-control form-control-sm" ng-model="newcomplaintTicket.SourceId">
                                                            <option ng-repeat="S in SourceList" ng-value="S.SourceId" ng-selected="newcomplaintTicket.SourceId==S.SourceId">
                                                                {{S.Name}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:90px">Nature @*<span style="color:red">*</span>*@</label>
                                                    <select class="form-control form-control-sm" ng-model="newcomplaintTicket.NatureId">
                                                        <option ng-repeat="N in NatureList" ng-value="N.NatureId" ng-selected="newcomplaintTicket.NatureId==N.NatureId">
                                                            {{N.Name}}
                                                        </option>
                                                    </select>                                                  
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-header p-0">
                                <div class="row" data-card-widget="collapse" data-toggle="tooltip" @*title="Click to expand it"*@>
                                    <div class="col-md-12">
                                        <div class="px-2" style="background-color: white; border: 2px solid #dee2e6;">
                                            <div class="row">
                                                <div class="col-md-5">
                                                    <div class="form-group d-flex mb-0">
                                                        <label class="my-1"><b>Vehicle Details</b> </label>
                                                    </div>
                                                </div>
                                                <div class="col-md-7">
                                                    <div class="form-inline float-right">
                                                        <div class="form-group form-inline float-right mb-0">
                                                            <label class="my-1"><b> {{S.ChieldColl.length}}</b></label>
                                                        </div>
                                                        <div class="card-tools">
                                                            <button type="button" class="mt-1 btn btn-tool" data-card-widget="collapse"
                                                                    data-toggle="tooltip" title="Click to expand it">
                                                                <i class="fas fa-plus text-info"></i>
                                                            </button>

                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            <div class="card-body p-0 expand">
                                <div class="row p-2 px-2">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-sm-8 col-lg-8 col-md-8 ">
                                                <div class="row">
                                                    <div class="col-sm-12 col-lg-12 col-md-12">
                                                        <div class="input-group-prepend">
                                                            <select class="input-group-text dropdown-toggle p-0"
                                                                    style="outline: none; border-top-right-radius: unset;border-bottom-right-radius: unset;margin-right: -3px;z-index: 1;" ng-model="newcomplaintTicket.SearchOption">

                                                                <option ng-repeat="ss in VehicleSearchOptions" ng-value="ss.value" ng-selected="ss.value==newcomplaintTicket.SearchOption">
                                                                    {{ss.text}}
                                                                </option>
                                                            </select>
                                                            <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-vehicle ng-model="newcomplaintTicket.VehicleEntryId" style="width:100%"
                                                                    placeholder="** Select Vehicle  **" showdetails="true" confirm-action="VehicleSelectionChange(newcomplaintTicket,$index)" vehicle-detail="newcomplaintTicket.vehicleDetail" side-bar-data="newcomplaintTicket.sideBarData" voucher-id="SelectedBranch.BranchId" search-by="newcomplaintTicket.SearchOption"></select>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>


                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:160px">Registration No.</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newcomplaintTicket.RegistrationNo" readonly />
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:140px">Make Code</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newcomplaintTicket.MakeCode" readonly />
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:100px">Model Code</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newcomplaintTicket.ModelCode" readonly />
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:160px">Model Version No.</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newcomplaintTicket.ModelVersionNo" readonly />
                                                </div>
                                            </div>






                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width: 140px">Model Version Desc.</label>
                                                    <input type="text" class="form-control form-control-sm" readonly ng-model="newcomplaintTicket.ChassisNo" />
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:100px">Engine No</label>
                                                    <input type="text" class="form-control form-control-sm" readonly ng-model="newcomplaintTicket.EngineNo" />
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:160px">Vehicle Warranty Status</label>
                                                    <input type="text" class="form-control form-control-sm" readonly ng-model="newcomplaintTicket.VehicleWarrantyStatus" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
