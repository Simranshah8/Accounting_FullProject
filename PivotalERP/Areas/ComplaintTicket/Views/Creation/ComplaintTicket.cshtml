<style>
    .dropdown {
        position: relative !important;
        display: inline !important;
    }


    .table-sm td {
        padding: 0.4rem !important;
    }
    .table-scroll-x-y{
        height:auto!important
    }
</style>


@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<link rel="stylesheet" href="~/wwwroot/plugins/ag-grid/css/ag-grid.css">
<link rel="stylesheet" href="~/wwwroot/plugins/ag-grid/css/ag-theme-alpine.css">
<script src="~/wwwroot/plugins/ag-grid/js/ag-grid-community.min.noStyle.js"></script>

<script src="~/jslib/ComplaintTicket/ComplaintTicket.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="ComplainTicketController" ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="pt-1"></div>
                <div class="tab-content" id="Ticket-Section">
                    <!-- Second Tab Content -->
                    <div class="card p-2">
                        <header class="row">
                            <div class="col-md-12 row mb-1">
                                <div class="col" style="max-width: 105px;">
                                    <label class="form-check-label" for="Open">
                                        Open
                                    </label>
                                    <span class="dot mt-1 ml-3" style=" height: 12px; width: 12px; background-color: red;  display: inline-block;"></span>
                                </div>

                                <div class="col" style="max-width: 135px;">
                                    <label class="form-check-label" for="InProgress">
                                        InProgress
                                    </label>
                                    <span class="dot mt-1 ml-3" style=" height: 12px; width: 12px; background-color: yellow;  display: inline-block;"></span>
                                </div>

                                <div class="col" style="max-width: 110px;">
                                    <label class="form-check-label" for="Closed">
                                        Closed
                                    </label>
                                    <span class="dot mt-1 ml-3" style=" height: 12px; width: 12px; background-color: green;  display: inline-block;"></span>
                                </div>

                                <div class="col" style="max-width: 180px;">
                                    <label class="form-check-label" for="Customer">
                                        Customer Waiting
                                    </label>
                                    <span class="dot mt-1 ml-3" style=" height: 12px; width: 12px; background-color: orange;  display: inline-block;"></span>
                                </div>


                                <div class="col" style="max-width: 191px;">
                                    <label class="form-check-label" for="Feedback">
                                        Feedback Pending
                                    </label>
                                    <span class="dot mt-1 ml-3" style=" height: 12px; width: 12px; background-color: darkorange;  display: inline-block;"></span>
                                </div>

                                <div class="col" style="max-width: 200px;">
                                    <label class="form-check-label" for="Waiting">
                                        Waiting for Spare parts
                                    </label>
                                    <span class="dot mt-1 ml-3" style=" height: 12px; width: 12px; background-color: lawngreen;  display: inline-block;"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="clearfix">
                                    <form class="form-inline mb-1">
                                        <div class="input-group input-group-sm mr-sm-2">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text cstm">Show</span>
                                            </div>
                                            <!-- <input type="text" class="form-control border-left-0" placeholder=""> -->
                                            <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.TransctionComplain">
                                                <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.TransctionComplain">{{pp.text}}</option>
                                            </select>
                                            <div class="input-group-append">
                                                <span class="input-group-text bg-white"><small>entries</small></span>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="input-group input-group-sm">
                                    <div class="input-group-prepend">
                                        <select class="input-group-text dropdown-toggle p-0" id="dropdownMenuButton" data-toggle="dropdown"
                                                aria-haspopup="true" aria-expanded="false" style="outline: none; font-size: 14px">
                                            <option class="dropdown-item">
                                                Open
                                            </option>
                                            <option class="dropdown-item">
                                                InProgress
                                            </option>
                                            <option class="dropdown-item">Customer Waiting</option>
                                            <option class="dropdown-item">Feedback Pending</option>
                                            <option class="dropdown-item">Waiting For Spare Part</option>
                                        </select>
                                    </div>
                                    <input type="text" class="form-control form-control-sm" />

                                </div>
                            </div>


                            <div class="col-md-3">
                                <button type="button" class="btn btn-sm btn-info load" style="min-width: 90px;  border: none;">
                                    <i class="fas fa-search mr-2"></i><span class="mb-0">Search</span>
                                </button>
                            </div>

                            <div class="col-md-3 text-right">
                                <div class="dropdown dnld-file"
                                     data-placement="top"
                                     title="Download File">
                                    <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                            type="button"
                                            id="dropdownMenuButton"
                                            data-toggle="dropdown"
                                            aria-haspopup="true"
                                            aria-expanded="false">
                                        <i class="fas fa-download"></i>
                                    </button>
                                    <div class="dropdown-menu dropdown-menu-right"
                                         aria-labelledby="dropdownMenuButton">
                                        <span class="dropdown-item">Choose an option:</span>
                                        <a class="dropdown-item" href="#">
                                            <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                 class="img-fluid exports-icon"
                                                 alt="Excel image" />
                                            Excel
                                        </a>
                                        <a class="dropdown-item" href="#">
                                            <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                 class="img-fluid exports-icon"
                                                 alt="Excel image" />
                                            CSV
                                        </a>
                                       
                                    </div>
                                </div>

                                <a href="#"
                                   class="btn btn-secondary btn-light btn-sm"
                                   data-placement="top"
                                   title="Print">
                                    <i class="fas fa-print"></i>
                                </a>

                                <button type="button"
                                        class="btn btn-sm btn-info load float-right"
                                        id="open-ComplainForm"
                                        style="min-width: 90px" ng-click="ClearFields()">
                                    <i class="fas fa-plus w-t"></i> Add Complaint Ticket
                                </button>
                            </div>
                        </header>
                        @*<div class="table-scroll-x-y table-scroll ag-theme-alpine" style="max-height: calc(100Vh - 6rem)!important;" id="myComplainTicket">
        </div>*@


                        <div class="table-scroll-x-y table-scroll">
                            <table id="ELeaveRequest"
                                   class="main-table table table-sm table-bordered bg-white">
                                <thead >
                                    <tr>
                                        <th style="width: 60px">S.No</th>
                                        <th style="width: 130px">Entry Date</th>
                                        <th style="width: 100px">Voucher No</th>
                                        <th style="width: 120px">Complain Status</th>
                                        <th style="width: 200px">Complain Detail</th>
                                        <th style="width: 140px">Customer Code</th>
                                        <th style="width: 200px">Customer Name</th>
                                        <th style="width: 200px">Customer Address</th>
                                        <th style="width: 130px">Phone Number</th>
                                        <th style="width: 130px">Model No</th>
                                        <th style="width: 150px">Model Version No</th>
                                        <th style="width: 120px">Vin No</th>
                                        <th style="width: 150px">Registration No</th>
                                        @*<th style="width: 80px">Action</th>*@
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr dir-paginate="cl in TransctionComplainColl | filter:searchData.TransctionComplain | itemsPerPage: perPage.TransctionComplain" current-page="currentPages.TransctionComplain" pagination-id="TransctionComplainPagination">
                                        <td>

                                            <a href="#" class="btn btn-sm btn-info" ng-click="GetTransactionComplainById(cl)"><i class="fas fa-pencil-alt"></i></a>
                                            {{$index+1}}
                                        </td>
                                        <td>{{cl.VoucherDate}}</td>
                                        <td>{{cl.AutoVoucherNo}}</td>
                                        <td>{{cl.ComplaintStatus}}</td>
                                        <td>{{cl.ComplainDetail}}</td>
                                        <td>{{cl.CustomerCode}}</td>
                                        <td>{{cl.CustomerName}}</td>
                                        <td>{{cl.CustomerAddress}}</td>
                                        <td>{{cl.PhoneNumber}}</td>
                                        <td>{{cl.ModelNo}}</td>
                                        <td>{{cl.ModelVersionNo}}</td>
                                        <td>{{cl.VinNo}}</td>
                                        <td>{{cl.RegdNo}}</td>                                       
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="col-md-12">
                            <dir-pagination-controls pagination-id="TransctionComplainPaginationPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                            </dir-pagination-controls>
                        </div>

                    </div>
                </div>

                <div class="mt-2">
                    <div class="mb-3" id="ComplainForm">
                        <div class="card">
                            <div class="card-header p-0">
                                <div class="row" data-card-widget="collapse" data-toggle="tooltip" @*title="Click to expand it"*@>
