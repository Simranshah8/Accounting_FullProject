
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Lab_RefRules)";
</script>
<script src="~/jslib/Lab/RefRules.js"></script>
<div id="ActionDiv" ng-app="myApp" ng-controller="RefrenceRule" ng-init="LoadData()" ng-cloak>
    <div class="content">
        <div class="p-1"></div>
        <div class="container-fluid">

            <div class="card">
                <div class="card-header p-0 border-bottom-0">
                    <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false" ng-click="ClearFields()">Reference</a>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-2">
                    <div class="tab-content" id="custom-tabs-four-tabContent">
                        <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                            <header class="row">
                                <div class="col-md-8">
                                    <div class="clearfix">
                                        <form class="form-inline">
                                            <div class="input-group input-group-sm table-search-filed">
                                                <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">
                                                <div class="input-group-append">
                                                    <button class="btn btn-default border-left-0" type="submit">
                                                        <i class="fas fa-search"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                                <div class="col-md-4 text-right">
                                    <div class="dropdown dnld-file"
                                         data-placement="top" title="Download File">
                                        <a class="btn btn-secondary btn-light btn-sm wait"
                                           title="Refresh" ng-click="GetReferebceRule()">
                                            <i class="fas fa-sync-alt"></i>
                                        </a>
                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                id="dropdownMenuButton" data-toggle="dropdown"
                                                aria-haspopup="true" aria-expanded="false">
                                            <i class="fas fa-download"></i>
                                        </button>
                                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                            <span class="dropdown-item">Choose an option:</span>
                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                     class="img-fluid exports-icon" alt="Excel image">
                                                Excel
                                            </a>
                                            <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                     class="img-fluid exports-icon">
                                                CSV
                                            </a>
                                        </div>
                                        <a print-tbl report-name="'List Of Specimen'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait"
                                           title="Print">
                                            <i class="fas fa-print"></i>
                                        </a>
                                        <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                           data-placement="bottom" title="Save List State" ng-click="saveRptListState()">
                                            <i class="fas fa-save"></i>
                                        </a>
                                    </div>
                                </div>
                            </header>

                            <div class="">
                                <div id="datatable" style="height: calc(100vh - 7rem); width: 100%;" class="ag-theme-alpine"></div>
                            </div>
                        </div>
                        <div class="tab-pane fade " id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                            <div>
                                <form>
                                    <div class="mb-3">
                                        <div class="d-flex gap-4">
                                            <label class="form-label fw-semibold pr-3">Mode:</label>

                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="mode"
                                                       ng-model="newDet.ModeId" id="ComponentWise" ng-value="false">
                                                <label for="ComponentWise" class="form-check-label pr-3">Component-wise</label>
                                            </div>

                                            <div class="form-check">
                                                <input class="form-check-input" id="TestWise" type="radio" name="mode"
                                                       ng-model="newDet.ModeId" ng-value="true">
                                                <label for="TestWise" class="form-check-label">Test-wise</label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-2 row">
                                        <div class="col-6" ng-show="newDet.ModeId === false">
                                            <label class="form-label fw-semibold">Component (global)</label>
                                            <select class="form-control form-control-sm" ng-model="newDet.ComponentGlobalId">
                                                <option value="">-- select component --</option>
                                                <option ng-value="CG.ComponentId" ng-repeat="CG in ComponentGlobalColl" ng-selected="CG.ComponentId==newDet.ComponentGlobalId">{{CG.Name}}</option>
                                            </select>
                                        </div>


                                        <div class="col-4" ng-show="newDet.ModeId == true">
                                            <label>Test Name</label>
                                            <select class="form-control form-control-sm" ng-model="newDet.TestNameId" ng-change="GetAllLabTestComponent(newDet.TestNameId)"
 >
                                                <option value="">-- select test --</option>
                                                <option ng-value="T.LabTestId" ng-repeat="T in TestNameColl" ng-selected="T.LabTestId==newDet.TestNameId">{{T.TestName}}</option>
                                            </select>
                                        </div>

                                        <div class="col-4" ng-show="newDet.ModeId == true">
                                            <label>Component (Within Selected Test)</label>
                                            <select class="form-control form-control-sm" ng-model="newDet.TestComponentId">
                                                <option value="">-- select component --</option>
                                                <option ng-value="TC.ComponentId" ng-repeat="TC in LabTestComponentColl" ng-selected="TC.ComponentId==newDet.TestComponentId">{{TC.Name}}</option>
                                            </select>
                                        </div>

                                        <div class="col-3">
                                            <label class="invisible d-block">Is Active?</label>
                                            <div class="icheck-primary d-inline">
                                                <input type="checkbox" id="checkboxPrimary1" ng-model="newDet.IsActive">
                                                <label for="checkboxPrimary1">Is Active?</label>
                                            </div>
                                        </div>
                                    </div>

                                </form>
                                <label><b> Lookups</b></label>
                                <div class="table-responsive">
                                    <table id="main-table" class="table table-sm table-bordered bg-white" style="table-layout: auto; width:100%;">
                                        <thead class="thead-light">
                                            <tr>
                                                <th style="width:100px">Gender</th>
                                                <th style="width:100px">Age Min(d)</th>
                                                <th style="width:100px">Age Max(d)</th>
                                                <th style="width:100px">Normal Low</th>
                                                <th style="width:100px">Normal High</th>
                                                <th style="width:100px">Critical Low</th>
                                                <th style="width:100px">Critical High</th>
                                                <th style="width:100px">Textual Reference</th>
                                                <th style="width:60px">Action</th>

                                            </tr>
                                        </thead>

                                        <tbody>
                                            <tr ng-repeat="pDet in newDet.RefRuleLookUpsColl">
                                                <td>
                                                    <select class="form-control form-control-sm" ng-model="pDet.GenderId">
                                                        <option ng-value="G.id" ng-repeat="G in GenderColl" ng-selected="G.id==pDet.GenderId">{{G.text}}</option>
                                                    </select>
                                                </td>
                                                <td><input class="form-control form-control-sm" ng-model="pDet.MinAge"></td>
                                                <td><input class="form-control form-control-sm" ng-model="pDet.MaxAge"></td>
                                                <td><input class="form-control form-control-sm" ng-model="pDet.NormalLow"></td>
                                                <td><input class="form-control form-control-sm" ng-model="pDet.NormalHigh"></td>

                                                <td><input class="form-control form-control-sm" ng-model="pDet.CriticalLow"></td>
                                                <td><input class="form-control form-control-sm" ng-model="pDet.CriticalHigh"></td>
                                                <td><input class="form-control form-control-sm" ng-model="pDet.TextualRef"></td>
                                                <td class="text-center">
                                                    <a ng-click="AddPHDDetails($index)" class="mr-1"><i class="fas fa-plus"></i></a>
                                                    <a ng-click="delPHDDetails($index)"><i class="fas fa-trash-alt text-danger"></i></a>
                                                </td>
                                            </tr>

                                            <!-- show a placeholder row when array is empty -->

                                        </tbody>
                                    </table>
                                </div>

                                <footer class="main-footer">
                                    <div class="text-right control-btns">
                                        <button type="button" class="btn btn-default btn" ng-click="ClearFields()"> <span class="glyphicon glyphicon-remove"></span>Clear</button>
                                        <button type="button" class="btn btn-primary btn" ng-click="SaveUpdateReferebceRule()"><span class="glyphicon glyphicon-save"></span>Save</button>
                                    </div>
                                </footer>

                            </div>
                        </div>

                    </div>
                    <!-- /.container-fluid -->
                </div>
            </div>
        </div>
    </div>

</div>