@{
    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table th, .table td {
        padding: 0.35rem;
    }
</style>
<script src="~/jslib/Lab/LabTechnician.js"></script>
<div ng-app="myApp" ng-controller="LabTechnician" ng-init="LoadData()">
    <div class="content">
        <div class="container-fluid">
            <div class="card">
                <div class="card-header p-0 border-bottom-0">
                    <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false" ng-click="ClearFields()">Lab Technician</a>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-0">
                    <div class="tab-content" id="custom-tabs-four-tabContent">
                        <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                            <div class="p-2">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.LabTechnician">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.LabTechnician">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed ml-2">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file">
                                            <a class="btn btn-secondary btn-light btn-sm wait"
                                               title="Refresh" ng-click="GetAllLabTechnician()">
                                                <i class="fas fa-sync-alt"></i>
                                            </a>
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'Report Template'" report-name="'List Of Lab Technician'" ignore-column="'6'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'Lab Technician',ignoreColumn:'6' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl report-name="'List Of Lab Technician'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait">
                                                <i class="fas fa-print"></i>
                                            </a>
                                            <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                               data-placement="bottom" title="Save Lab Technician" @*ng-click="saveRptListState()"*@>
                                                <i class="fas fa-save"></i>
                                            </a>
                                        </div>
                                    </div>
                                </header>
                                <div class="">
                                    <div id="datatable" style="height: calc(100vh - 7rem); width: 100%;" class="ag-theme-alpine"></div>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade p-2" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                            <div class="row">
                                <div class="col-md-10">
                                    <div class="row">

                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label>Name<span style="color:red;">*</span></label>
                                                <input class="form-control form-control-sm" style="margin-left:1px;" type="text" ng-model="newDet.Name">
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label>Address</label>
                                                <input class="form-control form-control-sm" style="margin-left:1px;" type="text" ng-model="newDet.Address">
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label>Mobile No.</label>
                                                <input class="form-control form-control-sm" style="margin-left:1px;" type="text" ng-model="newDet.MobileNo">
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label>Citizenship No.</label>
                                                <input class="form-control form-control-sm" style="margin-left:1px;" type="text" ng-model="newDet.CitizenshipNo">
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label>NMC No.</label>
                                                <input class="form-control form-control-sm" style="margin-left:1px;" type="text" ng-model="newDet.NMCNo">
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label>Designation</label>
                                                <input class="form-control form-control-sm" style="margin-left:1px;" type="text" ng-model="newDet.Designation">
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <div class="col-md-2">
                                    <label for="" class="invisible">Photo</label>
                                    <div class="img-wrap mx-auto">
                                        <img ng-src="{{newDet.SignatureData || newDet.Signature }}" class="img-fluid" alt="" id="Signature" style="height:130px; width:165px; border:1px solid #ccc">
                                    </div>
                                    <label for="choose-Sign" type="button" class="btn btn-default mt-1 mb-0 ml-4"><i class="fa fa-image"></i>&nbsp;Select Sign</label>
                                    <input id="choose-Sign" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newDet.Signature_Tmp" fileread="newDet.SignatureData" />
                                    <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                </div>
                               
                            </div>
                            <footer class="main-footer mt-2">
                                <div class="text-right control-btns">
                                    <button type="button" class="btn btn-default btn" ng-click="ClearFields()"> <span class="glyphicon glyphicon-remove"></span> Clear</button>
                                    <button type="button" class="btn btn-primary btn" ng-click="SaveUpdateLabTechnician()"><span class="glyphicon glyphicon-save"></span> {{newDet.Mode}}</button>
                                </div>
                            </footer>
                        </div>

                    </div>

                </div>

            </div>
            <!-- /.container-fluid -->
        </div>

    </div>
</div>
</div>
</div>