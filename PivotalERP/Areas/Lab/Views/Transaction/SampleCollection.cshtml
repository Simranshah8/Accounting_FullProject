                                                                <th style="width:200px !important;">Test Name</th>
                                                                <th style="width:150px !important;">Requested On</th>
                                                                <th style="width:150px !important;">BarCodeNumber</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <tr ng-repeat="test in patient.tests">
                                                                <td class="align-middle">{{test.name}}</td>
                                                                <td>
                                                                    <input style="border: none; background-color: #fff !important;" type="text" class="form-control form-control-sm" disabled date-picker ng-model="test.RequestDate_TMP" date-details="test.RequestDateDet" />
                                                                </td>
                                                                <td>
                                                                    <input style="border: none; background-color: #fff !important;" type="text" class="form-control form-control-sm" ng-click="selectTest(test)" readonly ng-model="test.BarCodeNumber" />
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
