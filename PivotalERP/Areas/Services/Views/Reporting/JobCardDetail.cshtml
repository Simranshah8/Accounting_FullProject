@{
    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/service/reporting/JobCardDetail.js"></script>
<style>


    .table-container {
        overflow: auto;
    }

    .table-scroll {
        max-height: 100%;
        overflow-y: auto;
    }

    .table {
        margin: 0;
        width: 100%;
    }

    .centered-cell {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100%;
    }

        .centered-cell button {
            margin: 0;
        }
</style>
<div class="hold-transition layout-navbar-fixed" ng-app="myApp" ng-controller="JobCardDetailController">
    <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
        <div class="overflow-hidden">
            <nav id="sidebarzz" class="order-last float-right active active">
                <div class="custom-menu">
                    <button type="button" id="ctmRightSidebarCollapse" class="btn btn-primary"></button>
                </div>
                <div class="" id="firstpanel">
                    <div class="right-box-wrap">
                        <!--Anything to be added here-->
                    </div>
                </div>
            </nav>
            <div class="content-wrapper-new">
                <!-- Main content -->
                <section>
                    <div class="container-fluid">
                        <section class="iframe-content-starts-here">
                            <div class="tab-content">
                                <div id="day-book-section">
                                    <div class="card p-2">
                                        <div class="row">
                                            <div class="col-sm-3">
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">From:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" date-picker ng-model="JobCardDetail.DateFrom_TMP" style="max-width:100px" date-detail="JobCardDetail.DateFromDet" />
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">To:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" date-picker ng-model="" style="max-width:100px" date-detail="JobCardDetail.DateToDet" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-4">

                                            </div>
                                            <div class="col-sm-4">
                                                <div class="form-group d-flex  mb-0">
                                                    <label class="mr-2 mt-1">PatientId</label>
                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-product ng-model="JobCardDetail.JobId" ng-change="loadBreakItemDetails(selectedJobId)" style="max-width :80%"
                                                            placeholder="* Select job  *" showdetails="true">
                                                        <option ng-repeat="job in jobs" value="{{job.id}}">
                                                            {{job.name}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-md-1">
                                                <div class="form-group">
                                                    <a href="#" class="btn btn-primary load px-1" style="float: right; min-width: 75px" data-toggle="tooltip" data-placement="top" title="" data-original-title="Load" ng-click="GetJobCardDetail()" ng-disabled="loadingstatus=='running'"><i class="fas fa-download"> &nbsp;&nbsp;Load</i></a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card p-2" id="grid-table">
                                        <header class="row">
                                            <div class="col-md-5 col-sm-5">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm mr-sm-2">
                                                            <div class="input-group-prepend">
                                                                <span class="input-group-text cstm">Find:</span>
                                                            </div>
                                                            <select class="form-control pr-0" id="exampleFormControlSelect1">
                                                                <option>Contain</option>
                                                                <option>Prefix</option>
                                                            </select>
                                                        </div>
                                                        <div class="input-group input-group-sm" style="width: 150px;">
                                                            <input type="text" name="table_search" class="form-control float-right" placeholder="Search">
                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-default">
                                                                    <i class="fas fa-search"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                            <div class="col-md-7 col-sm-7 text-right">
                                                <form class="form-inline float-right">
                                                    <div class="input-group input-group-sm mr-sm-2">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text cstm">Search By:</span>
                                                        </div>
                                                        <select class="form-control pr-0" id="exampleFormControlSelect1">
                                                            <option ng-value="cl.field" ng-repeat="cl in columnDefs">{{cl.headerName}}</option>
                                                        </select>
                                                    </div>
                                                    <div class="input-group input-group-sm" style="width: 170px;">
                                                        <input type="text" name="table_search" class="form-control float-right" placeholder="Search">
                                                        <div class="input-group-append">
                                                            <button type="submit" class="btn btn-default">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <div class="dropdown dnld-file ml-2">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="onBtExport()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image">
                                                                Excel
                                                            </a>
                                                            <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon">
                                                                CSV
                                                            </a>
                                                            <a class="dropdown-item" href="#">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image">
                                                                PDF
                                                            </a>
                                                            <a class="dropdown-item" href="#">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image">
                                                                Word
                                                            </a>
                                                            <a class="dropdown-item" href="#">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image">
                                                                Mail
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2" title="Print" ng-click="Print()">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2" data-toggle="modal" data-target="#itemAllocationForModal" data-placement="bottom" title="Filter">
                                                        <i class="fas fa-filter"></i>
                                                    </a>
                                                </form>
                                            </div>
                                        </header>
                                        <div id="datatable" style="height: 80vh; width: 100%;" class="ag-theme-alpine"></div>
                                    </div>
                                    <!-- Modal HTML -->
                                    <div class="modal fade" id="remarksModal" tabindex="-1" aria-labelledby="remarksModalLabel" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title" id="remarksModalLabel">Enter Remarks</h5>
                                                    <div class="row">
                                                        <div class="col-md-12">
                                                            <button type="button" class="close float-right" data-dismiss="modal">&times;</button>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="modal-body">
                                                    <form id="remarksForm">
                                                        <div class="mb-3">
                                                            <label for="remarksTextArea" class="form-label">Remarks</label>
                                                            <textarea class="form-control" id="remarksTextArea" rows="4"></textarea>
                                                        </div>
                                                    </form>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-primary" id="saveRemarksBtn">Save</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>


