    <div class="modal fade bd-example-modal-xl sales-invoice-page-modal" id="frmCustomColumns" role="dialog" aria-labelledby="exampleModalCenter2Title" aria-hidden="true" style="margin-top:20px">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header" style="padding: 1.5px; padding-left: 12px;">
                    <h6 class="modal-title" id="exampleModalCenterTitle"><b>Custom Columns</b></h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="row" style="margin-top: -10px">
                        <div class="table-responsive">
                            <div class="table-scroll-x-y mt-1" style="height: 200px!important">
                                <table id="main-table" class="main-table table table-head-fixed table-sm table-bordered bg-white">
                                    <thead class="text-center">
                                        <tr>
                                            <th style="width: 50px;background-color:#ececec!important">S.No.</th>
                                            <th style="width: 220px; background-color: #ececec !important ">Ref. Column</th>
                                            <th style="width: 220px; background-color: #ececec !important ">Source. Column</th>
                                            <th style="width: 150px; background-color: #ececec !important ">New Column</th>
                                            <th style="width: 250px; background-color: #ececec !important ">Formula</th>
                                            <th class="text-center align-middle;" style="width: 70px; background-color: #ececec !important ">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr ng-repeat="rtr in RefTableRows">
                                            <td align="center">{{$index+1}}</td>
                                            <td>
                                                <select class="form-control form-control-sm select2" active-select2 ng-model="rtr.RefColName">
                                                    <option ng-value="dp.name" ng-repeat="dp in RefTableColColl" ng-selected="dp.name==rpt.RefColName">{{dp.text}}-{{dp.name}}</option>
                                                </select>
                                            </td>
                                            <td>
                                                <select class="form-control form-control-sm select2" active-select2 ng-model="rtr.SourceColName">
                                                    <option ng-value="dp.name" ng-repeat="dp in SourceColColl" ng-selected="dp.name==rpt.SourceColName">{{dp.text}}</option>
                                                </select>
                                            </td>
                                            <td>
                                                <input class="form-control form-control-sm" type="text" ng-model="rtr.ColName" />
                                            </td>
                                            <td>
                                                <input class="form-control form-control-sm" type="text" ng-model="rtr.Formula" />
                                            </td>
                                            <td>
                                                <a class="p-1" href="#" data-original-title="Add Row" ng-click="AddRowIntoRefTblRow($index)">
                                                    <i class="fas fa-plus text-info"></i>
                                                </a>
                                                <a class="p-1" href="#" data-original-title="Delete Row." ng-click="delRowIntoRefTblRow($index)">
                                                    <i class="fas fa-trash-alt text-danger"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="row" style="margin-top: -10px">
                        <div class="table-responsive">
                            <div class="table-scroll-x-y mt-1" style="height: 350px!important">
                                <textarea rows="5" class="form-control form-control-sm" ng-model="CustomRptColumn.Qry"></textarea>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer p-2" style="padding: 3px;  ">
                    <button type="button" class="btn load btn-outline-secondary" data-dismiss="modal" style="min-width:70px">Cancel</button>
                    <button type="button" class="btn load btn-success" ng-click="OkRefTableRows()" style="min-width:70px">Ok</button>
                </div>
            </div>
