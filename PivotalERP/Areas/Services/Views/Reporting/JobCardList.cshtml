                                            <option ng-value="0" selected>All</option>
                                            <option ng-value="1">Open Only</option>
                                            <option ng-value="2">Close Only</option>
                                            <option ng-value="3">Cancel Only</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-2">
                                    <div class="col-md-6">
                                        <label>Total Open :  <b> {{dayBook.TotalOpen}}</b> </label>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="col-md-6">
                                        <label>Total Closed : <b> {{dayBook.TotalClose}}</b></label>
                                    </div>
                                </div>

                                <div class="col-md-1">
                                    <div class="form-group">
                                        <a href="#" class="btn btn-primary load" style="float: right; min-width: 100px" data-toggle="tooltip" data-placement="top" title="" data-original-title="Load" ng-click="GetDayBook()" ng-disabled="loadingstatus=='running'"><i class="fas fa-download"> &nbsp;&nbsp;Load</i></a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card p-2 ">
                            <header class="row">
                                <div class="col-md-5 col-sm-5">
