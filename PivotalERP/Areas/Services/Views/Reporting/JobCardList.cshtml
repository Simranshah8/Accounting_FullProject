    <!--Modal for USer Collection Report Starts-->
    <div class="modal fade sales-invoice-page-modal document-attach-modal" id="CollectionReport" tabindex="-1" role="dialog" aria-labelledby="documentAttachModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">User Collection Report</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <header class="row">
                        <div class="col-md-5 col-sm-5">
                            <div class="clearfix">
                                <form class="form-inline">
                                    <div class="input-group input-group-sm" style="width: 250px;">
                                        <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="searchData.UserColl">

                                        <div class="input-group-append">
                                            <button type="submit" class="btn btn-default">
                                                <i class="fas fa-search"></i>
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <div class="col-md-7 col-sm-7 text-right">
                            <form class="form-inline  float-right">
                                <div class="dropdown dnld-file ml-2">
                                    <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                            type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                            aria-haspopup="true" aria-expanded="false">
                                        <i class="fas fa-download"></i>
                                    </button>
                                    <div class="dropdown-menu dropdown-menu-right"
                                         aria-labelledby="dropdownMenuButton">
                                        <span class="dropdown-item">Choose an option:</span>
                                        <a class="dropdown-item wait" export-excel table-id="'#main-table'" sheet-name="'ClassWiseSubject'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                        <a class="dropdown-item wait" onClick="$('#main-table').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                        <a class="dropdown-item wait" onClick="$('#main-table').tableExport({type:'pdf',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image"> PDF</a>
                                        <a class="dropdown-item wait" onClick="$('#main-table').tableExport({type:'doc',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image"> Word</a>
                                        <a class="dropdown-item wait" onClick="$('#main-table').tableExport({type:'json',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image"> JSON</a>
                                    </div>
                                </div>
                                <a print-tbl table-id="'#main-table'" class="btn btn-secondary btn-light btn-sm ml-2"
                                   title="Print">
                                    <i class="fas fa-print"></i>
                                </a>
                                @*<a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                       data-target="#itemAllocationForModal" title="Filter">
                                        <i class="fas fa-filter"></i>
                                    </a>*@
                            </form>

                        </div>

                    </header>
                    <div class="table-scroll-x-y" style="height:354px!important;">
                        <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                            <thead>
                                <tr>
                                    <th rowspan="2" class="text-center align-middle" style="width: 150px; background-color: #ececec !important">Username</th>
                                    <th colspan="2" scope="colgroup" class="text-center" style="width: 180px; background-color: #ececec !important">Sales</th>
                                    <th colspan="2" scope="colgroup" class="text-center" style="width: 180px; background-color: #ececec !important">Sales Return</th>
                                    <th rowspan="2" class="text-center align-middle" style="width: 95px; background-color: #ececec !important">Cash Deposit</th>
                                    <th rowspan="2" class="text-center align-middle" style="width: 95px; background-color: #ececec !important">Cash Refund</th>
                                    <th rowspan="2" class="text-center align-middle" style="width: 150px; background-color: #ececec !important">Net Sales (Cash)<br />(Sales-Sales Return)</th>
                                    <th rowspan="2" class="text-center align-middle" style="width: 150px; background-color: #ececec !important">Net Cash Collection<br />(Deposit-Refund)</th>
                                    <th rowspan="2" class="text-center align-middle" style="width: 110px; background-color: #ececec !important">Net Cash<br />(Available)</th>
                                </tr>
                                <tr>
                                    <th scope="col" class="text-center" style="top: 30px; background-color: #ececec !important">Cash</th>
                                    <th scope="col" class="text-center" style="top: 30px; background-color: #ececec !important">Credit</th>
                                    <th scope="col" class="text-center" style="top: 30px; background-color: #ececec !important">Cash</th>
                                    <th scope="col" class="text-center" style="top: 30px; background-color: #ececec !important">Credit</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr ng-repeat="uc in UserWiseColl | filter:searchData.UserColl">
                                    <th class="align-middle cstm-sticky">{{uc.User}}</th>
                                    <td style="text-align:right">{{uc.SalesCash |number:2}}</td>
                                    <td style="text-align:right">{{uc.SalesCredit |number:2}}</td>
                                    <td style="text-align:right">{{uc.ReturnCash |number:2}}</td>
                                    <td style="text-align:right">{{uc.ReturnCredit |number:2}}</td>
                                    <td style="text-align:right">{{uc.Receipt |number:2}}</td>
                                    <td style="text-align:right">{{uc.Payment |number:2}}</td>
                                    <td style="text-align:right">{{uc.NetSales |number:2}}</td>
                                    <td style="text-align:right">{{uc.NetCash |number:2}}</td>
                                    <td style="text-align:right">{{uc.NetCashBal |number:2}}</td>
                                </tr>

                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- end modal body -->
                @*<div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Ok</button>
                    </div>*@
            </div>
        </div>
    </div>




