@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll {
        position: relative;
        width: 100%;
        z-index: 1;
        margin: auto;
        overflow: auto;
        height: 300px;
    }

        .table-scroll table {
            width: 100%;
            margin: auto;
            border-collapse: separate;
            border-spacing: 0;
        }

    .table-wrap {
        position: relative;
    }

    .table-scroll th,
    .table-scroll td {
        padding: 5px 10px;
        border: 1px solid #dce0e3;
        background: #fff;
        vertical-align: top;
    }

    .table-scroll thead th {
        background: #ececec;
        position: -webkit-sticky;
        position: sticky;
        top: 0;
    }
    
    .table-scroll tfoot,
    .table-scroll tfoot th,
    .table-scroll tfoot td {
        position: -webkit-sticky;
        position: sticky;
        bottom: 0;
        background: #ececec;
        color: #141515;
        z-index: 4;
    }
    
</style>
<script src="~/jslib/inventory/transaction/SSFClaim.js?v=20220831"></script>
