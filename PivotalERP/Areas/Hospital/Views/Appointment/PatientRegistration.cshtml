
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/Hospitals/Appointment/PatientRegistration.js"></script>
<div id="ActionDiv" ng-app="myApp" ng-controller="PatientRegistration" ng-init="LoadData()">
    <div class="content">
        <div class="container-fluid">
            <div class="card">
                <div class="card-header p-0 border-bottom-0">
                    <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false" ng-click="ClearFields()">Patient Registration</a>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-2">
                    <div class="tab-content" id="custom-tabs-four-tabContent">
                        <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                            <header class="row">
                                <div class="col-md-8">
                                    <div class="clearfix">
                                        <form class="form-inline">
                                            <div class="input-group input-group-sm">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text cstm">Show</span>
                                                </div>
                                                <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.PatientRegistration">
                                                    <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value == perPage.PatientRegistration">{{pp.text}}</option>
                                                </select>
                                                <div class="input-group-append">
                                                    <span class="input-group-text bg-white"><small>entries</small></span>
                                                </div>
                                            </div>
                                            <div class="input-group input-group-sm table-search-filed">
                                                <input class="form-control form-control-navbar" type="search"
                                                       placeholder="Search" aria-label="Search" ng-model="searchData.PatientRegistration">
                                                <div class="input-group-append">
                                                    <button class="btn btn-default border-left-0" type="submit">
                                                        <i class="fas fa-search"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                                <div class="col-md-4 text-right">
                                    <div class="dropdown dnld-file"
                                         data-placement="top" title="Download File">
                                        <a class="btn btn-secondary btn-light btn-sm wait"
                                           title="Refresh" ng-click="GetAllPatientList()">
                                            <i class="fas fa-sync-alt"></i>
                                        </a>
                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                id="dropdownMenuButton" data-toggle="dropdown"
                                                aria-haspopup="true" aria-expanded="false">
                                            <i class="fas fa-download"></i>
                                        </button>
                                        <div class="dropdown-menu dropdown-menu-right"
                                             aria-labelledby="dropdownMenuButton">
                                            <span class="dropdown-item">Choose an option:</span>
                                            <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'PatientRegistration'" report-name="'List of Appointment Type'" ignore-column="'3'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                            <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'PatientRegistration',ignoreColumn:'3' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                        </div>
                                        <a print-tbl report-name="'Appointment Type'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait"
                                           title="Print">
                                            <i class="fas fa-print"></i>
                                        </a>
                                    </div>
                                </div>
                            </header>
                            <div class="mt-2  table-scroll-x-y" style="max-height:calc(100vh - 6rem) !important;">

                                <table id="main-table" class="main-table table mb-2 mt-2 table-bordered table-hover table-sm">
                                    <thead>
                                        <tr>
                                            <th style="width: 60px;" class="text-center">S.No.</th>
                                            <th style="">Reg. No</th>
                                            <th style="width: 250px ;">Name</th>
                                            <th style="width: 150px;">Contact No</th>
                                            <th style="width: 150px ;">Nationality</th>
                                            <th style="width: 150px ;">Blood Group</th>
                                            <th style="width: 150px ;">Address</th>
                                            <th class="text-center">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr dir-paginate="beData in PatientList | filter:searchData.PatientRegistration| itemsPerPage:perPage.PatientRegistration" current-page="currentPages.PatientRegistration" pagination-id="PatientRegistrationPagination">
                                            <td class="text-center">{{$index+1}}</td>
                                            <td>{{beData.PatientRegNo}}</td>
                                            <td>{{beData.FirstName}} {{beData.LastName}}</td>
                                            <td>{{beData.Contact}}</td>
                                            <td>{{beData.Nationality}}</td>
                                            <td>{{beData.BloodGroup}}</td>
                                            <td>{{beData.PatientAddress}}</td>
                                            <td>
                                                <div class="btn-group-sm text-center">
                                                    <a href="#" class="btn btn-info" ng-click="GetPatientById(beData)"><i class="fas fa-pencil-alt"></i></a>
                                                    <a href="#" class="btn btn-danger" ng-click="deletePatient(beData, $index)"><i class="fas fa-trash"></i></a>
                                                </div>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <div class="col-md-12">
                                    <dir-pagination-controls pagination-id="PatientRegistrationPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                    </dir-pagination-controls>
                                </div>

                            </div>
                        </div>
                        <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                            <div>
                                <form>
                                    <div class="row">
                                        <div class=" row col-md-10">
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>First Name</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDet.FirstName">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Last Name</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDet.LastName">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Gender</label>
                                                    <select class="form-control form-control-sm form-select" ng-model="newDet.GenderId">
                                                        <option ng-value="G.id" ng-repeat="G in GenderColl" ng-selected="G.id == newDet.GenderId">{{ G.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>DOB</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.DOB_TMP" date-detail="newDet.DOBDet" />
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Age (yy-mm-dd)</label>
                                                    <div class="d-flex gap-1">
                                                        <input type="number" class="form-control form-control-sm" placeholder="2020" ng-model="newDet.AgeYear">
                                                        <input type="number" class="form-control form-control-sm" placeholder="1" ng-model="newDet.AgeMonth">
                                                        <input type="number" class="form-control form-control-sm" placeholder="1" ng-model="newDet.AgeDay">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Blood Group</label>
                                                    <input type="text" class="form-control-sm form-control">
                                                    <datalist id="lstBloodGroup">
                                                        <option data-ng-repeat="ttl in BloodGroupList" value="{{ttl}}">
                                                    </datalist>
                                                    @*<select class="form-control form-control-sm form-select select2"
                                        ng-model="newDet.BloodGroupId">
                                    <option ng-repeat="bg in BloodGroupList"
                                            ng-value="bg"
                                            ng-selected="bg == newDet.BloodGroup">
                                        {{ bg }}
                                    </option>
                                </select>*@
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Ethnicity</label>
                                                    <select class="form-control form-control-sm form-select select2" ng-model="newDet.EthinicityId">
                                                        <option ng-value="E.EthinicityId" ng-repeat="E in EthinicityList" ng-selected="E.EthinicityId == newDet.EthnicityId">{{ E.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Marital Status</label>
                                                    <select class="form-control form-control-sm form-select" ng-model="newDet.MaritalStatusId">
                                                        <option ng-value="G.id" ng-repeat="G in MaritalStatusColl" ng-selected="G.id == newDet.MaritalStatusId">{{ G.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Spouse Name</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDet.SpouseName">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Occupation</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDet.Occupation">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Nationality</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDet.Nationality">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Contact Number</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDet.Contact">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Email Id</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDet.Email">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>ID Type</label>
                                                    <select class="form-control form-control-sm" ng-model="newDet.DocumentTypeId">
                                                        <option ng-value="D.DocumentTypeId" ng-repeat="D in DocumentTypeList" ng-selected="D.DocumentTypeId == newDet.DocumentTypeId">{{D.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>ID No</label>
                                                    <div class="row">
                                                        <div class="col-md-5 pr-0">
                                                            <div class="form-group">
                                                                <input type="text"
                                                                       class="form-control form-control-sm"
                                                                       ng-model="newDet.IDNo">
                                                            </div>
                                                        </div>

                                                        <div class="col-md-7 pl-0">
                                                            <div class="form-group d-flex align-items-center">
                                                                <input type="file" id="flMoreFiles" accept="image/*"
                                                                       file-model ng-model="attachFile" style="display: none">

                                                                <label for="flMoreFiles"
                                                                       class="btn btn-default btn-sm d-flex align-items-center justify-content-center mb-0"
                                                                       title="Attach document"
                                                                       style="width:25px; height:28px;">
                                                                    <i class="fas fa-paperclip"></i>
                                                                </label>

                                                                <a class="p-1 d-flex align-items-center justify-content-center"
                                                                   href="#"
                                                                   ng-click="ShowPersonalImg(newDet.Document)"
                                                                   data-toggle="tooltip"
                                                                   title="View doc">
                                                                    <i class="fas fa-eye text-secondary" ng-show="attachFile"></i>
                                                                </a>

                                                                <span class="ml-2 text-truncate">
                                                                    {{ newDet.Document.Name || "No File" }}
                                                                </span>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Province</label>
                                                    <select class="form-control form-control-sm form-select select2" style="width: 100%;" ng-model="newDet.ProvinceId">
                                                        <option ng-repeat="cl in ProvinceColl" ng-value="cl.id" ng-selected="cl.id== newDet.ProvinceId">
                                                            {{cl.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> District</label>
                                                    <select class="form-control form-control-sm form-select select2" style="width: 100%;" ng-model="newDet.DistrictId">
                                                        <option ng-repeat="tdc in DistrictColl | filter: { stateId: newDet.ProvinceId }:true" ng-value="tdc.id" ng-selected="tdc.id==newDet.DistrictId">
                                                            {{tdc.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Local Level</label>
                                                    <select class="form-control form-control-sm form-select select2" style="width: 100%;" ng-model="newDet.LocalLevelId">
                                                        <option ng-repeat="tdc in VDCColl| filter: { districtId: newDet.DistrictId }:true" ng-value="tdc.id" ng-selected="tdc.id==newDet.LocalLevelId">
                                                            {{tdc.text}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label>Full Address</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDet.PatientAddress">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-2">
                                            <div class="person-photo-attachment-wrap text-center">
                                                <div class="img-wrap mx-auto">
                                                    <img ng-src="{{newDet.PhotoData || newDet.Photo }}" class="img-fluid" alt="" id="Photo" style="height:130px; width:165px; border:1px solid #ccc">
                                                </div>
                                                <label for="choose-sfile" type="button" class="btn btn-default mt-1 mb-0"><i class="fa fa-image"></i>Upload Image</label>
                                                <input id="choose-sfile" type="file" accept="image/*" style="display: none;" file-model ng-model="newDet.Photo_TMP" fileread="newDet.PhotoData" />
                                                <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                                <footer class="main-footer">
                                    <div class="text-right control-btns">
                                        <button type="button" class="btn btn-default" ng-click="ClearDetails()">Clear</button>
                                        <button type="button" class="btn btn-primary" ng-click="SaveUpdatePatient()">{{newDet.Mode}}</button>
                                    </div>
                                </footer>
                            </div>

                            <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
                                <div class="modal-dialog modal-lg" role="document">
                                    <div class="modal-content">
                                        <div class="modal-body mb-0 p-2">
                                            <iframe class="responsive-iframe" ng-hide="viewImg.FileType === 'image'" id="pdfViewer" style="width: 100%; height: 700px; border: none;"></iframe>
                                            <img ng-show="viewImg.FileType === 'image'" ng-src="{{viewImg.ContentPath}}" alt="" style="width: 100%; height: auto;" id="imgPreviewAdd">
                                        </div>
                                        <div class="modal-footer p-2">
                                            <div><a href="{{viewImg.ContentPath}}" download>Download</a></div>
                                            <button class="btn btn-success btn-rounded btn-sm ml-4 btn-add text-center" data-dismiss="modal" type="button" style="min-width: 70px;">Close</button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.querySelector('.responsive-iframe').onload = function () {
        const iframeDocument = this.contentDocument || this.contentWindow.document;
        const img = iframeDocument.querySelector('img');
        if (img) {
            img.style.width = '100%';
            img.style.height = 'auto';
        }
    };
</script>

