
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script src="~/jslib/Hospitals/Creation/Department.js"></script>
<div id="ActionDiv" ng-app="myApp" ng-controller="Department" ng-init="LoadData()">
    <div class="content">
        <div class="container-fluid p-0">
            <div class="card">
                <div class="card-header p-0 border-bottom-0">
                    <ul class="nav nav-tabs fixed-top" id="custom-tabs-four-tab" role="tablist" style="background-color: #fff !important;">
                        <li class="nav-item">
                            <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false" ng-click="ClearFields()">Department</a>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-2" style="margin-top: 38px !important">
                    <div class="tab-content" id="custom-tabs-four-tabContent">
                        <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">

                            <header class="row">
                                <div class="col-md-8">
                                    <div class="clearfix">
                                        <form class="form-inline">
                                            <div class="input-group input-group-sm">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text cstm">Show</span>
                                                </div>
                                                <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.Department">
                                                    <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.Department">{{pp.text}}</option>
                                                </select>
                                                <div class="input-group-append">
                                                    <span class="input-group-text bg-white"><small>entries</small></span>
                                                </div>
                                            </div>
                                            <div class="input-group input-group-sm table-search-filed ml-2">
                                                <input class="form-control form-control-navbar" type="search"
                                                       placeholder="Search" aria-label="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">
                                                <div class="input-group-append">
                                                    <button class="btn btn-default border-left-0" type="submit">
                                                        <i class="fas fa-search"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                                <div class="col-md-4 text-right">
                                    <div class="dropdown dnld-file">
                                        <a class="btn btn-secondary btn-light btn-sm wait"
                                           title="Refresh" ng-click="GetAllDepartment()">
                                            <i class="fas fa-sync-alt"></i>
                                        </a>
                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                id="dropdownMenuButton" data-toggle="dropdown"
                                                aria-haspopup="true" aria-expanded="false">
                                            <i class="fas fa-download"></i>
                                        </button>
                                        <div class="dropdown-menu dropdown-menu-right"
                                             aria-labelledby="dropdownMenuButton">
                                            <span class="dropdown-item">Choose an option:</span>
                                            <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'Report Template'" report-name="'List Of Lab Technician'" ignore-column="'6'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                            <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'Lab Technician',ignoreColumn:'6' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                        </div>
                                        <a print-tbl report-name="'List Of Lab Technician'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait">
                                            <i class="fas fa-print"></i>
                                        </a>
                                        <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                           data-placement="bottom" title="Save Lab Technician" @*ng-click="saveRptListState()"*@>
                                            <i class="fas fa-save"></i>
                                        </a>
                                    </div>
                                </div>
                            </header>

                            <div class="">
                                <div id="datatable" style="height: calc(100vh - 7rem); width: 100%;" class="ag-theme-alpine"></div>
                            </div>

                        </div>
                        <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab" style="height: calc(100vh - 120px); overflow-y: auto;">
                            <div>
                                <form class="timeline registration">
                                    <div class="time-label">
                                        <span style="border: 2px solid #dee2e6;">Department Detail</span>
                                    </div>
                                    <div class="row ml-5">
                                        <div class="col-3">
                                            <div class="form-group">
                                                <label>Name<span class="text-danger">*</span></label>
                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.Name">
                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <label>Alias</label>
                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.Alias">
                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <label>Room</label>
                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.RoomNo">
                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <label>Description</label>
                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.Description">
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <label> OutPatient Charge </label>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="custom-control custom-checkbox float-right">
                                                            <input class="custom-control-input" type="checkbox" id="checkboxCanOutPatient" ng-model="newDet.CanChangeOPDCharge" value="option1" checked>
                                                            <label for="checkboxCanOutPatient" class="custom-control-label"> Can Editable </label>
                                                        </div>
                                                    </div>
                                                </div>
                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.OutPatientCharge" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" ng-disabled="newDet.CanChangeOPDCharge">
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <label>Cash Deposite </label>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="custom-control custom-checkbox float-right">
                                                            <input class="custom-control-input" type="checkbox" id="checkboxCanCashDeposite" ng-model="newDet.CanChangeDepositeAmount" value="option1" checked>
                                                            <label for="checkboxCanCashDeposite" class="custom-control-label"> Can Editable </label>
                                                        </div>
                                                    </div>
                                                </div>
                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.DepositeAmount" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" ng-disabled="newDet.CanChangeDepositeAmount">
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <label> InPatient Charge </label>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="custom-control custom-checkbox float-right">
                                                            <input class="custom-control-input" type="checkbox" id="checkboxInPatient" ng-model="newDet.CanChageInCharge" value="option1" checked>
                                                            <label for="checkboxInPatient" class="custom-control-label"> Can Editable </label>
                                                        </div>
                                                    </div>
                                                </div>
                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.InPatientCharge" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" ng-disabled="newDet.CanChageInCharge">
                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <label>Ledger</label>
                                                <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="newDet.LedgerId" ledgertype="1"
                                                        placeholder="** Select Ledger **" showdetails="true" confirm-action="PartySelectionChange(newDet)" ledger-detail="newDet.LedgerDetails" side-bar-data="newDet.partySideBarData"></select>

                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <label>Branch</label>
                                                <select class="form-control form-control-sm select2" ng-model="newDet.BranchId">
                                                    <option ng-value="pp.id" ng-repeat="pp in BranchColl" ng-selected="pp.id==newDet.BranchId"> {{pp.text}} </option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <label>Cost Center</label>
                                                <select class="form-control form-control-sm select2" ng-model="pDet.CostCenterId">
                                                    <option ng-value="pp.id" ng-repeat="pp in CostCenterColl" ng-selected="pp.id==pDet.CostCenterId"> {{pp.text}} </option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <div class="form-group  clearfix">
                                                    <label for="" class="invisible d-block">Effect On Account</label>
                                                    <div class="custom-control custom-checkbox">
                                                        <input class="custom-control-input" type="checkbox" id="checkboxEffectonAcc" ng-model="newDet.ActiveAccount">
                                                        <label for="checkboxEffectonAcc" class="custom-control-label"> Effect On Account </label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3 mt-4">
                                            <div class="form-group">
                                                <div class="form-group custom-checkbox clearfix d-flex">
                                                    <div class="custom-control custom-checkbox mx-2">
                                                        <input class="custom-control-input" type="checkbox" id="checkboxPrimary2" ng-model="newDet.IsActive">
                                                        <label for="checkboxPrimary2" class="custom-control-label">Is Active</label>
                                                    </div>
                                                    <div class="custom-control custom-checkbox mx-2">
                                                        <input class="custom-control-input" type="checkbox" id="checkboxAllowDiscount" ng-model="newDet.ApplyTax">
                                                        <label for="checkboxAllowDiscount" class="custom-control-label"> Apply Tax </label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-3">
                                            <div class="form-group">
                                                <div class="form-group clearfix">
                                                    <label for="" class="invisible d-block">Included Tax</label>
                                                    <div class="custom-control custom-checkbox">
                                                        <input class="custom-control-input" type="checkbox" id="checkboxIncludedTax" ng-model="newDet.IncludeTax">
                                                        <label for="checkboxIncludedTax" class="custom-control-label">Included Tax</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <div class="form-group clearfix">
                                                    <label for="" class="invisible d-block">Is Appointment Applicable</label>
                                                    <div class="custom-control custom-checkbox">
                                                        <input class="custom-control-input" type="checkbox" id="checkboxIsAppointmentApplicable" ng-model="newDet.IsAppointmentApplicable">
                                                        <label for="checkboxIsAppointmentApplicable" class="custom-control-label">Is Appointment Applicable ?</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="time-label">
                                        <span style="border: 2px solid #dee2e6;">Department Wise Charge Setup</span>
                                    </div>
                                  
                                    <div class="row ml-5">
                                        <div class="table-responsive">
                                            <table id="main-table" class="table table-sm table-bordered bg-white" style="table-layout: auto; width:100%;">
                                                <thead class="thead-light">
                                                    <tr>
                                                        <th class="text-center" style="width: 40px">S.No</th>
                                                        <th class="text-center" style="width: 110px">OPD Ticket Type</th>
                                                        <th class="text-center" style="width: 80px">Out Patient Charge</th>
                                                        <th class="text-center" style="width: 80px">In Patient Charge</th>
                                                        <th class="text-center" style="width: 70px">Deposite Amount</th>
                                                        <th class="text-center" style="width: 70px">Valid Days</th>
                                                        <th class="text-center" style="width: 80px">ReOut Patient Charge</th>
                                                        <th class="text-center" style="width: 40px">Action  </th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr ng-repeat="pDet in newDet.DepartmentDetailsColl">
                                                        <td class="text-center">{{$index+1}}</td>
                                                        <td>
                                                            <select class="form-control form-control-sm" active-select2 ng-model="pDet.OPDTicketTypeId">
                                                                <option ng-value="pp.id" ng-repeat="pp in OpDTicketTypeColl" ng-selected="pp.id==pDet.OPDTicketTypeId"> {{pp.text}} </option>
                                                            </select>
                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control form-control-sm" ng-model="pDet.OutPatientCharge" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();">
                                                        </td>


                                                        <td>
                                                            <input type="text" class="form-control form-control-sm" ng-model="pDet.InPatientCharge" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();">

                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control form-control-sm" ng-model="pDet.DepositeAmount" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();">

                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control form-control-sm" ng-model="pDet.ValidDays" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();">

                                                        </td>

                                                        <td>
                                                            <input type="text" class="form-control form-control-sm" ng-model="pDet.ReOutPatientCharge" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();">

                                                            @*<input class="form-control form-control-sm" ng-model="pDet.ReOutPatientCharge" type="text">*@
                                                        </td>


                                                        <td class="text-center gap-2 align-middle">
                                                            <a ng-click="AddPHDDetails($index)" class="mr-2"><i class="fas fa-plus"></i></a>
                                                            <a ng-click="delPHDDetails($index)"><i class="fas fa-trash-alt text-danger"></i></a>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                   
                                    <div class="time-label">
                                        <span style="border: 2px solid #dee2e6;">Doctor Wise</span>
                                    </div>
                                    <div class="row ml-5">
                                        <div class="table-responsive" >
                                            <table id="main-table" class="table table-sm table-bordered bg-white" style="table-layout: auto; width:100%;">
                                                <thead class="thead-light">
                                                    <tr>
                                                        <th class="text-center" style="width: 40px">S.No</th>
                                                        <th class="text-center" style="width: 100px">Doctor</th>
                                                        <th class="text-center" style="width: 110px">OPD Ticket Type</th>
                                                        <th class="text-center" style="width: 80px">Out Patient Charge</th>
                                                        <th class="text-center" style="width: 80px">In Patient Charge</th>
                                                        <th class="text-center" style="width: 70px">Deposite Amount</th>
                                                        <th class="text-center" style="width: 70px">Valid Days</th>
                                                        <th class="text-center" style="width: 80px">ReOut Patient Charge</th>
                                                        <th class="text-center" style="width: 40px">Action  </th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr ng-repeat="D in newDet.DepartmentDoctorRateColl">
                                                        <td class="text-center">{{$index+1}}</td>
                                                        <td>

                                                            <select class="form-control form-control-sm" active-select2 ng-model="D.DoctorId">
                                                                <option ng-value="pp.DoctorId" ng-repeat="pp in DoctorColl" ng-selected="pp.DoctorId==pDet.DoctorId"> {{pp.FullName}} </option>
                                                            </select>
                                                        </td>
                                                        <td>
                                                            <select class="form-control form-control-sm" active-select2 ng-model="D.OPDTicketTypeId">
                                                                <option ng-value="O.OpDTicketTypeId" ng-repeat="O in OpDTicketTypeColl" ng-selected="O.OpDTicketTypeId==D.OPDTicketTypeId"> {{O.Name}} </option>
                                                            </select>
                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control form-control-sm" ng-model="D.OutPatientCharge" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();">
                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control form-control-sm" ng-model="D.InPatientCharge" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();">
                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control form-control-sm" ng-model="D.DepositeAmount" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();">
                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control form-control-sm" ng-model="D.ValidDays" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();">

                                                        </td>

                                                        <td>
                                                            <input type="text" class="form-control form-control-sm" ng-model="D.ReOutPatientCharge" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();">
                                                        </td>


                                                        <td class="text-center gap-2 align-middle">
                                                            <a ng-click="AddPHDDoctorWise($index)" class="mr-2"><i class="fas fa-plus"></i></a>
                                                            <a ng-click="delPHDDoctorWise($index)"><i class="fas fa-trash-alt text-danger"></i></a>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>

                                        </div>
                                       
                                            <div class="col-md-9">
                                                <div class="row">
                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>
                                                                Doctor
                                                                <span style="color:red;"></span>
                                                            </label>
                                                            <input class="form-control form-control-sm" style="margin-left:1px;" type="text" ng-model="newDet.LabDoctor">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>Designation</label>
                                                            <input class="form-control form-control-sm" style="margin-left:1px;" type="text" ng-model="newDet.DoctorDesignation">
                                                        </div>
                                                    </div>

                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>Lic No.</label>
                                                            <input class="form-control form-control-sm" style="margin-left:1px;" type="text" ng-model="newDet.DoctorLicNo">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>Notes</label>
                                                            <input class="form-control form-control-sm" style="margin-left:1px;" type="text" ng-model="newDet.DoctorNotes">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3" @*style="margin-bottom:55px;"*@>
                                                <div class="person-photo-attachment-wrap text-center">
                                                    <label for="" class="invisible">Photo</label>
                                                    <div class="img-wrap mx-auto">
                                                        <img ng-src="{{newDet.DoctorSignData || newDet.DoctorSign }}" class="img-fluid" alt="" id="Photo" style="height:60px; width:165px; border:1px solid #ccc">
                                                    </div>
                                                    <label for="choose-Photo" type="button" class="btn btn-default mt-1 mb-0"><i class="fa fa-image"></i>&nbsp;Signature</label>
                                                    <input id="choose-Photo" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newDet.DoctorSign_Tmp" fileread="newDet.DoctorSignData" />
                                                    <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                </div>

                                            </div>
                                            </div>
                                </form>
                                <footer class="main-footer">
                                    <div class="text-right control-btns">
                                        <button type="button" class="btn btn-default btn" ng-click="ClearFields()"> <span class="glyphicon glyphicon-remove"></span>Clear</button>
                                        <button type="button" class="btn btn-primary btn" ng-click="SaveUpdateDepartment()" ng-disabled="loadingstatus=='running'"><span class="glyphicon glyphicon-save"></span>Save</button>
                                    </div>
                                </footer>
                            </div>
                        </div>

                    </div>
                    <!-- /.container-fluid -->
                </div>
            </div>
        </div>
    </div>

</div>