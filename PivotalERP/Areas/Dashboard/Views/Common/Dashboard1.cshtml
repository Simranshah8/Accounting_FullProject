        color: #1f5d9e
    }
    /* Dropdown css */
    .boxss {
        width: 150px;
        height: 30px;
        border: 1px solid rgb(241, 227, 227);
        font-size: 15px;
        color: #111;
        background-color: #fff;
        border-radius: 5px;
        box-shadow: 4px 4px #ccc;
    }

    /* percentage piechart */
    :root {
        --size: 200px;
        --bord: 20px;
    }

    .chart {
        width: var(--size);
        height: var(--size);
        margin: 7em auto;
        border-radius: 50%;
        background-image: conic-gradient(#74b64d var(--value), lightgrey var(--value));
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
    }

        .chart::after {
            content: "";
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
            width: calc(100% - var(--bord));
            height: calc(100% - var(--bord));
            background: white;
            border-radius: inherit;
        }

        .chart p {
            position: relative;
            z-index: 1;
            text-align: center;
            font-size: 20px;
        }

    .x-60 {
        --value: 60%;
    }

    /* *****************************Custom Card***************************** */
    .body1 {
        height: 10px;
        margin-bottom: -10px;
    }

    .body2::-webkit-scrollbar {
        width: 8px;
    }

    /* Track */
    .body2::-webkit-scrollbar-track {
        /* -webkit-box-shadow: inset 0 0 6px rgba(252, 247, 247, 0.3);  */
        -webkit-border-radius: 10px;
        border-radius: 10px;
    }

    /* Handle */
    .body2::-webkit-scrollbar-thumb {
        -webkit-border-radius: 10px;
        border-radius: 10px;
        background: rgb(192, 192, 192);
        /* -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.5);  */
    }

        .body2::-webkit-scrollbar-thumb:window-inactive {
            background: #fff;
        }

    .body2 {
        margin-top: -25px;
        height: 250px;
        background-color: #fff;
    }

    .body3 {
        margin: 10px;
        text-align: center;
    }

    .body2 .name1 {
        display: flex;
        margin-top: 10px;
    }

        .body2 .name1 img {
            margin-right: 10px;
        }



    /* Apexchart css */
    .apexcharts-toolbar {
        display: none !important;
    }

    .apexcharts-yaxis-texts-g {
        display: none !important;
    }

    .apexcharts-xaxis-texts-g {
        display: none !important;
    }

    .apexcharts-gridlines-horizontal {
        display: none !important;
    }

    #SvgjsLine1663 {
        display: none !important;
    }

    /* Chart title */
    .highcharts-title {
        display: none !important;
    }
</style>

