
@{
    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .btn-outline-primary {
        color: rgb(18 125 194);
        border-color: rgb(18 125 194);
    }

        .btn-outline-primary:hover {
            color: rgb(255, 255, 255);
            background-color: rgb(18 125 194);
            border-color: rgb(18 125 194);
        }

    iframe img {
        max-width: 100%; /* Make the image scale down if its natural size is larger than the container */
        height: auto; /* Maintain the image's aspect ratio */
        display: block; /* Remove extra space below the image */
        margin: 0 auto; /* Center the image horizontally */
    }
    table th, table td {
        padding: 0.3rem !important
    }
</style>

<script src="~/jslib/Task/GenerateTask.js?v=2"></script>
<div ng-app="myApp" ng-controller="AssignTaskController" ng-init="LoadData()">
    <div class="container-fluid">
        <div class="page-content-wrapper">
            <div class="">
                <div class="card">
                    <div class="card-header" style="padding: 7px 10px;">
                        <h5 class="card-title mb-0 text-primary"><b>Assign Task</b></h5>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body  p-2">
                        <div class="row">
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>Task Type</label>
                                    <select class="form-control form-select form-control-sm select2" ng-model="newDet.TaskTypeId" style="width: 100%;">
                                        <option ng-repeat="c in TaskTypeList" ng-value="c.TaskTypeId" ng-selected="newDet.TaskTypeId==c.TaskTypeId">{{c.Name}}</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-3" @*ng-hide="newDet.TaskTypeId==9"*@>
                                <div class="form-group">
                                    <label>Assign To</label>

                                    <select class="form-control form-select form-control-sm select2" ng-model="newDet.AssignTo" style="width: 100%;" data-placeholder="**select Employee**" ng-change="GetAllGenerateTicketList()">
                                        <option ng-repeat="E in EmployeeProfileList" ng-value="E.EmployeeId" ng-selected="newDet.AssignTo==E.EmployeeId">{{E.Name}} - {{E.EmployeeCode}}</option>
                                    </select>
                                    @*<select class="form-control form-select form-control-sm select2" ng-model="newDet.AssignTo" style="width: 100%;" data-placeholder="**select Employee**" ng-change="GetAllGenerateTicketList()">
            <option ng-repeat="E in EmployeeProfileList" ng-value="E.EmployeeProfileId" ng-selected="newDet.AssignTo==E.EmployeeProfileId">{{E.Name}}</option>
        </select>*@
                                </div>
                            </div>

                            @*<div class="col-md-2" ng-show="newDet.TaskTypeId>1">
                                <div class="form-group">
                                    <label>Product</label>
                                    <select class="form-control form-select form-control-sm" ng-model="newDet.ProductNameId" style="width: 100%;">
                                        <option value="0">**select product**</option>
                                        <option ng-repeat="c in ProductNameList" ng-value="c.ProductNameId">{{c.Name}}</option>
                                    </select>
                                </div>
                            </div>*@
                            @*<div class="col-md-6" ng-show="newDet.TaskTypeId == 2 || newDet.TaskTypeId == 3 || newDet.TaskTypeId == 4">
                                <div class="form-group">
                                    <label style="min-width: 120px;">Select Customer</label>
                                    <select class="form-control select2 form-control-sm" style="width:100%" ng-model="newDet.CustomerId" ng-change="ChangeCustomer(newDet)">
                                        <option value="0">**select customer**</option>
                                        <option ng-repeat="C in CustomerList" ng-value="C.CustomerId" ng-selected="newDet.CustomerId==C.CustomerId">{{C.CompanyName}}-{{C.Address}}-{{C.Product}}-{{C.Package}}-{{C.CompanyCode}}</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-2" ng-show="newDet.TaskTypeId == 2 || newDet.TaskTypeId == 3 || newDet.TaskTypeId == 4">
                                <div class="form-group">
                                    <label style="min-width: 120px;">Code</label>
                                    <input type="text" placeholder="" ng-model="newDet.CompanyCode" class="form-control form-control-sm" readonly>
                                </div>
                            </div>*@
                            <div class="col-md-2" @*ng-hide="newDet.TaskTypeId==9"*@>
                                <div class="form-group">
                                    <label>Estimate Time(minutes)</label>
                                    <input type="number" placeholder="" ng-model="newDet.EstMinutes" class="form-control form-control-sm">
                                </div>
                            </div>
                            <div class="col-md-2" @*ng-hide="newDet.TaskTypeId==9"*@>
                                <div class="form-group">
                                    <label>Estimate Date</label>
                                    <input type="text" placeholder="" date-picker ng-model="newDet.Deadline_TMP" date-detail="newDet.DeadlineDet" class="form-control form-control-sm">
                                </div>
                            </div>
                        </div>

                        <div class="row">


                            <div class="col-md-2" @*ng-hide="newDet.TaskTypeId==9"*@>

                                <div class="form-group">
                                    <label>Priority</label>
                                    <select class="form-control form-select form-control-sm" ng-model="newDet.Priority" style="width: 100%;">
                                        <option ng-repeat="c in PriorityCol" ng-value="c.id" ng-selected="newDet.Priority==c.id">{{c.text}}</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-10">
                                <div class="form-group mb-2">
                                    <label>Heading</label>
                                    <input type="text" placeholder="" ng-model="newDet.Heading" class="form-control form-control-sm" required maxlength="50">
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="form-group mb-2">
                                    <label>Description</label>
                                    <textarea class="textarea form-control form-control-sm" placeholder="Place some text here"
                                              style="width: 100%; height: 200px; font-size: 14px; line-height: 18px; border: 1px solid #dddddd; padding: 10px;" ng-model="newDet.Description" html-editor></textarea>

                                </div>
                            </div>
                        </div>
                            <!-- attach file  -->
                            <div class="pl-2">
                                <div class="row">
                                    <div class="col-md-5">
                                        <div class="form-group">
                                            <label>Attach Document</label>
                                            <div class="form-group">
                                                <input id="choose-sfile" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" file-model ng-model="newDet.Photo_TMP" fileread="newDet.PhotoData" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                            <!-- attach file end -->
                       
                        <div class="row">
                            <div class="col-md-12 pb-2 d-flex justify-content-end ">
                                @*<div>
                                <button type="button" class="btn btn-outline-primary btn-sm "> View Generate Ticket</button>
                            </div>*@
                                <div>
                                    <button type="button" class="btn load btn-default" ng-click="ClearTask()" style="min-width: 80px;"><i class="fas fa-remove mr-2"></i>Clear</button>
                                    <button type="button" class="btn load btn-primary" ng-click="SaveUpdateAssignTask()" style="min-width: 80px;">Save</button>
                                </div>

                            </div>
                        </div>
                        <div>
                            <div class="table-scroll-x-y table-scroll">
                                <table  class="main-table table table-sm table-bordered bg-white">
                                    <thead>
                                        <tr>
                                            <th style="width: 120px">Action</th>
                                            <th style="width: 55px">S.No.</th>
                                            <th style="width: 82px">Task No.</th>
                                            <th style="width: 90px">Date</th>
                                            <th style="width: 150px">Task For</th>
                                            @*<th style="width: 150px">Product</th>*@
                                            <th style="width: 190px">Heading</th>
                                            <th style="width: 80px">Priority</th>
                                            <th style="width: 170px">Assigned To</th>
                                            <th style="width: 200px">Status</th>
                                            <th style="width: 160px">Comment</th>
                                            <th style="width: 160px">Estimated Time</th>
                                            <th style="width: 160px">Time Taken</th>
                                            <th style="width: 120px">Create By</th>
                                            <th style="width: 120px">Status Time</th>
                                            <th style="width: 120px">Pending Time</th>
                                            @*<th style="width: 210px">Customer Name</th>*@
                                            <th style="width: 120px">Approved By</th>
                                            <th style="width: 220px">Approved Remarks</th>
                                            <th style="width: 120px">Approved At</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr ng-repeat="V in ViewGenrateList | filter:searchData.ViewGenerate">
                                            <td>
                                                <a class="p-1" ng-click="openStatusModal(V)" data-toggle="tooltip" title="Add Status" ng-hide="V.TicketStatus=='Closed'">
                                                    <i class="fas fa-ban text-info"></i>
                                                </a>
                                                <a class="p-1" ng-click="GetTicketCommentById(V)" data-toggle="tooltip" title="Add Comment" ng-hide="V.TicketStatus=='Closed'">
                                                    <i class="far fa-comment text-info"></i>
                                                </a>
                                                <a class="p-1" ng-click="openAssignModal(V)" data-toggle="tooltip" title="AssignTo" ng-hide="V.TicketStatus=='Closed'">
                                                    <i class="fas fa-user-plus text-info"></i>
                                                </a>
                                                <a class="p-1" ng-click="GetTicketHisById(V)" data-toggle="tooltip" title="Hisotry">
                                                    <i class="fas fa-history text-info"></i>
                                                </a>
                                                <a class="p-1" ng-click="openFeedbackModal(V)" data-toggle="tooltip" title="Task Verify" ng-hide="V.TicketStatus=='Closed'">
                                                    <i class="fas fa-user-tag text-info"></i>
                                                </a>
                                                <!--Icon added by suresh for attachment on 15-12-2023-->
                                                <a class="p-1" ng-click="GetAllTicketAttachment(V)" data-toggle="tooltip" title="Task Attachment">
                                                    <i class="fas fa-paperclip text-info"></i>
                                                </a>
                                            </td>
                                            <td class="text-center">{{$index+1}}</td>
                                            <td>{{V.TranId}}</td>
                                            <td>{{V.LogMiti}} {{ V.LogDateTime |timeFormat}}</td>


                                            <td>{{V.TaskType}}</td>
                                            @*<td>{{V.ProductName}}</td>*@
                                            <td>{{V.Heading}}</td>
                                            <td>{{V.PriorityAs}}</td>
                                            <td>{{V.AssignTo}}</td>
                                            <td>{{V.TaskStatus}} <br /> {{V.StatusRemarks}}</td>
                                            <td>{{V.LastComment}}</td>
                                            <td>{{V.EstimatedTime}}</td>
                                            <td>{{V.TotalTimeTaken}}</td>
                                            <td>{{V.UserName}}</td>
                                            <td>{{V.StatusHDiff}}</td>
                                            <td>{{V.PendingHDiff}}</td>
                                            @*<td>
                                                {{V.CustomerName}} - ({{V.CustomerCode}})<br />
                                                - {{V.ProductName}}
                                            </td>*@

                                            <td>{{V.ApprovedBy}}</td>
                                            <td>{{V.ApprovedRemarks}}</td>
                                            <td>{{V.ApprovedMiti}} {{V.ApprovedAt |timeFormat}}</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <!-- /.card-body -->
                </div>
            </div>
            @*AddContactPerson modal here start*@
            <div class="modal fade" id="AddCustomerContact" style="margin-top:130px;">
                <div class="modal-dialog modal-xl">
                    <div class="modal-content">
                        <div class="modal-header p-2">
                            <h5 class="modal-title" id="exampleModalLongTitle">Contact Details</h5>
                            <button type="button" class="close" data-bs-dismiss="modal" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">×</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Contact Name</label>
                                        <input type="text" class="form-control form-control-sm" ng-model="newContact.Name">
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Designation</label>
                                        <select class="form-control select2 form-control-sm" style="width:100%" ng-model="newContact.DesignationId">
                                            <option ng-repeat="D in DesignationList" ng-value="D.DesignationId" ng-selected="newContact.DesignationId==D.DesignationId">{{D.Name}}</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Email</label>
                                        <input type="email" class="form-control form-control-sm" ng-model="newContact.EmailId">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group">
                                        <label>Mobile No</label>
                                        <input type="text" class="form-control form-control-sm" ng-model="newContact.MobileNo">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group">
                                        <label>Whatsapp No</label>
                                        <input type="text" class="form-control form-control-sm" ng-model="newContact.WhatsappNo">
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label>Remarks</label>
                                        <input type="text" class="form-control form-control-sm" ng-model="newContact.Remarks">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer p-2">
                            <button type="button" class="btn load btn-default" style="min-width: 90px;" ng-click="ClearContactDetail()">Reset</button>
                            <button type="button" class="btn load btn-success" style="min-width: 75px;" ng-click="SaveUpdateContactPerson()">Save</button>
                            <button type="button" class="btn load btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
