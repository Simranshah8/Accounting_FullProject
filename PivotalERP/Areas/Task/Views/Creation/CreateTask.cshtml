            @*Ticket Close Feedback modal start*@
            <div class="modal fade" id="TicketCloseFeedback">
                <div class="modal-dialog modal-xl">
                    <div class="modal-content">
                        <div class="modal-header p-2">
                            <h5 class="modal-title">Task Followup for :- <b>{{newFeedback.AssignTo}} ({{newFeedback.Heading}})</b></h5>
                            <button type="button" class="close" data-bs-dismiss="modal" data-dismiss="modal"  aria-label="Close">
                                <span aria-hidden="true">×</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="form-group d-flex">
                                        <label class="mr-4">Call Status :</label>
                                        <div class="form-group clearfix mb-0 pb-0">
                                            <div class="form-check form-check-inline">
                                                <input class="form-check mt-1 mr-2" type="radio" id="callstatusyes" ng-model="newFeedback.CallStatus" name="CallStatus" ng-value="true">
                                                <label class="form-check-label" for="callstatusyes">Connected</label><br>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check mt-1 mr-2" type="radio" id="callstatusno" ng-model="newFeedback.CallStatus" name="CallStatus" ng-value="false">
                                                <label class="form-check-label" for="callstatusno">Failed</label><br>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row" ng-show="newFeedback.CallStatus=='true' || newFeedback.CallStatus==true">
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Work Status</label>
                                            <select class="form-control form-control-sm form-select" ng-model="newFeedback.WorkStatusId">
                                                <option ng-repeat="W in WorkStatusColl" ng-value="W.id" ng-selected="newFeedback.WorkStatusId==W.id">{{W.text}}</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-3" ng-show="newFeedback.WorkStatusId==2">
                                        <div class="custom-control custom-checkbox mt-4">
                                            <input class="custom-control-input" type="checkbox"
                                                   id="reopen" value="option1" ng-model="newFeedback.ReopenTicket">
                                            <label for="reopen"
                                                   class="custom-control-label">
                                                Re-Open Ticket
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-3" ng-show="newFeedback.WorkStatusId==1">
                                        <div class="form-group">
                                            <label>Rating(Out of 10)</label>
                                            <input type="number" class="form-control form-control-sm" ng-model="newFeedback.Rating" />
                                        </div>
                                    </div>

                                </div>
                                <div class="row">
                                    <div class="col-md-12" ng-show="newFeedback.WorkStatusId==2||newFeedback.CallStatus=='false' || newFeedback.CallStatus==false">
                                        <div class="form-group">
                                            <label>Comment</label>
                                            <textarea class="form-control form-control-sm" rows="1" ng-model="newFeedback.Comment"></textarea>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <div class="modal-footer p-2">
                            <button type="button" class="btn load btn-success" style="min-width: 75px;" ng-click="SaveTicketCloseFeedback()">Save</button>
                        </div>
                    </div>
                </div>
            </div>
