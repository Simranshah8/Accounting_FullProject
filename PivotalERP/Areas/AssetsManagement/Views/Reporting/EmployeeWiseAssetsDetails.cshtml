@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<link href="~/wwwroot/dynamic-erp/css/newCss.css" rel="stylesheet" />
<script src="~/jslib/AssetsManagement/Reporting/EmployeeWiseAssetsDetails.js"></script>
<div id="ActionDiv" class="hold-transition layout-navbar-fixed" ng-app="myApp" ng-controller="EmployeeWiseAssetsDetController" ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="tab-content">
                    <div class="root">
                        <div class="card-primary card-tabs ">
                            <div class="tab-content" id="myTabContent">
                                <div class="card p-2 ">
                                    <header class="row">
                                        <div class="col-md-1">
                                            <div class="form-group">
                                                <select class="form-control form-control-sm" ng-model="newFilter.SearchType">
                                                    <option class="dropdown-item" ng-repeat="Ep in EmpSearchOptions" ng-value="Ep.id" ng-selected="newFilter.SearchType==Ep.id">
                                                        {{Ep.text}}
                                                    </option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-3" ng-show="newFilter.SearchType==2">
                                            <div class="form-group d-flex">
                                                <select class="form-control form-control-sm Dplaceholder" ng-model="newFilter.DepartmentId" ng-change="GetHodListDepartmentWise()" style="width:100%">
                                                    <option ng-value="T.CostCenterDepartmentId" ng-repeat="T in DepartmentList" ng-selected="T.CostCenterDepartmentId==newFilter.DepartmentId">{{T.Name}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-3" ng-show="newFilter.SearchType==2">
                                            <div class="form-group d-flex">
                                                <label class="mr-2">Name</label>
                                                <select class="form-control form-control-sm select2 HODplaceholder" ng-model="newFilter.UserId" style="width:100%" ng-change="GetData()">
                                                    <option ng-value="R.UserId" ng-repeat="R in HODList" ng-selected="R.UserId==newFilter.UserId">{{R.text}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-6" ng-show="newFilter.SearchType==1">
                                            <div class="form-group d-flex">
                                                <select class="input-group-text dropdown-toggle p-0" style="outline: none; border-top-right-radius: unset;border-bottom-right-radius: unset;margin-right: -3px;z-index: 1; font-size: 13px;" ng-model="newFilter.SelectEmployee"  >
                                                    <option ng-repeat="ss in EmployeeSearchOptions" ng-value="ss.value" ng-selected="ss.value==newFilter.SelectEmployee">
                                                        {{ss.text}}
                                                    </option>
                                                </select>
                                                <select class="form-control select2 form-control-sm" all-employee ng-model="newFilter.UserId" employee-detail="newFilter.EmployeeDetails" side-bar-data="newFilter.EmpSideBarData" ng-show="newFilter.SearchType == 1" search-by="newFilter.SelectEmployee" style="width: 100%;" confirm-action="GetData()">
                                                </select>
                                            </div>
                                        </div>



                                        <div class="col-sm-3 col-md-3 col-lg-3 text-right">
                                            <div class="clearfix">
                                                <form class="form-inline">
                                                    <div class="input-group input-group-sm table-search-filed" style="width:270px;">
                                                        <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">
                                                        <div class="input-group-append">
                                                            <button class="btn btn-default border-left-0" type="submit">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="col-md-1">
                                            <button type="button" class="btn btn-primary load float-right btn-sm" style="min-width: 90px;" ng-click="GetData()"><i class="fas fa-download"> &nbsp;&nbsp;</i>Load</button>
                                        </div>
                                        <div class="col-sm-1 col-md-1 col-lg-1 text-right">
                                            <div class="dropdown dnld-file" data-placement="top" title="Download File">
                                                <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                        id="dropdownMenuButton" data-toggle="dropdown"
                                                        aria-haspopup="true" aria-expanded="false">
                                                    <i class="fas fa-download"></i>
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                                    <span class="dropdown-item">Choose an option:</span>
                                                    <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                        <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                             class="img-fluid exports-icon" alt="Excel image">
                                                        Excel
                                                    </a>
                                                    <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                        <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                             class="img-fluid exports-icon">
                                                        CSV
                                                    </a>
                                                </div>
                                                <a print-tbl report-name="'List of Issue Status'" table-id="'#TableData'" class="btn btn-secondary btn-light btn-sm wait" title="Print"> <i class="fas fa-print"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </header>
                                    <div class="">
                                        <div id="TableData" style="height: calc(100vh - 4rem); width: 100%;" class="ag-theme-alpine"></div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </section>
</div>