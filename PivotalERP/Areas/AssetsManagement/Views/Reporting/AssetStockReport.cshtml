@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script src="~/jslib/AssetsManagement/Reporting/AssetStockReport.js"></script>
<link href="~/wwwroot/dynamic-erp/css/newCss.css" rel="stylesheet" />
<div ng-app="myApp" ng-controller="AssetStockReportController" ng-init="LoadData()">

    <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
        <div class="overflow-hidden">
            <!-- Main content -->
            <nav id="sidebarzz" class="order-last float-right active active">
                <div class="custom-menu">
                    <button type="button" id="ctmRightSidebarCollapse" class="btn btn-primary"></button>
                </div>
                <div class="" id="firstpanel">
                    <div class="right-box-wrap">
                        <ul class="list-group list-group-flush">
                            @*<li>
                                    <div class="form-group">
                                        <a class="btn py-0 btn-default" style="border-top-left-radius: 0px; border-bottom-left-radius: 0px; margin-left: -2px;" ng-click="">
                                            Select Asset Group
                                        </a>
                                    </div>
                                </li>*@
                            <li class="list-group-item">
                                <div class="form-group">
                                    <div class="icheck-primary d-inline ml-3">
                                        <input type="checkbox" id="radioisactiveNo1" ng-model="newFilter.ShowDetails">
                                        <label for="radioisactiveNo1">
                                            SHOW DETAILS
                                        </label>
                                    </div>
                                </div>
                            </li>
                        </ul>
                        <div class="d-xl-block" style="height: 200px;"></div>
                    </div>
                </div>
            </nav>
            <div class="content-wrapper-new">
                <section class="">
                    <div class="container-fluid">
                        <section class="iframe-content-starts-here">
                            <div class="tab-content">
                                <div id="day-book-section">
                                    <div class="card p-2">
                                        <div class="row">
                                            <div class="col-md-3">
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">From:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" date-picker ng-model="newFilter.DateFrom_TMP" style="max-width:100px" date-detail="newFilter.DateFromDet" />
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">To:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" date-picker ng-model="newFilter.DateTo_TMP" style="max-width:100px" date-detail="newFilter.DateToDet" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-0">
                                                    <label style="width:70px;" class="mt-1">Group</label>
                                                    <select class="form-control form-control-sm select2 ml-2 Gplaceholder" style="width: 90%;" ng-model="newFilter.AssetGroupId" ng-change="GetData()">
                                                        <option ng-value="i.AssetGroupId" ng-repeat="i in GroupList" ng-selected="newFilter.AssetGroupId == i.AssetGroupId">{{i.GroupName}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex mb-0">
                                                    <label style="width:70px;" class="mt-1">Branch</label>
                                                    <select class="form-control form-control-sm select2 Bplaceholder" ng-model="newFilter.BranchId">
                                                        <option ng-value="pl.id" ng-repeat="pl in BranchList" ng-selected="pl.id==newFilter.BranchId">{{pl.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-1"></div>
                                            <div class=" col-md-1 ml-auto text-right">
                                                <button type="button" class="btn btn-primary load float-right btn-sm" style="min-width: 90px;" ng-click="GetData()"><i class="fas fa-download"> &nbsp;&nbsp;</i>Load</button>
                                            </div>
                                        </div>

                                    </div>
                                    <div class="card p-2 ">
                                        <header class="row">
                                            <div class="col-md-8 col-sm-5">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm" style="width: 150px;">
                                                            <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">
                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-default">
                                                                    <i class="fas fa-search"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>

                                            <div class="col-md-4 text-right">
                                                <div class="dropdown dnld-file">
                                                    <a class="btn btn-secondary btn-light btn-sm wait"
                                                       title="Refresh" ng-click="GetData()">
                                                        <i class="fas fa-sync-alt"></i>
                                                    </a>
                                                    <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                            id="dropdownMenuButton" data-toggle="dropdown"
                                                            aria-haspopup="true" aria-expanded="false" title="Download">
                                                        <i class="fas fa-download"></i>
                                                    </button>
                                                    <div class="dropdown-menu dropdown-menu-right"
                                                         aria-labelledby="dropdownMenuButton">
                                                        <span class="dropdown-item">Choose an option:</span>
                                                        <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'Report Template'" report-name="'List of Asset Stock Report'" ignore-column="'6'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'AssetStockReport',ignoreColumn:'6' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                                    </div>
                                                    <a print-tbl report-name="'List of Asset Stock Report '" table-id="'#datatable'" title="Print" class="btn btn-secondary btn-light btn-sm wait">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       data-placement="bottom" title="Save Asset Stock Report" @*ng-click="saveRptListState()"*@>
                                                        <i class="fas fa-save"></i>
                                                    </a>
                                                </div>
                                            </div>

                                        </header>
                                        <div class="">
                                            <div id="TableData" style="height: calc(100vh - 7rem); width: 100%;" class="ag-theme-alpine" ></div>
                                        </div>

                                    </div>

                                </div>

                            </div>
                        </section>
                    </div>
                </section>

            </div>
        </div>
    </div>
</div>


<script>
    (function ($) {
        $('#ctmRightSidebarCollapse').on('click', function () {
            $('#sidebarzz').toggleClass('active');
        });
    })(jQuery);
</script>