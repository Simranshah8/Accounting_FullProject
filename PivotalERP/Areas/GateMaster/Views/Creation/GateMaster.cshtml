

@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script src="~/jslib/GateMaster/GateMaster.js"></script>
<div id="ActionDiv" ng-app="myApp" ng-controller="GateMasterController" ng-init="LoadData()">
    <div class="content">
        <div class="container-fluid">
            <div class="card">
                <div class="card-header p-0 border-bottom-0">
                    <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false" ng-click="ClearFields()">Gate Master</a>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-2">
                    <div class="tab-content" id="custom-tabs-four-tabContent">
                        <div class="tab-pane fade show active bg-white" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                            <header class="row">
                                <div class="col-md-8">
                                    <div class="clearfix">
                                        <form class="form-inline">

                                            <div class="input-group input-group-sm">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text cstm">Show</span>
                                                </div>
                                                <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.GateMaster">
                                                    <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="">{{pp.text}}</option>
                                                </select>
                                                <div class="input-group-append">
                                                    <span class="input-group-text bg-white"><small>entries</small></span>
                                                </div>
                                            </div>
                                            <div class="input-group input-group-sm table-search-filed">
                                                <input class="form-control form-control-navbar" type="search"
                                                       placeholder="Search" aria-label="Search" ng-model="searchData.GateMaster">
                                                <div class="input-group-append">
                                                    <button class="btn btn-default border-left-0" type="submit">
                                                        <i class="fas fa-search"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                                <div class="col-md-4 text-right">
                                    <div class="dropdown dnld-file"
                                         data-placement="top" title="Download File">
                                        <a class="btn btn-secondary btn-light btn-sm wait"
                                           title="Refresh" ng-click="GetAllGateMaster()">
                                            <i class="fas fa-sync-alt"></i>
                                        </a>
                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                id="dropdownMenuButton" data-toggle="dropdown"
                                                aria-haspopup="true" aria-expanded="false">
                                            <i class="fas fa-download"></i>
                                        </button>
                                        <div class="dropdown-menu dropdown-menu-right"
                                             aria-labelledby="dropdownMenuButton">
                                            <span class="dropdown-item">Choose an option:</span>
                                            <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'GateMaster'" report-name="'List of GateMaster'" ignore-column="'3'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                            <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'GateMaster',ignoreColumn:'3' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                        </div>
                                        <a print-tbl report-name="'GateMaster'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait"
                                           title="Print">
                                            <i class="fas fa-print"></i>
                                        </a>
                                    </div>
                                </div>
                            </header>

                            <div class="search-toolbar mb-3 mt-2">
                                <table cellpadding="12" class="main-table table table-bordered table-striped table-hover table-sm" id="datatable">
                                    <thead>
                                        <tr>
                                            <th style="width: 6%">S.No</th>
                                            <th style="width: 17%">Branch</th>
                                            <th style="width: 17%">Code</th>
                                            <th style="width: 20%">Name</th>
                                            <th style="width: 20%">Gate Type </th>
                                            <th style="width: 10%">VoucherId</th>
                                            <th style="width: 10%">IsActive</th>

                                            <th style="text-align:center" class="no-print " width="12%">Action</th>

                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr dir-paginate="beData in GateMasterList | filter:searchData.GateMaster| itemsPerPage:perPage.GateMaster" current-page="currentPages.GateMaster" pagination-id="GateMasterPagination">
                                            <td>{{$index + 1}}</td>
                                            <td>{{beData.BranchName}}</td>
                                            <td>{{beData.Code}}</td>
                                            <td>{{beData.Name}}</td>
                                            <td>{{beData.GateType}}</td>
                                            <td>{{beData.VoucherName}}</td>
                                            <td>{{beData.IsActive}}</td>


                                            <td class="project-actions no-print text-center">
                                                <div class="btn-group-sm">
                                                    <a href="#" class="btn btn-info" ng-click="GetGateMasterById(beData)"><i class="fas fa-pencil-alt"></i></a>
                                                    <a href="#" class="btn btn-danger" ng-click="deleteGateMaster(beData, $index)"><i class="fas fa-trash"></i></a>
                                                </div>
                                            </td>
                                        </tr>
                                    </tbody>

                                </table>
                                <div class="col-md-12">
                                    <dir-pagination-controls pagination-id="GateMasterPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                    </dir-pagination-controls>
                                </div>
                            </div>

                        </div>

                        <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                            <div>
                                <div class="row">

                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Branch</label><span style="color: red">*</span>
                                            <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.BranchId" data-placeholder="** Select Branch **">
                                                <option ng-value="cl.BranchId" ng-repeat="cl in BranchList" ng-selected="cl.BranchId==newDet.BranchId">{{cl.Name}}</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-4">
                                        <div class="form-group">
                                            <label>Code </label><span style="color: red">*</span>
                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.Code">
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="form-group">
                                            <label>Name </label><span style="color: red">*</span>
                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.Name">
                                        </div>
                                    </div>

                                    @*<div class="col-md-4">
                                            <div class="form-group">
                                                <label>GateType</label>
                                                <select class="form-control form-control-sm pl-0" ng-model="newDet.GateTypeId">
                                                    <option ng-value="A.text" ng-repeat="A in GateTypeColl" ng-selected="A.id == newDet.GateTypeId">{{A.text}}</option>
                                                </select>
                                            </div>
                                        </div>*@

                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>GateType</label>
                                            <select class="form-control form-control-sm pl-0" ng-model="newDet.GateType">
                                                <option ng-repeat="A in GateTypeColl" ng-value="A.text"> {{A.text}} </option>
                                            </select>
                                        </div>
                                    </div>


                                    <div class="col-4">
                                        <div class="form-group">
                                            <label>Voucher</label><span style="color: red">*</span>
                                             <select class="form-control form-control-sm" style="width: 100%;" ng-model="para.VoucherId">
                                                    <option ng-value="vt.VoucherId" ng-repeat="vt in VoucherTypeList" ng-selected="vt.VoucherId==para.VoucherId">{{vt.VoucherName}}</option>
                                                </select>

                                            @*<select class="form-control form-control-sm pl-0" ng-model="newDet.VoucherId">
                                                <option ng-value="A.id" ng-repeat="A in VoucherColl" ng-selected="A.id == newDet.VoucherId">{{A.text}}</option>
                                            </select>*@

                                        </div>
                                    </div>

                                    <div class="col-4">
                                        <div class="custom-control custom-checkbox mt-4">
                                            <input class="custom-control-input" type="checkbox"
                                                   id="customCheckbox1" ng-model="newDet.IsActive">
                                            <label for="customCheckbox1" class="custom-control-label"> Is Active </label>
                                        </div>
                                    </div>

                                </div>

                                <footer class="main-footer">
                                    <div class="text-right control-btns">
                                        <button type="button" class="btn btn-default btn" ng-click="ClearFields()"> <span class="glyphicon glyphicon-remove"></span>Clear</button>
                                        <button type="button" class="btn btn-primary btn" ng-click="SaveUpdateGateMaster()"><span class="glyphicon glyphicon-save"></span>Save</button>
                                    </div>
                                </footer>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>


