@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script src="~/jslib/Finance/Transaction/EndLoan.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="EndLoanController" ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div id="monthEnd-section">
                    <form action="">
                        <div class="card">
                            <div class="card-header header-corner-triangle p-2">
                                <h3 class="card-title">
                                    Loan Details
                                </h3>
                            </div>
                            <div class="card-body">
                                <!-- Row 1: Party, Loan Amount -->
                                <div class="row mb-3">
                                    <div class="col-md-6 d-flex align-items-center">
                                        <label for="party" style="min-width: 85px; margin: 0;">Party:</label>
                                        <select autoShowHide="true" class="select2 serial form-control form-control-sm" all-ledger ng-model="newDet.LedgerId" id="cboParty" style="width:95%" @*ledgertype="2"*@ fortransaction="true"
                                                placeholder="** Select Party Name **" showdetails="true" confirm-action="GetPartywiseLoanById(beData)" ledger-detail="beData.PartyLedger" side-bar-data="newDet.partySideBarData" voucher-id="SelectedVoucher.VoucherId" @*vouchertype="5"*@></select>
                                    </div>

                                    <div class="col-sm-3">
                                        <div class="form-group mb-2 d-flex">
                                            <label style="width:110px">Loan Detail: </label>
                                            <div class="input-group">
                                                <select class="form-control form-control-sm" ng-model="newDet.LoanId" ng-change="GetLoanCreationById()">
                                                    <option ng-repeat="P in LoanListLedgerwise" ng-value="P.TranId" ng-selected="newDet.LoanId==P.TranId">{{P.LoanTypeName}} - {{P.EngineNo}} - {{P.ChechisNo}}</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 d-flex align-items-center">
                                        <label for="loanAmount" style="min-width: 110px; margin: 0;">Loan Amount</label>
                                        <input type="text" id="loanAmount" class="form-control form-control-sm text-right" number-input placeholder="Amount" disabled ng-model="beData.LoanAmount">
                                    </div>
                                </div>

                                <!-- Row 2: Start Date, Period, Loan Type -->
                                <div class="row mb-3">
                                    <div class="col-md-4 d-flex align-items-center">
                                        <label for="startDate" style="min-width: 85px; margin: 0;">Start Date</label>
                                        <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.StartDate_TMP" disabled date-detail="beData.StartDateDet">
                                    </div>

                                    <div class="col-md-4 d-flex align-items-center">
                                        <div class="input-group input-group-sm mr-sm-2">
                                            <span>Period</span>
                                            <input type="text" class="form-control form-control-sm mx-2" ng-model="beData.Period" disabled />
                                            <select class="form-control form-control-sm" ng-model="beData.PeriodType" disabled>
                                                <option ng-repeat="P in PeriodTypesList" ng-value="P.id" ng-selected="beData.PeriodType==P.id">{{P.text}}</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-4 d-flex align-items-center">
                                        <label for="loanType" style="min-width: 110px; margin: 0;">Loan Type</label>
                                        <select class="form-control form-control-sm" ng-model="beData.LoanType" disabled>
                                            <option ng-value="pp.id" ng-repeat="pp in LoanTypeColl" ng-selected="pp.id==beData.LoanType">{{pp.text}}</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- Row 3: Rate, Notes -->
                                <div class="row mb-3">
                                    <div class="col-md-4 d-flex align-items-center">
                                        <label for="interestRate" style="min-width: 85px; margin: 0;">Rate</label>
                                        <input type="number" id="interestRate" class="form-control form-control-sm" placeholder="%" disabled ng-model="beData.InterestRate">
                                    </div>
                                    <div class="col-md-8 d-flex align-items-center">
                                        <label for="notes" style="margin: 0;" class="mr-2">Notes</label>
                                        <textarea class="form-control form-control-sm" rows="1" placeholder="Enter notes" ng-model="beData.Remarks"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <footer class="main-footer">
                    <div class="text-right control-btns">
                        <button type="button" class="btn btn-default" ng-click="ClearEndLoan()">Cancel</button>
                        <button type="button" class="btn btn-default" ng-click="GetAllEndLoan()">Search</button>
                        <button type="button" class="btn btn-primary" ng-click="SaveUpdateEndLoan()">{{beData.Mode}}</button>
                    </div>
                </footer>
            </section>

            <div class="modal fade sales-quotation-page-modal document-attach-modal" id="searVoucherRightBtn" tabindex="-1" role="dialog" aria-labelledby="partyAccRightBtn" aria-hidden="true">
                <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-lg" role="document">
                    <div class="modal-content">
                        <div class="modal-header p-2">
                            <h6 class="modal-title" id="exampleModalCenterTitle">Search Loan Creation</h6>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body gradient-bg">
                            <div class="row">
                                <div class="col-sm-6">
                                    <div class="form-group row">
                                        <label for="" class="col-sm-2 col-form-label col-form-label-sm text-center">Search By</label>
                                        <div class="col-sm-10">
                                            <div class="input-group input-group-sm">
                                                <div class="input-group-prepend">
                                                    <select class="form-control form-control-sm" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                        <option ng-value="asp" ng-repeat="asp in VoucherSearchOptions">{{asp.text}}</option>
                                                    </select>
                                                </div>
                                                <input type="text" class="form-control" placeholder="" ng-model="paginationOptions.SearchVal">
                                                <div class="input-group-append">
                                                    <div class="input-group-text">
                                                        <span class="fas fa-search" ng-click="ReSearchData(-1)"></span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <form class="float-right">
                                        <div class="form-row align-items-center">
                                            <div class="d-flex align-items-center">
                                                <label class="mr-sm-2 mb-0" for="inlineFormCustomSelect">Show</label>
                                                <input type="text" ng-model="paginationOptions.pageSize" class="form-control form-control-sm" placeholder="NoOfRows" @*ng-blur="ReSearchData(-2)"*@>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                            <div class="">
                                <table id="main-table" class="main-table table table-sm table-striped table-bordered">
                                    <thead>
                                        <tr>
                                            <th style="width:60px;">S.No</th>
                                            <th style="width:100px;">Ledger</th>
                                            <th style="width:100px;">Voucher Date</th>
                                            <th style="width:100px;">Loan Amount</th>
                                            <th style="width:100px;">InterestRate</th>
                                            @*<th style="width:100px;">Action</th>*@
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr dir-paginate="sd in SearchDataColl |orderBy:sortKey:reverse|itemsPerPage:paginationOptions.pageSize" total-items="paginationOptions.TotalRows">
                                            <td align="center">{{$index + 1}}</td>
                                            <td>{{sd.LedgerName}}</td>
                                            <td>{{sd.StartDate |dateFormat}}</td>
                                            <td align="right">{{sd.LoanAmount |number:2}}</td>
                                            <td align="right">{{sd.InterestRate|number:2}}</td>

                                            @*<td>
                                                <a class="p-1" href="#" ng-click="GetLoanCreationById(sd)">
                                                    <i class="fas fa-edit text-info"></i>
                                                </a>
                                                <a class="p-1" href="#" ng-click="DelLoanCreation(sd,$index)">
                                                    <i class="fas fa-trash-alt text-danger"></i>
                                                </a>
                                            </td>*@
                                        </tr>
                                    </tbody>
                                </table>
                                <dir-pagination-controls max-size="paginationOptions.pageSize" direction-links="true" boundary-links="true"
                                                         on-page-change="ReSearchData(newPageNumber)">
                                </dir-pagination-controls>
                            </div>

                        </div>
                        <!-- end modal body -->
                        <div class="modal-footer justify-content-between align-items-center py-2">
                            <h6 class="mb-0">Total Record: {{SearchDataColl.length}}</h6>
                            <div class="">
                                <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Close</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>


        </div>
    </section>
</div>