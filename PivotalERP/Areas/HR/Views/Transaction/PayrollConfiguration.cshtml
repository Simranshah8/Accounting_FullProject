
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")


<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Payroll_PayrollConfiguration)";
</script>



<script src="~/jslib/hr/Transaction/PayrollConfiguration.js"></script>
<div class="hold-transition layout-navbar-fixed" ng-app="myApp" ng-controller="PayrollConfigurationController" ng-init="LoadData()">

    <div class="box-body">
        <div class="content">
            <div class="container-fluid">

                <div>
                    <div class="card p-2">
                        <div class="card border">
                            <div class="p-2 card-header" style="background-color: aliceblue;">
                                <h6 class="mb-0">Journal Voucher</h6>
                            </div>
                            <div class="p-2 card-body">
                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="">Voucher</label>
                                            <select class="form-control form-control-sm select2" ng-model="newPayrollConfig.JV_VoucherId">
                                                <option ng-repeat="P in VoucherTypeColl" ng-value="P.VoucherId" ng-selected="P.VoucherId==newPayrollConfig.JV_VoucherId">{{P.VoucherName }}</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="">CostClass</label>
                                            <select class="form-control form-control-sm select2" ng-model="newPayrollConfig.JV_CostClassId">
                                                <option ng-repeat="P in CostClassColl" ng-value="P.CostClassId" ng-selected="P.CostClassId==newPayrollConfig.JV_CostClassId">{{P.Name}}</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <label>Auto Generate Journal </label>
                                        <div class="form-group clearfix">
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" id="HL-yes" name="HL" ng-value="true" ng-model="newPayrollConfig.JV_AutoGenerate">
                                                <label class="form-check-label" for="HL-yes">Yes</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" id="HL-no" name="HL" ng-value="false" ng-model="newPayrollConfig.JV_AutoGenerate">
                                                <label class="form-check-label" for="HL-no">No</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <label>Auto Cancel and re-generate Journal</label>
                                        <div class="form-group clearfix">
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" id="HT-yesJCancel" name="HT" ng-value="true" ng-model="newPayrollConfig.JV_AutoCancelRegenerate">
                                                <label class="form-check-label" for="HT-yesJCancel">Yes</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" id="HT-noJCancel" name="HT" ng-value="false" ng-model="newPayrollConfig.JV_AutoCancelRegenerate">
                                                <label class="form-check-label" for="HT-noJCancel">No</label>
                                            </div>
                                        </div>
                                    </div>


                                </div>

                            </div>
                        </div>

