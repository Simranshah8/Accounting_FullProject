                        <div class="card border mb-0">
                            <div class="p-2 card-header" style="background-color: aliceblue;">
                                <h6 class="mb-0">General Config.</h6>
                            </div>
                            <div class="p-2 card-body">
                                <div class="row">
                                    <div class="col-md-3">
                                        <label>Show Salary Attendance</label>
                                        <div class="form-group clearfix">
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" id="ShowSalaryAttend-Yes" name="ShowSalaryAttend" ng-value="true" ng-model="newPayrollConfig.ShowSalAttn">
                                                <label class="form-check-label" for="ShowSalaryAttend-Yes">Yes</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" id="ShowSalaryAttend-No" name="ShowSalaryAttend" ng-value="false" ng-model="newPayrollConfig.ShowSalAttn">
                                                <label class="form-check-label" for="ShowSalaryAttend-No">No</label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <label>Block Screenshot </label>
                                        <div class="form-group clearfix">
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" id="BlockScreenshot-yes" name="BlockScreenshot" ng-value="true" ng-model="newPayrollConfig.BlockScreenshot">
                                                <label class="form-check-label" for="BlockScreenshot-yes">Yes</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" id="BlockScreenshot-No" name="BlockScreenshot" ng-value="false" ng-model="newPayrollConfig.BlockScreenshot">
                                                <label class="form-check-label" for="BlockScreenshot-No">No</label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <label>Allow Payslip Download</label>
                                        <div class="form-group clearfix">
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" id="AllowPaySlipDownload-yes" name="AllowPaySlipDownload" ng-value="true" ng-model="newPayrollConfig.AllowPayslipDL">
                                                <label class="form-check-label" for="AllowPaySlipDownload-yes">Yes</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" id="AllowPaySlipDownload-No" name="AllowPaySlipDownload" ng-value="false" ng-model="newPayrollConfig.AllowPayslipDL">
                                                <label class="form-check-label" for="AllowPaySlipDownload-No">No</label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="">No Of Decimals</label>
                                            <input class="form-control form-control-sm" type="number" ng-model="newPayrollConfig.NoOfDecimal" />
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label for="">Payslip for App</label>
                                            <select class="form-control form-control-sm" ng-model="newPayrollConfig.PaySlipTemplateId">
                                                <option ng-selected="mt.RptTranId==dd.PaySlipTemplateId" ng-value="mt.RptTranId" ng-repeat="mt in PaySlipReportColl">{{mt.ReportName}}</option>
                                            </select>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                        @*end*@

                        <div class="time-label pb-3">
                            <span class="d-block border-0 text-center">
                                <button type="button" class="btn btn-sm btn-default load" style="min-width: 90px;" ng-click="ClearPayrollConfig()">Reset</button>
                                <button type="button" class="btn btn-sm btn-info load" style="min-width: 90px;" ng-click="SaveUpdatePayrollConfig()">Save</button>
                            </span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>


