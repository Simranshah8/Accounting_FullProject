@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>

<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Payroll_ArrearSalaryDetail)";
</script>



<script src="~/jslib/global/math.min.js"></script>
<script src="~/jslib/hr/Transaction/ArrearSalaryDetail.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="ArrearSalaryDetailController" ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="pb-1"></div>
                <div class="card p-2 mb-0">
                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Branch</label>
                                <select class="form-control form-control-sm select2" ng-model="newFilter.BranchId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-repeat="B in BranchList" ng-value="B.BranchId" ng-selected="B.BranchId==newFilter.BranchId">{{B.Name}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Department</label>
                                <select class="form-control form-control-sm select2" ng-model="newFilter.DepartmentId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-value="c.CostCenterDepartmentId" ng-repeat="c in DepartmentList" ng-selected="c.CostCenterDepartmentId==newFilter.DepartmentId">{{c.text}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Category</label>
                                <select class="form-control form-control-sm select2" ng-model="newFilter.CategoryId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-value="c.CategoryId" ng-repeat="c in CategoryList" ng-selected="c.CategoryId==newFilter.CategoryId">{{c.Name}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-2 col-md-2">
                            <div class="form-group">
                                <label>From Year</label>
                                <select class="form-control form-control-sm" ng-model="newFilter.YearId">
                                    <option ng-value="A.id" ng-repeat="A in AcademicYearColl" ng-selected="A.id==newFilter.YearId">{{A.text}}</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-sm-2 col-md-2">
                            <div class="form-group">
                                <label for="">From Month</label>
                                <select class="form-control form-control-sm select2" ng-model="newFilter.MonthId">
                                    <option ng-value="cl.id" ng-repeat="cl in MonthList" ng-selected="cl.id==newFilter.MonthId">{{cl.text}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-1">
                            <button class="btn btn-sm btn-outline-secondary btn-add mt-4 float-right" ng-click="GetEmployeeForArrearSalaryDetail()"><i class="fas fa-redo-alt"></i> Load</button>
                        </div>
                    </div>
                    <header class="row">
                        <div class="col-md-7">
                            <div class="clearfix">
                                <form class="form-inline">
                                    <div class="input-group input-group-sm mr-sm-2">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text cstm">Show</span>
                                        </div>
                                        <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.ArrearSalaryDetail">
                                            <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.ArrearSalaryDetail">{{pp.text}}</option>
                                        </select>
                                        <div class="input-group-append">
                                            <span class="input-group-text bg-white"><small>entries</small></span>
                                        </div>
                                    </div>
                                    <div class="input-group input-group-sm table-search-filed">
                                        <input class="form-control form-control-navbar"
                                               type="search" placeholder="Search"
                                               aria-label="Search" ng-model="searchData.ArrearSalaryDetail">
                                        <div class="input-group-append">
                                            <button class="btn btn-default border-left-0"
                                                    type="submit">
                                                <i class="fas fa-search"></i>
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="col-md-5 text-right">
                            <div class="dropdown dnld-file ml-2">
                                <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                        id="dropdownMenuButton" data-toggle="dropdown"
                                        aria-haspopup="true" aria-expanded="false">
                                    <i class="fas fa-download"></i>
                                </button>
                                <div class="dropdown-menu dropdown-menu-right"
                                     aria-labelledby="dropdownMenuButton">
                                    <span class="dropdown-item">Choose an option:</span>
                                    <a class="dropdown-item wait" export-excel table-id="'#ArrearSalaryDetail'" sheet-name="'ArrearSalaryDetailList'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                    <a class="dropdown-item wait" onClick="$('#ArrearSalaryDetail').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                </div>
                                @*<button class="btn btn-sm btn-add btn-info" ng-click="ReCalculate()"><i class="fas fa-refresh mr-1"></i> Re-Calculate</button>*@
                                <button class="btn btn-sm btn-add btn-success" ng-click="SaveArrearSalaryDetail()"><i class="fas fa-save mr-1"></i> Save</button>
                                <button class="btn btn-sm btn-add btn-danger" ng-click="DeleteArrearSalaryDetail()"><i class="far fa-trash-alt"></i> Delete</button>
                            </div>
                        </div>
                    </header>
                    <div class="table-scroll-x-y table-scroll mt-1 pb-2" style="max-height: calc(100vh - 10rem);">
                        <table id="ArrearSalaryDetail"
                               class="main-table table table-sm table-bordered bg-white">
                            <thead>
                                <tr>
                                    <th class="text-center align-middle cstm-sticky" style="width: 70px; left: 0; z-index: 4; background-color: #e9ecef !important" ng-click="sortEmpData('EmployeeCode')">Code</th>
                                    <th class="text-center align-middle cstm-sticky" style="width: 80px; left: 70px; z-index: 4; background-color: #e9ecef !important" ng-click="sortEmpData('EnrollNo')">Enroll No</th>
                                    <th class="align-middle cstm-sticky" style="width: 250px; left: 150px; z-index: 4; background-color: #e9ecef !important" ng-click="sortEmpData('EmployeeName')">Name</th>
                                    <th class="text-center" style="width: 120px; z-index: 3; background-color: #e9ecef !important" ng-repeat="Ph in PayHeadingList">
                                        {{Ph.Name}}
                                    </th>
                                    <th class="text-center" style="width: 120px; z-index: 3; background-color: #e9ecef !important">
                                        Earning
                                    </th>
                                    <th class="text-center" style="width: 120px; z-index: 3; background-color: #e9ecef !important">
                                        Deduction
                                    </th>
                                    <th class="text-center" style="width: 120px; z-index: 3; background-color: #e9ecef !important">
                                        Tax
                                    </th>
                                    <th class="text-center" style="width: 120px; z-index: 3; background-color: #e9ecef !important">
                                        Net Payable
                                    </th>
                                    <th class="text-center cstm-sticky" style="width: 62px; right: 0; z-index: 3; background-color: #e9ecef !important">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr dir-paginate="cl in EmployeeListForArrearSalaryDetail |orderBy:sortKeySS:reverseSS | filter:searchData.ArrearSalaryDetail | itemsPerPage: perPage.ArrearSalaryDetail" current-page="currentPages.ArrearSalaryDetail" pagination-id="ArrearSalaryDetailPagination">
                                    <td class="align-middle text-center cstm-sticky" style="width: 70px; left: 0; z-index: 2; background-color: #fff !important">{{cl.EmployeeCode}}</td>
                                    <td class="align-middle text-center cstm-sticky" style="width: 80px; left: 70px; z-index: 2; background-color: #fff !important">{{cl.EnrollNo}}</td>
                                    <td class="align-middle cstm-sticky" style="width: 180px; left: 150px; z-index: 2; background-color: #fff !important">{{cl.EmployeeName}}</td>
                                    <td class="text-center" ng-repeat="Ph in cl.PayHeadColl">
                                        <span ng-show="false">{{Ph.Amount |number:2}}</span>
                                        <div class="input-group input-group-sm ">
                                            <input ng-disabled="Ph.IsEditable==false" type="text" number-input noofdecimal="2" style="text-align:right;" onfocus="this.select();" class="form-control form-control-sm" ng-model="Ph.Amount" ng-change="ChangeRate(cl,Ph)">
                                            <div class="input-group-append" ng-show="Ph.PayheadType==4 || Ph.PayheadType==6">
                                                <button class="btn btn-info" ng-click="ShowTaxDetails(cl,Ph)">
                                                    ...
                                                </button>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <input readonly type="text" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="cl.Earning">
                                    </td>
                                    <td>
                                        <input readonly type="text" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="cl.Deduction">
                                    </td>
                                    <td>
                                        <input readonly type="text" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="cl.Tax">
                                    </td>
                                    <td>
                                        <input readonly type="text" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="cl.Netpayable">
                                    </td>
                                    <td class="text-center cstm-sticky" style="width: 62px; right: 0; z-index: 2; background-color: #e9ecef !important">
                                        <a class="p-1 btn btn-sm btn-info" data-toggle="tooltip" title="Update" href="#" ng-click="UpdateDetailData(cl,$index)">
                                            <i class="fas fa-save "></i>
                                        </a>
                                        <a class="p-1 btn btn-danger btn-sm" data-toggle="tooltip" title="Delete" href="#" ng-click="DelArrearSalaryDetailData(cl)">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <footer class="row align-items-center">
                        <div class="col-md-12">
                            <dir-pagination-controls pagination-id="ArrearSalaryDetailPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                            </dir-pagination-controls>
                        </div>
                    </footer>
                </div>
            </section>
        </div>
    </section>

    <div class="modal fade" id="detailmodel" style="margin-top:35px;">
        <div class="modal-dialog modal-xl" style="max-width:680px!important">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title">Tax Calculation Detail</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="table-scroll-x-y table-scroll" style="max-height:430px!important">
                        <table id="main-table"
                               class="main-table table table-sm table-bordered bg-white">
                            <thead>
                                <tr class="text-center">
                                    <th style="width: 40px">S.No.</th>
                                    <th style="width: 110px">Amount</th>
                                    <th style="width: 110px">Rate</th>
                                    <th style="width: 100px">Tax</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr ng-repeat="TD in CurTaxDetailsColl">
                                    <td class="text-center">{{$index+1}}</td>
                                    <td class="text-right">{{TD.Amount |number:2}}</td>
                                    <td class="text-center">{{TD.Rate |number:2}}</td>
                                    <td class="text-center">{{TD.Tax |number:2}}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>