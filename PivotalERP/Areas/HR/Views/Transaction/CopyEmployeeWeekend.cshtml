@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>

<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Att_CopyEmployeeWeekend)";
</script>



<script src="~/jslib/hr/Transaction/CopyEmployeeWisWeekend.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="CopyEmployeeWeekendController" ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="card p-2">
                    <div class="row">
                        <div class="col-sm-2 col-md-2">
                            <div class="form-group">
                                <label>From Year</label>
                                <select class="form-control form-control-sm select2" ng-model="newFilter.FromYearId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-value="A.id" ng-repeat="A in YearList" ng-selected="A.id==newFilter.FromYearId">{{A.text}}</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-sm-2 col-md-2">
                            <div class="form-group">
                                <label for="">From Month</label>
                                <select class="form-control form-control-sm select2" ng-model="newFilter.FromMonthId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-value="cl.id" ng-repeat="cl in MonthList" ng-selected="cl.id==newFilter.FromMonthId">{{cl.text}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-2 col-md-2">
                            <div class="form-group">
                                <label>To Year</label>
                                <select class="form-control form-control-sm select2" ng-model="newFilter.ToYearId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-value="A.id" ng-repeat="A in YearList" ng-selected="A.id==newFilter.ToYearId">{{A.text}}</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-sm-2 col-md-2">
                            <div class="form-group">
                                <label for="">To Month</label>
                                <select class="form-control form-control-sm select2" ng-model="newFilter.ToMonthId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-value="cl.id" ng-repeat="cl in MonthList" ng-selected="cl.id==newFilter.ToMonthId">{{cl.text}}</option>
                                </select>
                            </div>
                        </div>

                        @*<div class="col-md-1">
                                <button class="btn btn-sm btn-outline-secondary mt-4 btn-add float-right" ng-click="getNepaliCalendar()"><i class="fas fa-redo-alt"></i> Load</button>
                            </div>*@
                    </div>
                    <header class="row">
                        <div class="col-md-7">

                        </div>
                        <div class="col-md-5 text-right">
                            <button class="btn  btn-add btn-primary load" ng-click="CopyEmpWiseWeekend()"><i class="fas fa-save mr-1"></i>Copy Employee Wise Weekend</button>
                        </div>
                    </header>

                </div>
            </section>
        </div>
    </section>
</div>