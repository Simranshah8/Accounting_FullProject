@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script>
        var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Att_EmployeeLoan)";
</script>

<style>
    .table-scroll-x-y {
        height: auto !important;
    }

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>

<script src="~/jslib/hr/Transaction/EmployeeLoan.js"></script>
<div ng-app="myApp" ng-controller="EmployeeLoanController" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllEmployeeLoan()">


    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card my-1 card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" ng-click="ClearEmployeeLoan()" aria-controls="custom-tabs-four-profile" aria-selected="false">Employee Loan</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body p-2">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm mr-2">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.EmployeeLoan">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.EmployeeLoan">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.EmployeeLoan">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file" title="Download File">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#EmployeeLoan'" sheet-name="'EmployeeLoanList'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#EmployeeLoan').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl table-id="'#EmployeeLoan'" class="btn btn-secondary btn-light btn-sm wait"
                                               title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>
                                            <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                               data-toggle="modal" data-target="#itemAllocationForModal" data-placement="bottom" title="Filter">
                                                <i class="fas fa-filter"></i>
                                            </a>
                                        </div>


                                    </div>
                                </header>
                                <div>
                                    <div class="table-scroll-x-y table-scroll">
                                        <table id="EmployeeLoan"
                                               class="main-table table table-sm table-bordered bg-white">
                                            <thead>
                                                <tr>
                                                    <th style="width: 50px">S.No.</th>
                                                    <th style="width: 255px">Company</th>
                                                    <th style="width: 150px">Branch</th>
                                                    <th style="width: 100px">EmpCode</th>
                                                    <th style="width: 150px">EmpName</th>
                                                    <th style="width: 120px">EmployeeLoan</th>
                                                    <th style="width: 120px">Principle Amount</th>
                                                    <th style="width: 100px">Interest Rate</th>
                                                    <th style="width: 100px">Loan Period</th>
                                                    <th style="width: 100px">EMI Amount</th>
                                                    <th style="width: 110px">Effective  Date</th>
                                                    <th style="width: 170px">Remarks</th>
                                                    <th style="width: 70px">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>

                                                <tr dir-paginate="cl in EmployeeLoanList | filter:searchData.EmployeeLoan | itemsPerPage: perPage.EmployeeLoan" current-page="currentPages.EmployeeLoan" pagination-id="EmployeeLoanPagination">
                                                    <td>{{$index+1}}</td>
                                                    <td>{{cl.CompanyName}}</td>
                                                    <td>{{cl.BranchName}}</td>
                                                    <td>{{cl.EmployeeCode}}</td>
                                                    <td>{{cl.EmployeeName}}</td>
                                                    <td>{{cl.LoanTypeName}}</td>
                                                    <td>{{cl.PrincipleAmount}}</td>
                                                    <td>{{cl.InterestRate}}</td>
                                                    <td>{{cl.Period}}</td>
                                                    <td>{{cl.EMIAmount}}</td>
                                                    <td>{{cl.EffMiti}}</td>
                                                    <td>{{cl.Remarks}}</td>
                                                    <td>
                                                        <a class="p-1" href="#" ng-click="GetEmployeeLoanById(cl)">
                                                            <i class="fas fa-edit text-info"></i>
                                                        </a>
                                                        <a class="p-1" href="#" ng-click="deleteEmployeeLoan(cl,$index)">
                                                            <i class="fas fa-trash-alt text-danger"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <footer class="row align-items-center">
                                    <div class="col-md-12">
                                        <dir-pagination-controls pagination-id="EmployeeLoanPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                        </dir-pagination-controls>
                                    </div>
                                </footer>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                                <div class="">
                                    <form>
                                        <div class="row ">
                                            <div class="col-md-8">
                                                <div class="form-group">
                                                    <label for="">Employee</label>
                                                    <div class="input-group-prepend">
                                                        <select class="form-control select2bs4 form-control-sm" all-employee ng-model="newEmployeeLoan.UserId" employee-detail="newEmployeeLoan.EmployeeDetails" side-bar-data="newEmployeeLoan.EmpSideBarData" search-by="newEmployeeLoan.EmployeeSearchBy" confirm-action="SelectEmployeeId(newEmployeeLoan.EmployeeDetails)">
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label for="">Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="newEmployeeLoan.LoanDate_TMP" date-detail="newEmployeeLoan.LoanDateDet">
                                                </div>
                                            </div>

                                            <div class="col-sm-4 col-md-4">
                                                <div class="form-group">
                                                    <label for="">Loan Type</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newEmployeeLoan.LoanTypeId">
                                                        <option ng-repeat="L in LoanTypeList" ng-value="L.TranId" ng-selected="L.TranId==newEmployeeLoan.LoanTypeId">{{L.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label for="">Principle Amount</label>
                                                    <input type="text" class="form-control form-control-sm" number-input onfocus="this.select();" ng-model="newEmployeeLoan.PrincipleAmount" ng-change="calculateEMI()" />
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label for="">Interest Rate</label>
                                                    <input type="text" class="form-control form-control-sm" number-input onfocus="this.select();" ng-model="newEmployeeLoan.InterestRate" ng-change="calculateEMI()" />
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label for="">Period(Month)</label>
                                                    <input type="text" class="form-control form-control-sm" number-input ng-model="newEmployeeLoan.Period" ng-change="calculateEMI()" />
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label for="">EMI Amount</label>
                                                    <input type="text" class="form-control form-control-sm" number-input onfocus="this.select();" ng-model="newEmployeeLoan.EMIAmount" />
                                                </div>
                                            </div>

                                            <div class="col-sm-4 col-md-4">
                                                <div class="form-group">
                                                    <label for="">Effective Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="newEmployeeLoan.EffDate_TMP" date-detail="newEmployeeLoan.EffDateDet">
                                                </div>
                                            </div>
                                            <div class="col-sm-12 col-md-12">
                                                <div class="form-group">
                                                    <label>Remarks</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newEmployeeLoan.Remarks">
                                                </div>
                                            </div>

                                        </div>
                                    </form>
                                    <footer class="main-footer">
                                        <div class="text-right control-btns">
                                            <button type="button" class="btn btn-sm btn-default load" style="min-width: 90px;" ng-click="ClearEmployeeLoan()">Reset</button>
                                            <button type="button" class="btn btn-sm btn-primary load" style="min-width: 90px;" ng-click="SaveUpdateEmployeeLoan()">{{newEmployeeLoan.Mode}}</button>
                                        </div>
                                    </footer>

                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->
        </div>
    </div>
</div>

