
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.RptFormsEntity.Att_DailyAppAttendance)";
</script>
<script src="~/jslib/hr/report/MonthlyAppAttendance.js"></script>

<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="MonthlyAppSummaryController" ng-init="LoadData()">
            <div class="content-wrapper-new">
                <section class="">
                    <div class="container-fluid">
                        <section class="iframe-content-starts-here">
                            <div class="tab-content">
                                <div id="day-book-section">
                                    <div class="card px-2 pt-2 pb-0">
                                        <div class="row">
                                            <div class="col-md-1">
                                                <div class="form-group">
                                                    <label>Date Style</label>
                                                    <select name="class-group" id="" form="" class="form-control form-control-sm " ng-model="newMonthly.DateStyle">
                                                        <option ng-value="cl.id" ng-repeat="cl in DateStyleColl" ng-selected="cl.id==newMonthly.DateStyle">{{cl.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-2" ng-show="newMonthly.DateStyle==2">
                                                <div class="form-group">
                                                    <label>Year</label>
                                                    <select name="class-group" id="" form="" class="form-control form-control-sm " ng-model="newMonthly.YearId">
                                                        <option ng-value="cl.id" ng-repeat="cl in YearList" ng-selected="cl.id==newMonthly.YearId">{{cl.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-2" ng-show="newMonthly.DateStyle==2">
                                                <div class="form-group">
                                                    <label>For Month</label>
                                                    <select name="class-group" id="" form="" class="form-control form-control-sm " ng-model="newMonthly.MonthId">
                                                        <option ng-value="cl.id" ng-repeat="cl in MonthList" ng-selected="cl.id==newMonthly.MonthId">{{cl.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-2" ng-show="newMonthly.DateStyle==1">
                                                <div class="form-group">
                                                    <label> Date From</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="newMonthly.DateFrom_TMP" date-detail="newMonthly.DateFromDet">
                                                </div>
                                            </div>
                                            <div class="col-md-2" ng-show="newMonthly.DateStyle==1">
                                                <div class="form-group">
                                                    <label> Date To</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="newMonthly.DateTo_TMP" date-detail="newMonthly.DateToDet">
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label>Company</label>
                                                    <multi-select-option ng-model="newMonthly.CompanyRelationshipIds" data="CompanyRelationshipList" label="Name" value="TranId"></multi-select-option>
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group" ng-show="BranchList.length>1">
                                                    <label>Branch</label>
                                                    <multi-select-option ng-model="newMonthly.BranchIds" data="BranchList" label="Name" value="BranchId"></multi-select-option>
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label>Department</label>
                                                    <multi-select-option ng-model="newMonthly.DepartmentIds" data="DepartmentList" label="Name" value="CostCenterDepartmentId"></multi-select-option>
                                                </div>
                                            </div>
                                            <div class="col-md-1 mt-4">
                                                <div class="form-group">
                                                    <button class="btn btn-sm btn-info load" type="button" style="width: 100%;" ng-click="GetMonthAttendance()"><i class="fas fa-sync-alt mr-2"></i>Load</button>
                                                </div>
                                            </div>
                                        </div>
                                        <header class="row">                                            
                                            <div class="col-md-7">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm" style="width: 250px;">
                                                            <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">
                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-default"><i class="fas fa-search"></i></button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                            <div class="col-md-5">
                                                <div class="float-right form-inline">
                                                    <div class="dropdown dnld-file ml-2" data-toggle="tooltip"
                                                         data-placement="top" title="Download File">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"><i class="fas fa-download"></i></button>
                                                        <div class="dropdown-menu dropdown-menu-right"
                                                             aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()"> <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image">Excel</a>
                                                            <a class="dropdown-item" href="#" ng-click="onBtExportCSV()"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"class="img-fluid exports-icon">CSV</a>
                                                        </div>
                                                    </div>
                                                    <a class="btn btn-secondary btn-light btn-sm ml-2" title="Print" ng-click="GetDataForPrint()"><i class="fas fa-print"></i></a>
                                                </div>
                                            </div>
                                        </header>
                                        @*<div class="row">
                                                <div class="col-md-2 col-sm-2">
                                                    <label><b>Total Employees: {{newDaily.TotalEmployees}}</b></label>
                                                </div>
                                                <div class="col-md-2 col-sm-2">
                                                    <label>
                                                        <b>
                                                            Present: {{newDaily.TotalPresent || 0 }} ({{ ((newDaily.TotalPresent || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)
                                                        </b>
                                                    </label>
                                                </div>
                                                <div class="col-md-2 col-sm-2">
                                                    <label>
                                                        <b>
                                                            Absent: {{newDaily.TotalAbsent || 0 }} ({{ ((newDaily.TotalAbsent || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)
                                                        </b>
                                                    </label>
                                                </div>
                                                <div class="col-md-2 col-sm-2">
                                                    <label>
                                                        <b>
                                                            Leave: {{newDaily.TotalLeave || 0 }} ({{ ((newDaily.TotalLeave || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)
                                                        </b>
                                                    </label>
                                                </div>
                                                <div class="col-md-2 col-sm-2">
                                                    <label><b>Weekend:   {{newDaily.TotalWeekEnd || 0 }} ({{ ((newDaily.TotalWeekEnd || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)</b></label>
                                                </div>
                                            </div>*@
                                        <div id="datatable1" style="height: calc(100vh - 8rem);width: 100%;" class="ag-theme-alpine"></div>
                                    </div>

                                    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="EmpDetail" role="dialog" tabindex="-1">
                                        <div class="modal-dialog modal-md" style="max-width: 500px !important;" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header p-2">
                                                    <h5 class="modal-title">Employee Attendance Details for Day {{modalDetails.Day}}</h5>
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                        <span aria-hidden="true">&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body mb-0 p-2">
                                                    <p><strong>Employee Code:</strong> {{modalDetails.EmpCode}}</p>
                                                    <p><strong>Name:</strong> {{modalDetails.Name}}</p>
                                                    <p><strong>Designation:</strong> {{modalDetails.Designation}}</p>
                                                    <p><strong>Date:</strong> {{modalDetails.FullDate}}</p>
                                                    <p><strong>In Time:</strong> {{modalDetails.LateInMinutes || "N/A"}}</p>
                                                    <p><strong>Out Time:</strong> {{modalDetails.OutTime || "N/A"}}</p>
                                                </div>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                        <!-- /.row -->
                    </div>
                    <!--/. container-fluid -->
                </section>
            </div>
            <!-- /.content -->
       
</div>
