<script src="~/jslib/hr/Report/HRDashboard.js"></script>
<div ng-app="myApp" ng-controller="HRDashbardController" ng-init="LoadData()">
    <div class="content container-fluid" @*style="background-color:white!important;"*@>
        <!--HRDashboard section-->
        <div id="HRDasboard-section">
            <div class="container-fluid p-2">
                <div class="row g-3 justify-content-around" style=" margin-left: -27px; margin-right: -27px;">

                    <!-- Total Employees -->
