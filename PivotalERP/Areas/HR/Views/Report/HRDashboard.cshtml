                                    <div class="col-md-5 col-sm-5 col-lg-5 mr-2">
                                        <label><b>Employee leaves</b></label>
                                    </div>
                                    <div class="col-sm-2 col-md-2 col-lg-2 mr-1">
                                        <button class="card-tab-btn">Today</button>
                                    </div>
                                    <div class="col-sm-2 col-md-2 col-lg-2 mr-1">
                                        <button class="card-tab-btn">Weekly</button>
                                    </div>
                                    <div class="col-sm-2 col-md-2 col-lg-2 mr-1">
                                        <button class="card-tab-btn">Monthly</button>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <canvas id="EmployeeLeaves" style="max-height:230px;width:100%"></canvas>
                            </div>
                            <div class="card-footer p-1 text-right pr-3" style="color:green;">
                                <label></label>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="p-2 pb-0" @*style="background-color:white;"*@>
                <div class="row">
                    <!-- Attendance Report -->
                    <div class="col-md-12">
                        <div class="card card-default" style="border-radius: 12px;">
                            <div class="card-header p-1 pl-4">
                                <div class="row p-1">
                                    <div class="col-md-9 col-sm-9 col-lg-9 mr-4">
                                        <label><b>Attendance Report</b></label>
                                    </div>
                                    <div class="col-sm-1 col-md-1 col-lg-1 p-0" style="margin-right:-15px;">
                                        <button class="card-tab-btn">Today</button>
                                    </div>
                                    <div class="col-sm-1 col-md-1 col-lg-1 p-0" style="margin-right:-15px;">
                                        <button class="card-tab-btn">Weekly</button>
                                    </div>
                                    <div class="col-sm-1 col-md-1 col-lg-1 p-0" style="margin-right:-15px;">
                                        <button class="card-tab-btn">Monthly</button>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body p-0" style="border-bottom: 1px solid #DCDCDC; border-bottom-left-radius: 12px; border-bottom-right-radius:12px;">
                                <div class="table-scroll-x-y table" style="height: auto !important; max-height: calc(100Vh - 18rem) !important; overflow: auto !important;">
                                    <table class="styled-table">
