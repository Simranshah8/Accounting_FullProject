
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    body {
        font-family: 'Poppins', sans-serif;
    }

    .calendar-header {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        padding: 3px 20px;
        background: #fff;
        border-bottom: 1px solid #eee;
    }

        .calendar-header select {
            border: none;
            background: transparent;
            font-size: 16px;
            font-weight: 500;
            color: #333;
            cursor: pointer;
            outline: none;
        }

    .date-strip {
        display: flex;
        overflow-x: auto;
        white-space: nowrap;
        padding: 10px 0;
        scrollbar-width: none;
        background: #fafafa;
    }

        .date-strip::-webkit-scrollbar {
            display: none;
        }

    .date-item {
        flex: 0 0 auto;
        text-align: center;
        padding: 0 12px;
        color: #555;
        cursor: pointer;
    }

        .date-item.active {
            color: #00a859;
            font-weight: bold;
        }

        .date-item .day {
            font-size: 12px;
            color: #777;
        }

        .date-item .date {
            font-size: 14px;
            margin-top: 2px;
        }

    /* Event section */
    .event-list {
        padding: 0 20px;
        background: #fff;
    }

    .event-item {
        padding: 3px 0;
        border-bottom: 1px solid #f0f0f0;
    }

        .event-item:last-child {
            border-bottom: none;
        }

    .event-title {
        font-weight: 600;
        color: #333;
        font-size: 13px;
    }

    .event-desc {
        color: #555555;
        font-size: 10px;
        margin-top: 2px;
    }
</style>
<style>

    /* Responsive stat cards */
    .insidecard {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        color: black;
        border-radius: 12px;
        box-shadow: 0px 2px 4px 0px #0000001A;
        transition: transform 0.2s ease-in-out;
        height: 80px;
    }

        /* Hover effect */
        .insidecard:hover {
            transform: translateY(-4px);
        }

    /* Image circle box */
    .imgcard {
        height: 45px;
        width: 45px;
        border-radius: 15px;
        margin-right: 10px;
        background-color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-shrink: 0;
    }

        .imgcard img {
            width: 20px;
            height: 20px;
        }

    /* Label & heading */
    .insidecard label {
        font-size: 14px;
        font-weight: 500;
        display: block;
        margin-bottom: 2px;
    }

    .insidecard h5 {
        font-size: 18px;
        margin: 0;
        font-weight: 600;
    }

    /* Responsive adjustments */
    @@media (max-width: 767px) {
        .insidecard {
            width: 100%;
            justify-content: flex-start;
            height: auto;
            padding: 10px;
        }
    }


    /* Table container controls scrolling */
    .table {
        width: 100%;
        overflow-x: auto; /* horizontal scroll hide */
        overflow-y: auto;
    }

    .table-sm td {
        padding: 0.5rem !important;
    }

    .table-sm th {
        padding: 0.5rem !important;
    }
    /* Table styling */
    .styled-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 10px;
        color: #333;
    }

        /* Header */
        .styled-table thead {
            background-color: #f5f5f5 !important;
        }

            .styled-table thead th {
                text-align: left;
                font-weight: 700;
                padding: 10px !important;
            }

        .styled-table tbody td {
            padding: 6px !important;
            font-weight: 600;
        }

    .table .styled-table tbody tr:nth-child(odd) {
        background-color: #f7f7f7 !important;
    }

    .table .styled-table tbody tr:nth-child(even) {
        background-color: #f0f0f0 !important;
    }

    .card-tab-btn {
        background-color: #c9ead9;
        border-radius: 5px;
        padding: 5px 10px; /* better padding for small screens */
        min-width: 60px; /* ensures buttons don’t shrink too much */
        border: none;
        cursor: pointer;
        flex: 1 1 auto; /* allows flexible width on smaller screens */
        text-align: center;
    }

        .card-tab-btn:hover {
            background-color: #2aae68;
            color: white;
        }

    /* stack buttons vertically on very small screens */
    @@media (max-width: 576px) {
        .card-tab-btn {
            width: 100%; /* full width on extra small screens */
        }
    }


    /* Profile inside table */
    .profile {
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .profile img {
            width: 25px;
            height: 25px;
            border-radius: 50%;
            object-fit: cover;
        }

    .profile-circle {
        width: 25px;
        height: 25px;
        background-color: #27ae60;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 10px;
    }
</style>

<style>

    .date-strip::-webkit-scrollbar {
        height: 6px;
    }

    .date-strip::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 4px;
    }

        .date-strip::-webkit-scrollbar-thumb:hover {
            background: #999;
        }

    .date-item {
        display: inline-block;
        padding: 6px 4px !important;
        min-width: 39px;
        cursor: pointer;
        border-radius: 8px;
        transition: 0.2s;
    }

        .date-item.active {
            background-color: #e6f4ff;
            border: 1px solid #1f5d9e;
        }

        .date-item.selected {
            border: 2px solid #00a859;
            background-color: #f8fff8;
        }

        .date-item:hover {
            background-color: #f0f8ff;
        }

    .event-item:hover {
        background-color: #f3f3f3;
    }

    .img-circle {
        border-radius: 50%;
    }
</style>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels"></script>

<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0-rc"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.1.1/chart.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

