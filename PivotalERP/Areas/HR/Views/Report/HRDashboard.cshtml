                                <div class="row">
                                    <!-- Canvas -->
                                    <div class="col-sm-8">
                                        <canvas id="genderratio" style="height: 177px; width: 100%"></canvas>
                                    </div>
                                    <!-- Gender Stats -->
                                    <div class="col-sm-4 pt-4">
                                        <div class="d-flex flex-column justify-content-center">
                                            <div class="d-flex justify-content-between mb-2" ng-repeat="item in GenderRatioColl">
                                                <span>{{item.Gender}}</span>
                                                <span style="color: #92C960; font-weight: bold;">{{item.TotalEmployees}}</span>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                            </div>
                            <div class="card-footer" style="text-align: right; ">
                                <a id="View-genderRatio" style="color: #00a859;" ng-click="GenderDetails()">View All<i class="fas fa-arrow-right" style="color: green;"></i></a>
                            </div>
                        </div>
                    </div>

                    <!-- Marital Status -->
                    <div class="col-md-4">
                        <div class="card card-default" style="border-radius: 12px;">
                            <div class="card-header p-2 pl-4">
                                <label><b>Marital Status</b></label>
                            </div>
                            <div class="card-body pt-0 pl-0" style="border-bottom: 1px solid #DCDCDC; border-bottom-left-radius: 12px; border-bottom-right-radius:12px;">
                                <div class="row">
                                    <div class="col-md-8">
                                        <canvas id="maritalStatusChart" style="height:179px;width:100%"></canvas>
                                    </div>
                                    <div class="col-sm-4 pt-4">
                                        <div class="d-flex flex-column justify-content-center">
                                            <div class="d-flex justify-content-between mb-2" ng-repeat="M in MaritalStatusSumColl">
                                                <span>{{M.MaritalStatusName}}</span>
                                                <span style="color: #92C960; font-weight: bold;">{{M.TotalEmployees}}</span>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                            </div>
                            <div class="card-footer" style="text-align: right; ">
                                <a id="View-MaritalStatus" style="color: #00a859;" ng-click="MaritalStatusDetails()">View All<i class="fas fa-arrow-right" style="color: green;"></i></a>
                            </div>
                        </div>
                    </div>

                    <!-- Department Distribution -->
                    <div class="col-md-4">
                        <div class="card card-default" style="border-radius: 12px;">
                            <div class="card-header p-2 pl-4">
                                <label><b>Department Distribution</b></label>
                            </div>
                            <div class="card-body pt-0 pl-0" style="border-bottom: 1px solid #DCDCDC; border-bottom-left-radius: 12px; border-bottom-right-radius:12px;">
                                <div class="row">
                                    <div class="col-md-8">
                                        <canvas id="statusDistribution" style="height:179px;width:100%"></canvas>
                                    </div>
                                    <div class="col-md-4 pt-4">
                                        <div class="d-flex flex-column justify-content-center">
                                            @*<div class="d-flex justify-content-between mb-2" ng-repeat="M in StatusDistributionColl">
                                                    <span>{{M.Department}}</span>
                                                    <span style="color: #92C960; font-weight: bold;">{{M.TotalEmployees}}</span>
                                                </div>*@
                                        </div>
                                    </div>
                                </div>

                            </div>
                            <div class="card-footer" style="text-align: right; ">
                                <a id="View-StatusDistribution" style="color: #00a859;" ng-click="StatusDistributionDetails()">View All<i class="fas fa-arrow-right" style="color: green;"></i></a>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="p-2 pb-0" @*style="background-color:white;"*@>
                <div class="row">
                    <!-- Leave Details -->
                    <div class="col-md-4">
                        <div class="card card-default" style="border-radius: 12px;">
                            <div class="card-header p-2 pl-4">
                                <label><b>Leave Details</b></label>
                            </div>
                            <div class="card-body pt-0 " style="border-bottom: 1px solid #DCDCDC; border-bottom-left-radius: 12px; border-bottom-right-radius:12px;">
                                <div class="row">
                                    <div class="col-md-7">
                                        <canvas id="LeaveDetails" style="height:202px;width:100%"></canvas>
                                    </div>
                                    <div class="col-md-5 d-flex flex-column justify-content-center" ng-repeat="L in LeaveDetailsColl">
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Leave Request</span>
                                            <span style="color: #92C960; font-weight: bold;">{{L.LeaveRequest}}</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Not Approved Leave</span>
                                            <span style="color:#92C960; font-weight:bold;">{{L.NotApproved}}</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Approved Leave</span>
                                            <span style="color: #92C960; font-weight: bold;">{{L.Approved}}</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Cancelled Leave</span>
                                            <span style="color: #92C960; font-weight: bold;">{{L.Cancelled}}</span>
                                        </div>

                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Rejected Leave</span>
                                            <span style="color: #92C960; font-weight: bold;">{{L.Rejected}}</span>
                                        </div>

                                    </div>
                                </div>
                            </div>
                            <div class="card-footer" style="text-align: right; ">
                                <a id="view-LeaveDetails" style="color: #00a859;">View All<i class="fas fa-arrow-right" style="color: green;"></i></a>
                            </div>
                        </div>
                    </div>

                    <!-- Transfers -->
                    <div class="col-md-4">
                        <div class="card card-default" style="border-radius: 12px;">
                            <div class="card-header p-2 pl-4">
                                <label><b>Transfers</b></label>
                            </div>
                            <div class="card-body p-0" style="border-bottom: 1px solid #DCDCDC; border-bottom-left-radius: 12px; border-bottom-right-radius:12px;">
                                <div class="table">
                                    <table class="styled-table">

                                        <thead>
                                            <tr>
                                                <th style="text-align:center;">S.No.</th>
                                                <th>Name</th>
                                                <th>Designation</th>
                                                <th>Branch</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="T in TransferList track by $index">
                                                <td style="text-align:center;">{{$index+1}}</td>
                                                <td>
                                                    <div class="profile">
                                                        <div class="profile-circle">SG</div>
                                                        <span>{{T.EmployeeName}}</span>
                                                    </div>
                                                </td>
                                                <td>{{T.Designation}}</td>
                                                <td>{{T.Branch}}</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="card-footer" style="text-align: right; ">
                                <a id="view-Transfer" style="color: #00a859;" ng-click="TransferDetails()">View All<i class="fas fa-arrow-right" style="color: green;"></i></a>
                            </div>
                        </div>
                    </div>

                    <!-- Retirement -->
                    <div class="col-md-4">
                        <div class="card card-default" style="border-radius: 12px;">
                            <div class="card-header p-2 pl-4">
                                <label><b>Retirement</b></label>
                            </div>
                            <div class="card-body p-0" style="border-bottom: 1px solid #DCDCDC; border-bottom-left-radius: 12px; border-bottom-right-radius:12px;">
                                <div class="table">
                                    <table class="styled-table">
                                        <thead>
                                            <tr>
                                                <th style="text-align:center;">S.No.</th>
                                                <th>Name</th>
                                                <th>Branch</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="R in RetirementList track by $index">
                                                <td style="text-align:center;">{{$index+1}}</td>
                                                <td>
                                                    <div class="profile">
                                                        <div class="profile-circle">SG</div>
                                                        <span>{{R.EmployeeName}}</span>
                                                    </div>
                                                </td>
                                                <td>{{R.Branch}}</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="card-footer" style="text-align: right; ">
                                <a id="view-Retirement" style="color: #00a859;" ng-click="RetirementDetails()">View All<i class="fas fa-arrow-right" style="color: green;"></i></a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="p-2 pb-0" @*style="background-color:white;"*@>
