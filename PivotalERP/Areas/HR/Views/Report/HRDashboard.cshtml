                        <div class="insidecard p-2" style="background-color: #e4fff1;">
                            <div class="imgcard">
                                <img src="~/wwwroot/dynamic-erp/images/4.png" />
                            </div>
                            <div>
                                <label>Branches</label>
                                <h5>{{beData.Branches}}</h5>
                            </div>
                        </div>
                    </div>

                    <!-- Departments -->
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                        <div class="insidecard p-2" style="background-color: #feeefb;">
                            <div class="imgcard">
                                <img src="~/wwwroot/dynamic-erp/images/5.png" />
                            </div>
                            <div>
                                <label>Departments</label>
                                <h5>{{beData.Departments}}</h5>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="p-2 pb-0">
