                                <img src="~/wwwroot/dynamic-erp/images/1.png" />
                            </div>
                            <div>
                                <label>Total Employees</label>
                                <h5>{{beData.TotalEmployee}}</h5>
                            </div>
                        </div>
                    </div>

                    <!-- New Joins -->
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                        <div class="insidecard p-2" style="background-color: #e7fde5;">
                            <div class="imgcard">
                                <img src="~/wwwroot/dynamic-erp/images/2.png" />
                            </div>
                            <div>
                                <label>New Joins</label>
                                <h5>{{beData.NewJoins}}</h5>
                            </div>
                        </div>
                    </div>

                    <!-- Expiring Contract -->
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                        <div class="insidecard p-2" style="background-color: #d0f7ff;">
                            <div class="imgcard">
                                <img src="~/wwwroot/dynamic-erp/images/3.png" />
                            </div>
                            <div>
                                <label>Expiring Contract</label>
                                <h5>{{beData.ExpiringContract}}</h5>
                            </div>
                        </div>
                    </div>

                    <!-- Branches -->
