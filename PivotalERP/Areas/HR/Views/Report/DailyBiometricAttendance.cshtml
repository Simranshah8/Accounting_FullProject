
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.RptFormsEntity.Att_DailyBiometricAttendance)";
</script>


<script src="~/jslib/hr/Report/DailyBiometricAttendance.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="DailyBiometricAttendanceController" ng-init="LoadData()">
    <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
        <div class="overflow-hidden">
            <nav id="sidebarzz" class="order-last float-right active">
                <div class="custom-menu">
                    <button type="button" id="ctmRightSidebarCollapse" class="btn btn-primary"></button>
                </div>
                <div class="" id="firstpanel">
                    <div class="right-box-wrap">
                        <!--Add the required Contents of sidebar-->
                        <div class="d-xl-block" style="height: 200px;"></div>
                    </div>
                </div>
            </nav>
            <div class="content-wrapper-new">
                <section class="">
                    <div class="container-fluid">
                        <section class="iframe-content-starts-here">
                            <div class="tab-content">
                                <div id="day-book-section">
                                    <div class="card px-2 pt-2 pb-0">
                                        <div class="row">
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label> For Date</label>
                                                    <input type="text"
                                                           class="form-control form-control-sm" date-picker ng-model="newDaily.ForDate_TMP" date-detail="newDaily.ForDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group" ng-show="CompanyRelationshipList.length>1">
                                                    <label> Company</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newDaily.CompanyId" style="width: 100%;">
                                                        <option ng-value="0">**Select All**</option>
                                                        <option ng-repeat="tdc in CompanyRelationshipList" ng-value="tdc.TranId"> {{tdc.Name}} </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group" ng-show="BranchList.length>1">
                                                    <label> Branch</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newDaily.BranchId">
                                                        <option ng-value="0" selected>All</option>
                                                        <option ng-value="brc.BranchId" ng-repeat="brc in BranchList">{{brc.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group" ng-show="DepartmentList.length>1">
                                                    <label> Department</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newDaily.DepartmentId">
                                                        <option ng-value="0" selected>All</option>
                                                        <option ng-value="D.CostCenterDepartmentId" ng-repeat="D in DepartmentList">{{D.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                           
                                        </div>
                                        <header class="row">
                                            <div class="col-md-5 col-sm-5">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm" style="width: 250px;">
                                                            <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">
                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-default"><i class="fas fa-search"></i></button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                            <div class="col-md-7 col-sm-7">
                                                <form class="form-inline float-right">
                                                    <button class="btn btn-sm btn-info load" style="min-width: 90px;" type="button" ng-click="GetDailyAttendance()"><i class="fas fa-sync-alt mr-2"></i>Load</button>
                                                    <div class="dropdown dnld-file ml-2">
                                                        <div class="dropdown dnld-file ml-2" data-toggle="tooltip"
                                                             data-placement="top" title="Download File">
                                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                    type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                    aria-haspopup="true" aria-expanded="false">
                                                                <i class="fas fa-download"></i>
                                                            </button>
                                                            <div class="dropdown-menu dropdown-menu-right"
                                                                 aria-labelledby="dropdownMenuButton">
                                                                <span class="dropdown-item">Choose an option:</span>
                                                                <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                    <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                         class="img-fluid exports-icon" alt="Excel image">
                                                                    Excel
                                                                </a>
                                                                <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                                    <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                         class="img-fluid exports-icon">
                                                                    CSV
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <a print-tbl table-id="'#DailyAppAttendance'" report-name="'Daily App Attendance'" class="btn btn-secondary btn-light btn-sm wait" title="Print"><i class="fas fa-print"></i></a>
                                                </form>
                                            </div>
                                        </header>
                                        <div class="row">
                                            <div class="col-md-2 col-sm-2">
                                                <label><b>Total Employees: {{newDaily.TotalEmployees}}</b></label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label>
                                                    <b>
                                                        Present: {{newDaily.TotalPresent || 0 }} ({{ ((newDaily.TotalPresent || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)
                                                    </b>
                                                </label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label>
                                                    <b>
                                                        Absent: {{newDaily.TotalAbsent || 0 }} ({{ ((newDaily.TotalAbsent || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)
                                                    </b>
                                                </label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label>
                                                    <b>
                                                        Leave: {{newDaily.TotalLeave || 0 }} ({{ ((newDaily.TotalLeave || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)
                                                    </b>
                                                </label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label><b>Weekend:   {{newDaily.TotalWeekEnd || 0 }} ({{ ((newDaily.TotalWeekEnd || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)</b></label>
                                            </div>
                                        </div>
                                        <div id="datatable" style="height: calc(100vh - 9rem);width: 100%;" class="ag-theme-alpine"></div>
                                    </div>

                                </div>
                            </div>
                        </section>
                        <!-- /.row -->
                    </div>
                    <!--/. container-fluid -->
                </section>
            </div>
            <!-- /.content -->
        </div>
    </div>
</div>
<script>
    (function ($) {
        "use strict";
        var fullHeight = function () {
            $('.js-fullheight').css('height', $(window).height());
            $(window).resize(function () {
                $('.js-fullheight').css('height', $(window).height());
            });

        };
        fullHeight();
        $('#ctmRightSidebarCollapse').on('click', function () {
            $('#sidebarzz').toggleClass('active');
        });

    })(jQuery);
</script>