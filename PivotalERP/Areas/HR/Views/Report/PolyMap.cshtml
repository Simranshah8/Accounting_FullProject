
@{

    ViewBag.Title = "";
    Layout = null;
}
<meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests">

@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.3.1/leaflet.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.3.1/leaflet.js"></script>
<script src="~/jslib/map/leaflet.polylineDecorator.js"></script>

@*<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-polylinedecorator@1.7.2/dist/leaflet.polylineDecorator.min.js"></script>*@
<script src="~/jslib/hr/report/PolyMap.js"></script>

<div class="hold-transition layout-navbar-fixed" ng-app="myApp" ng-controller="OutLetMapController">
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="tab-content">
                    <div id="day-book-section">
                        <div class="card p-2">
                            <div class="row">
                                <div class="col-sm-3">
                                    <div class="d-inline-block">
                                        <div class="input-group input-group-sm">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">From:</span>
                                            </div>
                                            <input class="form-control text-dark input-sm" type="text" date-picker ng-model="newFilter.DateFrom_TMP" style="max-width:100px" date-detail="newFilter.DateFromDet" />
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">To:</span>
                                            </div>
                                            <input class="form-control text-dark input-sm" type="text" date-picker ng-model="newFilter.DateTo_TMP" style="max-width:100px" date-detail="newFilter.DateToDet" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label>Employee</label>
                                        </div>
                                        <div class="col-md-8">
                                            @*<select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newFilter.AgentId">
                                                    <option ng-value="pg.AgentId" ng-repeat="pg in SalesManList">{{pg.Name}}-{{pg.Code}}</option>
                                                </select>*@
                                            <select class="form-control form-select form-control-sm select2" ng-model="newFilter.UserId" style="width: 100%;" data-placeholder="**select Employee**">
                                                <option ng-repeat="E in EmployeeProfileList" ng-value="E.UserId">{{E.Name}}-{{E.EmployeeCode}}</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label>Total Distance</label>
                                        </div>
                                        <div class="col-md-6">
                                            {{newFilter.Distance}} K.M.
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-1 ">
                                    <div class="form-group">
                                        <a href="#" class="btn btn-primary load" style="float: right; min-width: 60px" data-toggle="tooltip" data-placement="top" title="" data-original-title="Load" ng-click="GetOutLet()" ng-disabled="loadingstatus=='running'"><i class="fas fa-download"> &nbsp;&nbsp;Load  {{DataColl.length}}</i></a>
                                    </div>
                                </div>

                            </div>

                        </div>
                        <div class="card p-2">
                            <div class="row">
                                <div class="col-md-12">
                                    <!-- Map Embed -->
                                    <div style="height: calc(100vh - 8rem);" id="map">

                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>

                </div>

            </section>
            <!-- /.row -->
        </div>
        <!--/. container-fluid -->
    </section>

</div>


<script src="https://unpkg.com/leaflet-polylinedecorator@1.7.0/dist/leaflet.polylineDecorator.min.js"></script>