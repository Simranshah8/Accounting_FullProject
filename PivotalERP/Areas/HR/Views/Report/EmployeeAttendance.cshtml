

@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script src="~/jslib/export/tableExport.js"></script>

<script src="~/jslib/hr/Report/EmployeeAttendance.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="EmployeeAttendanceController" @*ng-init="LoadData()"*@>
    <div class="box-body">
        <!-- Main content -->
        <div class="content">
            <div class="container-fluid">

                <div class="card card-primary card-outline card-outline-tabs">

                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="myTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <a class="nav-link active" id="home-tab" data-toggle="tab" href="#home" role="tab"
                                   aria-controls="home" aria-selected="true">Daily Biometric Attendance</a>
                            </li>

                            <li class="nav-item" role="presentation">
                                <a class="nav-link" id="student-tab" data-toggle="tab" href="#student" role="tab"
                                   aria-controls="student" aria-selected="false">Attendance Summary</a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" id="medium-tab" data-toggle="tab" href="#medium" role="tab"
                                   aria-controls="medium" aria-selected="false">Employee Attendance</a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" id="manual-tab" data-toggle="tab" href="#manual" role="tab"
                                   aria-controls="manual" aria-selected="false">Manual Attendance</a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" id="absent-tab" data-toggle="tab" href="#absent" role="tab"
                                   aria-controls="absent" aria-selected="false">Absent Only</a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" id="inoutdet-tab" data-toggle="tab" href="#inoutdet" role="tab"
                                   aria-controls="inoutdet" aria-selected="false">InOut Details</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body p-2">
                        <div class="tab-content" id="myTabContent">
                            <!-- Daily Biometric Attendance starts -->
                            <div class="tab-pane fade show active main-section" id="home" role="tabpanel"
                                 aria-labelledby="home-tab">
                                <div class="tab-content">
                                    <div id="day-book-section">
                                        <div class="row">
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label> For Date</label>
                                                    <input type="text"
                                                           class="form-control form-control-sm" date-picker ng-model="newDaily.ForDate_TMP" date-detail="newDaily.ForDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-5">
                                                <div class="form-group" ng-show="BranchList.length>1">
                                                    <label> Branch</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newDaily.BranchId">
                                                        <option ng-value="0" selected>All</option>
                                                        <option ng-value="brc.BranchId" ng-repeat="brc in BranchList">{{brc.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-5 mt-4">
                                                <div class="float-right form-inline">
                                                    <button class="btn btn-sm btn-info load" style="min-width: 90px;" type="button" ng-click="GetDailyAttendance()">Load</button>
                                                    <div class="dropdown dnld-file ml-2" data-toggle="tooltip"
                                                         data-placement="top" title="Download File">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right"
                                                             aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                     class="img-fluid exports-icon" alt="Excel image">
                                                                Excel
                                                            </a>
                                                            <a class="dropdown-item" href="#" ng-click="csvDailyAttendance()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                     class="img-fluid exports-icon">
                                                                CSV
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       data-toggle="tooltip" data-placement="bottom" title="Print">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-2 col-sm-2">
                                                <label><b>Total Employees: {{newDaily.TotalEmployees}}</b></label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label>
                                                    <b>
                                                        Present: {{newDaily.TotalPresent || 0 }} ({{ ((newDaily.TotalPresent || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)
                                                    </b>
                                                </label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label>
                                                    <b>
                                                        Absent: {{newDaily.TotalAbsent || 0 }} ({{ ((newDaily.TotalAbsent || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)
                                                    </b>
                                                </label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label>
                                                    <b>
                                                        Leave: {{newDaily.TotalLeave || 0 }} ({{ ((newDaily.TotalLeave || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)
                                                    </b>
                                                </label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label><b>Weekend:   {{newDaily.TotalWeekEnd || 0 }} ({{ ((newDaily.TotalWeekEnd || 0) / (newDaily.TotalEmployees || 1)) * 100 | number:2 }} %)</b></label>
                                            </div>
                                        </div>
                                        <div id="datatable" style="height: calc(100vh - 9rem);width: 100%;" class="ag-theme-alpine"></div>
                                    </div>
                                </div>
                            </div>
                            <!-- Daily Biometric Attendance ends -->
                            <!-- Attendance Summary Starts -->
                            <div class="tab-pane fade main-section" id="student" role="tabpanel" aria-labelledby="student-tab">
                                <div class="tab-content">
                                    <div id="day-book-section">
                                        <div class="row">
                                            <div class="col-md-2">
                                                <label>Year</label>
                                                <select name="class-group" id="" form="" class="form-control form-control-sm " ng-model="newMonthly.YearId">
                                                    <option ng-value="cl.id" ng-repeat="cl in YearList" ng-selected="cl.id==newMonthly.YearId">{{cl.text}}</option>
                                                </select>
                                            </div>
                                            <div class="col-md-2">
                                                <label>For Month</label>
                                                <select name="class-group" id="" form="" class="form-control form-control-sm " ng-model="newMonthly.MonthId">
                                                    <option ng-value="cl.id" ng-repeat="cl in MonthList" ng-selected="cl.id==newMonthly.MonthId">{{cl.text}}</option>
                                                </select>
                                            </div>
                                            <div class="col-md-5">
                                                <div class="form-group" ng-show="BranchList.length>1">
                                                    <label> Branch</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newMonthly.BranchId">
                                                        <option ng-value="0" selected>All</option>
                                                        <option ng-value="brc.BranchId" ng-repeat="brc in BranchList">{{brc.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-md-3 mt-4">
                                                <div class="float-right form-inline">
                                                    <button class="btn btn-sm btn-info load" style="min-width: 90px;" type="button" ng-click="GetMonthAttendance()">Load</button>
                                                    <div class="dropdown dnld-file ml-2" data-toggle="tooltip"
                                                         data-placement="top" title="Download File">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right"
                                                             aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                     class="img-fluid exports-icon" alt="Excel image">
                                                                Excel
                                                            </a>
                                                            <a class="dropdown-item" href="#" ng-click="csvMonthAttendance()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                     class="img-fluid exports-icon">
                                                                CSV
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       data-toggle="tooltip" data-placement="bottom" title="Print">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="pt-1">
                                            <div id="datatable1" style="height: calc(100vh - 8rem);width: 100%;" class="ag-theme-alpine"></div>
                                        </div>
                                    </div>

                                    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="EmpDetail" role="dialog" tabindex="-1">
                                        <div class="modal-dialog modal-md" style="max-width: 500px !important;" role="document">
                                            <div class="modal-content" >
                                                <div class="modal-header p-2">
                                                    <h5 class="modal-title">Employee Attendance Details for Day {{modalDetails.Day}}</h5>
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                        <span aria-hidden="true">&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body mb-0 p-2">
                                                    <p><strong>Employee Code:</strong> {{modalDetails.EmpCode}}</p>
                                                    <p><strong>Name:</strong> {{modalDetails.Name}}</p>
                                                    <p><strong>Designation:</strong> {{modalDetails.Designation}}</p>
                                                    <p><strong>Date:</strong> {{modalDetails.FullDate}}</p>
                                                    <p><strong>In Time:</strong> {{modalDetails.LateInMinutes || "N/A"}}</p>
                                                    <p><strong>Out Time:</strong> {{modalDetails.OutTime || "N/A"}}</p>
                                                </div>

                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            <!-- Attendance Summary Ends -->
                            <!-- Employee Attendance Starts -->
                            <div class="tab-pane fade main-section" id="medium" role="tabpanel" aria-labelledby="medium-tab">
                                <div class="tab-content">
                                    <div id="day-book-section">
                                        <div class="row">
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label> Date From</label>
                                                    <input type="text"
                                                           class="form-control form-control-sm" date-picker ng-model="newEmp.DateFrom_TMP" date-detail="newEmp.DateFromDet">
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label> Date To</label>
                                                    <input type="text"
                                                           class="form-control form-control-sm" date-picker ng-model="newEmp.DateTo_TMP" date-detail="newEmp.DateToDet">
                                                </div>
                                            </div>
                                            <div class="col-md-5 mt-4" id="selectStu">
                                                <label class="sr-only"
                                                       for="inlineFormInputGroup">Select Employee</label>
                                                <div class="input-group-prepend">
                                                    <select class="input-group-text dropdown-toggle p-0"
                                                            style="outline: none;
                                                            border-top-right-radius: unset;
                                                            border-bottom-right-radius: unset;
                                                            margin-right: -3px;
                                                            z-index: 1;
                                                            font-size: 13px;
                                                    " ng-model="newEmp.SelectEmployee">

                                                        <option ng-repeat="ss in EmployeeSearchOptions" ng-value="ss.value" ng-selected="ss.value==newEmp.SelectEmployee">
                                                            {{ss.text}}
                                                        </option>

                                                    </select>

                                                    <select class="form-control select2 form-control-sm" all-employee ng-model="newEmp.EmployeeId" employee-detail="newEmp.EmployeeDetails" side-bar-data="newEmp.EmpSideBarData" search-by="newEmp.SelectEmployee" style="width: 100%;" confirm-action="getEmpBIOAttendance()">
                                                    </select>

                                                </div>
                                            </div>
                                            <div class="col-md-3 mt-4">
                                                <div class="float-right form-inline">
                                                    <button class="btn btn-sm btn-info load" ng-click="getEmpBIOAttendance()" style="min-width: 90px;">Load</button>
                                                    <div class="dropdown dnld-file ml-2" data-toggle="tooltip"
                                                         data-placement="top" title="Download File">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right"
                                                             aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                     class="img-fluid exports-icon" alt="Excel image">
                                                                Excel
                                                            </a>
                                                            <a class="dropdown-item" href="#" ng-click="csvEmpBIOAttendance()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                     class="img-fluid exports-icon">
                                                                CSV
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       data-toggle="tooltip" data-placement="bottom" title="Print">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-2 col-sm-2">
                                                <label><b>Total Days: {{newEmp.TotalDays}}</b></label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label><b>Present: {{newEmp.TotalPresent}}</b></label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label><b>Absent: {{newEmp.TotalAbsent}}</b></label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label><b>Weekend: {{newEmp.TotalWeekEnd}}</b></label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label><b>Holiday: {{newEmp.TotalHoliday}}</b></label>
                                            </div>
                                            <div class="col-md-2 col-sm-2">
                                                <label><b>Total OT Hours: {{newEmp.TotalOTHours}}</b></label>
                                            </div>
                                        </div>
                                        <div class="">
                                            <div id="datatable3" style="height: calc(100vh - 9rem);width: 100%;" class="ag-theme-alpine"></div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Employee Attendance Ends -->
                            <!-- Manual Attendance Starts -->
                            <div class="tab-pane fade main-section" id="manual" role="tabpanel" aria-labelledby="manual-tab">
                                <div class="tab-content">
                                    <div id="day-book-section">
                                        <div class="row">
                                            <div class="col-md-3">
                                                <div class="form-group">
                                                    <label>For Date</label>
                                                    <input type="text"
                                                           class="form-control form-control-sm" date-picker ng-model="newManual.ForDate_TMP" date-detail="newManual.ForDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-5">
                                                <div class="form-group" ng-show="BranchList.length>1">
                                                    <label> Branch</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newManual.BranchId">
                                                        <option ng-value="0" selected>All</option>
                                                        <option ng-value="brc.BranchId" ng-repeat="brc in BranchList">{{brc.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4 mt-4">
                                                <div class="float-right form-inline">
                                                    <button class="btn btn-sm btn-info load" style="min-width: 90px;" ng-click="GetManualDailyAttendance()">Load</button>
                                                    <div class="dropdown dnld-file ml-2" data-toggle="tooltip"
                                                         data-placement="top" title="Download File">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right"
                                                             aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                     class="img-fluid exports-icon" alt="Excel image">
                                                                Excel
                                                            </a>
                                                            <a class="dropdown-item" href="#" ng-click="csvManualDaily()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                     class="img-fluid exports-icon">
                                                                CSV
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       data-toggle="tooltip" data-placement="bottom" title="Print">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="">
                                            <div id="datatable4" style="height: calc(100vh - 9rem);width: 100%;" class="ag-theme-alpine"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Manual Attendance Ends -->
                            <!-- Absent Only Starts -->
                            <div class="tab-pane fade show main-section" id="absent" role="tabpanel"
                                 aria-labelledby="absent-tab">
                                <div class="tab-content">
                                    <div id="day-book-section">
                                        <div class="row">
                                            <div class="col-md-3">
                                                <div class="form-group">
                                                    <label> For Date</label>
                                                    <input type="text"
                                                           class="form-control form-control-sm" date-picker ng-model="newAbsent.ForDate_TMP" date-detail="newAbsent.ForDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-5">
                                                <div class="form-group" ng-show="BranchList.length>1">
                                                    <label> Branch</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newAbsent.BranchId">
                                                        <option ng-value="0" selected>All</option>
                                                        <option ng-value="brc.BranchId" ng-repeat="brc in BranchList">{{brc.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4 mt-4">
                                                <div class="float-right form-inline">
                                                    <button class="btn btn-sm btn-info load" style="min-width: 90px;" type="button" ng-click="GetEmpAbsentAttendance()">Load</button>
                                                    <div class="dropdown dnld-file ml-2" data-toggle="tooltip"
                                                         data-placement="top" title="Download File">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right"
                                                             aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                     class="img-fluid exports-icon" alt="Excel image">
                                                                Excel
                                                            </a>
                                                            <a class="dropdown-item" href="#" ng-click="csvEmpAbsent()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                     class="img-fluid exports-icon">
                                                                CSV
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       data-toggle="tooltip" data-placement="bottom" title="Print">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="">
                                            <div id="datatable5" style="height: calc(100vh - 9rem);width: 100%;" class="ag-theme-alpine"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Daily Biometric Attendance ends -->
                            <!-- Absent Only Ends -->
                            <!-- Date Wise In Out Details Starts -->
                            <div class="tab-pane fade show main-section" id="inoutdet" role="tabpanel"
                                 aria-labelledby="inoutdet-tab">
                                <div class="tab-content">
                                    <div id="day-book-section">
                                        <div class="row">
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label> From Date</label>
                                                    <input type="text"
                                                           class="form-control form-control-sm" date-picker ng-model="newInOutDet.FromDate_TMP" date-detail="newInOutDet.FromDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label> To Date</label>
                                                    <input type="text"
                                                           class="form-control form-control-sm" date-picker ng-model="newInOutDet.ToDate_TMP" date-detail="newInOutDet.ToDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <label>Select Report </label>
                                                <select name="comment-group" id="" form="" class="form-control form-control-sm select2" ng-change="PrintInOutDet()" ng-model="newInOutDet.RptTranId">
                                                    <option ng-value="0" ng-selected="true">Select Report</option>
                                                    <option ng-value="rt.RptTranId" ng-repeat="rt in newInOutDet.TemplatesColl">{{rt.ReportName}}</option>
                                                </select>
                                            </div>
                                            <div class="col-md-4 mt-4">
                                                <div class="float-right">
                                                    <button class="btn btn-sm btn-info load" style="min-width: 90px;" type="button" ng-click="PrintInOutDet()">Load</button>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="">
                                            <div class="row">
                                                <iframe id="frmRptTabulation" style='width: 100%;height:calc(100vh - 200px);background-color: white;visibility: visible;' frameborder='0' scrolling='yes'></iframe>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Daily Biometric Attendance ends -->
                            <!-- Absent Only Ends -->
                        </div>


                        <!-- /.row -->
                    </div>
                </div>
                <!--/. container-fluid -->
            </div>
            <!-- /.content -->
        </div>

    </div>

</div>
