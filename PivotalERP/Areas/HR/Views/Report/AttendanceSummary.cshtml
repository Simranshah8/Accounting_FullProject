
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.RptFormsEntity.Att_AttendanceSummary)";
</script>

<script src="~/jslib/hr/Report/AttendanceSummary.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="AttendanceSummaryController" ng-init="LoadData()">
    <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
        <div class="overflow-hidden">
            <nav id="sidebarzz" class="order-last float-right active">
                <div class="custom-menu">
                    <button type="button" id="ctmRightSidebarCollapse" class="btn btn-primary"></button>
                </div>
                <div class="" id="firstpanel">
                    <div class="right-box-wrap">
                        <!--Add the required Contents of sidebar-->
                        <div class="d-xl-block" style="height: 200px;"></div>
                    </div>
                </div>
            </nav>
            <div class="content-wrapper-new">
                <section class="">
                    <div class="container-fluid">
                        <section class="iframe-content-starts-here">
                            <div class="tab-content">
                                <div id="day-book-section">
                                    <div class="card px-2 pt-2 pb-0">
                                        <div class="row">
                                            <div class="col-md-1">
                                                <label>Year</label>
                                                <select name="class-group" id="" form="" class="form-control form-control-sm " ng-model="newMonthly.YearId">
                                                    <option ng-value="cl.id" ng-repeat="cl in YearList" ng-selected="cl.id==newMonthly.YearId">{{cl.text}}</option>
                                                </select>
                                            </div>
                                            <div class="col-md-2">
                                                <label>Month</label>
                                                <select name="class-group" id="" form="" class="form-control form-control-sm " ng-model="newMonthly.MonthId">
                                                    <option ng-value="cl.id" ng-repeat="cl in MonthList" ng-selected="cl.id==newMonthly.MonthId">{{cl.text}}</option>
                                                </select>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label> Company</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newMonthly.CompanyRelationshipId" style="width: 100%;">
                                                        <option ng-value="0">**Select All**</option>
                                                        <option ng-repeat="tdc in CompanyRelationshipList" ng-value="tdc.TranId"> {{tdc.Name}} </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label> Branch</label>
                                                    <multi-select-option ng-model="newMonthly.BranchIds" data="BranchList" label="Name" value="BranchId"></multi-select-option>
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label>Department</label>
                                                    <multi-select-option ng-model="newMonthly.DepartmentIds" data="DepartmentList" label="Name" value="CostCenterDepartmentId"></multi-select-option>
                                                </div>
                                            </div>
                                        </div>
                                        <header class="row">
                                            <div class="col-md-5 col-sm-5">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm" style="width: 250px;">
                                                            <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">
                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-default"><i class="fas fa-search"></i></button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                            <div class="col-md-7 col-sm-7">
                                                <form class="form-inline float-right">
                                                    <button class="btn btn-sm btn-info load" style="min-width: 90px;" type="button" ng-click="GetMonthAttendance()"><i class="fas fa-sync-alt mr-2"></i>Load</button>
                                                    <div class="dropdown dnld-file ml-2">
                                                        <div class="dropdown dnld-file ml-2" data-toggle="tooltip"
                                                             data-placement="top" title="Download File">
                                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                    type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                    aria-haspopup="true" aria-expanded="false">
                                                                <i class="fas fa-download"></i>
                                                            </button>
                                                            <div class="dropdown-menu dropdown-menu-right"
                                                                 aria-labelledby="dropdownMenuButton">
                                                                <span class="dropdown-item">Choose an option:</span>
                                                                <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                    <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                         class="img-fluid exports-icon" alt="Excel image">
                                                                    Excel
                                                                </a>
                                                                <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                                    <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                         class="img-fluid exports-icon">
                                                                    CSV
                                                                </a>
                                                                <a class="dropdown-item" href="#" ng-click="DownloadDetAsXls()">
                                                                    <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                         class="img-fluid exports-icon" alt="Excel image">
                                                                    Details Excel
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </header>
                                        <div id="datatable1" style="height: calc(100vh - 8rem);width: 100%;" class="ag-theme-alpine"></div>
                                    </div>

                                    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="EmpDetail" role="dialog" tabindex="-1">
                                        <div class="modal-dialog modal-md" style="max-width: 500px !important;" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header p-2">
                                                    <h5 class="modal-title">Employee Attendance Details for Day {{modalDetails.Day}}</h5>
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                        <span aria-hidden="true">&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body mb-0 p-2">
                                                    <p><strong>Employee Code:</strong> {{modalDetails.EmpCode}}</p>
                                                    <p><strong>Name:</strong> {{modalDetails.Name}}</p>
                                                    <p><strong>Designation:</strong> {{modalDetails.Designation}}</p>
                                                    <p><strong>Date:</strong> {{modalDetails.FullDate}}</p>
                                                    <p><strong>In Time:</strong> {{modalDetails.LateInMinutes || "N/A"}}</p>
                                                    <p><strong>Out Time:</strong> {{modalDetails.OutTime || "N/A"}}</p>
                                                </div>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                        <!-- /.row -->
                    </div>
                    <!--/. container-fluid -->
                </section>
            </div>
            <!-- /.content -->
        </div>
    </div>
</div>
<script>
    (function ($) {
        "use strict";
        var fullHeight = function () {
            $('.js-fullheight').css('height', $(window).height());
            $(window).resize(function () {
                $('.js-fullheight').css('height', $(window).height());
            });

        };
        fullHeight();
        $('#ctmRightSidebarCollapse').on('click', function () {
            $('#sidebarzz').toggleClass('active');
        });

    })(jQuery);
</script>