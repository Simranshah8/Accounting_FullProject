
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.HR_EmployeeProfile)";
</script>



<script src="~/jslib/hr/master/EmployeeProfile.js"></script>

<div ng-app="myApp" ng-controller="EmployeeProfileController" ng-init="LoadData()">

    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-body p-2">
                        <div class="tab-content">
                            <div id="employee-profile-section">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm mr-2">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-select form-control border-left-0 border-right-0 px-1" ng-model="perPage.Employee" style="width:65px;" ng-change="GetEmployeeWithPag()">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.Employee">{{pp.text}}</option>
                                                    </select>

                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.Employee" ng-change="GetEmployeeWithPag()">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file" data-placement="top" title="Download File">
                                            <a class="btn btn-secondary btn-light btn-sm wait" title="Refresh" ng-click="GetEmployeeWithPag()">
                                                <i class="fas fa-redo-alt"></i>
                                            </a>
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#EmployeeProfile'" sheet-name="'EmployeeProfile'" report-name="'Employee Profile'" ignore-column="'5'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#EmployeeProfile').tableExport({type:'csv',escape:'false',reportName:'Employee Profile',ignoreColumn:'5' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                                 </div>
                                            <a print-tbl table-id="'#EmployeeProfile'" class="btn btn-secondary btn-light btn-sm wait"title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-primary load" ng-click="ClearEmpProfile()" id="add-employee-details" style="min-width: 110px;">
                                                <i class="fas fa-plus w-t"></i> Add Employee
                                            </button>
                                        </div>


                                    </div>
                                </header>
                                <div class="table-scroll-x-y" style="height:auto!important;max-height: calc(100vh - 6rem)!important; ">
                                    <table cellpadding="12" class="table table-bordered table-striped table-hover table-sm" id="EmployeeProfile">
                                        <thead>
                                            <tr>
                                                <th style="text-align: center; width: 60px; background-color:#ececec !important;"> S.No  </th>
                                                <th style="text-align: center; width: 120px; background-color:#ececec !important;" title="Employee Code"> E. Code  </th>
                                                <th style="text-align: center; width: 150px; background-color:#ececec !important;" title="Employee Name">  Name </th>
                                                <th style="text-align: center; width: 150px; background-color:#ececec !important;" title="Department"> Department </th>
                                                <th style="text-align: center; width: 150px; background-color:#ececec !important;" title="Designation"> Designation </th>
                                                <th style="text-align: center; width: 200px; background-color:#ececec !important;" title="EmailId"> EmailId </th>
                                                <th style="text-align: center; width: 150px; background-color:#ececec !important;" title="Contact No"> Contact No</th>
                                                <th style="text-align: center; width: 150px; background-color:#ececec !important;" title="Enroll Number"> Enroll Number </th>
                                                <th style="text-align: center; width: 150px; background-color:#ececec !important;" title="Branch"> Branch </th>
                                                <th style="text-align: center; width: 150px; background-color: #ececec !important;" class="no-print">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr dir-paginate="E in AllEmployeeList | filter:searchData.Employee |orderBy:sortKey:reverse|itemsPerPage:perPage.Employee" total-items="paginationOptions.TotalRows">
                                                <td style="text-align:center;margin:auto">
                                                    {{$index+1}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{E.EmployeeCode}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{E.Name}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{E.DepartmentName}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{E.DesignationName}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{E.EmailId}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{E.ContactPer}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{E.EnrollNumber}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{E.BranchName}}
                                                </td>
                                                <td class="project-actions align-middle no-print" style="text-align:center;">
                                                    <div class="btn-group-sm">
                                                        <a href="#" class="btn btn-info btn-sm my-1" ng-click="getEmployeeById(E)"><i class="fas fa-pencil-alt"></i></a>
                                                        <a href="~/HR/Master/Employee?EmployeeId= {{E.EmployeeId}}" class="btn btn-primary btn-sm my-1"><i class="fas fa-pencil-alt"></i></a>
                                                        <a href="#" class="btn btn-danger btn-sm my-1" ng-click="DelEmployeeById(E)"><i class="fas fa-trash"></i></a>
                                                        <a href="~/HR/Master/EmpPrint?EmployeeId= {{E.EmployeeId}}" class="btn btn-secondary my-1 btn-sm"><i class="fas fa-print"></i></a>
                                                        <a href="#" class="btn btn-info btn-sm my-1" ng-click="getDocViewById(E)"><i class="fas fa-eye"></i></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>

                                </div>
                                <div class="col-md-12">
                                    <dir-pagination-controls max-size="perPage.Employee" direction-links="true" boundary-links="true" on-page-change="ReSearchData(newPageNumber)">
                                    </dir-pagination-controls>
                                </div>
                            </div>

                            <div id="employee-profile-form">
                                <form>
                                    <div class="timeline registration mt-3">
                                        <!-- Timeline for  Permanent Address* -->
                                        <div class="time-label">
                                            <span style="border: 2px solid #dee2e6;">
                                                Employee Detail <span style="color:red">*</span>
                                            </span>
                                        </div>
                                        <div class="row ml-5">
                                            <div class="col-md-9 ">
                                                <div class="row">
                                                    <div class="col-sm-4" hidden>
                                                        <div class="form-group">
                                                            <label>Employee Id</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.EmployeeNo" disabled>
                                                        </div>
                                                    </div>

                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Employee Code<span style="color:red">*</span></label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.EmployeeCode" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Enroll Number</label>
                                                            <input type="number" class="form-control form-control-sm" ng-model="newDet.EnrollNumber" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>First Name <span style="color:red">*</span></label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.FirstName" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Middle Name</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.MiddleName" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Last Name <span style="color:red">*</span></label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.LastName" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Gender <span style="color:red">*</span></label>
                                                            <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.GenderId">
                                                                <option ng-repeat="G in GenderColl" ng-value="G.text" ng-selected="G.GenderId == G.text">{{ G.text}}</option>
                                                            </select>
                                                        </div>
                                                    </div>

                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Blood Group</label>
                                                            <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.BloodGroupId">
                                                                <option ng-repeat="G in BloodGroupColl" ng-value="G.text" ng-selected="G.BloodGroupId == G.text">{{ G.text}}</option>
                                                            </select>
                                                        </div>
                                                    </div>

                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Religion <span style="color:red">*</span></label>
                                                            <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.ReligionId" id="religionName">
                                                                <option ng-repeat="G in ReligionColl" ng-value="G.id" ng-selected="G.ReligionId == G.id">{{ G.text}}</option>
                                                            </select>
                                                        </div>
                                                    </div>


                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Date of Birth (BS)</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.DobAD_TMP"
                                                                   date-detail="newDet.DobADDet" after-days="0" confirm-action="updateDOB()" @*ng-blur="updateDOB(); updateRetirementDate()"*@>
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Date of Birth (AD)</label>
                                                            <input type="date" class="form-control form-control-sm" ng-model="newDet.DobAD_TMP" style="width:100%">
                                                        </div>
                                                    </div>

                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Marital Status <span style="color:red">*</span></label>
                                                            <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.MaritalStatusId">
                                                                <option ng-repeat="G in MaritalStatusColl" ng-value="G.id" ng-selected="G.MaritalStatusId == G.id">{{ G.text}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Nationality <span style="color:red">*</span></label>
                                                            <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.NationalityId">
                                                                <option ng-repeat="G in NationalityList" ng-value="G.NationalityId" ng-selected="newDet.NationalityId == G.NationalityId">{{G.Name}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Pan Id</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.PanId" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Citizenship No</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.CitiNum" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Citizenship Issue Date</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.CitiIssueDate_TMP" date-detail="newDet.CitiIssueDateDet" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>CitizenShip Issue Place</label>
                                                            <select class="form-control form-control-sm select2" id="cboDistrictCiti" style="width: 100%;" ng-model="newDet.CitiIssuePlaceId" data-placeholder="* select district *">
                                                                <option ng-repeat="tdc in DistrictColl" ng-value="tdc.id" ng-selected="tdc.id==newDet.CitiIssuePlaceId">
                                                                    {{tdc.text}}
                                                                </option>
                                                            </select>

                                                        </div>
                                                    </div>

                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Email Id</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.EmailId" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Office Contact No.</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.OfficeNum" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Personal Contact No.</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.PersonalNum" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Father Name <span style="color:red">*</span></label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.FatherName" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Mother Name</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.MotherName" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Grand Father</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.GFatherName" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label for="">Spouse Name</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.SpouseName">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Anniversary Date</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.AnniversaryDate_TMP" date-detail="newDet.AnniversaryDateDet" style="width:100%">
                                                        </div>
                                                    </div>

                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Driving Licence No</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.DrivingLicNum" style="width:100%">
                                                        </div>
                                                    </div>

                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Licence Issue Place</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.LicIssuePlace" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Licence Issue Date</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.LicIssueDate_TMP" date-detail="newDet.LicIssueDateDet" style="width:100%">
                                                        </div>
                                                    </div>

                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Licence Expiry Date</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.LicExpiryDate_TMP" date-detail="newDet.LicExpiryDateDet" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Passport No</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.PassportNum" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Passport Issue Date</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.PassportIssueDate_TMP" date-detail="newDet.PassportIssueDateDet" style="width:100%">
                                                        </div>
                                                    </div>

                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Passport Expiry Date</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.PassportExpiryDate_TMP" date-detail="newDet.PassportExpiryDateDet" style="width:100%">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Passport Issue Place</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.PassportIssuePlace" placeholder="* Enter Passport Issue Place *" style="width:100%">
                                                        </div>
                                                    </div>

                                                    <div class="col-sm-{{uf.ColWidth}}" ng-repeat="uf in UDFFeildsColl | filter: { FieldAfter: 1 }:true">
                                                        <div class="form-group">
                                                            <label>{{uf.Name}} <span style="color:red" ng-show="uf.IsMandatory==true">*</span></label>
                                                            <udf-field udf="uf" change-event="ChangeUDFField(uf.NameId)"></udf-field>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                            <div class="col-md-3">
                                                <div class="person-photo-attachment-wrap text-center">
                                                    <label style=" font-weight: 600;">Employee Photo</label>
                                                    <div class="img-wrap mx-auto">
                                                        <img ng-src="{{newDet.PhotoData || newDet.Photo }}" class="img-fluid" alt="" id="imgPhoto1" style="height:130px; width:165px; border:1px solid #ccc">
                                                    </div>
                                                    <label for="choose-sfile" type="button" class="btn btn-default mt-1 mb-0"><i class="fa fa-image"></i>Choose Photo</label>
                                                    <input id="choose-sfile" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newDet.Photo_TMP" fileread="newDet.PhotoData" />
                                                    <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                </div>
                                                <div class="person-photo-attachment-wrap text-center">
                                                    <label style=" font-weight: 600;">Citizenship Front</label>
                                                    <div class="img-wrap mx-auto">
                                                        <img ng-src="{{newDet.CitiFrontImgData || newDet.CitiFrontImg }}" class="img-fluid" alt="" id="imgPhoto2" style="height:130px; width:165px; border:1px solid #ccc">
                                                    </div>
                                                    <label for="choose-sfileF" type="button" class="btn btn-default mt-1 mb-0"><i class="fa fa-image"></i>Choose Photo</label>
                                                    <input id="choose-sfileF" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newDet.CitiFrontImg_Tmp" fileread="newDet.CitiFrontImgData" />
                                                    <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                </div>
                                                <div class="person-photo-attachment-wrap text-center">
                                                    <label style=" font-weight: 600;">Citizenship Back</label>
                                                    <div class="img-wrap mx-auto">
                                                        <img ng-src="{{newDet.CitiBackImgData || newDet.CitiBackImg }}" class="img-fluid" alt="" id="imgPhoto3" style="height:130px; width:165px; border:1px solid #ccc">
                                                    </div>
                                                    <label for="choose-sfileB" type="button" class="btn btn-default mt-1 mb-0"><i class="fa fa-image"></i>Choose Photo</label>
                                                    <input id="choose-sfileB" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newDet.CitiBackImg_tmp" fileread="newDet.CitiBackImgData" />
                                                    <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                </div>
                                            </div>

                                        </div>


                                        <!-- Timeline for  Official Detail* -->
                                        <div class="time-label">
                                            <span style="border: 2px solid #dee2e6;">
                                                Official Detail <span style="color:red">*</span>
                                            </span>
                                        </div>
                                        <div class="">
                                            <div class="row ml-5">
                                                <div class="col-md-12">
                                                    <div class="row">

                                                        <div class="col-md-4">
                                                            <div class="form-group">
                                                                <label>Company Relationship</label>
                                                                <select class="form-control form-control-sm select2" ng-model="newDet.CompanyRelationshipId" style="width: 100%;">
                                                                    <option ng-repeat="tdc in CompanyRelationshipList" ng-value="tdc.TranId" ng-selected="tdc.TranId==newDet.CompanyRelationshipId"> {{tdc.Name}} </option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <div class="form-group">
                                                                <label>Branch</label><span style="color: red">*</span>
                                                                <select class="form-control form-control-sm select2" ng-model="newDet.BranchId" style="width: 100%;">
                                                                    <option ng-repeat="tdc in BranchList" ng-value="tdc.BranchId" ng-selected="tdc.BranchId==newDet.BranchId"> {{tdc.Name}} </option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <div class="form-group">
                                                                <label>Sub Branch</label>
                                                                <select class="form-control form-control-sm select2" ng-model="newDet.SubBranch" style="width: 100%;">
                                                                    <option ng-repeat="tdc in SubBranchList" ng-value="tdc.SubBranchId" ng-selected="tdc.SubBranchId==newDet.SubBranch"> {{tdc.Name}} </option>
                                                                </select>
