                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link " id="BankAcc-tab" data-toggle="pill" href="#BankAccDet" role="tab" aria-controls="BankAcc" aria-selected="false">Bank Account</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link " id="Insurance-tab" data-toggle="pill" href="#InsuranceDet" role="tab" aria-controls="Insurance" aria-selected="false">Insurance</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link " id="Account-tab" data-toggle="pill" href="#AccountDet" role="tab" aria-controls="Account" aria-selected="false">Account Detail</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link " id="Qualification-tab" data-toggle="pill" href="#QualificationDet" role="tab" aria-controls="Qualification" aria-selected="false">Qualification</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link " id="Experience-tab" data-toggle="pill" href="#ExperienceDet" role="tab" aria-controls="Experience" aria-selected="false">Experience</a>
                                    </li>
                                    <li class="nav-item">
