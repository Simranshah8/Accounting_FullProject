                                </ul>
                            </div>
                            <div class="tab-content">

                                <div class="tab-pane fade show active" id="EmpDet" role="tabpanel" aria-labelledby="EmployeeDet-tab">
                                    <div id="employee-detail-section">
                                        <form class="row mb-5">
                                            <div class="row m-3">
                                                <div class="col-md-9 ">
                                                    <div class="row">
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Employee Id</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.EmployeeId" disabled>
                                                            </div>
                                                        </div>

                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Employee Code<span style="color:red">*</span></label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.EmployeeCode" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Enroll Number</label>
                                                                <input type="number" class="form-control form-control-sm" ng-model="newDet.EnrollNumber" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>First Name <span style="color:red">*</span></label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.FirstName" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Middle Name</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.MiddleName" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Last Name <span style="color:red">*</span></label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.LastName" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Gender <span style="color:red">*</span></label>
                                                                <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.GenderId">
                                                                    <option ng-repeat="G in GenderColl" ng-value="G.text" ng-selected="G.GenderId == G.text">{{ G.text}}</option>
                                                                </select>
                                                            </div>
                                                        </div>

                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Blood Group</label>
                                                                <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.BloodGroupId">
                                                                    <option ng-repeat="G in BloodGroupColl" ng-value="G.text" ng-selected="G.BloodGroupId == G.text">{{ G.text}}</option>
                                                                </select>
                                                            </div>
                                                        </div>

                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Religion <span style="color:red">*</span></label>
                                                                <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.ReligionId">
                                                                    <option ng-repeat="G in ReligionColl" ng-value="G.text" ng-selected="G.ReligionId == G.text">{{ G.text}}</option>
                                                                </select>
                                                            </div>
                                                        </div>


                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Date of Birth (BS)</label>
