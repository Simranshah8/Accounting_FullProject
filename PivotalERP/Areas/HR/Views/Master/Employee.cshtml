                                                                       date-detail="newDet.DobADDet" after-days="0" confirm-action="updateDOB()" ng-blur="updateDOB()">
                                                                @*<input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.DobAD_TMP" date-detail="newDet.DobADDet" after-days="0" confirm-action="ChangeDOB()" ng-blur="ChangeDOB()">*@
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Date of Birth (AD)</label>
                                                                <input type="date" class="form-control form-control-sm" ng-model="newDet.DobAD_TMP" style="width:100%">
                                                            </div>
                                                        </div>

                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Marital Status <span style="color:red">*</span></label>
                                                                <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.MaritalStatusId">
                                                                    <option ng-repeat="G in MaritalStatusColl" ng-value="G.id" ng-selected="G.MaritalStatusId == G.id">{{ G.text}}</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Nationality <span style="color:red">*</span></label>
                                                                <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.NationalityId">
                                                                    <option ng-repeat="G in NationalityList" ng-value="G.NationalityId" ng-selected="newDet.NationalityId == G.NationalityId">{{G.Name}}</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Pan Id</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.PanId" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Citizenship No</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.CitiNum" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Citizenship Issue Date</label>
                                                                <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.CitiIssueDate_TMP" date-detail="newDet.CitiIssueDateDet" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>CitizenShip Issue Place</label>
                                                                <select class="form-control form-control-sm select2" id="cboDistrictCiti" style="width: 100%;" ng-model="newDet.CitiIssuePlaceId" data-placeholder="* select district *">
                                                                    <option ng-repeat="tdc in DistrictColl" ng-value="tdc.id" ng-selected="tdc.id==newDet.CitiIssuePlaceId">
                                                                        {{tdc.text}}
                                                                    </option>
                                                                </select>

                                                            </div>
                                                        </div>

                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Email Id</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.EmailId" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Office Contact No.</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.OfficeNum" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Personal Contact No.</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.PersonalNum" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Father Name <span style="color:red">*</span></label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.FatherName" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Mother Name</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.MotherName" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Grand Father</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.GFatherName" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label for="">Spouse Name</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.SpouseName">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Anniversary Date</label>
                                                                <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.AnniversaryDate_TMP" date-detail="newDet.AnniversaryDateDet" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Driving Licence No</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.DrivingLicNum" style="width:100%">
                                                            </div>
                                                        </div>

                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Licence Issue Place</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.LicIssuePlace" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Licence Issue Date</label>
                                                                <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.LicIssueDate_TMP" date-detail="newDet.LicIssueDateDet" style="width:100%">
                                                            </div>
                                                        </div>

                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Licence Expiry Date</label>
                                                                <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.LicExpiryDate_TMP" date-detail="newDet.LicExpiryDateDet" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Passport No</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.PassportNum" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Passport Issue Date</label>
                                                                <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.PassportIssueDate_TMP" date-detail="newDet.PassportIssueDateDet" style="width:100%">
                                                            </div>
                                                        </div>

                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Passport Expiry Date</label>
                                                                <input type="text" class="form-control form-control-sm" date-picker ng-model="newDet.PassportExpiryDate_TMP" date-detail="newDet.PassportExpiryDateDet" style="width:100%">
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <div class="form-group">
                                                                <label>Passport Issue Place</label>
                                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.PassportIssuePlace" placeholder="* Enter Passport Issue Place *" style="width:100%">
                                                            </div>
                                                        </div>
                                                    </div>

                                                </div>
                                                <div class="col-md-3">
                                                    <div class="person-photo-attachment-wrap text-center">
                                                        <label style=" font-weight: 600;">Employee Photo</label>
                                                        <div class="img-wrap mx-auto">
                                                            <img ng-src="{{newDet.PhotoData || newDet.Photo }}" class="img-fluid" alt="" id="imgPhoto1" style="height:130px; width:165px; border:1px solid #ccc">
                                                        </div>
                                                        <label for="choose-sfile" type="button" class="btn btn-default mt-1 mb-0"><i class="fa fa-image"></i>Choose Photo</label>
                                                        <input id="choose-sfile" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newDet.Photo_TMP" fileread="newDet.PhotoData" />
                                                        <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                    </div>
                                                    <div class="person-photo-attachment-wrap text-center">
                                                        <label style=" font-weight: 600;">Citizenship Front</label>
                                                        <div class="img-wrap mx-auto">
                                                            <img ng-src="{{newDet.CitiFrontImgData || newDet.CitiFrontImg }}" class="img-fluid" alt="" id="imgPhoto2" style="height:130px; width:165px; border:1px solid #ccc">
                                                        </div>
                                                        <label for="choose-sfileF" type="button" class="btn btn-default mt-1 mb-0"><i class="fa fa-image"></i>Choose Photo</label>
                                                        <input id="choose-sfileF" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newDet.CitiFrontImg_Tmp" fileread="newDet.CitiFrontImgData" />
                                                        <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                    </div>
                                                    <div class="person-photo-attachment-wrap text-center">
                                                        <label style=" font-weight: 600;">Citizenship Back</label>
                                                        <div class="img-wrap mx-auto">
                                                            <img ng-src="{{newDet.CitiBackImgData || newDet.CitiBackImg }}" class="img-fluid" alt="" id="imgPhoto3" style="height:130px; width:165px; border:1px solid #ccc">
                                                        </div>
                                                        <label for="choose-sfileB" type="button" class="btn btn-default mt-1 mb-0"><i class="fa fa-image"></i>Choose Photo</label>
                                                        <input id="choose-sfileB" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newDet.CitiBackImg_tmp" fileread="newDet.CitiBackImgData" />
                                                        <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-12 mt-1 main-footer text-right">
                                                <a href="~/HR/Master/EmployeeProfile" ng-show="newDet.EmployeeId != null" class="btn btn-secondary btn-sm my-1 load">Exit</a>
                                                <button type="button" class="btn btn-sm btn-primary load" style="min-width: 110px;  color: #ffff;" ng-click="SaveEmployeeDetails()"> Update</button>
                                                <button type="button" id="emp-add-question" class="btn btn-sm btn-info load" style="min-width: 110px;  color: #ffff; "> Next <i class='fal fa-angle-right'></i></button>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="EmpAdd" role="tabpanel" aria-labelledby="EmployeeAdd-tab">
                                    <div id="employee-address-form">
                                        <form class="row ">
                                            <div class="timeline registration m-3 mt-3">
                                                <!-- Timeline for  Permanent Address* -->
                                                <div class="time-label">
                                                    <span style="border: 2px solid #dee2e6;">
                                                        Permanent Address <span style="color:red">*</span>
                                                    </span>
                                                </div>


                                                <div class="">
                                                    <div class="row ml-5">
                                                        <div class="col-md-12">
                                                            <div class="row">
                                                                <div class="col-md-4">
                                                                    <div class="form-group">
                                                                        <label>Country</label>
                                                                        <select class="form-control form-control-sm select2" ng-model="newDet.PCountryId" style="width: 100%;" ng-change="clearP()" data-placeholder="* select Country *">
                                                                            <option ng-repeat="tdc in CountryColl" ng-value="tdc.id" ng-selected="tdc.id==newDet.PCountryId"> {{tdc.text}} </option>
                                                                        </select>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <div class="form-group" ng-hide="newDet.PCountryId == 2">
                                                                        <label>State</label>
                                                                        <select class="form-control form-control-sm select2" id="cboProvincePer"
                                                                                style="width: 100%;" ng-model="newDet.PStateId" data-placeholder="* select State *">
                                                                            <option ng-repeat="cl in ProvinceColl" ng-value="cl.id" ng-selected="cl.id==newDet.PStateId">
                                                                                {{cl.text}}
                                                                            </option>
                                                                        </select>
                                                                    </div>
                                                                    <div class="form-group" ng-show="newDet.PCountryId == 2">
                                                                        <label>State</label>
                                                                        <input type="text" id="cboProvincePer" class="form-control form-control-sm" ng-model="newDet.PStateName" style="width:100%">
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <div class="form-group" ng-hide="newDet.PCountryId == 2">
                                                                        <label>District</label>
                                                                        <select class="form-control form-control-sm select2" id="cboDistrictPer"
                                                                                style="width: 100%;" ng-model="newDet.PDistrictId" data-placeholder="* select district *">
                                                                            <option ng-repeat="tdc in DistrictColl | filter: { stateId: newDet.PStateId }:true" ng-value="tdc.id" ng-selected="tdc.id==newDet.PDistrictId">
                                                                                {{tdc.text}}
                                                                            </option>
                                                                        </select>
                                                                    </div>
                                                                    <div class="form-group" ng-show="newDet.PCountryId == 2">
                                                                        <label>District</label>
                                                                        <input type="text" id="cboDistrictPer" class="form-control form-control-sm" ng-model="newDet.PDistrictName" style="width:100%">
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <div class="form-group" ng-hide="newDet.PCountryId == 2">
                                                                        <label>Municipality/VDC</label>
                                                                        <select class="form-control form-control-sm select2" id="cboAreaPer"
                                                                                style="width: 100%;" ng-model="newDet.P_LocalLevelId" data-placeholder="* select Municipality/VDC *">
                                                                            <option ng-repeat="tdc in VDCColl| filter: { districtId: newDet.PDistrictId }:true" ng-value="tdc.id" ng-selected="tdc.id==newDet.P_LocalLevelId">
                                                                                {{tdc.text}}
                                                                            </option>
                                                                        </select>
                                                                    </div>
