@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script src="~/jslib/hr/Master/LetterTemplate.js"></script>
<div ng-app="myApp" ng-controller="LetterTemplateController" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllLetterTemplate()">
    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true">List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" ng-click="ClearLetterTemplate()" aria-controls="custom-tabs-four-profile" aria-selected="false">Letter Template</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body p-2">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm mr-2">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.LetterTemplate">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.LetterTemplate">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search" placeholder="Search" aria-label="Search" ng-model="searchData.LetterTemplate">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file" title="Download File">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"><i class="fas fa-download"></i></button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#LetterTemplate'" sheet-name="'LetterTemplateList'" report-name="'Letter Template List'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#LetterTemplate').tableExport({type:'csv',escape:'false',reportname:'Letter Template List'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl table-id="'#LetterTemplate'" class="btn btn-secondary btn-light btn-sm wait" title="Print"><i class="fas fa-print"></i></a>
                                        </div>
                                    </div>
                                </header>
                                <div class="search-toolbar mt-2">
                                    <div class="">
                                        <table cellpadding="12" class="main-table table table-bordered table-striped table-hover table-sm" id="LetterTemplate">
                                            <thead>
                                                <tr>
                                                    <th style="text-align: center; width: 60px; ">S.No</th>
                                                    <th style="text-align: center; width: 200px; ">Template Type</th>
                                                    <th style="text-align: center; width: 80px;">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="D in LetterTemplateList | filter:searchData.LetterTemplate | itemsPerPage: perPage.LetterTemplate" current-page="currentPages.LetterTemplate" pagination-id="LetterTemplatePagination">
                                                    <td style="text-align:center;margin:auto">{{$index+1}}</td>
                                                    <td style="text-align:left;margin:auto">{{D.TemplateType}}</td>
                                                    <td class="project-actions" style="text-align:center">
                                                        <div class="btn-group-sm text-white">
                                                            <a class="btn btn-info" ng-click="getLetterTemplateById(D, $index)"><i class="fas fa-pencil-alt"></i></a>
                                                            <a class="btn btn-danger" ng-click="DelLetterTemplateById(D)"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="LetterTemplatePagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                                <div class="">
                                    <form>
                                        <div class="row">
                                            <div class="col-sm-4">
                                                <div class="form-group">
                                                    <label>Tempalte Type</label>
                                                    <select class="form-control form-control-sm select2" ng-model="beData.TemplateTypeId">
                                                        <option ng-value="U.id" ng-repeat="U in TemplateTypeList" ng-selected="U.id==beData.TemplateTypeId">{{U.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-12">
                                                <div class="form-group">
                                                    <label>Template Description</label>
                                                    <textarea class="textarea" variables="variableList" placeholder="Place some text here" style="width: 100%; height: 200px; font-size: 14px; line-height: 18px; border: 1px solid #dddddd; padding: 10px;" ng-model="beData.Description" html-editor></textarea>
                                                </div>
                                            </div>
                                            @*<div class="col-sm-12">
                                                <div class="form-group">
                                                    <label>Variables</label><br />
                                                    <span class="badge badge-primary m-1" ng-repeat="v in variableList" style="cursor:pointer" ng-click="addVariable(v)">{{v}}</span>
                                                </div>
                                            </div>*@
                                        </div>
                                    </form>
                                    <footer class="main-footer p-3">
                                        <div class="text-right control-btns">
                                            <button type="button" class="btn btn-default" ng-click="ClearLetterTemplate()">Clear</button>
                                            <button type="button" class="btn btn-primary" ng-click="SaveLetterTemplate()">{{beData.Mode}}</button>
                                        </div>
                                    </footer>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
