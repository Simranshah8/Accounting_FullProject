
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/hr/master/EmployeeLeftType.js"></script>
<div ng-app="myApp" ng-controller="EmployeeLeftTypeController" ng-init="LoadData()">

    <div class="box-body">
        <div class="content">
            <div class="p-1"></div>
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-body">
                        <div class="tab-content">
                            <div id="EmployeeLeftType-section">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.EmployeeLeftType">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.EmployeeLeftType">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.EmployeeLeftType">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file"
                                             data-placement="top" title="Download File">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#EmployeeLeftType'" sheet-name="'EmployeeLeftTypeDetails'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#EmployeeLeftType').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                                <a class="dropdown-item wait" onClick="$('#EmployeeLeftType').tableExport({type:'pdf',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image"> PDF</a>
                                                <a class="dropdown-item wait" onClick="$('#EmployeeLeftType').tableExport({type:'doc',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image"> Word</a>
                                                <a class="dropdown-item wait" onClick="$('#EmployeeLeftType').tableExport({type:'json',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image"> JSON</a>
                                            </div>
                                            <a print-tbl table-id="'#EmployeeProfile'" class="btn btn-secondary btn-light btn-sm wait"
                                               title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>
                                            <button type="button"
                                                    class="btn btn-sm btn-primary load"
                                                    id="add-EmployeeLeftType-details" style="min-width: 110px;" ng-click="ClearEmployeeLeftType()">
                                                <i class="fas fa-plus w-t"></i> Add New EmployeeLeftType
                                            </button>
                                        </div>


                                    </div>
                                </header>
                                <div class="search-toolbar mb-3">
                                    <table cellpadding="12" class="table table-bordered table-striped table-hover table-sm" id="datatable">
                                        <thead>
                                            <tr>
                                                <th style="text-align: center; width: 60px; ">
                                                    S.No
                                                </th>
                                                <th style="text-align: center; width: 200px; ">
                                                    Name
                                                </th>
                                                <th style="text-align: center; width: 150px; ">
                                                    Left Date
                                                </th>
                                                <th style="text-align: center; width: 150px; ">
                                                    Effective Date
                                                </th>
                                                <th style="text-align: center; width: 80px;">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr dir-paginate="C in EmployeeLeftTypeList | filter:searchData.EmployeeLeftType | itemsPerPage: perPage.EmployeeLeftType" current-page="currentPages.EmployeeLeftType" pagination-id="EmployeeLeftTypePagination">
                                                <td style="text-align:center;margin:auto">
                                                    {{$index+1}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{C.Name}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{C.LeftDate | dateFormat}}
                                                </td>
                                                <td style="text-align:left;margin:auto">
                                                    {{C.EffectiveDate | dateFormat}}
                                                </td>
                                                <td class="project-actions" style="text-align:center">
                                                    <div class="btn-group-sm">
                                                        <a class="btn btn-info" style="color:#fff" ng-click="getEmployeeLeftTypeById(C, $index)"><i class="fas fa-pencil-alt"></i></a>
                                                        <a class="btn btn-danger" style="color:#fff" ng-click="DelEmployeeLeftTypeById(C)"><i class="fas fa-trash"></i></a>
                                                        <a class="btn btn-primary" style="color:#fff" data-toggle="tooltip" data-placement="top" data-original-title="View" ng-click="getAppById(C)"><i class="fas fa-eye"></i></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <div class="col-md-12">
                                        <dir-pagination-controls pagination-id="EmployeeLeftTypePagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                        </dir-pagination-controls>
                                    </div>
                                </div>
                            </div>

                            <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="approved" role="dialog" tabindex="-1">
                                <div class="modal-dialog modal-dialog-centered modal-sm" role="form" style="margin-left:90px; margin-right:90px;">
                                    <div class="modal-content">
                                        <div class="modal-body mb-0 p-2">
                                            <div class="row">

                                                <div class="col-sm-4">
                                                    <div class="form-group">
                                                        <label>Remarks</label>
                                                        <textarea class="form-control form-control-sm" rows="1" style="width:100%" ng-model="newDet.ApprovedRemarks"></textarea>
                                                    </div>
                                                </div>
                                                <div class="col-sm-4">
                                                    <div class="form-group">
                                                        <label>Effective Date</label>
                                                        <input type="text" class="form-control form-control-sm" style="width:100%" ng-model="newDet.EffectiveDate_TMP" date-picker date-detail="newDet.EffectiveDateDet">
                                                    </div>
                                                </div>

                                            </div>

                                        </div>
                                        <div class="modal-footer p-2">
                                            <button type="button" class="btn btn-sm btn-primary load" style="min-width: 110px;  color: #ffff; " ng-click="SaveEmployeeLeftType()"> {{newDet.Mode}}</button>
                                        </div>
                                    </div>
                                </div>
                            </div>


                            <div id="EmployeeLeftType-form">
                                <form>
                                    <div class="row">

                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Employee Name</label>
                                                <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.EmployeeId">
                                                    <option ng-repeat="G in EmployeeList" ng-value="G.EmployeeId" ng-selected="G.EmployeeId == G.EmployeeId">{{ G.Name}}</option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Left Date</label>
                                                <input type="text" class="form-control form-control-sm" style="width:100%" ng-model="newDet.LeftDate_TMP" date-picker date-detail="newDet.LeftDateDet">
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Effective Date</label>
                                                <input type="text" class="form-control form-control-sm" style="width:100%" ng-model="newDet.EffectiveDate_TMP" date-picker date-detail="newDet.EffectiveDateDet">
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Left Type</label>
                                                <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.LeftTypeId">
                                                    <option ng-repeat="G in LeftList" ng-value="G.LeftTypeId" ng-selected="G.LeftTypeId == G.LeftTypeId">{{ G.Name}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label>Reason</label>
                                                <textarea class="form-control form-control-sm" rows="1" style="width:100%" ng-model="newDet.Reason"></textarea>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="my-1">
                                        <label style="font-weight: bold; font-size: 15px;">Document Attachment</label>
                                    </div>
                                    <div>
                                        <div class="timeline-item">
                                            <div class="pb-2 add-more-than-one-form-block">
                                                <form class="mb-0">
                                                    <article>
                                                        <div class="row">
                                                            <div class="col-sm-2">
                                                                <div class="form-group">
                                                                    <label>Type Of Document</label>
                                                                    <select class="form-control form-control-sm select2" ng-model="docType">
                                                                        <option ng-value="dc" ng-repeat="dc in DocumentList">{{dc.Name}}</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-10">
                                                                <div class="row">
                                                                    <div class="col-sm-4">
                                                                        <div class="form-group">
                                                                            <label>Attach Document</label>
                                                                            <div class="form-group">
                                                                                <input type="file" id="flMoreFiles" class="form-control-file form-control form-control-sm border bg-white" file-model ng-model="attachFile">
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-6">
                                                                        <div class="form-group">
                                                                            <label>Description</label>
                                                                            <input type="text" class="form-control form-control-sm"
                                                                                   ng-model="docDescription"
                                                                                   placeholder="">
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-sm-2">
                                                                        <div class="d-flex">
                                                                            <div>
                                                                                <label class="invisible d-block">for height</label>
                                                                                <button type="button" class="btn btn-sm btn-outline-secondary light-btn" ng-click="AddMoreFilesReceived(attachFile,docType,docDescription)"><i class="fas fa-plus"></i> Add More</button>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </article>
                                                </form>
                                            </div>
                                            <div class="pb-3">
                                                <div class="table-responsive">
                                                    <table class="table table-hover border bg-white">
                                                        <thead>
                                                            <tr>
                                                                <th scope="col" style="width: 20px">S.No.</th>
                                                                <th scope="col" style="width: 40%">Document Type</th>
                                                                <th scope="col">Attachment</th>
                                                                <th scope="col">Description</th>
                                                                <th scope="col" style="width: 100px">Action</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <tr ng-repeat="ac in newDet.AttachmentColl">
                                                                <th scope="row">{{$index+1}}</th>
                                                                <td>{{(DocumentList | findById:'DocumentTypeId':ac.DocumentTypeId).Name}}</td>
                                                                <td>{{ac.Name}}</td>
                                                                <td>{{ac.Description}}</td>
                                                                <td>

                                                                    <div>
                                                                        <a class="p-1" href="" data-toggle="tooltip" data-placement="top" title="" ng-click="ShowPersonalImg(ac)" data-original-title="View doc">
                                                                            <i class="fas fa-eye text-secondary"></i>
                                                                        </a>
                                                                        <a ng-hide="ac.DocPath==null" class="p-1" href="{{ac.DocPath}}" download="" data-toggle="tooltip" data-placement="top" title="" data-original-title="Download doc.">
                                                                            <i class="fas fa-download  text-info"></i>
                                                                        </a>
                                                                        <a class="p-1" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete doc." ng-click="delAttachmentDoc($index)">
                                                                            <i class="fas fa-trash-alt text-danger"></i>
                                                                        </a>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                        @* modal- for View----------- *@
                                        <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="ImgDocView" role="dialog" tabindex="-1">
                                            <div class="modal-dialog modal-lg" role="document">
                                                <div class="modal-content">
                                                    <div class="modal-body mb-0 p-2">
                                                        <iframe ng-hide="viewImg.FileType === 'image'" id="pdfViewer" style="width: 100%; height: 700px; border: none;"></iframe>
                                                        <img ng-show="viewImg.FileType === 'image'" ng-src="{{viewImg.ContentPath}}" alt="" style="width: 100%; height: auto;" id="imgPreviewAdd">
                                                    </div>
                                                    <div class="modal-footer p-2">
                                                        <div><a href="{{viewImg.ContentPath}}" download>Download</a></div>
                                                        <button class="btn btn-success btn-rounded btn-sm ml-4 btn-add text-center" data-dismiss="modal" type="button" style="min-width: 70px;">Close</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                                <footer class="main-footer">
                                    <div class="text-right control-btns">
                                        <button type="button" class="btn btn-default" ng-click="ClearEmployeeLeftType()">Cancel</button>
                                        <button type="button" class="btn btn-secondary" id="back-to-EmployeeLeftType-list">Back to List</button>

                                        <button type="button" class="btn btn-primary" ng-click="SaveEmployeeLeftType()">{{newDet.Mode}}</button>
                                    </div>
                                </footer>
                            </div>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->
        </div>




    </div>
</div>

<style>

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>
