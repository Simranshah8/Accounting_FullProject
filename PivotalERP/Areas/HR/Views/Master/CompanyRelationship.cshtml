@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")



<script src="~/jslib/hr/master/CompanyRelationship.js"></script>

<div ng-app="myApp" ng-controller="CompanyRelationshipController" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllCompanyRelationship()">


    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card my-1 card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" ng-click="ClearDetails()" aria-controls="custom-tabs-four-profile" aria-selected="false">Company Relationship</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body p-2">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm mr-2">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.CompanyRelationship">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.CompanyRelationship">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.CompanyRelationship">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file" title="Download File">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#CompanyRelationship'" sheet-name="'CompanyRelationshipList'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#CompanyRelationship').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl table-id="'#CompanyRelationship'" class="btn btn-secondary btn-light btn-sm wait"
                                               title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>
                                        </div>

                                    </div>
                                </header>

                                <div class="search-toolbar">
                                    <div class="table-scroll-x-y table-scroll pb-2" style="height:auto!important;max-height:calc(100vh - 8rem)!important">
                                        <table id="CompanyRelationship" class="main-table table table-sm table-bordered bg-white">
                                            <thead>
                                                <tr>
                                                    <th style="width: 50px">S.No.</th>
                                                    <th style="width: 130px">Name</th>
                                                    <th style="width: 150px">Display Name</th>
                                                    <th style="width: 150px">Full Address</th>
                                                    <th style="width: 150px">Phone No</th>
                                                    <th style="width: 100px">PAN/VAT No</th>
                                                    <th style="width: 120px">Reg No</th>
                                                    <th style="width: 120px">Email</th>
                                                    <th style="width: 180px">Relationship Type</th>
                                                    <th class="cstm-sticky" style="width: 60px; right: 0; background-color: #ececec !important;">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="SL in CompanyRelationshipList | filter:searchData.CompanyRelationship | itemsPerPage: perPage.CompanyRelationship" current-page="currentPages.CompanyRelationship" pagination-id="CompanyRelationshipPagination">
                                                    <td>{{$index + 1}}</td>
                                                    <td>{{SL.Name}}</td>
                                                    <td>{{SL.DisplayName}}</td>
                                                    <td>{{SL.FullAddress}}</td>
                                                    <td>{{SL.Phone}}</td>
                                                    <td>{{SL.PanVatNo}}</td>
                                                    <td>{{SL.RegNo}}</td>
                                                    <td>{{SL.Email}}</td>
                                                    <td>{{SL.RelationshipType}}</td>

                                                    <td class="cstm-sticky" style="width: 60px; right: 0; z-index: 3; background-color: #FFF !important;">
                                                        <a class="p-1" href="#" ng-click="getCompanyRelationshipById(SL)">
                                                            <i class="fas fa-edit text-info"></i>
                                                        </a>
                                                        <a class="p-1" href="#" ng-click="DelCompanyRelationshipById(SL,$index)">
                                                            <i class="fas fa-trash-alt text-danger"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            </tbody>

                                        </table>
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <dir-pagination-controls pagination-id="CompanyRelationshipPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                    </dir-pagination-controls>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                                <div class="">
                                    <form>
                                        <div class="row">

                                            <div class="col-md-10">
                                                <div class="row">
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label> Name <span style="color:red">*</span></label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.Name" />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Display Name</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.DisplayName">

                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Full Address <span style="color:red">*</span></label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.FullAddress" />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>State</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.State" />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Country</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.Country" />

                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Zip Code</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.ZipCode" />
                                                        </div>
                                                    </div>

                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Reg No.</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.RegNo">
                                                        </div>
                                                    </div>


                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>PAN/VAT No.</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.PanVatNo">
                                                        </div>
                                                    </div>

                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Phone No</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.Phone" />
                                                        </div>
                                                    </div>

                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Fax Number</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.Fax" />
                                                        </div>
                                                    </div>

                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Email</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.Email">
                                                        </div>
                                                    </div>

                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Website</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.Website">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Relationship Type</label>
                                                            <select class="form-control form-control-sm" ng-model="newCompanyDetail.RelationshipType">
                                                                <option ng-repeat="pp in RelationshipTypeColl" ng-value="pp.text" ng-selected="pp.text==newCompanyDetail.RelationshipType">{{pp.text}}</option>
                                                            </select>

                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Api URL</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.ApiURL">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-2">
                                                        <div class="form-group">
                                                            <label>Api User</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="newCompanyDetail.UserName">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-2">
                                                        <div class="form-group">
                                                            <label>Api Pwd</label>
                                                            <input type="password" class="form-control form-control-sm" ng-model="newCompanyDetail.Password">
                                                        </div>
                                                    </div>

                                                </div>

                                            </div>

                                            <div class="col-md-2">
                                                <div class="person-photo-attachment-wrap text-center">
                                                    <label style=" font-weight: 600;">Logo</label>
                                                    <div class="img-wrap mx-auto">
                                                        <img ng-src="{{newCompanyDetail.LogoData || newCompanyDetail.LogoPath }}" class="img-fluid" alt="" id="imgPhoto1" style="height:130px; width:165px; border:1px solid #ccc">
                                                    </div>
                                                    <label for="choose-sfile" type="button" class="btn btn-default mt-1 mb-0"><i class="fa fa-image"></i>Upload Logo</label>
                                                    <input id="choose-sfile" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newCompanyDetail.Logo_TMP" fileread="newCompanyDetail.LogoData" />
                                                    <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                </div>
                                            </div>

                                        </div>

                                    </form>
                                    <footer class="main-footer">
                                        <div class="text-right control-btns">
                                            <button type="button" class="btn btn-default" ng-click="ClearDetails()">Clear</button>
                                            <button type="button" class="btn btn-primary" ng-click="SaveCompanyRelationship()">{{newCompanyDetail.Mode}}</button>
                                        </div>
                                    </footer>

                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->
        </div>
    </div>
</div>
