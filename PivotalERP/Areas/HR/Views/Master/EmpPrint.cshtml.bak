

@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script>
    EmployeeID = @ViewBag.EmployeeID;
</script>
<script src="~/jslib/hr/master/EmpPrint.js"></script>

<div ng-app="myApp" ng-controller="EmpPrintController" ng-init="LoadData()">
    <div class="box-body">
        <div class="content">
            <div class="p-1" id="PrintEmpDetails">
                <div class="container-fluid">
                    <div class="card" style="border: 1px solid #11101052">
                        <div class="card-body">
                            <div class="tab-content">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-2">
                                                <div class="form-group d-flex">
                                                    <img ng-src="{{CompanyDetail.CompanyLogoPath}}" class="img-fluid" alt="" id="imgPhoto1" style="height:120px; width:auto;" />
                                                </div>
                                            </div>
                                            <div class="col-md-8">
                                                <div class="text-center">
                                                    <h3 style="font-weight: 600; font-size: 25px;">{{CompanyDetail.Name}} </h3>
                                                    <h5 style="font-weight: 500; font-size: 15px;">{{CompanyDetail.Address}}, {{CompanyDetail.Country}} </h5>
                                                    <h5 style="font-weight: 500; font-size: 15px;">{{CompanyDetail.PhoneNo}}, {{CompanyDetail.EmailId}}</h5>
                                                    <h4 class="pt-1" style="font-weight: 700; font-size: 22px;"><u>Employee Information</u></h4>
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        @*/.card*@
                    </div>


                    <div class="card" style="border: 1px solid #11101052">
                        <div class="card-header header-corner-triangle py-1" style="background-color: #1f5d9e30;">
                            <div class="row">
                                <div class="col-md-8">
                                    <h3 class="card-title">Employee Details</h3>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="tab-content">
                                <div class="row">
                                    <div class="col-md-9">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px">Employee Id </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.EmployeeId}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px">Employee Code </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.EmployeeCode}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px">Employee Name </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.Name}}</label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px">Gender </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.GenderName}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Blood Group</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.BloodGpName}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Religion</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.ReligionName}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Date of Birth (BS) </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.DobBS}}  </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Date of Birth (AD)</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.DobAD | dateFormat}}  </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Marital Status</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.MaritalStatusName}}  </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Nationality</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.NationalityName}}  </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Pan No. </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PanId}}  </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Citizen No.</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.CitiNum}}  </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Citiizen Issue Date </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.CitiIssueDateBS}}  </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">CitizenShip Issue Place</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.CitiIssuePlace}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">EmailId:</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.EmailId}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Office Contact No. </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.OfficeNum}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Personal Contact No.</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PersonalNum}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Father Name </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.FatherName}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Mother Name</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.MotherName}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Grand Father</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.GFatherName}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Driving Licence No </b> </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.DrivingLicNum}} </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Licence Issue Place </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.LicIssuePlace}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Licence Issue Date</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.LicIssueDateBS}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Licence Expiry Date</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.LicIssueDateBS}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Passport No</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PassportNum}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Passport Issue Date</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PassportIssueDateBS}} </label>

                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Passport Expiry Date </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PassportExpiryDateBS}} </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:160px;">Passport Issue Place</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PassportIssuePlace}} </label>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="person-photo-attachment-wrap text-center">
                                            <label style=" font-weight: 600;">Employee Photo</label>
                                            <div class="img-wrap mx-auto">
                                                <img ng-src="{{newDet.PhotoData || newDet.Photo }}" class="img-fluid" alt="" id="imgPhoto1" style="height:200px; width:auto; border:1px solid #ccc">
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                        @*/.card*@
                    </div>

                    <div class="card" style="border: 1px solid #11101052">
                        <div class="card-header header-corner-triangle py-1" style="background-color: #1f5d9e30;">
                            <div class="row">
                                <div class="col-md-8">
                                    <h3 class="card-title">Permanent Address</h3>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="tab-content">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 135px">Country </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PerCountry}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 80px ">State</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PStateName}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 100px ">District</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PDistrictName}}</label>

                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 135px">Municipality/VDC </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.P_LocalLevelName}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 80px; ">  City </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PCity}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 100px; ">Ward</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PWard}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 135px;">Street </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PStreet}}  </label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 80px;">House No </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PHouseNum}}  </label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 100px; ">Full Address</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.PFullAddr}}  </label>
                                                </div>
                                            </div>

                                        </div>
                                    </div>


                                </div>
                            </div>
                        </div>
                        @*/.card*@
                    </div>


