                                        <div class="row">
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 120px">Person Name </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.ContactPer}}</label>
