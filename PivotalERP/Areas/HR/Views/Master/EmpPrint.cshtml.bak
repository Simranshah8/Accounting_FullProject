                    </div>

                    <div class="card" style="border: 1px solid #11101052">
                        <div class="card-header header-corner-triangle py-1" style="background-color: #1f5d9e30;">
                            <div class="row">
                                <div class="col-md-8">
                                    <h3 class="card-title">Work Experience</h3>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="tab-content">
                                <div class="row">
                                    <div class="col-md-12">

                                        <div class="mt-2">
                                            @*table input start*@
                                            <div class="table-responsive">
                                                <div class="card table-scroll-x-y" style="height: auto !important; max-height: calc(100Vh - 18rem) !important; overflow: auto !important;">
                                                    <table id="main-table" class="main-table table table-sm table-bordered">
                                                        <thead>
                                                            <tr>
                                                                <th style="width: 56px; background-color: #ececec !important; z-index:2;">SNo.</th>
                                                                <th style="width: 150px; background-color: #ececec !important; z-index: 2;">Organization</th>
                                                                <th style="width: 150px; background-color: #ececec !important; z-index: 2;"> Department</th>
                                                                <th style="width: 150px; background-color: #ececec !important; z-index: 2;">Job Title</th>
                                                                <th style="width: 150px; background-color: #ececec !important; z-index: 2;">Start Date </th>
                                                                <th style="width: 150px; background-color: #ececec !important; z-index: 2;">End Date </th>
                                                                <th style="width: 200px; background-color: #ececec !important; z-index: 2;"> Remarks</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <tr ng-repeat="W in newDet.WorkExpColl">
                                                                <td>{{$index+1}}</td>
                                                                <td>{{W.Org}}</td>
                                                                <td>{{W.DepartmentName}}</td>
                                                                <td>{{W.JobTitle}}</td>
                                                                <td>{{W.StartDateBS}}</td>
                                                                <td>{{W.EndDateBS}}</td>
                                                                <td>{{W.Remarks}}</td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </div>
                                                @*tabel input end*@
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                        @*/.card*@
                    </div>

                    <div class="card" style="border: 1px solid #11101052">
                        <div class="card-header header-corner-triangle py-1" style="background-color: #1f5d9e30;">
                            <div class="row">
                                <div class="col-md-8">
                                    <h3 class="card-title">Supervisor</h3>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="tab-content">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 120px">First Level</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.FSName}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 120px">Second Level</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.SSName}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 120px">Third Level</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.TSName}}</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        @*/.card*@
                    </div>

                    <div class="card" style="border: 1px solid #11101052">
                        <div class="card-header header-corner-triangle py-1" style="background-color: #1f5d9e30;">
                            <div class="row">
                                <div class="col-md-8">
                                    <h3 class="card-title">Document Attachment</h3>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="tab-content">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-4" ng-repeat="A in newDet.AttachmentColl">
                                                <div class="img-wrap mx-auto">
                                                    <img ng-src="{{A.DocPathData || A.DocPath }}" class="img-fluid" alt="" id="imgPhoto1" style="height:200px; width:auto; border:1px solid #ccc">
                                                </div>
                                                <label>{{A.DocumentTypeName}}</label>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                        @*/.card*@
                    </div>

                    @*/.card*@
                </div>
                @*/.container-fluid*@
            </div>

            <div class="text-center control-btns" style="color:#FFF;">
                <a href="~/Payroll/Master/EmployeeProfile" ng-show="newDet.EmployeeId != null" class="btn btn-secondary  my-1 load">Back to List</a>
                <a ng-click="Print()" class="btn btn-secondary  my-1 load">Print</a>
            </div>
        </div>



    </div>
</div>

