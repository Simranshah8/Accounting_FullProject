                    <div class="card" style="border: 1px solid #11101052">
                        <div class="card-header header-corner-triangle py-1" style="background-color: #1f5d9e30;">
                            <div class="row">
                                <div class="col-md-8">
                                    <h3 class="card-title">Official Detail</h3>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="tab-content">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 120px">Company </label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.CompanyName}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 150px ">Branch</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.BranchName}}</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 150px ">Sub Branch</label>
                                                    <label class="text-nowrap font-weight-bold">: {{newDet.SubBranch}}</label>

                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 120px">Department </label>
