@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")



<script src="~/jslib/hr/Master/GrievanceType.js"></script>
<div ng-app="myApp" ng-controller="GrievanceTypeController" ng-class="{waiting: loadingstatus=='running'}" ng-init="LoadData()">
    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true" ng-click="GetAllGrievanceType()"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" ng-click="ClearGrievanceType()" aria-controls="custom-tabs-four-profile" aria-selected="false">GrievanceType</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body p-2">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm mr-1">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.GrievanceType">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.GrievanceType">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.GrievanceType">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file" title="Download File">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#GrievanceType'" sheet-name="'GrievanceTypeList'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#GrievanceType').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl table-id="'#GrievanceType'" class="btn btn-secondary btn-light btn-sm wait"
                                               title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>
                                        </div>
                                    </div>
                                </header>
                                <div class="search-toolbar mt-2">
                                    <div class="">
                                        <table cellpadding="12" class="main-table table table-bordered table-striped table-hover table-sm" id="GrievanceType">
                                            <thead>
                                                <tr>
                                                    <th style="text-align: left; width: 60px;">S.No</th>
                                                    <th style="text-align: left; width: 100px;">Name</th>
                                                    <th style="text-align: left; width: 100px;">Code</th>
                                                    <th style="text-align: left; width: 60px;">Order No</th>
                                                    <th class="no-print" style="text-align: center; width: 60px;">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="D in GrievanceTypeList | filter:searchData.GrievanceType | itemsPerPage: perPage.GrievanceType" current-page="currentPages.GrievanceType" pagination-id="GrievanceTypePagination">
                                                    <td >{{$index+1}}</td>
                                                    <td >{{D.Name}}</td>
                                                    <td >{{D.Code}}</td>
                                                    <td >{{D.OrderNo}}</td>
                                                    <td class="project-actions no-print" style="text-align:center">
                                                        <div class="btn-group-sm text-white">
                                                            <a class="btn btn-info" ng-click="getGrievanceTypeById(D, $index)"><i class="fas fa-pencil-alt"></i></a>
                                                            <a class="btn btn-danger" ng-click="DelGrievanceTypeById(D)"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="GrievanceTypePagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Name<span style="color:red">*</span></label>
                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.Name" id="GrievanceTypeName">
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Code<span style="color:red"></span></label>
                                            <input type="text" class="form-control form-control-sm" ng-model="newDet.Code">
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Order No</label>
                                            <input type="number" class="form-control form-control-sm" ng-model="newDet.OrderNo">
                                        </div>
                                    </div>

                                    <div class="col-md-3 mt-4">
                                        <div class="custom-control custom-checkbox form-group">
                                            <input class="custom-control-input" type="checkbox" id="customCheckbox1" value="option" ng-model="newDet.IsActive">
                                            <label for="customCheckbox1" class="custom-control-label"> IsActive ? </label>
                                        </div>
                                    </div>

                                    <div class="col-md-12">
                                        <div class="form-group">
                                            <label>Description</label>
                                            <textarea rows="1" class="form-control form-control-sm" ng-model="newDet.Description"></textarea>
                                        </div>
                                    </div>
                                </div>


                                <div class="table-scroll-x-y table-scroll pb-3" style="height: auto !important; max-height: calc(100vh - 8rem) !important; margin-bottom:50px; ">
                                    <table id="main-table" class="main-table table table-sm table-bordered bg-white cstm-sales-invoice-table border-0 dynamic-uiux-table">
                                        <thead style="background: #e6f5fb;">
                                            <tr>
                                                <th class="cstm-sticky text-center" style="width: 60px; left: 0; background-color: #e6f5fb !important; z-index: 4">S.No.</th>
                                                <th class="cstm-sticky" style="width: 80px; left: 60px; background-color: #e6f5fb !important; z-index: 4 ">Alter</th>
                                                <th class="cstm-sticky" style="width: 250px; left: 140px; background-color: #e6f5fb !important; z-index: 4 ">Name</th>
                                                <th style="width: 160px; z-index: 3; background-color: #e6f5fb !important;">Label</th>
                                                <th style="width: 120px; z-index: 3; background-color: #e6f5fb !important;">Data Type</th>
                                                <th style="width: 140px; z-index: 3; background-color: #e6f5fb !important;">Default Value</th>
                                                <th style="width: 100px; z-index: 3; background-color: #e6f5fb !important;" class="text-center">IsMandatory</th>
                                                <th style="width: 200px; z-index: 3; background-color: #e6f5fb !important;">SelectOptions</th>
                                                <th style="width: 300px; z-index: 3; background-color: #e6f5fb !important;">Source</th>
                                                <th style="width: 150px; z-index: 3; background-color: #e6f5fb !important;">Formula</th>
                                                <th style="width: 80px; z-index: 3; background-color: #e6f5fb !important;">Width</th>
                                                <th style="width: 180px; z-index: 3; background-color: #e6f5fb !important;">Reference</th>
                                                <th style="width: 150px; z-index: 3; background-color: #e6f5fb !important;">Text Col</th>
                                                <th class="align-middle text-center" style="width: 80px; z-index: 2; background-color: #e6f5fb !important;">Action</th>
                                            </tr>

                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="EAC in newDet.VoucherUDFCol">
                                                <td class="cstm-sticky text-center" style="left: 0; background-color: #ffffff !important; z-index: 3">
                                                    <input type="number" class="form-control form-control-sm" ng-model="EAC.SNo" />
                                                </td>
                                                <td class="cstm-sticky" style="width: 60px; left: 60px; background-color: #ffffff !important; z-index: 3 ">
                                                    <input type="checkbox" class="form-control form-control-sm" ng-model="EAC.CanAlter" ng-show="EAC.FieldId>0" />
                                                </td>
                                                <td class="cstm-sticky" style="width: 60px; left: 140px; background-color: #ffffff !important; z-index: 3 "> <input type="text" class="form-control form-control-sm" ng-model="EAC.Name" ng-disabled="EAC.FieldId>0" /></td>
                                                <td> <input type="text" class="form-control form-control-sm" ng-model="EAC.Label" /></td>
                                                <td>
                                                    <select class="form-control form-control-sm" active-select2 ng-model="EAC.FieldType" ng-disabled="(EAC.CanAlter ? false : (EAC.FieldId>0 ? true : false)) ">
                                                        <option ng-repeat="dt in DataTypeColl" ng-value="dt.id" ng-selected="dt.id==EAC.FieldType">{{dt.text}}</option>
                                                    </select>
                                                </td>
                                                <td> <input type="text" class="form-control form-control-sm" ng-model="EAC.DefaultValue" /></td>
                                                <td class="text-center">
                                                    <div class="custom-control custom-checkbox">
                                                        <input type="checkbox" class="custom-control-input" id="customCheckboxCHE3{{$index}}" ng-model="EAC.IsMandatory" />
                                                        <label for="customCheckboxCHE3{{$index}}" class="custom-control-label"> </label>
                                                    </div>
                                                </td>
                                                <td>
                                                    <textarea class="textarea form-control form-control-sm" rows="1" ng-model="EAC.DropDownList"></textarea>
                                                </td>
                                                <td> <input type="text" class="form-control form-control-sm" ng-model="EAC.Source" /></td>
                                                <td> <input type="text" class="form-control form-control-sm" ng-model="EAC.Formula" /></td>
                                                <td> <input type="number" class="form-control form-control-sm" ng-model="EAC.ColWidth" /></td>
                                                <td>
                                                    <select class="form-control form-control-sm select2" active-select2 ng-model="EAC.SelectedRefTable"  >
                                                        <option ng-repeat="dt in PkTablesColl" ng-value="dt"  ng-selected="dt.Table==EAC.SelectedRefTable.TableName">{{dt.Table}}</option>
                                                    </select>
                                                </td>
                                                <td> <input type="text" class="form-control form-control-sm" ng-model="EAC.TextColumn" /></td>
                                                <td style="text-align:center;">
                                                    <a class="p-1" ng-click="AddCurItemUdf($index)">
                                                        <i class="fas fa-plus text-secondary"></i>
                                                    </a>
                                                    <a class="p-1" ng-click="delCurItemUdf($index)">
                                                        <i class="fas fa-trash-alt text-danger"></i>
                                                    </a>
                                                </td>

                                            </tr>

                                        </tbody>
                                    </table>
                                </div>


                                <footer class="main-footer">
                                    <div class="text-right control-btns">
                                        <button type="button" class="btn btn-default" ng-click="ClearGrievanceType()">Clear</button>
                                        <button type="button" class="btn btn-primary" ng-click="SaveGrievanceType()">{{newDet.Mode}}</button>
                                    </div>
                                </footer>
                            </div>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->
        </div>
    </div>
</div>
