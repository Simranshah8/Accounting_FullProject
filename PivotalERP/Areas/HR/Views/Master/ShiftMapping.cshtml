@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }

    .os-theme-dark > .os-scrollbar-horizontal, .os-theme-light > .os-scrollbar-horizontal {
        right: 10px;
        height: 14px !important;
    }
</style>

<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Att_ShiftMapping)";
</script>


<script src="~/jslib/hr/Master/ShiftMapping.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="MappingController">
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="pb-1"></div>
                <div class="card p-2 mb-0">
                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="">Date From</label>
                                <input type="text"
                                       class="form-control form-control-sm" date-picker ng-model="newMapping.DateFrom_TMP" date-detail="newMapping.DateFromDet">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <div class="form-group">
                                    <label for="">Date To</label>
                                    <input type="text"
                                           class="form-control form-control-sm" date-picker ng-model="newMapping.DateTo_TMP" date-detail="newMapping.DateToDet">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Working Shift</label>
                                <select class="form-control form-control-sm select2" ng-model="newMapping.WorkingShiftId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-value="ws.WorkingShiftId" ng-repeat="ws in WorkingShiftList" ng-selected="ws.WorkingShiftId==newMapping.WorkingShiftId">{{ws.Name}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2" ng-show="CompanyRelationshipList.length>1">
                            <div class="form-group">
                                <label>Company</label>
                                <select class="form-control form-control-sm select2" ng-model="newMapping.CompanyId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-repeat="B in CompanyRelationshipList" ng-value="B.TranId" ng-selected="B.TranId==newMapping.CompanyId">{{B.Name}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Branch</label>
                                <select class="form-control form-control-sm select2" ng-model="newMapping.BranchId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-repeat="B in BranchList" ng-value="B.BranchId" ng-selected="B.BranchId==newMapping.BranchId">{{B.Name}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Department</label>
                                <select class="form-control form-control-sm select2" ng-model="newMapping.DepartmentId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-value="c.CostCenterDepartmentId" ng-repeat="c in DepartmentList" ng-selected="c.CostCenterDepartmentId==newMapping.DepartmentId">{{c.text}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Category</label>
                                <select class="form-control form-control-sm select2" ng-model="newMapping.CategoryId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-value="c.CategoryId" ng-repeat="c in CategoryList" ng-selected="c.CategoryId==newMapping.CategoryId">{{c.Name}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Designation</label>
                                <select class="form-control form-control-sm select2" ng-model="newMapping.DesignationId">
                                    <option ng-value="0">**Select All**</option>
                                    <option ng-value="c.DesignationId" ng-repeat="c in DesignationList" ng-selected="c.DesignationId==newMapping.DesignationId">{{c.Name}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-1">
                            <button class="btn btn-sm btn-outline-secondary btn-add mt-4 float-left" ng-click="GetAllMappingList()"><i class="fas fa-redo-alt"></i> Load</button>
                        </div>
                    </div>
                    <header class="row">
                        <div class="col-md-7">
                            <div class="clearfix">
                                <form class="form-inline">
                                    <div class="input-group input-group-sm mr-sm-2">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text cstm">Show</span>
                                        </div>
                                        <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.ShiftMapping">
                                            <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.ShiftMapping">{{pp.text}}</option>
                                        </select>
                                        <div class="input-group-append">
                                            <span class="input-group-text bg-white"><small>entries</small></span>
                                        </div>
                                    </div>
                                    <div class="input-group input-group-sm table-search-filed">
                                        <input class="form-control form-control-navbar"
                                               type="search" placeholder="Search"
                                               aria-label="Search" ng-model="searchData.ShiftMapping">
                                        <div class="input-group-append">
                                            <button class="btn btn-default border-left-0"
                                                    type="submit">
                                                <i class="fas fa-search"></i>
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="col-md-5 text-right">
                            <div class="dropdown dnld-file ml-2">
                                <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                        id="dropdownMenuButton" data-toggle="dropdown"
                                        aria-haspopup="true" aria-expanded="false">
                                    <i class="fas fa-download"></i>
                                </button>
                                <div class="dropdown-menu dropdown-menu-right"
                                     aria-labelledby="dropdownMenuButton">
                                    <span class="dropdown-item">Choose an option:</span>
                                    <a class="dropdown-item wait" export-excel table-id="'#ShiftMapping'" sheet-name="'ShiftMappingList'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                    <a class="dropdown-item wait" onClick="$('#ShiftMapping').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                </div>
                                <button class="btn load btn-add btn-primary" ng-click="SaveShiftMappingColl()"><i class="fas fa-save mr-1"></i> Save</button>
                                <button class="btn load btn-add btn-danger" ng-click="DelShiftMapping()"><i class="far fa-trash-alt"></i> Delete</button>
                            </div>
                        </div>
                    </header>
                    <div class="table-scroll-x-y table-scroll mt-1 pb-3" style="max-height: calc(100vh - 10rem);">
                        <table id="ShiftMapping" class="main-table table table-sm table-bordered bg-white">
                            <thead>
                                <tr>
                                    <th class="text-center align-middle cstm-sticky" style="width: 70px; left: 0; z-index: 4; background-color: #e9ecef !important" ng-click="sortEmpData('EmployeeCode')">Code</th>
                                    <th class="text-center align-middle cstm-sticky" style="width: 80px; left: 70px; z-index: 4; background-color: #e9ecef !important" ng-click="sortEmpData('EnrollNo')">Enroll No</th>
                                    <th class="align-middle cstm-sticky" style="width: 150px; left: 150px; z-index: 4; background-color: #e9ecef !important" ng-click="sortEmpData('EmployeeName')">Name</th>
                                    <th class="align-middle cstm-sticky" style="width: 150px; z-index: 4; background-color: #e9ecef !important" ng-click="sortEmpData('Branch')">Branch</th>
                                    <th class="align-middle cstm-sticky" style="width: 150px; z-index: 4; background-color: #e9ecef !important" ng-click="sortEmpData('Department')">Department</th>
                                    <th class="align-middle cstm-sticky" style="width: 150px; z-index: 4; background-color: #e9ecef !important" ng-click="sortEmpData('Designation')">Designation</th>
                                    <th class="align-middle" style="width: 150px; left: 150px; z-index: 4; background-color: #e9ecef !important">Working Shift</th>
                                    <th class="align-middle" style="width: 150px; left: 150px; z-index: 4; background-color: #e9ecef !important">Date From</th>
                                    <th class="align-middle" style="width: 150px; left: 150px; z-index: 4; background-color: #e9ecef !important">Date To</th>
                                    <th class="text-center cstm-sticky" style="width: 62px; right: 0; z-index: 2; background-color: #e9ecef !important">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr dir-paginate="cl in MappingEmployeeList | orderBy:sortKeySS:reverseSS | filter:searchData.ShiftMapping | itemsPerPage: perPage.ShiftMapping" track by cl.EmployeeId current-page="currentPages.ShiftMapping" pagination-id="ShiftMappingPagination">
                                    <td class="align-middle text-center cstm-sticky" style="width: 70px; left: 0; z-index: 2; background-color: #fff !important">{{cl.EmpCode}}</td>
                                    <td class="align-middle text-center cstm-sticky" style="width: 80px; left: 70px; z-index: 2; background-color: #fff !important">{{cl.EnrollNumber}}</td>
                                    <td class="align-middle cstm-sticky" style="width: 180px; left: 150px; z-index: 2; background-color: #fff !important">{{cl.EmpName}}</td>
                                    <td class="align-middle cstm-sticky" style="width: 180px; left: 150px; z-index: 2; background-color: #fff !important">{{cl.BranchName}}</td>
                                    <td class="align-middle cstm-sticky" style="width: 180px; left: 150px; z-index: 2; background-color: #fff !important">{{cl.Department}}</td>
                                    <td class="align-middle cstm-sticky" style="width: 180px; left: 150px; z-index: 2; background-color: #fff !important">{{cl.Designation}}</td>
                                    <td class="align-middle text-center">
                                        <div class="form-group">
                                            <select class="form-control form-control-sm" ng-model="cl.WorkingShiftId">
                                                <option ng-value="0">**Select All**</option>
                                                <option ng-value="ws.WorkingShiftId" ng-repeat="ws in WorkingShiftList" ng-selected="ws.WorkingShiftId==cl.WorkingShiftId">{{ws.Name}}</option>
                                            </select>
                                        </div>
                                    </td>
                                    <td class="align-middle text-center">
                                        <div class="form-group">
                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="cl.DateFrom_TMP" date-detail="cl.DateFromDet">
                                        </div>
                                    </td>
                                    <td class="align-middle text-center">
                                        <div class="form-group">
                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="cl.DateTo_TMP" date-detail="cl.DateToDet">
                                        </div>
                                    </td>
                                    <td class="text-center cstm-sticky" style="width: 62px; right: 0; z-index: 2; background-color: #e9ecef !important">
                                        <a class="p-1 btn btn-sm btn-info" data-toggle="tooltip" title="Update" href="#" ng-click="SaveUpdateMapping(cl,$index)">
                                            <i class="fas fa-save "></i>
                                        </a>
                                        <a class="p-1 btn btn-danger btn-sm" data-toggle="tooltip" title="Delete" href="#" ng-click="DelMappingById(cl)">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <footer class="row align-items-center">
                        <div class="col-md-12">
                            <dir-pagination-controls pagination-id="ShiftMappingPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                            </dir-pagination-controls>
                        </div>
                    </footer>
                </div>
            </section>
        </div>
    </section>


</div>
