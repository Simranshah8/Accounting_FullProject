
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")


<script src="~/jslib/hr/Master/AttendanceRule.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="AttendanceRuleController" ng-init="GetAttendanceRuleById()">
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="card p-2">
                    <div class="card" style="border: 1px solid #d4e1db;">
                        <div class="card-header p-2" style="background-color: aliceblue;">
                            Advance Employee Policy Details
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-sm-6 col-md-6">
                                    <div class="form-group">
                                        <label>Permitted Late Arrival(In Min.)</label>
                                        <input type="text" number-input onfocus="this.select();" placeholder="5 min" class="form-control form-control-sm" ng-model="newAttendanceRule.PermittedLateArrival" />
                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-6">
                                    <div class="form-group">
                                        <label>Permitted Early Departure(In Min.)</label>
                                        <input type="text" number-input onfocus="this.select();" placeholder="5 min" class="form-control form-control-sm" ng-model="newAttendanceRule.PermittedEarlyDeparture" />
                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-6">
                                    <div class="form-group">
                                        <label>Mark as Half Day if working hour Less Than(In Min.)</label>
                                        <input type="text" number-input onfocus="this.select();" placeholder="5 min" class="form-control form-control-sm" ng-model="newAttendanceRule.HalfDayLessThanHr" />
                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-6">
                                    <div class="form-group">
                                        <label>Mark as Absent if working hour Less Than(In Min.)</label>
                                        <input type="text" number-input onfocus="this.select();" placeholder="5 min" class="form-control form-control-sm" ng-model="newAttendanceRule.AbsentiLessThanHr" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card" style="border: 1px solid #d4e1db;">
                        <div class="card-header p-2" style="background-color: aliceblue;">
                            Half Day & Absent For Late Arrival & Early Departure
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-sm-3 col-md-3">
                                    <div class="form-group">
                                        <label>Late Arrival(In Min.)</label>
                                        <input type="text" number-input onfocus="this.select();" placeholder="5 min" class="form-control form-control-sm" ng-model="newAttendanceRule.LateArrival" />
                                    </div>
                                </div>
                                <div class="col-sm-3 col-md-3">
                                    <div class="form-group">
                                        <label>Show As for Late Arrival</label>
                                        <select class="form-control form-control-sm select2" ng-model="newAttendanceRule.LateArrivalCut">
                                            <option ng-repeat="A in ArrivalCutColl" ng-value="A.id" ng-selected="A.id == newAttendanceRule.LateArrivalCut "> {{A.text}}</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-3 col-md-3">
                                    <div class="form-group">
                                        <label>Early Departure(In Min.)</label>
                                        <input type="text" number-input onfocus="this.select();" placeholder="5 min" class="form-control form-control-sm" ng-model="newAttendanceRule.EarlyDeparture" />
                                    </div>
                                </div>
                                <div class="col-sm-3 col-md-3">
                                    <div class="form-group">
                                        <label>Show As for Early Departure</label>
                                        <select class="form-control form-control-sm select2" ng-model="newAttendanceRule.EarlyDepartureCut">
                                            <option ng-repeat="A in ArrivalCutColl" ng-value="A.id" ng-selected="A.id == newAttendanceRule.EarlyDepartureCut "> {{A.text}}</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card" style="border: 1px solid #d4e1db;">
                        <div class="card-header p-2" style="background-color: aliceblue;">
                            <div class="custom-control custom-checkbox">
                                <input class="custom-control-input" type="checkbox" ng-model="newAttendanceRule.LateIncoming"
                                       id="customCheckbox1" value="option1">
                                <label for="customCheckbox1"
                                       class="custom-control-label">Enable Late Incoming</label>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-sm-3 col-md-3">
                                    <div class="form-group">
                                        <label>No Of Late In A Month</label>
                                        <input type="text" number-input onfocus="this.select();" placeholder="5 Times" class="form-control form-control-sm" ng-model="newAttendanceRule.NoOfLateInAMonth" />
                                    </div>
                                </div>
                                <div class="col-sm-3 col-md-3">
                                    <div class="form-group">
                                        <label>Cut Days</label>
                                        <select class="form-control form-control-sm select2" ng-model="newAttendanceRule.CutDays">
                                            <option ng-repeat="A in ArrivalCutColl" ng-value="A.id" ng-selected="A.id == newAttendanceRule.CutDays "> {{A.text}}</option>

                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-3 col-md-3">
                                    <div class="form-group">
                                        <label>Ignore Over time Less than(In Min)</label>
                                        <input type="text" number-input onfocus="this.select();" placeholder="5 min" class="form-control form-control-sm" ng-model="newAttendanceRule.IgnoreOTDLessthan" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="time-label">
                        <span class="d-block border-0 p-3 text-center">
                            <button type="button" class="btn btn-sm btn-default load" style="min-width: 90px;" ng-click="ClearAttendanceRule()">Reset</button>
                            <button type="button" class="btn btn-sm btn-info load" style="min-width: 90px;" ng-click="SaveUpdateAttendanceRule()"> Save</button>
                        </span>
                    </div>
                </div>
                <!-- form area ends -->
            </section>
            <!-- /.row -->
        </div>
        <!--/. container-fluid -->
    </section>
    <!-- /.content -->
</div>
