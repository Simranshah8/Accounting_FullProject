@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script src="~/jslib/global/WebSocketEx.js"></script>
<script src="~/jslib/hr/master/ViewDevices.js"></script>
<div ng-app="myApp" ng-controller="VDeviceController" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllDeviceList()">


    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card  card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" ng-click="ClearDevice()" aria-controls="custom-tabs-four-profile" aria-selected="false">Device</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body px-2">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <div id="tableone">
                                    <header class="row">
                                        <div class="col-md-12">
                                            <div class="clearfix">
                                                <form class="form-inline">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text cstm">Show</span>
                                                        </div>
                                                        <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.Device">
                                                            <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.Device">{{pp.text}}</option>
                                                        </select>
                                                        <div class="input-group-append">
                                                            <span class="input-group-text bg-white"><small>entries</small></span>
                                                        </div>
                                                    </div>
                                                    <div class="input-group input-group-sm table-search-filed ml-2">
                                                        <input class="form-control form-control-navbar" type="search"
                                                               placeholder="Search" aria-label="Search" ng-model="searchData.Device">
                                                        <div class="input-group-append">
                                                            <button class="btn btn-default border-left-0" type="submit">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>

                                                    <div class="form-group d-flex mb-0 ml-3">
                                                        <label>
                                                            Port
                                                        </label>
                                                        <input type="number" ng-model="DevicePort" class="ml-2 form-control form-control-sm">
                                                    </div>

                                                    <div class="form-group d-flex mb-0 ml-1">
                                                        <div class="icheck-primary d-inline ml-3">
                                                            <input type="checkbox" id="chkUseSSL" name="chkGodownWise" ng-model="UseSSL">
                                                            <label for="chkUseSSL">
                                                                Use SSL
                                                            </label>
                                                        </div>
                                                    </div>

                                                    @*<a class="btn btn-success btn-sm ml-2" style="color:#fff;"
                                                       ng-click="showSelectDeviceMessage()">
                                                        <i class="fas fa-upload w-t"></i> Upload Card No
                                                    </a>
                                                    <a class="btn btn-danger btn-sm ml-2" style="color:#fff;"
                                                       ng-click="showDeleteDeviceMessage()">
                                                        <i class="fas fa-trash w-t"></i> Delete Card No
                                                    </a>*@
                                                    <a class="btn btn-success btn-sm ml-1" data-toggle="modal" data-target="#SearchCardNo" style="color:#fff;">
                                                        <i class="fas fa-search w-t">
                                                        </i>
                                                        Search Card No
                                                    </a>
                                                    <button type="button" class="btn btn-sm btn-info ml-1"
                                                            style="min-width: 90px" ng-click="checkDeviceStatus()">
                                                        <i class="fas fa-chart-bar w-t"></i> Show Device Status
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                        <!-- end col-md-8 -->
                                    </header>
                                    <div class="search-toolbar">
                                        <div class="table-scroll-x-y table-scroll pb-2" style="height:auto!important;max-height:calc(100vh - 8rem)!important">
                                            <table id="AddDevice"
                                                   class="main-table table table-sm table-bordered bg-white">
                                                <thead>
                                                    <tr>
                                                        <th style="width:60px">
                                                            <div class="custom-control custom-checkbox">
                                                                <input type="checkbox" class="custom-control-input" id="customCheckbox3" ng-model="chkFull" ng-change="toggleAllDevices(chkFull)" />
                                                                <label for="customCheckbox3" class="custom-control-label">All</label>
                                                            </div>
                                                        </th>
                                                        <th style="width: 50px">S.No.</th>
                                                        <th style="width: 150px">Name</th>
                                                        <th style="width: 140px">Machine Serial No.</th>
                                                        <th style="width: 120px">IP Address</th>
                                                        <th style="width: 120px">Branch</th>
                                                        <th style="width: 180px">Department</th>
                                                        <th style="width: 150px">Location</th>
                                                        <th style="width: 140px">Status</th>
                                                        <th class="cstm-sticky" style="width: 330px; right: 0; z-index: 4; background-color: #e9ecef !important;">Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr dir-paginate="cl in DeviceList | filter:searchData.Device | itemsPerPage: perPage.Device" current-page="currentPages.Device" pagination-id="UnitOfWorkPagination">
                                                        <td class="text-center">
                                                            <div class="custom-control custom-checkbox">
                                                                <input class="custom-control-input" type="checkbox" ng-model="cl.IsSelected" id="customCheckbox2{{$index+1}}">
                                                                <label for="customCheckbox2{{$index+1}}" class="custom-control-label"></label>
                                                            </div>
                                                        </td>
                                                        <td>{{$index+1}}</td>
                                                        <td>{{cl.Name}}</td>
                                                        <td>{{cl.MachineSerialNo}}</td>
                                                        <td>{{cl.IPAddress}}</td>
                                                        <td>{{cl.BranchName}}</td>
                                                        <td>{{cl.DepartmentName}}</td>
                                                        <td>{{cl.Location}}</td>
                                                        <td>{{cl.Status}}</td>
                                                        <td class="project-actions cstm-sticky" style="text-align: center; right: 0; z-index: 3;background-color:#ffffff!important">
                                                            <div class="btn-group-sm">                                                                
                                                                <a class="btn btn-default" data-toggle="tooltip" title="View Card" ng-click="GetDeviceEnrollmentById(cl)"><i class="fas fa-eye text-info"></i></a>
                                                                <a class="btn btn-default" data-toggle="tooltip" title="Download All User Finger"> <i class="fas fa-download text-primary"></i> </a>                                                                
                                                                <a class="btn btn-default" data-toggle="tooltip" title="Download All Attendance Log" ng-click="doDeviceAction(cl,'getalllog')"> <i class="fas fa-file-download text-primary"></i> </a>
                                                                <a class="btn btn-default" data-toggle="tooltip" title="Download New Attendance Log Only" ng-click="doDeviceAction(cl,'getnewlog')"> <i class="fas fa-file-download text-primary"></i> </a>                                                                
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>

                                            </table>

                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <dir-pagination-controls pagination-id="UnitOfWorkPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                        </dir-pagination-controls>
                                    </div>
                                </div>

                                <div id="eyetab">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label> Name : <b>{{newDet.Name}}</b></label>
                                        </div>
                                        <div class="col-md-4">
                                            <label> Machine Serial No : <b>{{newDet.MachineSerialNo}}</b></label>
                                        </div>
                                        <div class="col-md-4">
                                            <label> IP Address : <b>{{newDet.IPAddress}}</b></label>
                                        </div>
                                    </div>

                                    <div class="mt-2">

                                        <div class="row">
                                            <div class="col-md-2">
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.Card">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <label> Total Cards : <b>123</b></label>
                                            </div>
                                        </div>
                                        <div class="table-scroll-x-y table-scroll mt-2" style="height:auto!important;max-height:calc(100vh - 8rem)!important">
                                            <table class="main-table table table-sm table-bordered bg-white">
                                                <thead>
                                                    <tr>
                                                        <th style="width: 20px">S.No.</th>
                                                        <th style="width: 250px">RFID Card Number</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr>
                                                        <td>{{$index+1}}</td>
                                                        <td>{{cl.RFIDCardNumber}}</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="text-center">
                                                <div class="time-label">
                                                    <span class="d-block border-0 p-3 text-center">
                                                        <button type="button" class="btn load btn-info" id="backbtn" style="min-width: 90px;">Back to List</button>

                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                                <div class="">
                                    <form>
                                        <div class="row">
                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label>Name</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDevice.Name">
                                                </div>
                                            </div>

                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label>Machine Serial No</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDevice.MachineSerialNo">
                                                </div>
                                            </div>

                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label>Location</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDevice.Location">
                                                </div>
                                            </div>

                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label for="">Device Company</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newDevice.DeviceCompanyId">
                                                        <option ng-value="dc.id" ng-repeat="dc in DeviceCompanyColl" ng-selected="dc.id==newDevice.DeviceCompanyId">{{dc.text}}</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label>IP Address</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newDevice.IPAddress">
                                                </div>
                                            </div>
                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label for="">Branch</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newDevice.BranchId">
                                                        <option ng-repeat="B in BranchList" ng-value="B.BranchId" ng-selected="B.BranchId==newDevice.BranchId">{{B.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label for="">Department</label>
                                                    <select class="form-control form-control-sm select2" ng-model="newDevice.DepartmentId">
                                                        <option ng-value="c.CostCenterDepartmentId" ng-repeat="c in DepartmentList" ng-selected="c.CostCenterDepartmentId==newDevice.DepartmentId">{{c.text}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>

                                    </form>
                                    <footer class="main-footer">
                                        <div class="text-right control-btns">
                                            <button type="button" class="btn btn-default" ng-click="ClearDevice()">Clear</button>
                                            <button type="button" class="btn btn-primary" ng-click="SaveUpdateDevice()">{{newDevice.Mode}}</button>
                                        </div>
                                    </footer>

                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->


                <div class="modal fade" id="UploadCard" style="margin-top: 0px;">
                    <div class="modal-dialog modal-sm" style="max-width: 400px!important;">
                        <div class="modal-content">
                            <div class="modal-header  p-2">
                                <h6 class="modal-title">Upload Card No</h6>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <div class="form-group">
                                    <label for="">Card No</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="newUpload.CardNo" />
                                </div>
                            </div>
                            <div class="time-label">
                                <span class="d-block border-0 p-3 text-center">
                                    <button ng-disabled="loadingstatus=='running'" type="button" class="btn load btn-success" ng-click="UploadCardno()" style="min-width: 60px;">Upload</button>
                                </span>
                            </div>
                        </div>
                    </div>
                    <!-- /.modal-content -->
                </div>


                <div class="modal fade" id="DeleteCard" style="margin-top: 0px;">
                    <div class="modal-dialog modal-sm" style="max-width: 400px!important;">
                        <div class="modal-content">
                            <div class="modal-header  p-2">
                                <h6 class="modal-title">Delete Card No</h6>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <div class="form-group">
                                    <label for="">Card No</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="newDelete.CardNo" />
                                </div>
                            </div>
                            <div class="time-label">
                                <span class="d-block border-0 p-3 text-center">
                                    <button ng-disabled="loadingstatus=='running'" type="button" class="btn load btn-success" ng-click="DeleteCardno()" style="min-width: 60px;">Delete</button>
                                </span>
                            </div>
                        </div>
                    </div>
                    <!-- /.modal-content -->
                </div>

                <div class="modal fade" id="SearchCardNo" style="margin-top: 0px;">
                    <div class="modal-dialog modal-sm">
                        <div class="modal-content">
                            <div class="modal-header  p-2">
                                <h6 class="modal-title">Search Card No</h6>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group d-flex">
                                            <label style="width:90px">Card No : </label>
                                            <input class="form-control form-control-sm" type="text" ng-model="searchData.CardNo">

                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <button type="button" class="btn btn-sm btn-success" ng-click="FindCardno()" style="min-width: 60px;">Find</button>
                                    </div>

                                </div>
                                <div class="table-scroll-x-y table-scroll mt-2" style="height:auto!important;max-height:calc(100vh - 8rem)!important">
                                    <table class="main-table table table-sm table-bordered bg-white">
                                        <thead>
                                            <tr>
                                                <th style="width: 140px">RFID Card No.</th>
                                                <th style="width: 180px">Device Name</th>
                                                <th style="width: 130px">Machine Serial</th>
                                                <th style="width: 120px">IP Address</th>
                                                <th style="width: 140px">Location</th>
                                                <th style="width: 130px">Branch</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="cl in CardNolist | filter:searchData.CardNo">
                                                <td>{{cl.RFIDCardNumber}}</td>
                                                <td>{{cl.DeviceName}}</td>
                                                <td>{{cl.MachineSerial}}</td>
                                                <td>{{cl.IPAddress}}</td>
                                                <td>{{cl.Location}}</td>
                                                <td>{{cl.Branch}}</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>
                    <!-- /.modal-content -->
                </div>

            </div>
            <!-- /.container-fluid -->
        </div>
    </div>
</div>
