@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Att_ManualAttendance)";
</script>


<script src="~/jslib/hr/Master/ManualAttendance.js"></script>
<div ng-app="myApp" ng-controller="ManualAttendanceController" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAllManualAttendance()">


    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" ng-click="ClearManualAttendance()" aria-controls="custom-tabs-four-profile" aria-selected="false">ManualAttendance</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.ManualAttendance">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.ManualAttendance">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.ManualAttendance">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file" title="Download File">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#ManualAttendance'" sheet-name="'ManualAttendanceList'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#ManualAttendance').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl table-id="'#ManualAttendance'" class="btn btn-secondary btn-light btn-sm wait"
                                               title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>
                                            <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                               data-toggle="modal" data-target="#itemAllocationForModal" data-placement="bottom" title="Filter">
                                                <i class="fas fa-filter"></i>
                                            </a>
                                        </div>


                                    </div>
                                </header>
                                <div class="search-toolbar mt-2">

                                    <div class="">
                                        <table cellpadding="12" class="main-table table table-bordered table-striped table-hover table-sm" id="ManualAttendance">
                                            <thead>
                                                <tr>
                                                    <th style="text-align: center; width: 60px; ">
                                                        S.No
                                                    </th>
                                                    <th style="text-align: center; width: 150px; ">
                                                        UserId
                                                    </th>
                                                    <th style="text-align: center; width: 150px; ">
                                                        For Date
                                                    </th>
                                                    <th style="text-align: center; width: 200px; ">
                                                        In Time
                                                    </th>
                                                    <th style="text-align: center; width: 200px; ">
                                                        Out Time
                                                    </th>
                                                    <th style="text-align: center; width: 80px;">Action</th>

                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="D in ManualAttendanceList | filter:searchData.ManualAttendance | itemsPerPage: perPage.ManualAttendance" current-page="currentPages.ManualAttendance" pagination-id="ManualAttendancePagination">
                                                    <td style="text-align:center;margin:auto">
                                                        {{$index+1}}
                                                    </td>
                                                    <td style="text-align:left;margin:auto">
                                                        {{D.UserId}}
                                                    </td>
                                                    <td style="text-align:left;margin:auto">
                                                        {{D.ForDateBS}}
                                                    </td>
                                                    <td style="text-align:left;margin:auto">
                                                        {{D.InTime | timeFormat}}
                                                    </td>
                                                    <td style="text-align:left;margin:auto">
                                                        {{D.OutTime | timeFormat}}
                                                    </td>
                                                    <td class="project-actions" style="text-align:center">
                                                        <div class="btn-group-sm text-white">
                                                            <a class="btn btn-info" ng-click="getManualAttendanceById(D, $index)"><i class="fas fa-pencil-alt"></i></a>
                                                            <a class="btn btn-danger" ng-click="DelManualAttendanceById(D)"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>

                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="ManualAttendancePagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                                <div class="">
                                    <form>
                                        <div class="row">
                                            <div class="col-md-9">
                                                <div class="row">
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Employee Name<span style="color:red">*</span></label>
                                                            <div class="input-group-prepend">
                                                                @*<select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.UserId">
                                                                        <option ng-repeat="G in UserList" ng-value="G.UserId" ng-selected="newDet.UserId == G.UserId">{{ G.text}}</option>
                                                                    </select>*@
                                                                <select class="form-control select2bs4 form-control-sm" all-employee ng-model="newDet.UserId" employee-detail="newDet.EmployeeDetails" side-bar-data="newDet.EmpSideBarData" search-by="newDet.EmployeeSearchBy">
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group">
                                                            <label>Device Id</label>
                                                            <input type="number" class="form-control form-control-sm" style="width:100%" ng-model="newDet.DeviceId">
                                                        </div>
                                                    </div>

                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label>Attendance Type</label>
                                                            <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newDet.AttendanceType">
                                                                <option ng-repeat="G in AttendanceTypeColl" ng-value="G.id" ng-selected="newDet.AttendanceType == G.id">{{ G.text}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="person-photo-attachment-wrap text-center">
                                                    <label style=" font-weight: 600;"> </label>
                                                    <div class="img-wrap mx-auto">
                                                        <img ng-src="{{newDet.PhotoPathData || newDet.PhotoPath }}" class="img-fluid" alt="" id="imgPhoto1" style="height:130px; width:165px; border:1px solid #ccc">
                                                    </div>
                                                    <label for="choose-sfile" type="button" class="btn btn-default mt-1 mb-0"><i class="fa fa-image"></i>Choose Photo</label>
                                                    <input id="choose-sfile" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newDet.PhotoPath_TMP" fileread="newDet.PhotoPathData" />
                                                    <canvas id="canvas" width="320" height="240" style="display:none"></canvas>
                                                </div>
                                            </div>


                                            <label><b>Manual Attendance Details :</b></label>
                                            <div class="table-scroll-x-y table-scroll">
                                                <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 60px; background-color: #e9ecef !important;">S.No.</th>
                                                            <th style="width: 150px; background-color: #e9ecef !important">In Out Mode</th>
                                                            <th style="width: 110px; background-color: #e9ecef !important">For Date</th>
                                                            <th style="width: 110px; background-color: #e9ecef !important">InTime </th>
                                                            <th style="width: 110px; background-color: #e9ecef !important">OutTime</th>
                                                            <th style="width: 290px; background-color: #e9ecef !important">Remarks</th>
                                                            <th style="width: 90px; background-color: #e9ecef !important">Action</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr ng-repeat="pDet in newDet.ManualAttDetailsColl">
                                                            <td>{{$index+1}}</td>
                                                            <td>
                                                                <select class="form-control form-control-sm select2" ng-model="pDet.InOutModeId">
                                                                    <option ng-value=" ">**Select In Out Mode</option>
                                                                    <option ng-repeat="G in InOutModeColl" ng-value="G.id" ng-selected="newDet.InOutModeId == G.id">{{ G.text}}</option>
                                                                </select>
                                                            </td>
                                                            <td>
                                                                <input type="text" class="form-control form-control-sm" style="width:100%" ng-model="pDet.ForDate_TMP" date-picker date-detail="pDet.ForDateDet">
                                                            </td>
                                                            <td>
                                                                <input type="time" class="form-control form-control-sm" style="width:100%" ng-model="pDet.InTime_TMP">
                                                            </td>
                                                            <td>
                                                                <input type="time" class="form-control form-control-sm" style="width:100%" ng-model="pDet.OutTime_TMP">
                                                            </td>
                                                            <td>
                                                                <textarea class="form-control form-control-sm" ng-model="pDet.Remarks"
                                                                          rows="1"
                                                                          placeholder=""></textarea>
                                                            </td>
                                                            <td>
                                                                <a class="p-1" ng-click="AddAttDetails($index)">
                                                                    <i class="fas fa-plus text-secondary"></i>
                                                                </a>
                                                                <a class="p-1" ng-click="delAttDetails($index)">
                                                                    <i class="fas fa-trash-alt text-danger"></i>
                                                                </a>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>


                                        </div>

                                    </form>
                                    <footer class="main-footer">
                                        <div class="text-right control-btns">
                                            <button type="button" class="btn btn-default" ng-click="ClearManualAttendance()">Clear</button>
                                            <button type="button" class="btn btn-primary" ng-click="SaveManualAttendance()">{{newDet.Mode}}</button>
                                        </div>
                                    </footer>

                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->
        </div>
    </div>
</div>
