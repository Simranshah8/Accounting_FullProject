@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table th, .table td {
        padding: 0.35rem;
    }
    @@media print {
  .table-scroll-x-y {
    overflow: visible !important;
  }
  .btn, .no-print {
    display: none !important;
  }
}

</style>
<script src="~/jslib/hr/expenses/MonthlyExpenseSummary.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="MonthlyExpensesSummaryController" ng-init="LoadData()">
    <div class="box-body">
        <div class="content">
            <div class="container-fluid">
                <div class="card p-2" id="printSection">
                    <h5 style="text-align:center;">
                        Expenses Statement of <span style="text-transform:uppercase;">{{CompanyDetail.Name}}</span>
                    </h5>
                    <h5 style="text-align:center;">
                        For the Period of <span style="text-transform:uppercase;">{{PeriodName}}</span>
                        <a href="#" class="btn btn-secondary btn-light btn-sm ml-2" data-toggle="tooltip" data-placement="bottom" title="Print" ng-click="printReport()">
                            <i class="fas fa-print"></i>
                        </a>
                    </h5>

                    <div class="row">
                        <div class="col-sm-3">
                            <div class="d-flex align-items-center">
                                <label style="width:120px;">Date From:</label>
                                <input type="text" placeholder="" date-picker ng-model="newFilter.DateFrom_TMP" date-detail="newFilter.DateFromDet" class="form-control form-control-sm" confirm-action="GetMonthlyExpenseSummary()">
                            </div>
                        </div>
                        <div class="col-sm-3" style="margin-bottom:7px;margin-left:-7px;">
                            <div class="d-flex align-items-center">
                                <label style="margin-right: 5px; width: 95px">Date To:</label>
                                <input type="text" placeholder="" date-picker ng-model="newFilter.DateTo_TMP" date-detail="newFilter.DateToDet" class="form-control form-control-sm" confirm-action="GetMonthlyExpenseSummary()">
                            </div>
                        </div>
                        <div class="col-sm-6 col-md-6">
                            <div class="form-group d-flex">
                                <label class="mr-2">Employee</label>
                                @*<select class="form-control select2 form-control-sm" style="width:85%" all-employee ng-model="newFilter.EmployeeId" employee-detail="newFilter.EmployeeDetails" confirm-action="GetMonthlyExpenseSummary()">
                                    </select>*@
                                <select class="form-control form-control-sm select2" active-select2 ng-model="newFilter.UserId" data-placeholder="*Select Employee*" ng-change="GetMonthlyExpenseSummary()">
                                    <option ng-value="cl.UserId" ng-repeat="cl in AgentColl">{{cl.Name}}-{{cl.Code}}</option>
                                </select>


                            </div>
                        </div>
                    </div>

                    <div class="row mb-1">
                        <div class="col-sm-6">
                            <table class="main-table table table-sm table-bordered bg-white" style="margin-top:29px;width:65%">
                                <tbody>
                                    <tr>
                                        <td colspan="2">
                                            NAME: {{newDet.EmployeeName}}
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="2">
                                            DESIGNATION: {{newDet.Designation}}
                                        </td>
                                    </tr>
                                    <tr>
                                        <td> HEAD QUARTER: </td>
                                        <td> {{CompanyDetail.Address}} </td>
                                    </tr>
                                </tbody>

                            </table>
                        </div>
                        <div class="col-sm-6" style="margin-left:-7px;">
                            <table class="main-table table table-sm table-bordered bg-white" style="width:63.5%;">
                                <tbody>
                                    <tr>
                                        <td>NO. ENCLOSER DAYS: </td>
                                        <td style="width: 120px;"> {{newDet.EncloserDays}}</td>
                                    </tr>
                                    <tr>
                                        <td>NO. OF WORKING DAYS: </td>
                                        <td style="width: 120px;"> {{newDet.WorkingDays}}</td>
                                    </tr>
                                    <tr>
                                        <td>NO. OF REST DAYS: </td>
                                        <td style="width: 120px;"> {{newDet.RestDays}}</td>

                                    </tr>
                                    <tr>
                                        <td>NO. OF LEAVE DAYS: </td>
                                        <td style="width: 120px;"> {{newDet.LeaveDays}}</td>

                                    </tr>
                                </tbody>

                            </table>
                        </div>

                    </div>
                    <div class="table-scroll-x-y" style="height: auto !important; margin-top: -18px; overflow: auto !important;">
                        <table class="main-table table table-sm table-bordered bg-white">
                            <thead style=" ">
                                <tr>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle;width:100px">Date</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle;width:100px">Miti</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 90px">Days</th>
                                    <th colspan="2" style=" text-align: center; vertical-align: middle; width: 250px">FROM DEPARTURE</th>
                                    <th colspan="2" style=" text-align: center; vertical-align: middle; width: 250px">TO ARRIVAL</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 130px">MODE OF TRAVEL</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 130px">TRAVEL FARE FUEL NRS</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 120px">LOCAL AND H.Q. ALLOWANCE NRS</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 120px">UP/EX COUNTRY ALLOWANCE NRS</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 120px">GRAND TOTAL</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 110px">K.M</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 120px">check in</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 120px">check Out</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 150px">Total Working</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 180px">Remarks</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle; width: 100px">Attachment</th>
                                </tr>
                                <tr>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle;">HEAD QUARTERS/TOWN </th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle;">TIME</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle;">TOWN & MAR</th>
                                    <th rowspan="2" style=" text-align: center; vertical-align: middle;">TIME</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr ng-repeat="EC in newDet.ExpenseClaimDetailsColl">
                                    <td>{{EC.ExpenseDate |dateFormat}}</td>
                                    <td>{{EC.ExpenseMitti}}</td>
                                    <td>{{EC.DayName}}</td>
                                    <td>{{EC.DestinationFrom}}</td>
                                    <td>{{EC.DepartureTime}}</td>
                                    <td>{{EC.DestinationTo}}</td>
                                    <td>{{EC.ArrivalTime}}</td>
                                    <td>{{EC.TravelMode}}</td>
                                    <td>{{EC.TravelFuelAmt | number: 2}}</td>
                                    <td>{{EC.LocalAllowanceAmt | number: 2}}</td>
                                    <td>{{EC.CountryAlowanceAmt | number: 2}}</td>
                                    <td>{{EC.GrandTotal | number: 2}}</td>
                                    <td>{{EC.Distance}}</td>
                                    <td>{{EC.CheckIn}}</td>
                                    <td>{{EC.CheckOut}}</td>
                                    <td>{{EC.TotalWoking}}</td>
                                    <td>{{EC.Description}}</td>
                                    <td class="text-center" ng-click="ShowPersonalImg(EC)"><i class="fa fa-file" ng-show="EC.HasAttachment==true"></i></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <!--/. container-fluid -->
        </div>
    </div>

    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-body mb-0 p-2">
                    <iframe class="responsive-iframe" ng-hide="viewImg.FileType === 'image'" id="pdfViewer" style="width: 100%; height: 700px; border: none;"></iframe>
                    <img ng-show="viewImg.FileType === 'image'" ng-src="{{viewImg.ContentPath}}" alt="" style="width: 100%; height: auto;" id="imgPreviewAdd">
                </div>
                <div class="modal-footer p-2">
                    <div><a href="{{viewImg.ContentPath}}" download>Download</a></div>
                    <button class="btn btn-success btn-rounded btn-sm ml-4 btn-add text-center dynamic-uiux-sm-btn" data-dismiss="modal" type="button" style="min-width: 70px;">Close</button>
                </div>
            </div>
        </div>
    </div>

</div>