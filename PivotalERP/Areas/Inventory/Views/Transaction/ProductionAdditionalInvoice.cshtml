@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/inventory/transaction/ProductionAdditionalInvoice.js?V=20240801"></script>
<script>
    var VoucherType = @ViewBag.VoucherType;
    var EntityId = @ViewBag.EntityId;
	var TranId=@ViewBag.TranId;
	 var DefaultKeyValues = "@ViewBag.DefaultKeyValues";
</script>
<style>
    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>
<link href="~/wwwroot/dynamic-erp/css/newCss.css" rel="stylesheet" />
<div ng-app="myApp" ng-controller="SJAdditionalInvoiceController" ng-cloak>
    <form>
        <!-- Main content -->
        <div class="sale-page-wrap">
            <div class="overflow-hidden">
                @RenderPage("~/Views/Global/_WaitDialog.cshtml")
                @RenderPage("~/Views/Global/_LedgerDetails.cshtml")
                <!-- Page Content  -->
                <div class="content-wrapper-new main-sales-invoice-page-wrap">
                    <div class="card bodypart">
                        <div class="demo-container h-100">
                            <div class="demo-header">
                                <div class="card-header header-corner-triangle pt-1 pb-0 px-3">
                                    <div class="row">
                                        <div class="col-sm-4" ng-hide="HideShow.VoucherType==true">
                                            <div class="form-group row mb-0">
                                                <label for="inputEmail3" class="col-sm-6 col-form-label text-nowarp  mb-0 d-flex align-items-center justify-content-end">Voucher Type<span style="color:red">*</span></label>
                                                <div class="col-sm-6">
                                                    <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()">
                                                        <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" ng-value="vt.VoucherId" ng-selected="vt.VoucherId == beData.VoucherId">
                                                            {{vt.VoucherName}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-sm-4" ng-hide="HideShow.CostClass==true">
                                            <div class="form-group row mb-0">
                                                <label for="inputEmail3" class="col-sm-4 col-form-label text-nowarp mb-0 d-flex align-items-center justify-content-end">For Year<span style="color:red">*</span></label>
                                                <div class="col-sm-8">
                                                    <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()">
                                                        <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == beData.CostClassId">
                                                            {{cc.Name}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-sm-3"></div>
                                        <div class="col-sm-1 ml-auto text-right">
                                            <div class="d-flex float-right">
                                                <div class="cursor-pointer"
                                                     data-toggle="collapse"
                                                     data-target="#collapseOne"
                                                     aria-expanded="{{!isCollapsed}}"
                                                     aria-controls="collapseOne"
                                                     ng-click="isCollapsed = !isCollapsed">
                                                    <i class="mt-2 mr-2 text-primary fas"
                                                       ng-class="{'fa-chevron-up': !isCollapsed, 'fa-chevron-down': isCollapsed}"></i>
                                                </div>
                                                <div class="dropdown cstm-more-actions">
                                                    <button class="btn btn-default right-sidebar-call dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                        More
                                                    </button>
                                                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                                        <div class="custom-menu">
                                                            <button type="button" id="" class="btn btn-text-link w-100 ctmRightSidebarCollapse"> Remaining Details  <i class="fas fa-arrow-right m-0"></i></button>
                                                            <button type="button" id="ctmRightSidebarCollapse1" class="btn btn-secondary" ng-click="UDFClick=!UDFClick" ng-show="SelectedVoucher.ActiveUDF==true">UDF</button>
                                                            <input class="btn btn-secondary" id="ctmRightSidebarCollapse2" type="file" accept="application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" product-file-model ng-model="ImportItemData.Files_TMP" itemfilepath="ItemFilePath" sheetcoll="SheetColl" />
                                                            <button class="btn btn-text-link w-100 dropdown-toggle w-100" type="button" ng-click="ShowMultipleModal()">
                                                                <i class="fas fa-file-import"></i> Create Multiple Data
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>

                                </div>
                                <div id="collapseOne" class="panel-collapse collapse in show" role="tabpanel" aria-labelledby="headingOne" ng-class="{'show': isCollapsed}">
                                    <div class="card-body py-2 gradient-bg">
                                        <div class="row">
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label for="" class="mt-1" style="min-width:110px;">Voucher No.</label>
                                                    <input type="text" class="form-control form-control-sm serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                    <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group d-flex mb-1">
                                                    <label for="" class="mt-1 mr-2" style="min-width:50px">Ref No.</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.RefNo" style="width:100%" />
                                                    <button class="btn btn-sm btn-default" style="min-width:80px;" data-toggle="modal" @*data-target="#PurchaseList"*@ ng-click="GetPurchaseList()">Voucher</button>

                                                </div>
                                            </div>
                                            <div class="col-md-2"></div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1" id="dvDTVoucher">
                                                    <label for="inputEmail3" style="min-width: 100px;">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Voucher Date'}}<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width:110px;">Gate InWard No</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.GateInWardNo" />
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width:110px;">Bill No </label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.BillDateNo" />
                                                </div>
                                            </div>

                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width:120px;">P.P.No</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.PPNo" />
                                                </div>
                                            </div>

                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width:110px;">L.C. No</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.LCNo" />
                                                </div>
                                            </div>

                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width:110px;">Job No</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.JobNo" />
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width:110px;">Builty No</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.BuiltyNo" />
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width:120px;">Gate InWard Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.GateInWardDate_TMP" date-detail="beData.LCDetail.GateInWardDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width:110px;">Bill Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.BillDate_TMP" date-detail="beData.LCDetail.BillDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width:110px;">P.P.Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.PPDate_TMP" date-detail="beData.LCDetail.PPDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width:110px;">L.C. Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.LCDate_TMP" date-detail="beData.LCDetail.LCDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width:120px;">Builty Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.BuiltyDate_TMP" date-detail="beData.LCDetail.BuiltyDateDet">
                                                </div>
                                            </div>
                                        </div>

                                        @*<div class="row">
                                            <div class="col-md-12">
                                                <div class="form-group">
                                                    <label>Narration</label>
                                                    <input type="text" list="lstNarration" class="form-control form-control-sm hideSideBar" name="" id="" rows="3" placeholder="Narration" ng-model="beData.Narration">
                                                    <datalist id="lstNarration">
                                                        <option ng-repeat="x1 in NarrationList track by $index" value="{{x1}}">
                                                    </datalist>
                                                </div>
                                            </div>
                                        </div>*@

                                    </div>
                                </div>
                                </div>
                                <div class="table-scroll-x-y table-container flex-grow-1">
                                    <div class="outer-scroll-wrapper-h-scrollbar-fix">
                                        <div class="table-h-scrollbar-fix table-scroll-wrapper">
                                            <table id="main-table" make-table-resizable class="main-table table table-sm table-bordered bg-white cstm-sales-invoice-table border-0 dynamic-uiux-table">
                                                <thead style="background: #e6f5fb;">
                                                    <tr>
                                                        <th title="S.No." class="text-center align-middle cstm-sticky" style="width: 46px; left: 0; z-index: 3;">S.No.</th>
                                                        <th title="DR/CR" class="text-center align-middle cstm-sticky text-truncate" style="width: 60px; left: 46px; z-index: 3;">DR/CR</th>
                                                        <th title="Particulars" class="text-center align-middle text-truncate cstm-sticky highlight-on-scroll" style="width: 200px; left:106px; z-index: 3;">Particulars</th>
                                                        <th class="text-center align-middle text-truncate" title="Current Balance" style="width: 150px; z-index: 2;">Current Balance</th>
                                                        <th class="text-center align-middle text-truncate" title="Dr.Amount" style="width: 120px;z-index: 2">Dr.Amount</th>
                                                        <th class="text-center align-middle text-truncate" title="Cr.Amount" style="width: 120px;z-index: 2">Cr.Amount</th>
                                                        <th class="text-center align-middle text-truncate" title="Narration" ng-show="SelectedVoucher.EachNarrationEntry==true" style="width: 150px; z-index: 2">Narration</th>
                                                        <th class="text-center align-middle text-truncate cstm-sticky sticky-action-col highlight-on-scroll" style="width: 76px;">
                                                            <select id="table-action-select" class="form-control form-control-sm action-dropdown">
                                                                <option value="" disabled selected>Action</option>
                                                                <option value="save">Save Layout</option>
                                                                <option value="reset">Reset Layout</option>
                                                            </select>
                                                        </th>
                                                    </tr>
                                                </thead>
                                                <tbody class="position-relative">
                                                    <tr ng-repeat="ledAllocation in beData.LedgerAllocationColl">
                                                        <td class="cstm-sticky" style="width: 46px; left: 0; z-index: 3; background-color: #fff">{{$index+1}}</td>
                                                        <td class="cstm-sticky" style="left: 46px; z-index: 3; background-color: #fff ">
                                                            <select class="form-control form-control-sm rounded-0" ng-model="ledAllocation.DrCr" ng-change="ChangeDrCr(ledAllocation)">
                                                                <option ng-value="d.id" ng-repeat="d in DrCrList" ng-selected="d.id==ledAllocation.DrCr">{{d.text}}</option>
                                                            </select>
                                                        </td>
                                                        <td class="cstm-sticky highlight-on-scroll" style="left: 106px; z-index: 3; background-color: #fff ">
                                                            <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="ledAllocation.LedgerId" ledgertype="1" fortransaction="true"
                                                                    placeholder="** Select Ledger Name **" showdetails="true" confirm-action="ChangeParticularLedger(ledAllocation)" ledger-detail="ledAllocation.LedgerDetails" side-bar-data="ledAllocation.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="3"></select>

                                                        </td>
                                                        <td>{{ledAllocation.CurrentBal |number:2}}</td>
                                                        <td><input type="text" number-input noofdecimal="SelectedVoucher.NoOfDecimalPlaces" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="ledAllocation.DrAmount" ng-blur="AddRowInLedgerAllocation($index,true)" ng-change="ChangeDrCrAmount()" ng-disabled="ledAllocation.DrCr==2"></td>
                                                        <td><input type="text" number-input noofdecimal="SelectedVoucher.NoOfDecimalPlaces" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="ledAllocation.CrAmount" ng-blur="AddRowInLedgerAllocation($index,true)" ng-change="ChangeDrCrAmount()" ng-disabled="ledAllocation.DrCr==1"></td>
                                                        <td ng-show="SelectedVoucher.EachNarrationEntry==true"><input type="text" onfocus="this.select();" class="form-control form-control-sm" ng-model="ledAllocation.Narration"></td>
                                                        <td class="project-actions no-print text-center cstm-sticky sticky-action-col highlight-on-scroll" style="z-index:3;">
                                                            <a class="p-1" href="#" data-original-title="Add Row" ng-click="AddRowInLedgerAllocation($index)">
                                                                <i class="fas fa-plus text-info"></i>
                                                            </a>
                                                            <a class="p-1" href="#" data-original-title="Delete Row." ng-click="delRowLedgerAllocation($index)">
                                                                <i class="fas fa-trash-alt text-danger"></i>
                                                            </a>
                                                        </td>
                                                    </tr>

                                                </tbody>
                                            </table>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
    </form>
    <footer class="main-footer control-btns pt-0">
        <div class="secondary-footer mt-2">
            <div class="row">
                <div class="col-md-8">
                    <div class="form-group">
                        <input type="text" list="lstNarration" class="form-control form-control-sm hideSideBar" name="" id="" rows="1" placeholder="Narration" ng-model="beData.Narration">
                        <datalist id="lstNarration">
                            <option ng-repeat="x1 in NarrationList track by $index" value="{{x1}}">
                        </datalist>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group row">
                        <label class="col-md-3">DR.</label>
                        <label class="form-control form-control-sm col-md-9">
                            {{ beData.DrAmount |number:SelectedVoucher.NoOfDecimalPlaces }}
                        </label>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group row">
                        <label class="col-md-3">CR.</label>
                        <label class="form-control form-control-sm col-md-9">
                            {{ beData.CrAmount |number:SelectedVoucher.NoOfDecimalPlaces }}
                        </label>
                    </div>
                </div>
            </div>
            <div class="row ">
                <div class="col-md-4">
                    <button type="button" class="btn btn-default" data-toggle="modal" data-target="#documentAttachModal">
                        Document Attach ({{ (beData.AttechFiles.length+(beData.DocumentColl ? beData.DocumentColl.length : 0)) }} )
                    </button>

                </div>
                <div class="col-md-8">
                    <span class="d-block text-right">
                        <button type="button" class="btn btn-default" style="min-width: 80px;" ng-click="SearchData()">Search</button>
                        <button type="button" class="btn btn-default" style="min-width: 80px;" ng-click="Print()">Re-Print</button>
                        <button type="button" class="btn btn-outline-danger" style="min-width: 80px;" ng-click="Clear()">Reset</button>
                        <button type="button" class="btn btn-primary" style="min-width: 80px;" ng-click="SaveJournal()" ng-disabled="loadingstatus=='running'">{{beData.Mode}}</button>
                    </span>
                </div>
            </div>

        </div>
    </footer>
    <div class="modal fade sales-quotation-page-modal document-attach-modal modal-header-n-sec-scrollbar-fix" id="searVoucherRightBtn" tabindex="-1" role="dialog" aria-labelledby="partyAccRightBtn" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Search Addtional Journal</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group row">
                                <label for="" class="col-sm-2 col-form-label col-form-label-sm text-center">Search By</label>
                                <div class="col-sm-10">
                                    <div class="input-group input-group-sm mb-3">
                                        <div class="input-group-prepend">
                                            <select class="form-control form-control-sm" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                <option ng-value="asp" ng-repeat="asp in VoucherSearchOptions">{{asp.text}}</option>
                                            </select>
                                        </div>
                                        <input type="text" class="form-control" placeholder="" ng-model="paginationOptions.SearchVal" ng-change="ReSearchData(-1)">
                                        <div class="input-group-append">
                                            <div class="input-group-text">
                                                <span class="fas fa-search" ng-click="ReSearchData(-1)"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <form class="float-right">
                                <div class="form-row align-items-center">
                                    <div class="d-flex align-items-center">
                                        <label class="mr-sm-2 mb-0" for="inlineFormCustomSelect">Show</label>
                                        <input type="text" ng-model="paginationOptions.pageSize" class="form-control form-control-sm input-sm" placeholder="NoOfRows" @*ng-blur="ReSearchData(-2)"*@>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                    <div class="">
                        <table id="main-table" class="main-table table table-sm table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th>Voucher No</th>
                                    <th>RefNo</th>
                                    <th>Voucher Date</th>
                                    <th>Voucher Name</th>
                                    <th>CostClass</th>
                                    <th>Amount</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr dir-paginate="sd in SearchDataColl |orderBy:sortKey:reverse|itemsPerPage:paginationOptions.pageSize" total-items="paginationOptions.TotalRows">
                                    <td align="center">{{sd.VoucherNo}}</td>

                                    <td>{{sd.RefNo}}</td>
                                    <td align="center">{{sd.VoucherDate |dateFormat}}</td>
                                    <td>{{sd.VoucherName}}</td>
                                    <td>{{sd.CostClass}}</td>
                                    <td>{{sd.Amount |number:3}}</td>
                                    <td>
                                        <a class="p-1" href="#" ng-click="GetTransactionById(sd)">
                                            <i class="fas fa-edit text-info"></i>
                                        </a>
                                        <a class="p-1" href="#" ng-click="DelTransactionById(sd)">
                                            <i class="fas fa-trash-alt text-danger"></i>
                                        </a>
                                        <a class="p-1" href="#" ng-click="PrintVoucher(sd.TranId,sd.VoucherId)">
                                            <i class="fas fa-print text-primary"></i>
                                        </a>
                                    </td>
                                </tr>
                            </tbody>

                        </table>
                        <dir-pagination-controls max-size="paginationOptions.pageSize" direction-links="true" boundary-links="true"
                                                 on-page-change="ReSearchData(newPageNumber)">
                        </dir-pagination-controls>
                    </div>

                </div>
                <!-- end modal body -->
                <div class="modal-footer justify-content-between align-items-center py-2">
                    <h6 class="mb-0">Total Record: {{paginationOptions.TotalRows}}</h6>
                    <div class="">
                        <button type="button" class="btn btn-sm btn-outline-secondary dynamic-uiux-sm-btn" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>



    <!-- /.content -->
    @*file-upload modal*@

    <div class="modal fade sales-invoice-page-modal document-attach-modal modal-header-n-sec-scrollbar-fix" id="documentAttachModal" tabindex="-1" role="dialog" aria-labelledby="documentAttachModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Document Attach</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="timeline-item">
                        <div class="add-more-than-one-form-block">
                            <form>
                                <article>
                                    <div class="row">
                                        @*UIUX code update: grid from col-sm-10 to col-sm-12*@
                                        <div class="col-sm-12">
                                            <div class="row">
