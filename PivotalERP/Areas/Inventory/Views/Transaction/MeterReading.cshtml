                                                    <span class="dropdown-item">Choose an option:</span>
                                                    <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'debtorcreditortypes'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                    <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>

                                                </div>
                                                <button print-tbl table-id="'#datatable'" class="btn btn-default btn-sm wait"
                                                        title="Print" style="font-size:13px;padding:7px">
                                                    <i class="fas fa-print"></i>
                                                </button>
                                                <button class="btn btn-sm btn-success" id="addnozzle" style="font-size:13px"><i class="fas fa-plus mr-2"></i>Add Nozzle</button>
                                            </div>


                                        </div>
                                    </header>
                                    <div class="search-toolbar mb-3 mt-2">
                                        <div class="">

                                            <table class="main-table table table-bordered table-striped table-hover table-sm" id="Nozzle">
                                                <tr>
                                                    <th style="text-align: center; width:50px"> S.No </th>
                                                    <th style="width:200px"> Name</th>
                                                    <th style="width:450px"> Description </th>
                                                    <th style="text-align: center; width: 70px">Action</th>

                                                </tr>
                                                <tr dir-paginate="beData in NozzleList | orderBy:sortKey:reverse | filter:searchData.Nozzle | itemsPerPage:perPage.Nozzle" current-page="currentPages.Nozzle" pagination-id="NozzlePagination">


                                                    <td style="text-align:center;margin:auto">
                                                        {{$index+1}}
                                                    </td>
                                                    <td style="text-align: left; margin: auto">
                                                        {{beData.Name}}
                                                    </td>


                                                    <td style="text-align: left; margin: auto">
                                                        {{beData.Description}}
                                                    </td>
                                                    <td class="project-actions text-center" style="text-align:center">
                                                        <div class="btn-group-sm">
                                                            <a href="#" class="btn btn-info btn-sm" ng-click="GetNozzleById(beData)"><i class="fas fa-pencil-alt"></i></a>
                                                            <a href="#" class="btn btn-danger btn-sm" ng-click="DelNozzle(beData,$index)"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </table>
                                            <div class="col-md-12">
                                                <dir-pagination-controls pagination-id="NozzlePagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                                </dir-pagination-controls>
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div id="NozzleForm">
                                    <div class="p-2">
                                        <form>
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label>Name</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="newNozzle.Name">
                                                </div>
                                            </div>
                                            <div class="col-sm-6 mb-3">
                                                <div class="form-group">
                                                    <label>Description</label>
                                                    <textarea type="text" rows="3" class="form-control form-control-sm" ng-model="newNozzle.Description"></textarea>
                                                </div>
                                            </div>

                                            <div class="mt-4 ml-2">
                                                <button type="button" class="btn btn-sm btn-primary" style="min-width:80px;font-size:13px" id="backtonozzle">BackToList</button>
                                                <button type="button" class="btn  btn-sm btn-default" style="min-width: 80px; font-size: 13px" ng-click="ClearNozzle()">Cancel</button>
                                                <button type="button" class="btn  btn-sm btn-success" style="min-width: 80px; font-size: 13px" ng-click="SaveUpdateNozzle()">{{newNozzle.Mode}}</button>
                                            </div>
                                        </form>

                                    </div>

                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                                <div id="PumpTable">
