                                            <th style="width:110px">For Miti</th>
                                            <th style="width:160px">Pump</th>
                                            <th style="width:160px">Nozzle</th>
                                            <th style="width:110px">Last Reading</th>
                                            <th style="width:110px">Current Value</th>
                                            <th style="width:110px">Sales</th>
                                            <th class="text-center" style="width:90px">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr dir-paginate="sd in AllTranColl |filter:searchData.MeterReading|itemsPerPage:perPage.MeterReading"   current-page="currentPages.MeterReading" pagination-id="MeterReadingPagination">
