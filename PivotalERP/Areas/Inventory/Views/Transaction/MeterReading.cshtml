@{
    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/export/tableExport.js"></script>
<script src="~/jslib/export/jquery.base64.js"></script>
<script src="~/jslib/export/jspdf/libs/sprintf.js"></script>
<script src="~/jslib/export/jspdf/jspdf.js"></script>
<script src="~/jslib/export/jspdf/libs/base64.js"></script>
<script src="~/jslib/inventory/transaction/MeterReading.js"></script>

<div ng-app="myApp" ng-controller="NatureController" ng-class="{waiting: loadingstatus=='running'}" ng-init="LoadData()">
    <div class="box-body">
        <div class="pt-2"></div>
        <div class="content">
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true" ng-click="ClearNozzle()"> Nozzle</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false" ng-click="ClearPump()">Pump</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-meter-tab" data-toggle="pill" href="#custom-tabs-meter-profile" role="tab" aria-controls="custom-tabs-meter-profile" aria-selected="false" ng-click="ClearMeterReading()">Meter Reading</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-report-meter-tab" data-toggle="pill" href="#custom-tabs-report-profile" role="tab" aria-controls="custom-tabs-report-profile" aria-selected="false">Report</a>
