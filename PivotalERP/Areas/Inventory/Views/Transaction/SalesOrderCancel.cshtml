@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<link href="~/wwwroot/dynamic-erp/css/newCss.css" rel="stylesheet" />
<script src="~/jslib/inventory/transaction/SalesOrderCancel.js?v=20250725"></script>
<script>
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
	var TranId=@ViewBag.TranId;
	 var DefaultKeyValues = "@ViewBag.DefaultKeyValues";
</script>
<style>
    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .sale-page-wrap .content-wrapper-new {
        padding-left: 0px;
    }
    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>
<div ng-app="myApp" ng-controller="SalesOrderCancelController" ng-cloak>
    <div class="sale-page-wrap">
        <div class="overflow-hidden">
            @RenderPage("~/Views/Global/_WaitDialog.cshtml")
            @RenderPage("~/Views/Global/_LedgerDetails.cshtml")

            <!-- Page Content  -->
            <div class="content-wrapper-new main-sales-invoice-page-wrap">

                <div class="card bodypart">

                    <div class="demo-container h-100">
                        <div class="demo-header">
                            <div class="card-header header-corner-triangle pt-1 pb-0 px-3">
                                <div class="row">
                                    <div class="col-md-3">
                                        <h3 class="card-title">{{SelectedVoucher && SelectedVoucher.VoucherName ? SelectedVoucher.VoucherName : 'Sales Order Cancel'}}</h3>
                                    </div>
                                    <div class="col-md-8" ng-hide="HideShow.CostClass==true && HideShow.VoucherType==true">
                                        <div class="row align-items-center">
                                            <div class="col-sm-4" ng-hide="HideShow.VoucherType==true">
                                                <div class="form-group row">
                                                    <label for="inputEmail3" class="col-sm-6 text-nowarp mb-0 d-flex align-items-center justify-content-end">Voucher Type<span style="color:red">*</span></label>
                                                    <div class="col-sm-6">
                                                        <select class="form-control form-control-sm  hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                            <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" ng-value="vt.VoucherId" ng-selected="vt.VoucherId == beData.VoucherId">
                                                                {{vt.VoucherName}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-hide="HideShow.CostClass==true">
                                                <div class="form-group row">
                                                    <label for="inputEmail3" class="col-sm-4 text-nowarp mb-0 d-flex align-items-center justify-content-end">For Year<span style="color:red">*</span></label>
                                                    <div class="col-sm-8">
                                                        <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                            <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == beData.CostClassId">
                                                                {{cc.Name}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-sm-1 ml-auto text-right">
                                        <div class="d-flex float-right mb-1">
                                            <div class="cursor-pointer"
                                                 data-toggle="collapse"
                                                 data-target="#collapseOne"
                                                 aria-expanded="{{!isCollapsed}}"
                                                 aria-controls="collapseOne"
                                                 ng-click="isCollapsed = !isCollapsed">
                                                <i class="mt-2 mr-2 text-primary fas"
                                                   ng-class="{'fa-chevron-up': !isCollapsed, 'fa-chevron-down': isCollapsed}"></i>
                                            </div>
                                            <div class="dropdown cstm-more-actions">
                                                <button class="btn btn-default right-sidebar-call dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    More
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                                    <div class="custom-menu">
                                                        <button type="button" id="" class="btn btn-text-link w-100 ctmRightSidebarCollapse"> Remaining Details  <i class="fas fa-arrow-right m-0"></i></button>
                                                        <button type="button" id="ctmRightSidebarCollapse1" class="btn btn-secondary" ng-click="UDFClick=!UDFClick" ng-show="SelectedVoucher.ActiveUDF==true">UDF</button>
                                                        <input class="btn btn-secondary" id="ctmRightSidebarCollapse2" type="file" accept="application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" product-file-model ng-model="ImportItemData.Files_TMP" itemfilepath="ItemFilePath" sheetcoll="SheetColl" />
                                                        <button class="btn btn-text-link w-100 dropdown-toggle w-100" type="button" ng-click="ShowMultipleModal()">
                                                            <i class="fas fa-file-import"></i> Create Multiple Data
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div id="collapseOne" class="panel-collapse collapse in show" role="tabpanel" aria-labelledby="headingOne" ng-class="{'show': isCollapsed}">
                                <div class="card-body py-1 gradient-bg">
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width: 100px;">Invoice No.<span style="color:red">*</span></label>
                                                <input type="text" class="form-control form-control-sm serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                            </div>
                                        </div>

                                        <div class="col-md-9">
                                            <div class="d-flex justify-content-between" style="gap: 8px">
                                                <div style="display: flex; flex-grow: 1;">
                                                    <div class="cstm-three-elems-wrap">
                                                        <div>
                                                            <div class="form-group d-flex ref-block-cstm" ng-hide="HideShow.RefNo==true">
                                                                <label class="cstm-label-truncate" title="{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}" for="inputEmail3">{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}</label>
                                                                <input type="text" class="form-control form-control-sm serial hideSideBar  text-truncate show-tooltip" placeholder="" ng-model="beData.RefNo" onfocus="this.select();">
                                                            </div>
                                                        </div>

                                                        <div class="">
                                                            <div class="form-group d-flex cstm-entry-date-field" ng-hide="HideShow.EntryDate==true">
                                                                <label class="cstm-label-truncate" title="{{SelectedVoucher.EntryDateLabel ? SelectedVoucher.EntryDateLabel : 'Entry Date'}}" for="inputEmail3">{{SelectedVoucher.EntryDateLabel ? SelectedVoucher.EntryDateLabel : 'Entry Date'}}</label>
                                                                <input type="text" class="form-control form-control-sm float-right serial hideSideBar" name="EntryDate" date-picker ng-model="beData.EntryDate_TMP" date-detail="beData.EntryDateDet" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="cstm-voucher-date-group-field">
                                                    <div class="form-group d-flex" id="dvDTVoucher">
                                                        <label for="inputEmail3">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Allotment Date'}}<span style="color:red">*</span></label>
                                                        <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-sm-8">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width: 100px;">Party A/C<span style="color:red">*</span></label>
                                                <div class="input-group">
                                                    <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="beData.PartyLedgerId" id="cboParty1" style="width:95%" ledgertype="3" fortransaction="true"
                                                            placeholder="** Select Party Name **" showdetails="true" confirm-action="PartySelectionChange(beData)" ledger-detail="beData.PartyLedger" side-bar-data="beData.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="33"></select>
                                                </div>
                                                <span class="cstm-detail-btn-wrap">
                                                    <a class="btn py-0 btn-default">
                                                        <span class="cstm-detail-btn" data-toggle="modal" data-target="#ledgerdetailid">
                                                            Detail
                                                        </span>
                                                    </a>
                                                </span>
                                            </div>
                                        </div>

                                        <div class="col-sm-4" ng-show="HideShow.ActiveBarCode==false">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width: 100px;">Bar Code</label>
                                                <input barcode-scanner on-barcode-scan="barcodeScanned(barcode)" type="text" class="form-control form-control-sm serial" data-ng-model="beData.ProductBarCode" id="txtBarcode" name="txtBarcode" onfocus="this.select();" autocomplete="off" />
                                            </div>
                                        </div>
                                        <div class="col-sm-4" ng-hide="HideShow.PartyCostCenter==true">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width: 100px;">Party Cost Center</label>

                                                <select autoShowHide="true" class="select2 serial form-control-sm" all-cost-center ng-model="beData.PartyCostCenter" id="cboPartyCostCenter" style="width:95%" fortransaction="true"
                                                        placeholder="** Select CostCenter **" showdetails="true" confirm-action="ShowSideBar(beData.partyCCSideBarData)" costcenter-detail="beData.PartyCC" side-bar-data="beData.partyCCSideBarData" voucher-id="SelectedVoucher.VoucherId" ledger-id="beData.PartyLedgerId" cost-center-type="2"></select>

                                            </div>
                                        </div>
                                        <div class="col-sm-4" ng-hide="HideShow.SalesLedger==true">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width: 100px;">Sales A/C</label>
                                                <select class="form-control form-control-sm select2 serial" style="width: 100%; background-color: #fff" ng-model="beData.SalesLedgerId">
                                                    <option ng-value="sl.LedgerId" ng-repeat="sl in SalesLedgerColl" ng-selected="itemDet.LedgerId==sl.LedgerId">{{sl.Name}}</option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="col-md-4" ng-hide="HideShow.Agent==true">
                                            <div class="form-group d-flex">
                                                <label for="" style="min-width: 100px;">Salesman</label>

                                                <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-sales-man ng-model="beData.AgentId" id="cboAgent" style="width:95%"
                                                        placeholder="** Select Salesman Name **" showdetails="true" confirm-action="ShowSideBar(beData.salesmanSideBarData)" salesman-detail="beData.SalesMan" side-bar-data="beData.salesmanSideBarData"></select>

                                            </div>
                                        </div>
                                        <div class="col-sm-4" ng-hide="HideShow.TranCostCenter==true">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width: 100px;">Cost Center</label>

                                                <select autoShowHide="true" class="select2 serial form-control-sm serial" all-cost-center ng-model="beData.TranCostCenter" id="cboTranCostCenter" style="width:95%" fortransaction="true"
                                                        placeholder="** Select Sales CostCenter **" showdetails="true" confirm-action="ShowSideBar(beData.salescostcenterSideBarData)" salesman-detail="beData.TranCostCenterDet" side-bar-data="beData.salescostcenterSideBarData" voucher-id="SelectedVoucher.VoucherId" ledger-id="beData.PartyLedgerId" cost-center-type="3"></select>

                                            </div>
                                        </div>

                                        <div class="col-sm-4" ng-hide="HideShow.Currency==true">
                                            <div class="row">
                                                <div class="col-sm-8">
                                                    <div class="form-group d-flex">
                                                        <label for="inputEmail3" style="min-width: 100px;">Currency</label>
                                                        <select class=" form-control form-control-sm serial" style="width: 100%;" ng-model="beData.CurrencyId">
                                                            <option ng-repeat="curC in CurrencyColl" ng-value="curC.CurrencyId" ng-selected="curC.CurrencyId == beData.CurrencyId">
                                                                {{curC.Name}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-sm-4">
                                                    <div class="form-group d-flex">
                                                        <label for="inputEmail3" class="mr-2">Rate</label>
                                                        <input type="number" class="form-control form-control-sm serial" placeholder="" ng-model="beData.CurRate" onfocus="this.select();">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>


                        <!-- end form fiels -->

                        <div class="table-scroll-x-y table-container flex-grow-1">
                            <div class="outer-scroll-wrapper-h-scrollbar-fix">
                                <div class="table-h-scrollbar-fix table-scroll-wrapper">
                                    <table id="main-table" make-table-resizable class="main-table table table-sm table-bordered bg-white cstm-sales-invoice-table border-0 dynamic-uiux-table">
                                        <thead style="background: #e6f5fb;">
                                            <tr>
                                                <th rowspan="2" class="text-center align-middle cstm-sticky" style="width: 46px; left: 0; z-index: 3;">S.N.</th>
                                                <th rowspan="2" class="text-center align-middle cstm-sticky highlight-on-scroll text-truncate" title="Particulars" style="width: 300px; left: 46px; z-index: 3;">Particulars</th>
                                                <th ng-hide="HideShow.ProductDescription==true" rowspan="2" class="text-center align-middle text-truncate" style="width: 150px; z-index: 2;" title="Description">Description</th>
                                                <th ng-hide="HideShow.ProductLedger==true" rowspan="2" class="text-center align-middle text-truncate" style="width: 150px; z-index: 2;" title="Sales Ledger">Sales Ledger</th>
                                                <th ng-hide="HideShow.Godown==true" rowspan="2" class="text-center align-middle text-truncate" style="width: 150px; z-index: 2;" title="Godown">Godown</th>
                                                <th ng-hide="HideShow.Batch==true" rowspan="2" class="text-center align-middle text-truncate" style="width: 100px; z-index: 2;" title="{{SelectedVoucher.Product.BatchLabel ? SelectedVoucher.Product.BatchLabel : 'Batch No.' }}">{{SelectedVoucher.Product.BatchLabel ? SelectedVoucher.Product.BatchLabel : 'Batch No.' }}</th>
                                                <th colspan="{{(HideShow.BilledQty==true ? 2 : 3 )}}" scope="colgroup" class="text-center text-truncate" style="width: 250px; z-index: 2;" title="Quantity">Quantity</th>
                                                <th ng-show="SelectedVoucher.Product.ActiveWeight==true" colspan="2" scope="colgroup" class="text-center text-truncate" style="width: 170px; z-index: 2;" title="Weight">Weight</th>
                                                <th ng-show="SelectedVoucher.Product.ActiveVolum==true" colspan="2" scope="colgroup" class="text-center text-truncate" style="width: 170px; z-index: 2;" title="Volume">Volume</th>
                                                <th ng-hide="HideShow.AlternetUnit1==true" colspan="2" scope="colgroup" class="text-center text-truncate" style="width: 180px; z-index: 2;" title="Alt.Unit 1">Alt.Unit 1</th>
                                                <th ng-hide="HideShow.AlternetUnit2==true" colspan="2" scope="colgroup" class="text-center text-truncate" style="width: 180px; z-index: 2;" title="Alt.Unit 2">Alt.Unit 2</th>
                                                <th ng-hide="HideShow.AlternetUnitMultiple==true" colspan="2" scope="colgroup" class="text-center text-truncate" style="width: 170px; z-index: 2;" title="Alt.Unit">Alt.Unit</th>
                                                <th rowspan="2" class="text-center align-middle text-truncate" style="width: 90px;" title="Rate">Rate</th>
                                                <th ng-hide="HideShow.Discount==true" colspan="2" scope="colgroup" class="text-center text-truncate" style="width: 180px; z-index: 2;" title="Discount">Discount</th>
                                                <th ng-hide="HideShow.Amount==true" rowspan="2" class="text-center align-middle text-truncate" style="width: 90px;" title="Amount">Amount</th>
                                                <th ng-hide="HideShow.ExciseDuty==true" rowspan="2" class="text-center align-middle text-truncate" style="width: 100px;" title="Excise Duty">Excise Duty</th>
                                                <th ng-hide="HideShow.Vat==true" rowspan="2" class="text-center align-middle text-truncate" style="width: 90px;" title="Taxable">Taxable</th>
                                                <th ng-hide="HideShow.Vat==true" rowspan="2" class="text-center align-middle text-truncate" style="width: 80px;" title="VAT">VAT</th>
                                                <th ng-hide="HideShow.EachNarration==true" rowspan="2" class="text-center align-middle text-truncate" style="width: 250px;" title="Narration">Narration</th>
                                                <th rowspan="2" class="text-center align-middle cstm-sticky sticky-action-col highlight-on-scroll" style="width: 76px;">
                                                    @*Action*@
                                                    <select id="table-action-select" class="form-control form-control-sm action-dropdown">
                                                        <option value="" disabled selected>Action</option>
                                                        <option value="save">Save Layout</option>
                                                        <option value="reset">Reset Layout</option>
                                                    </select>
                                                </th>
                                            </tr>
                                            <tr>
                                                <th scope="col" class="cstm-sticky text-center" style="top: 28px; z-index: 2;">Actual</th>
                                                <th ng-hide="HideShow.BilledQty==true" scope="col" class="cstm-sticky text-center" style="top: 28px; z-index: 2; ">Billed</th>
                                                <th scope="col" class="cstm-sticky text-center " style="top: 28px; z-index: 2;">Unit</th>
                                                <th ng-show="SelectedVoucher.Product.ActiveWeight==true" scope="col" class="cstm-sticky text-center" style="top: 30px; z-index: 2; ">Qty.</th>
                                                <th ng-show="SelectedVoucher.Product.ActiveWeight==true" scope="col" class="cstm-sticky text-center " style="top: 30px; z-index: 2; ">Unit</th>
                                                <th ng-show="SelectedVoucher.Product.ActiveVolum==true" scope="col" class="cstm-sticky text-center " style="top: 30px; z-index: 2; ">Qty.</th>
                                                <th ng-show="SelectedVoucher.Product.ActiveVolum==true" scope="col" class="cstm-sticky text-center " style="top: 30px; z-index: 2; ">Unit</th>
                                                <th ng-hide="HideShow.AlternetUnit1==true" scope="col" class="cstm-sticky text-center " style="top: 30px; z-index: 2;">Qty.</th>
                                                <th ng-hide="HideShow.AlternetUnit1==true" scope="col" class="cstm-sticky text-center " style="top: 30px; z-index: 2;">Unit</th>
                                                <th ng-hide="HideShow.AlternetUnit2==true" scope="col" class="cstm-sticky text-center " style="top: 30px; z-index: 2;">Qty.</th>
                                                <th ng-hide="HideShow.AlternetUnit2==true" scope="col" class="cstm-sticky text-center " style="top: 30px; z-index: 2;">Unit</th>
                                                <th ng-hide="HideShow.AlternetUnitMultiple==true" scope="col" class="cstm-sticky text-center " style="top: 30px; z-index: 2;">Qty.</th>
                                                <th ng-hide="HideShow.AlternetUnitMultiple==true" scope="col" class="cstm-sticky text-center " style="top: 30px; z-index: 2;">Unit</th>
                                                <th ng-hide="HideShow.Discount==true" scope="col" class="cstm-sticky text-center " style="top: 30px; z-index: 2;">Per(%)</th>
                                                <th ng-hide="HideShow.Discount==true" scope="col" class="cstm-sticky text-center " style="top: 30px; z-index: 2;">Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="itemDet in beData.ItemDetailsColl | filter: { RowType: 'P' } track by $index">
                                                <th class="align-middle cstm-sticky" style="width: 45px; left: 0; z-index: 2; background-color: #fff" ng-click="ShowCurProductDetail(itemDet,$index)"><u>{{$index+1}}({{itemDet.RowType}})</u></th>
                                                <td class="align-middle cstm-sticky highlight-on-scroll" style="width: 250px; z-index: 2; left: 46px; background-color: #fff">
                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-product ng-model="itemDet.ProductId" style="width:100%"
                                                            placeholder="** Select Product  **" showdetails="true" confirm-action="ProductSelectionChange(itemDet)" product-detail="itemDet.productDetail" side-bar-data="itemDet.sideBarData"></select>
                                                </td>
                                                <td ng-hide="HideShow.ProductDescription==true"><input ng-show="itemDet.RowType=='P'" type="text" class="form-control form-control-sm" ng-model="itemDet.Description"></td>
                                                <td style="z-index: 1;" ng-hide="HideShow.ProductLedger==true">
                                                    <select ng-disabled="itemDet.AutoCharge==true" class="form-control form-control-sm select2bs4" active-select2 style="width: 100%; background-color: #fff" ng-model="itemDet.LedgerId" data-placeholder="**Select Sales Ledger**">
                                                        <option ng-value="sl.LedgerId" ng-repeat="sl in SalesLedgerColl" ng-selected="itemDet.LedgerId==sl.LedgerId">{{sl.Name}}</option>
                                                    </select>
                                                </td>
                                                <td style="z-index: 1;" ng-hide="HideShow.Godown==true">
                                                    <select ng-disabled="itemDet.AutoCharge==true" class="form-control form-control-sm select2bs4" active-select2 style="width: 100%; background-color: #fff" ng-model="itemDet.GodownId" data-placeholder="**Select Godown**">
                                                        <option ng-repeat="cc in SelectedVoucher.VoucherWiseGodownColl track by cc.GodownId" ng-value="cc.GodownId" ng-selected="cc.GodownId == itemDet.GodownId">
                                                            {{cc.Name}}
                                                        </option>
                                                    </select>
                                                </td>
                                                <td ng-hide="HideShow.Batch==true">
                                                    <select ng-hide="itemDet.productDetail.MaintainBatchWise==false" class="form-control form-control-sm select2bs4" active-select2 style="width: 100%; background-color: #fff" ng-model="itemDet.Batch">
                                                        <option selected="selected"></option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input ng-hide="itemDet.RowType=='L'" type="text" number-input class="form-control form-control-sm serial hideSideBar" name="ActualQty" style="text-align:center" onfocus="this.select();" ng-change="ChangeItemRowValue(itemDet,'aQty')" positive="true" noofdecimal="itemDet.QtyDecimal" ng-model="itemDet.ActualQty" ng-disabled="itemDet.ReadOnlyQty==true">
                                                </td>
                                                <td ng-hide="HideShow.BilledQty==true">
                                                    <input ng-hide="itemDet.RowType=='L'" type="text" number-input class="form-control form-control-sm serial hideSideBar" name="ActualQty" style="text-align:center" onfocus="this.select();" ng-change="ChangeItemRowValue(itemDet,'bQty')" positive="true" noofdecimal="itemDet.QtyDecimal" ng-model="itemDet.BilledQty" ng-disabled="itemDet.ReadOnlyQty==true">
                                                </td>
                                                <td>
                                                    @*<select class="form-control form-control-sm" style="width: 100%; background-color: #fff" ng-model="itemDet.TranUnitId" data-placeholder="**Select UOM**" ng-show="HideShow.AlternetUnitMultiple==false">
