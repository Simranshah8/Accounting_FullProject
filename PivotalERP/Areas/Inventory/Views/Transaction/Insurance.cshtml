@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script src="~/jslib/inventory/transaction/Insurance.js?v=20240801"></script>
<script>
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Insurance)";
	 var DefaultKeyValues = "@ViewBag.DefaultKeyValues";
</script>
<div ng-app="myApp" ng-controller="InsuranceController" ng-cloak>
    <div class="sale-page-wrap">
        <div class="overflow-hidden">
            @RenderPage("~/Views/Global/_WaitDialog.cshtml")

            <!-- Page Content  -->
            <div class="content-wrapper-new">

                <div class="card">
                    <div class="card-header header-corner-triangle overflow-hidden">
                        <h3 class="card-title">Insurance Details</h3>
                    </div>
                    <div class="card-body">
                        <form action="">
                            <div class="row">
                                <div class="col-sm-8">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-3 col-form-label">Insurance Name</label>
                                        <div class="col-sm-9 col-md-9">
                                            <input type="text" class="form-control serial" placeholder="" ng-model="beData.InsuranceName" id="txtInsuranceName" name="InsuranceName">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Branch</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control serial" placeholder="" ng-model="beData.BranchName">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Contact No.(1)</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial" ng-model="beData.ContactNo1" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Contact No.(2)</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial" ng-model="beData.ContactNo2" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Engine No.</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial" ng-model="beData.EngineNo" ng-blur="getVehilceDetails()" id="txtEngineNo" name="EngineNo" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Chassis No.</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right" ng-model="beData.ChassisNo" readonly />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Segment</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right" ng-model="beData.Segment" />
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Regd.No.</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right" ng-model="beData.RegdNo" readonly />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Model</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right" ng-model="beData.Model" readonly />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">MFG. Year</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right" ng-model="beData.MFGYear" readonly />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">C.C.</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial" ng-model="beData.CC" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Customer Name</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right" ng-model="beData.CustomerName" readonly />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Customer Address.</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial" ng-model="beData.CustomerAddress" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Mobile No.1</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial" ng-model="beData.CustomerMobile1" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Mobile No.2</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial" ng-model="beData.CustomerMobile2" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Group Name</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right" ng-model="beData.PartyGroup" readonly />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Value</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" number-input class="form-control float-right serial" ng-model="beData.SalesRate" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Policy No.</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial" ng-model="beData.PolicyNo" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Issue Date</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial" voucher-date-ad ng-model="beData.IssueDateDet" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Expired After Days</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" number-input class="form-control float-right serial" ng-model="beData.ExpiredAfterDays" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Namsari Name</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial" ng-model="beData.NamsariName" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Namsari Date</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control float-right serial" voucher-date-ad ng-model="beData.NamsariDateDet" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Attchment Ins. Amount</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" number-input class="form-control float-right serial" ng-model="beData.AttchemtAmount" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Insurance By</label>
                                        <div class="col-sm-6 col-md-6">
                                            <select class="form-control select2 serial" style="width: 100%;" ng-model="beData.InsuranceBy">
                                                <option ng-value="1">COMPANY</option>
                                                <option ng-value="2">CUSTOMER</option>
                                                <option ng-value="3">BY BRANCH</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- row -->
                        </form>
                    </div>
                    <!-- /.card body -->
                </div>
                <div style="height: 30px"></div>
            </div>
        </div>
        <!-- /.container-fluid -->
    </div>

    <footer class="main-footer control-btns pt-0">
        <div class="row">
            <div class="col-sm-4">
                <button type="button" class="btn btn-default" data-toggle="modal" data-target="#documentAttachModal">
                    Policy Attach ({{beData.AttechFiles.length}} )
                </button>
            </div>
            <div class="col-sm-8">
                <form class="form-inline justify-content-end">
                    <button type="button" class="btn btn-default ml-1" ng-click="SearchData()">Search</button>
                    <button type="button" class="btn btn-secondary ml-1 serial" ng-click="AddInsurance()" ng-disabled="loadingstatus=='running'">Save</button>
                    <button type="button" class="btn btn-default ml-1" ng-click="Clear()">Reset</button>
                </form>

            </div>
        </div>
    </footer>
    <!--  Document Attach footer Modal demo -->
    <div class="modal fade sales-invoice-page-modal document-attach-modal" id="documentAttachModal" tabindex="-1" role="dialog" aria-labelledby="documentAttachModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Policy Attach</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="input-group" ng-repeat="fl in beData.AttechFiles">
                        <a href="#">{{$index+1}}  -  {{fl.name}}</a>
                    </div>
                    <div class="input-group">
                        <div class="custom-file">
                            <input type="file" class="custom-file-input" id="exampleInputFile" multiple file-model="beData.AttechFiles">
                            <label class="custom-file-label" for="exampleInputFile">Choose file ({{beData.AttechFiles.length}} )</label>
                        </div>
                    </div>
                </div>
                <!-- end modal body -->
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Ok</button>
                    @*<button type="button" class="btn btn-sm btn-primary">Ok</button>*@
                </div>
            </div>
        </div>
    </div>
    <!--  Search Voucher right button Modal demo -->
    <div class="modal fade sales-invoice-page-modal document-attach-modal" id="searVoucherRightBtn" tabindex="-1" role="dialog" aria-labelledby="partyAccRightBtn" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Search Sales Invoice Voucher</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group row">
                                <label for="" class="col-sm-2 col-form-label col-form-label-sm text-center">Search By</label>
                                <div class="col-sm-10">
                                    <div class="input-group input-group-sm mb-3">
                                        <div class="input-group-prepend">
                                            <select class="form-control form-control-sm" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                <option ng-value="asp" ng-repeat="asp in VoucherSearchOptions">{{asp.text}}</option>
                                            </select>
                                        </div>
                                        <input type="text" class="form-control" placeholder="" ng-model="paginationOptions.SearchVal"  ng-change="ReSearchData(-1)">
                                        <div class="input-group-append">
                                            <div class="input-group-text">
                                                <span class="fas fa-search" ng-click="ReSearchData(-1)"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <form class="float-right">
                                <div class="form-row align-items-center">
                                    <div class="d-flex align-items-center">
                                        <label class="mr-sm-2 mb-0" for="inlineFormCustomSelect">Show</label>
                                        <input type="text" ng-model="paginationOptions.pageSize" class="form-control input-sm" placeholder="NoOfRows" @*ng-blur="ReSearchData(-2)"*@>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                    <div class="">
                        <table id="main-table" class="main-table table table-sm table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Miti</th>
                                    <th>Days</th>
                                    <th>Invoice No.</th>
                                    <th>Ref. No.</th>
                                    <th>Party Ledger</th>
                                    <th>Amount</th>
                                    <th>Voucher</th>
                                    <th>CostClass</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr dir-paginate="sd in SearchDataColl |orderBy:sortKey:reverse|itemsPerPage:paginationOptions.pageSize" total-items="paginationOptions.TotalRows">
                                    <td align="center">{{sd.VoucherDate |dateFormat}}</td>
                                    <td align="center">{{sd.VoucherMiti}}</td>
                                    <td align="center">{{sd.Days}}</td>
                                    <td align="center">{{sd.VoucherNo}}</td>
                                    <td>{{sd.RefNo}}</td>
                                    <td>{{sd.PartyLedger}}</td>
                                    <td align="right">
                                        {{sd.Amount |number:2}}
                                    </td>
                                    <td>{{sd.VoucherName}}</td>
                                    <td>{{sd.CostClass}}</td>
                                    <td>
                                        @*<a class="p-1" href="#" ng-click="GetClassById(cl)">
                                                <i class="fas fa-edit text-info"></i>
                                            </a>
                                            <a class="p-1" href="#" ng-click="DelClassById(cl)">
                                                <i class="fas fa-trash-alt text-danger"></i>
                                            </a>*@
                                        <a class="p-1" href="#" ng-click="PrintVoucher(sd.TranId,sd.VoucherId)">
                                            <i class="fas fa-print text-primary"></i>
                                        </a>
                                    </td>
                                </tr>
                            </tbody>

                        </table>
                        <dir-pagination-controls max-size="paginationOptions.pageSize" direction-links="true" boundary-links="true"
                                                 on-page-change="ReSearchData(newPageNumber)">
                        </dir-pagination-controls>
                    </div>

                </div>
                <!-- end modal body -->
                <div class="modal-footer justify-content-between align-items-center py-2">
                    <h6 class="mb-0">Total Record: {{paginationOptions.TotalRows}}</h6>
                    <div class="">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @RenderPage("~/Global/_ReportTemplates.cshtml");
    @RenderPage("~/Views/Global/_IsValidTran.cshtml")
</div>

<script>
    (function ($) {

        "use strict";

        var fullHeight = function () {

            $('.js-fullheight').css('height', $(window).height());
            $(window).resize(function () {
                $('.js-fullheight').css('height', $(window).height());
            });

        };
        fullHeight();

        $('#ctmRightSidebarCollapse').on('click', function () {
            $('#sidebarzz').toggleClass('active');
        });

    })(jQuery);
</script>
<script>

    $(document).ready(function () {

        $(document).on('keyup', '.serial', function (e) {
            if (e.which == 13) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    e.preventDefault();
                    var inputs = $(this).closest('form').find(':input:visible');
                    inputs.eq(inputs.index(this) + 1).focus();
                }
            }
        });



    });


</script>