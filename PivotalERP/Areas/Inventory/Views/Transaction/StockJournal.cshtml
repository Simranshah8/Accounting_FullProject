@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/inventory/transaction/StockJournal.js?v=20250923"></script>

<script>
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
    var TranId=@ViewBag.TranId;
    var DefaultKeyValues = "@ViewBag.DefaultKeyValues";
</script>
<style>
    .custom-file {
        position: relative;
        display: flex;
        align-items: center;
    }

    .custom-file-label {
        flex: 1;
    }

    .custom-file i {
        cursor: pointer;
        font-size: 18px;
    }
</style>

<link href="~/wwwroot/dynamic-erp/css/stock-flow.css" rel="stylesheet" />
<div ng-app="myApp" ng-controller="StockJournal" ng-init="getVoucherNo()" ng-cloak>
    <div class="sale-page-wrap cstm-stock-journal-page-wrap" @*style="height: 62rem;"*@>
        <div class="overflow-hidden h-100" style="overflow-y:auto!important">
            @RenderPage("~/Views/Global/_WaitDialog.cshtml")
            @RenderPage("~/Views/Global/_LedgerDetails.cshtml")

            <!-- Page Content  -->
            <div class="content-wrapper-new pr-0 dynamic-uiux-page-wrap">
                <div class="container-fluid p-0 bg-white h-100">

                    <div class="card shadow-none">
                        <div class="">
                            <div class="card-header header-corner-triangle pt-1 pb-0 px-3">
                                <div class="row">
                                    <div class="col-md-2">
                                        <h3 class="card-title">{{SelectedVoucher && SelectedVoucher.VoucherName ? SelectedVoucher.VoucherName : 'Stock Journal'}}</h3>
                                    </div>
                                    <div class="col-md-9">
                                        <div class="row" ng-hide="HideShow.CostClass==true && HideShow.VoucherType==true">

                                            <div class="col-sm-4" ng-hide="HideShow.VoucherType==true">
                                                <div class="form-group row">
                                                    <label for="inputEmail3" class="col-sm-4">Voucher Type<span style="color:red">*</span></label>
                                                    <div class="col-sm-8">
                                                        <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                            <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" ng-value="vt.VoucherId" ng-selected="vt.VoucherId == beData.VoucherId">
                                                                {{vt.VoucherName}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-hide="HideShow.CostClass==true">
                                                <div class="form-group row">
                                                    <label for="inputEmail3" class="col-sm-4">For Year<span style="color:red">*</span></label>
                                                    <div class="col-sm-8">
                                                        <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                            <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == beData.CostClassId">
                                                                {{cc.Name}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-show="SelectedVoucher.ActiveProject==true">
                                                <div class="form-group row">
                                                    <label for="" class="col-sm-4 col-form-label text-nowrap">Project</label>
                                                    <div class="col-sm-8">
                                                        <select class="form-control form-control-sm hideSideBar" active-select2 style="width: 100%;" ng-model="beData.ProjectId" data-placeholder="** select project **">
                                                            <option ng-repeat="cc in ProjectColl track by cc.ProjectId" ng-value="cc.ProjectId" ng-selected="cc.ProjectId == beData.ProjectId">
                                                                {{cc.Name}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                    <!--Added by UIUX-->
                                    <div class="col-sm-1 ml-auto text-right">
                                        <div class="d-flex float-right mb-1">
                                            <div class="cursor-pointer"
                                                 data-toggle="collapse"
                                                 data-target="#collapseOne"
                                                 aria-expanded="{{!isCollapsed}}"
                                                 aria-controls="collapseOne"
                                                 ng-click="isCollapsed = !isCollapsed">
                                                <i class="mt-2 mr-2 text-primary fas"
                                                   ng-class="{'fa-chevron-up': !isCollapsed, 'fa-chevron-down': isCollapsed}"></i>
                                            </div>
                                            <div class="dropdown cstm-more-actions">
                                                <button class="btn btn-default right-sidebar-call dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    More
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                                    <div class="custom-menu">
                                                        <button type="button" id="" class="btn btn-text-link w-100 ctmRightSidebarCollapse"> Remaining Details  <i class="fas fa-arrow-right m-0"></i></button>
                                                        <button type="button" id="ctmRightSidebarCollapse1" class="btn btn-secondary" ng-click="UDFClick=!UDFClick" ng-show="SelectedVoucher.ActiveUDF==true">UDF</button>
                                                        <input class="btn btn-secondary" id="ctmRightSidebarCollapse2" type="file" accept="application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" product-file-model ng-model="ImportItemData.Files_TMP" itemfilepath="ItemFilePath" sheetcoll="SheetColl" />
                                                        <button class="btn btn-text-link w-100 dropdown-toggle w-100" type="button" ng-click="ShowMultipleModal()">
                                                            <i class="fas fa-file-import"></i> Create Multiple Data
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                    <!--Ends-->
                                </div>
                            </div>

                            <div class="gradient-bg">
                                <div id="collapseOne" class="panel-collapse collapse in show" role="tabpanel" aria-labelledby="headingOne" ng-class="{'show': isCollapsed}">
                                    <div class="card-body px-3 py-1 pt-2">

                                        <div class="row">
                                            <div class="col-sm-3">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width:120px;">Stock Journal No.<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                    <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                </div>
                                            </div>
                                            <div class="col-sm-9">
                                                <div class="d-flex justify-content-between" style="gap: 8px">
                                                    <div style="display: flex; flex-grow: 1;">
                                                        <div class="cstm-three-elems-wrap">
                                                            <div style="">
                                                                <div class="form-group d-flex" @*ng-hide="HideShow.RefNo==true"*@>
                                                                    <label for="inputEmail3" style="min-width:70px;">{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}<span style="color:red">*</span></label>
                                                                    <input type="text" class="form-control form-control-sm dynamic-uiux serial hideSideBar" placeholder="" ng-model="beData.RefNo">
                                                                </div>
                                                            </div>

                                                            <div class="align-self-center px-2" style="width:140px">
                                                                <div class="form-group" @*ng-show="comDet.Maintain==5"*@>
                                                                    <div class="custom-control custom-checkbox dynamic-uiux-checkbox-md d-flex mb-0">
                                                                        <input class="custom-control-input" type="checkbox"
                                                                               id="customCheckbox1" ng-model="beData.ForVehicle">
                                                                        <label for="customCheckbox1"
                                                                               class="custom-control-label">
                                                                            Fixed Product
                                                                        </label>
                                                                    </div>
                                                                </div>

                                                            </div>
                                                            <div class="">
                                                                <div class="form-group d-flex cstm-entry-date-field" @*ng-hide="HideShow.EntryDate==true"*@>
                                                                    <label for="inputEmail3">{{SelectedVoucher.EntryDateLabel ? SelectedVoucher.EntryDateLabel : 'Entry Date'}}</label>
                                                                    <input type="text" class="form-control form-control-sm dynamic-uiux serial hideSideBar" name="EntryDate" date-picker ng-model="beData.EntryDate_TMP" date-detail="beData.EntryDateDet" />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="cstm-voucher-date-group-field">
                                                            <div class="">
                                                                <div class="form-group d-flex" id="dvDTVoucher">
                                                                    <label for="inputEmail3" style="min-width: 100px;" title="{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : ' Date'}}">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : ' Date'}}<span style="color:red">*</span></label>
                                                                    <input type="text" class="form-control form-control-sm dynamic-uiux float-right serial hideSideBar" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-2">
                                            <div class="form-group d-flex mb-1">
                                                <label for="" class="mt-1" style="min-width:70px">Order No.</label>
                                                <input type="text" class="form-control form-control-sm" ng-model="beData.OrderNo" style="width:100%" disabled />
                                                <button class="btn btn-sm btn-default" data-toggle="modal" ng-click="GetPendingOrder()"><b>::</b></button>
                                            </div>
                                        </div>
                                        <div class="row" ng-show="BOMColl.length>0">
                                            <div class="col-md-3">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:120px">Godown</label>
                                                    <select class="select2 form-control form-control-sm select2" ng-model="beData.FGodownId" style="width:100%">
                                                        <option ng-value="at.GodownId" ng-repeat="at in SelectedVoucher.VoucherWiseGodownColl" ng-selected="at.GodownId == beData.FGodownId">
                                                            {{at.Name}}
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-md-2">
                                                <div class="form-group d-flex">
                                                    <label for="" class="mr-2">B.O.M.</label>
                                                    <select class="form-control form-control-sm select2" style="width: 100%; background-color: #fff" ng-model="beData.BOMTranId" ng-change="BOMChange()">
                                                        <option ng-value="sl.TranId" ng-repeat="sl in BOMColl" ng-selected="itemDet.TranId==sl.BOMTranId">{{sl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex">
                                                    <label for="" class="mr-2">Product</label>
                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-product ng-model="beData.FProductId" style="width:100%"
                                                            placeholder="** Select Product  **" showdetails="true" product-detail="beData.productDetail" side-bar-data="beData.sideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="17" godown-id="beData.FGodownId"></select>
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width: 60px;">Quantity</label>
                                                    <input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:center" onfocus="this.select();" ng-change="ChangeOrderQty()" ng-model="beData.Qty">
                                                    <label class="text-nowrap">{{beData.BaseUnit}}</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mt-1" style="display:flex;justify-content:space-between">
                                    <div class="col-md-3">
                                        <p class="mb-1 px-3"><b>Consumption (Outward)</b></p>
                                    </div>
                                    <div class="col-sm-2">
                                        @*<div class="form-group d-flex">
                                                <label class="mt-1">Code</label>
                                                <input type="text" class="form-control form-control-sm ml-2" />
                                            </div>*@
                                    </div>

                                </div>
                                <div class="table-scroll-x-y h-auto">
                                    <div class="outer-scroll-wrapper-h-scrollbar-fix">
                                        <div class="table-h-scrollbar-fix table-scroll-wrapper">
                                            <table id="main-table" make-table-resizable class="main-table col-shadow-table table table-sm table-bordered bg-white dynamic-uiux-table">
                                                <thead>
                                                    <tr>
                                                        <th rowspan="2" class="text-center align-middle cstm-sticky" style="width: 50px; left: 0; z-index: 3;">S.N.</th>
                                                        <th rowspan="2" class="text-center align-middle cstm-sticky highlight-on-scroll" style="width: 300px; left: 50px; z-index: 3;">Particulars</th>
                                                        <th ng-hide="HideShow.ProductDescription==true" rowspan="2" class="text-center align-middle" style="width: 150px; z-index: 2;">Description</th>
                                                        <th ng-hide="HideShow.ProductLedger==true" rowspan="2" class="text-center align-middle" style="width: 150px; z-index: 2;">Sales Ledger</th>
                                                        <th ng-hide="HideShow.Godown==true" rowspan="2" class="text-center align-middle" style="width: 150px; z-index: 2;">Godown</th>
                                                        <th ng-show="SelectedVoucher.Product.ActiveRack==true" rowspan="2" class="text-center align-middle" style="width: 150px; z-index: 2;">Rack</th>
                                                        <th ng-hide="HideShow.CurrentBalance==true" rowspan="2" class="text-center align-middle" style="width: 150px; z-index: 2;">Closing Stock</th>
                                                        <th ng-hide="HideShow.Batch==true" rowspan="2" class="text-center align-middle" style="width: 100px; z-index: 2;">{{SelectedVoucher.Product.BatchLabel ? SelectedVoucher.Product.BatchLabel : 'Batch No.' }}</th>
                                                        <th ng-hide="HideShow.MFGDate==true" rowspan="2" class="text-center align-middle" style="width: 100px; z-index: 2;">MFG.Date</th>
                                                        <th ng-hide="HideShow.EXPDate==true" rowspan="2" class="text-center align-middle" style="width: 100px; z-index: 2;">EXP.Date</th>

                                                        <th ng-show="SelectedVoucher.FixedProduct.ShowEngineNo==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle" style="width: 180px; z-index: 2;">{{SelectedVoucher.FixedProduct.EngineNo}}</th>
                                                        <th ng-show="SelectedVoucher.FixedProduct.ShowChassisNo==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.ChassisNo}}</th>
                                                        <th ng-show="SelectedVoucher.FixedProduct.ShowRegdNo==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle" style="width: 180px; z-index: 2;">{{SelectedVoucher.FixedProduct.RegdNo}}</th>

                                                        <th ng-show="SelectedVoucher.FixedProduct.ShowModel==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle" style="width: 180px; z-index: 2;">{{SelectedVoucher.FixedProduct.Model}}</th>
                                                        <th ng-show="SelectedVoucher.FixedProduct.ShowType==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.Type}}</th>
                                                        <th ng-show="SelectedVoucher.FixedProduct.ShowColor==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.Color}}</th>
                                                        <th ng-show="SelectedVoucher.FixedProduct.ShowKeyNo==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.KeyNo}}</th>
                                                        <th ng-show="SelectedVoucher.FixedProduct.ShowCodeNo==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.CodeNo}}</th>
                                                        <th ng-show="SelectedVoucher.FixedProduct.ShowMFGYear==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.MFGYear}}</th>

                                                        <th ng-show="comDet.Maintain==2" rowspan="2" class="text-center align-middle" style="width: 80px; z-index: 2;">Weight<br />(gm)</th>
                                                        <th ng-show="comDet.Maintain==2 && SelectedVoucher.Jewellery.Loss==true" rowspan="2" class="text-center align-middle" style="width: 70px; z-index: 2;">Loss<br />(%)</th>
                                                        <th ng-show="comDet.Maintain==2 && SelectedVoucher.Jewellery.Loss==true" rowspan="2" class="text-center align-middle" style="width: 80px; z-index: 2;">Loss<br />(gm)</th>

                                                        <th ng-show="comDet.Maintain==2 && SelectedVoucher.Jewellery.Fine==true" rowspan="2" class="text-center align-middle" style="width: 70px; z-index: 2;">Fine<br />(%)</th>
                                                        <th ng-show="comDet.Maintain==2 && SelectedVoucher.Jewellery.Fine==true" rowspan="2" class="text-center align-middle" style="width: 80px; z-index: 2;">Fine<br />(gm)</th>
                                                        <th ng-show="comDet.Maintain==2 && SelectedVoucher.Jewellery.Processing==true" rowspan="2" class="text-center align-middle" style="width: 70px; z-index: 2;">Processing<br />(%)</th>
                                                        <th ng-show="comDet.Maintain==2 && SelectedVoucher.Jewellery.Processing==true" rowspan="2" class="text-center align-middle" style="width: 80px; z-index: 2;">Processing<br />(gm)</th>

                                                        <th colspan="{{(HideShow.BilledQty==true ? 2 : 3 )}}" scope="colgroup" class="text-center" style="width: 250px; z-index: 2;">{{comDet.Maintain==2 ? 'Total' :'Quantity' }}</th>
                                                        <th ng-hide="HideShow.AlternetUnit1==true" colspan="2" scope="colgroup" class="text-center" style="width: 170px; z-index: 2;">Alt.Unit 1</th>
                                                        <th ng-hide="HideShow.AlternetUnit2==true" colspan="2" scope="colgroup" class="text-center" style="width: 170px; z-index: 2;">Alt.Unit 2</th>
                                                        <th rowspan="2" class="text-center align-middle" style="width: 90px;">Rate</th>
                                                        <th ng-hide="HideShow.Discount==true" colspan="2" scope="colgroup" class="text-center" style="width: 180px; z-index: 2;">Discount</th>
                                                        <th ng-hide="HideShow.Amount==true" rowspan="2" class="text-center align-middle" style="width: 90px;">Amount</th>

                                                        <th ng-show="comDet.Maintain==2" rowspan="2" class="text-center align-middle" style="width: 90px;">Making</th>
                                                        <th ng-show="comDet.Maintain==2" rowspan="2" class="text-center align-middle" style="width: 90px;">Stone/Extra</th>
                                                        <th ng-show="comDet.Maintain==2" rowspan="2" class="text-center align-middle" style="width: 90px;">Total</th>

                                                        <th ng-hide="HideShow.EachNarration==true" rowspan="2" class="text-center align-middle" style="width: 250px;">Narration</th>
                                                        <th ng-hide="SelectedVoucher.Product.ImageAttachment==true" rowspan="2" class="text-center align-middle" style="width: 190px;">Image</th>
                                                        <th rowspan="2" class="text-center align-middle cstm-sticky sticky-action-col highlight-on-scroll" style="width: 76px;">
                                                            @*Action*@
                                                            <select id="table-action-select" class="form-control form-control-sm action-dropdown">
                                                                <option value="" disabled selected>Action</option>
                                                                <option value="save">Save Layout</option>
                                                                <option value="reset">Reset Layout</option>
                                                            </select>
                                                        </th>
                                                    </tr>
                                                    <tr>
                                                        <th scope="col" class="cstm-sticky text-center" style="top: 28px; z-index: 2;">{{comDet.Maintain==2 ? 'Weight' :'Actual' }}</th>
                                                        <th ng-hide="HideShow.BilledQty==true" scope="col" class="cstm-sticky text-center" style="top: 28px; z-index: 2; background-color: #ececec !important;">Billed</th>
                                                        <th scope="col" class="cstm-sticky text-center" style="top: 28px; z-index: 2;">Unit</th>
                                                        <th ng-hide="HideShow.AlternetUnit1==true" scope="col" class="cstm-sticky text-center" style="top: 28px; z-index: 2;">Qty.</th>
                                                        <th ng-hide="HideShow.AlternetUnit1==true" scope="col" class="cstm-sticky text-center" style="top: 28px; z-index: 2;">Unit</th>
                                                        <th ng-hide="HideShow.AlternetUnit2==true" scope="col" class="cstm-sticky text-center" style="top: 28px; z-index: 2;">Qty.</th>
                                                        <th ng-hide="HideShow.AlternetUnit2==true" scope="col" class="cstm-sticky text-center" style="top: 28px; z-index: 2;">Unit</th>
                                                        <th ng-hide="HideShow.Discount==true" scope="col" class="cstm-sticky text-center" style="top: 28px; z-index: 2;">Per(%)</th>
                                                        <th ng-hide="HideShow.Discount==true" scope="col" class="cstm-sticky text-center" style="top: 28px; z-index: 2;">Amount</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr dir-paginate="itemDet in beData.SourceItemDetailsColl | itemsPerPage:perPage.SourceItemDetRow" current-page="currentPages.SourceItemDetRow" pagination-id="SourceItemPagination">
                                                        <th class="align-middle cstm-sticky" style="width: 50px; left: 0; z-index: 2; background-color: #fff" ng-click="ShowCurProductDetail(itemDet,$index)"><u>{{($index+((currentPages.SourceItemDetRow - 1) * (perPage.SourceItemDetRow)))+1}}</u></th>
                                                        <td class="cstm-sticky highlight-on-scroll" style="width: 250px; z-index: 2; left: 50px; background-color: #fff">
                                                            <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-product ng-model="itemDet.ProductId" style="width:100%"
                                                                    placeholder="** Select Product  **" showdetails="true" confirm-action="ProductSelectionChange(itemDet,$index)" product-detail="itemDet.productDetail" side-bar-data="itemDet.sideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="17" godown-id="(itemDet.GodownId>0 ? itemDet.GodownId : beData.GodownId)" godown-change="GodownChange"></select>
                                                        </td>
                                                        <td ng-hide="HideShow.ProductDescription==true"><input type="text" class="form-control form-control-sm" ng-model="itemDet.Description"></td>
                                                        <td style="z-index: 1;" ng-hide="HideShow.ProductLedger==true">
                                                            <select ng-disabled="itemDet.AutoCharge==true" class="form-control form-control-sm select2bs4" active-select2 style="width: 100%; background-color: #fff" ng-model="itemDet.LedgerId" data-placeholder="**Select Sales Ledger**">
                                                                <option ng-value="sl.LedgerId" ng-repeat="sl in SalesLedgerColl" ng-selected="itemDet.LedgerId==sl.LedgerId">{{sl.Name}}</option>
                                                            </select>
                                                        </td>
                                                        <td style="z-index: 1;" ng-hide="HideShow.Godown==true">
                                                            <select ng-disabled="itemDet.AutoCharge==true" class="form-control form-control-sm select2bs4" active-select2 style="width: 100%; background-color: #fff" ng-model="itemDet.GodownId" data-placeholder="**Select Godown**" confirm-action="GodownChange(itemDet.GodownId,itemDet,$index)">
