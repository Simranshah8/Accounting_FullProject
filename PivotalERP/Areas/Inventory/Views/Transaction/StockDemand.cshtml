@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script src="~/jslib/inventory/transaction/StockDemand.js?v=20250725"></script>

<script>
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
	var TranId=@ViewBag.TranId;
	 var DefaultKeyValues = "@ViewBag.DefaultKeyValues";
</script>
<style>
    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>
<link href="~/wwwroot/dynamic-erp/css/newCss.css" rel="stylesheet" />
<div ng-app="myApp" ng-controller="StockDemand" ng-cloak>
    <div class="sale-page-wrap">
        <div class="overflow-hidden">
            @RenderPage("~/Views/Global/_WaitDialog.cshtml")
            @RenderPage("~/Views/Global/_LedgerDetails.cshtml")

            <!-- Page Content  -->
            <div class="content-wrapper-new main-sales-invoice-page-wrap">

                <div class="card bodypart">
                    <div class="demo-container h-100">
                        <div class="demo-header">
                            <div class="card-header header-corner-triangle pt-1 pb-0 px-3">
                                <div class="row">
                                    <div class="col-md-2">
                                        <h3 class="card-title">{{SelectedVoucher && SelectedVoucher.VoucherName ? SelectedVoucher.VoucherName : 'Stock Journal'}}</h3>

                                    </div>

                                    <div class="col-md-9" ng-hide="HideShow.CostClass==true && HideShow.VoucherType== true">
                                        <div class="row align-items-center">
                                            <div class="col-sm-4" ng-hide="HideShow.VoucherType==true">
                                                <div class="form-group mb-0 row">
                                                    <label for="inputEmail3" class="col-sm-6 text-nowarp  mb-0 d-flex align-items-center justify-content-end">Voucher Type<span style="color:red">*</span></label>
                                                    <div class="col-sm-6">
                                                        <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                            <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" ng-value="vt.VoucherId" ng-selected="vt.VoucherId == beData.VoucherId">
                                                                {{vt.VoucherName}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-hide="HideShow.CostClass==true">
                                                <div class="form-group row mb-0">
                                                    <label for="inputEmail3" class="col-sm-4 ptext-nowarp  mb-0 d-flex align-items-center justify-content-end">For Year<span style="color:red">*</span></label>
                                                    <div class="col-sm-8">
                                                        <select class="form-control form-control-sm   hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                            <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == beData.CostClassId">
                                                                {{cc.Name}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-show="SelectedVoucher.ActiveProject==true">
                                                <div class="form-group row mb-0">
                                                    <label for="" class="col-sm-4 col-form-label text-nowrap">Project</label>
                                                    <div class="col-sm-8">
                                                        <select class="form-control form-control-sm hideSideBar" active-select2 style="width: 100%;" ng-model="beData.ProjectId" data-placeholder="** select project **">
                                                            <option ng-repeat="cc in ProjectColl track by cc.ProjectId" ng-value="cc.ProjectId" ng-selected="cc.ProjectId == beData.ProjectId">
                                                                {{cc.Name}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                    <div class="col-sm-1 ml-auto text-right">
                                        <div class="d-flex float-right">
                                            <div class="cursor-pointer"
                                                 data-toggle="collapse"
                                                 data-target="#collapseOne"
                                                 aria-expanded="{{!isCollapsed}}"
                                                 aria-controls="collapseOne"
                                                 ng-click="isCollapsed = !isCollapsed">
                                                <i class="mt-2 mr-2 text-primary fas"
                                                   ng-class="{'fa-chevron-up': !isCollapsed, 'fa-chevron-down': isCollapsed}"></i>
                                            </div>
                                            <div class="dropdown cstm-more-actions">
                                                <button class="btn btn-default right-sidebar-call dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    More
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                                    <div class="custom-menu">
                                                        <button type="button" id="" class="btn btn-text-link w-100 ctmRightSidebarCollapse"> Remaining Details  <i class="fas fa-arrow-right m-0"></i></button>
                                                        <button type="button" id="ctmRightSidebarCollapse1" class="btn btn-secondary" ng-click="UDFClick=!UDFClick" ng-show="SelectedVoucher.ActiveUDF==true">UDF</button>
                                                        <input class="btn btn-secondary" id="ctmRightSidebarCollapse2" type="file" accept="application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" product-file-model ng-model="ImportItemData.Files_TMP" itemfilepath="ItemFilePath" sheetcoll="SheetColl" />
                                                        <button class="btn btn-text-link w-100 dropdown-toggle w-100" type="button" ng-click="ShowMultipleModal()">
                                                            <i class="fas fa-file-import"></i> Create Multiple Data
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                            <div id="collapseOne" class="panel-collapse collapse in show" role="tabpanel" aria-labelledby="headingOne" ng-class="{'show': isCollapsed}">
                                <div class="card-body px-3 py-1 gradient-bg">
                                    <div class="row">

                                        <div class="col-md-3">
                                            <div class="form-group d-flex">
                                                <label for="inputEmail3" style="min-width:100px;">Demand No.<span style="color:red">*</span></label>
                                                <input type="text" class="form-control form-control-sm serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                            </div>

                                        </div>
                                        <div class="col-sm-9">
                                            <div class="d-flex justify-content-between" style="gap: 8px">
                                                <div style="display: flex; flex-grow: 1;">
                                                    <div style="display: flex; flex-grow: 1;">
                                                        <div class="cstm-three-elems-wrap">
                                                            <div>
                                                                <div class="form-group d-flex ref-block-cstm" ng-hide="HideShow.RefNo==true">
                                                                    <label for="inputEmail3" class="col-sm-6">{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}<span style="color:red">*</span></label>

                                                                    <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.RefNo">

                                                                </div>
                                                            </div>
                                                            <div class="">
                                                                <div class="form-group d-flex cstm-entry-date-field" ng-hide="HideShow.EntryDate==true">
                                                                    <label for="inputEmail3" class="cstm-label-truncate">{{SelectedVoucher.EntryDateLabel ? SelectedVoucher.EntryDateLabel : 'Entry Date'}}</label>

                                                                    <input type="text" class="form-control form-control-sm float-right serial hideSideBar" name="EntryDate" date-picker ng-model="beData.EntryDate_TMP" date-detail="beData.EntryDateDet" />

                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="cstm-voucher-date-group-field">
                                                        <div class="form-group d-flex" id="dvDTVoucher">
                                                            <label for="inputEmail3" style="min-width: 100px;">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Demand Date'}}<span style="color:red">*</span></label>
                                                            <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group d-flex">
                                                <label style="min-width:100px;">From Godown</label>
                                                <select class="form-control form-control-sm serial hideSideBar" ng-model="beData.SourceGodownId" style="width:100%">
                                                    <option ng-value="at.GodownId" ng-repeat="at in GodownColl" ng-selected="at.GodownId == beData.SourceGodownId">
                                                        {{at.Name}}
                                                    </option>
                                                </select>
                                            </div>

                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group d-flex">
                                                <label style="min-width:100px">To Godown</label>
                                                <select class="select2 form-control form-control-sm select2" style="width:100%" ng-model="beData.TargetGodownId">
                                                    <option ng-value="at.GodownId" ng-repeat="at in TargetGodownColl" ng-selected="at.GodownId == beData.TargetGodownId">
                                                        {{at.Name}}
                                                    </option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-3">
                                            <div class="form-group d-flex">
                                                <label style="min-width:100px">Brand</label>
                                                <select class="select2 form-control form-control-sm select2" style="width:100%" ng-model="beData.ProductBrandId">
                                                    <option ng-value="at.ProductBrandId" ng-repeat="at in ProductBrandColl" ng-selected="at.ProductBrandId == beData.ProductBrandId">
                                                        {{at.Name}}
                                                    </option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="col-sm-3">
                                            <div class="form-group float-right">
                                                <div class="custom-control custom-checkbox">
                                                    <input class="custom-control-input" type="checkbox"
                                                           id="optionberak" value="optionberak" ng-model="beData.IsBreakDownParts">
                                                    <label for="optionberak"
                                                           class="custom-control-label">
                                                        Is Break Down Parts
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row col-12" ng-show="beData.IsBreakDownParts==true">
                                            <div class="col-md-3">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:100px">Model</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.Model" />
                                                </div>
                                            </div>

                                            <div class="col-md-3">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:100px">Chassis No</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.ChassisNo" />
                                                </div>
                                            </div>

                                            <div class="col-md-3">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:100px">Hours Run</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.HoursRun" />
                                                </div>
                                            </div>

                                            <div class="col-md-3">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:100px">Date of Sale</label>
                                                    <input type="text" class="form-control form-control-sm" name="SaleeDate" date-picker ng-model="beData.DateOfSale_TMP" date-detail="beData.DateOfSaleDet" />
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:100px">Date of Failure</label>
                                                    <input type="text" class="form-control form-control-sm" name="FailureDate" date-picker ng-model="beData.FailureDate_TMP" date-detail="beData.FailureDateDet" />
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:100px">K.M. Run</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.KMRun" />
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:100px">Failure Details</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.FailureDetails" />
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:100px">Job Card No</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.JobCardNo" />
                                                </div>
                                            </div>
                                            <div class="col-md-9">
                                                <div class="form-group d-flex">
                                                    <label style="min-width:100px">Remarks</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.Remarks" />
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>

                        </div>
                        <!-- end form fiels -->

                        <div class="table-scroll-x-y table-container flex-grow-1">
                            <div class="outer-scroll-wrapper-h-scrollbar-fix">
                                <div class="table-h-scrollbar-fix table-scroll-wrapper">
                                    <table id="main-table" make-table-resizable class="main-table table table-sm table-bordered bg-white cstm-sales-invoice-table border-0 dynamic-uiux-table">
                                        <thead style="background: #e6f5fb;">
                                            <tr>
                                                <th rowspan="2" class="text-center align-middle cstm-sticky" style="width: 46px; left: 0; z-index: 3;">S.N.</th>
                                                <th rowspan="2" class="text-center align-middle cstm-sticky highlight-on-scroll text-truncate" title="Particulars" style="width: 300px; left: 46px; z-index: 3;">Particulars</th>
                                                <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 1 }:true" rowspan="2" class="text-center align-middle text-truncate" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>
                                                <th ng-hide="HideShow.ProductDescription==true" rowspan="2" class="text-center align-middle text-truncate" title="Description" style="width: 150px; z-index: 2;">Description</th>
                                                <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 2 }:true" rowspan="2" class="text-center align-middle" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>
                                                <th ng-hide="HideShow.CurrentBalance==true" rowspan="2" class="text-center align-middle text-truncate" title="Closing Stock" style="width: 150px; z-index: 2;">Closing Stock</th>
                                                <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 5 }:true" rowspan="2" class="text-center align-middle text-truncate" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>
                                                <th ng-colspan=" HideShow.BilledQty==true ? 2 : 1" scope="colgroup" class="text-center text-truncate" title="Quantity" style="width: 200px;z-index: 2;">Quantity</th>
                                                <th rowspan="2" class="text-center align-middle text-truncate" title="Alternate Unit" style="width: 150px" ng-hide="HideShow.AlternetUnit==true">Alternate Unit</th>
                                                <th rowspan="2" class="text-center align-middle text-truncate" title="Rate" style="width: 100px;z-index: 2; ">Rate</th>
                                                <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 8 }:true" rowspan="2" class="text-center align-middle text-truncate" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>
                                                <th rowspan="2" class="text-center align-middle text-truncate" title="Per" style="width: 100px;z-index: 2;">Per</th>
                                                <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 9 }:true" rowspan="2" class="text-center align-middle text-truncate" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>
                                                <th rowspan="2" class="text-center align-middle text-truncate" title="Amount" style="width: 90px;z-index: 2; ">Amount</th>
                                                <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 0 }:true" rowspan="2" class="text-center align-middle text-truncate" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>

                                                <th rowspan="2" class="text-center align-middle cstm-sticky sticky-action-col highlight-on-scroll" style="width: 76px;">

                                                    <select id="table-action-select" class="form-control form-control-sm action-dropdown">
                                                        <option value="" disabled selected>Action</option>
                                                        <option value="save">Save Layout</option>
                                                        <option value="reset">Reset Layout</option>
                                                    </select>

                                                </th>
                                            </tr>
                                            <tr>
                                                <th style="top:28px;" scope="col">{{ HideShow.BilledQty==false ? 'Actual' :''  }}</th>
                                                <th style="top:28px;" scope="col" ng-hide="HideShow.BilledQty==true">Billed</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="itemDet in beData.ItemDetailsColl">
                                                <td class="align-middle cstm-sticky text-center" style="width: 46px; left: 0; z-index: 2; background-color: #fff" ng-click="ShowCurProductDetail(itemDet,$index)">
                                                    <u>{{$index+1}}</u>
                                                </td>
                                                <td class="align-middle cstm-sticky highlight-on-scroll" style="left: 46px; z-index: 2; background-color: #fff">
                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-product ng-model="itemDet.ProductId" style="width:100%"
                                                            placeholder="** Select Product  **" showdetails="true" confirm-action="ProductSelectionChange(itemDet)" product-detail="itemDet.productDetail" side-bar-data="itemDet.sideBarData"></select>
                                                </td>
                                                <td ng-repeat="uf in itemDet.UDFFeildsColl | filter: { FieldAfter: 1 }:true ">
                                                    <udf-field voucher="SelectedVoucher" udf="uf" change-event="ChangeItemRowValue(itemDet,uf.NameId)"></udf-field>
                                                </td>
                                                <td ng-hide="HideShow.ProductDescription==true"><input type="text" class="form-control form-control-sm" ng-model="itemDet.Description"></td>
                                                <td ng-repeat="uf in itemDet.UDFFeildsColl | filter: { FieldAfter: 2 }:true ">
                                                    <udf-field udf="uf" voucher="SelectedVoucher" change-event="ChangeItemRowValue(itemDet,uf.NameId)"></udf-field>
                                                </td>
                                                <td ng-hide="HideShow.CurrentBalance==true">{{itemDet.ClosingQty}}</td>
                                                <td ng-repeat="uf in itemDet.UDFFeildsColl | filter: { FieldAfter: 5 }:true ">
                                                    <udf-field udf="uf" voucher="SelectedVoucher" change-event="ChangeItemRowValue(itemDet,uf.NameId)"></udf-field>
                                                </td>
                                                <td><input type="text" number-input class="form-control form-control-sm serial hideSideBar" name="ActualQty" style="text-align:center" onfocus="this.select();" ng-change="ChangeItemRowValue(itemDet,'aQty')" ng-model="itemDet.ActualQty" ng-style="itemDet.IsNegativeQty==true && { 'color' : 'red' }"></td>
                                                <td ng-hide="HideShow.BilledQty==true"><input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:center" name="BilledQty" onfocus="this.select();" ng-change="ChangeItemRowValue(itemDet,'bQty')" ng-model="itemDet.BilledQty"></td>
                                                <td ng-hide="HideShow.AlternetUnit==true"><input type="text" class="form-control form-control-sm hideSideBar" name="Alternet Unit" ng-model="itemDet.AlternetUnitDet"></td>
                                                <td><input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-change="ChangeItemRowValue(itemDet,'rate')" noofdecimal="itemDet.RateDecimal" ng-model="itemDet.Rate" ng-readonly="itemDet.CanEditRate==false"></td>
                                                <td ng-repeat="uf in itemDet.UDFFeildsColl | filter: { FieldAfter:7 }:true ">
                                                    <udf-field udf="uf" voucher="SelectedVoucher" change-event="ChangeItemRowValue(itemDet,uf.NameId)"></udf-field>
                                                </td>
                                                <td>
                                                    <input type="text" class="form-control form-control-sm hideSideBar" readonly name="Unit" ng-model="itemDet.UnitName">
                                                </td>

                                                <td ng-repeat="uf in itemDet.UDFFeildsColl | filter: { FieldAfter:8 }:true ">
                                                    <udf-field udf="uf" voucher="SelectedVoucher" change-event="ChangeItemRowValue(itemDet,uf.NameId)"></udf-field>
                                                </td>
                                                <td><input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" onfocus="this.select();" name="Amount" ng-model="itemDet.Amount" readonly ng-blur="AddRowInItemDetails($index,true)"></td>
                                                <td ng-repeat="uf in itemDet.UDFFeildsColl | filter: { FieldAfter:10 }:true ">
                                                    <udf-field udf="uf" voucher="SelectedVoucher" change-event="ChangeItemRowValue(itemDet,uf.NameId)"></udf-field>
                                                </td>
                                                <td ng-repeat="uf in itemDet.UDFFeildsColl | filter: { FieldAfter:0 }:true ">
                                                    <udf-field udf="uf" voucher="SelectedVoucher" change-event="ChangeItemRowValue(itemDet,uf.NameId)"></udf-field>
                                                </td>
                                                <td class="project-actions no-print text-center cstm-sticky sticky-action-col highlight-on-scroll" style="z-index:3;">
                                                    <div class="btn-group btn-group-sm">
                                                        <a href="#" class="btn btn-info" data-toggle="tooltip" data-placement="top" title="" data-original-title="Add Row" ng-click="AddRowInItemDetails($index,false)"><i class="fas fa-plus"></i></a>
                                                        <a href="#" class="btn btn-danger ml-2" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete Row." ng-click="delRowFromItemDetails($index)"><i class="fas fa-trash"></i></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>

                                </div>
                            </div>
                        </div>

                        <!-- /.card body -->
                    </div>
                </div>
            </div>
        </div>
        <!-- /.container-fluid -->
    </div>

    <footer class="main-footer control-btns pt-0">
        <div class="secondary-footer mb-1 mt-2">
            <div class="row">
                <div class="col-md-8 col-xl-9">
                    <div class="form-group">
                        <input type="text" list="lstNarration" class="form-control hideSideBar" name="" id="" rows="3" placeholder="Narration" ng-model="beData.Narration">
                        <datalist id="lstNarration">
                            <option ng-repeat="x1 in NarrationList track by $index" value="{{x1}}">
                        </datalist>
                    </div>
                </div>
                <div class="col-md-4 col-xl-3">
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-5 col-sm-6 col-form-label font-weight-bold text-dark text-right">Total:</label>
                        <div class="col-7 col-sm-6 col-md-6">
                            <input type="text" number-input class="form-control hideSideBar" style="text-align: right; font-size: x-large" placeholder="" readonly ng-model="beData.TotalAmount">
                        </div>
                    </div>
                </div>
            </div>
        </div>
