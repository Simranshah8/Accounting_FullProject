@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/inventory/transaction/SalesInvoice.js"></script>
<script>
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
</script>
<style>
    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .sale-page-wrap .content-wrapper-new {
        padding-left: 0px;
    }
    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }

    .table-scroll-x-y {
        height: auto !important;
    }

    .alink:hover {
        text-decoration: underline!important;
    }
</style>
<div ng-app="myApp" ng-controller="SalesInvoiceController">
    <div class="sale-page-wrap">
        <div class="overflow-hidden">
            @RenderPage("~/Views/Global/_WaitDialog.cshtml")
            @RenderPage("~/Views/Global/_LedgerDetails.cshtml")

            <!-- Page Content  -->
            <div class="content-wrapper-new">
                <div class="container-fluid">
                    <div class="card p-2">
                        <div class="card-header header-corner-triangle overflow-hidden" ng-hide="HideShow.CostClass==true && HideShow.VoucherType==true">
                            <div class="row">
                                <h3 class="card-title">{{SelectedVoucher && SelectedVoucher.VoucherName ? SelectedVoucher.VoucherName : 'Sales Invoice'}}</h3>
                                <div class="col-sm-4" ng-hide="HideShow.VoucherType==true">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-4 col-form-label">Voucher<span style="color:red">*</span></label>
                                        <div class="col-sm-8">
                                            <select class="form-control  hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()">
                                                <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" value="{{vt.VoucherId}}" ng-selected="vt.VoucherId == beData.VoucherId">
                                                    {{vt.VoucherName}}
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4" ng-hide="HideShow.CostClass==true">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-4 col-form-label">For Year<span style="color:red">*</span></label>
                                        <div class="col-sm-8">
                                            <select class="form-control  hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()">
                                                <option ng-repeat="cc in CostClassColl track by cc.CostClassId" value="{{cc.CostClassId}}" ng-selected="cc.CostClassId == beData.CostClassId">
                                                    {{cc.Name}}
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="">
                            <div class="row">
                                <div class="col-sm-3">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6">Invoice No.<span style="color:red">*</span></label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control form-control-sm serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true">
                                            <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false">
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-3">
                                    <div class="form-group row" ng-hide="HideShow.RefNo==true">
                                        <label for="inputEmail3" class="col-sm-6">{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.RefNo">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group row" ng-hide="HideShow.EntryDate==true">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">{{SelectedVoucher.EntryDateLabel ? SelectedVoucher.EntryDateLabel : 'Entry Date'}}</label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control form-control-sm float-right serial hideSideBar" name="EntryDate" date-picker ng-model="beData.EntryDate_TMP" date-detail="beData.EntryDateDet" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-6 col-form-label">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Invoice Date'}}<span style="color:red">*</span></label>
                                        <div class="col-sm-6 col-md-6">
                                            <input type="text" class="form-control form-control-sm float-right serial hideSideBar" name="VoucherDate" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" disabled />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-8">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-2 ">Party A/C<span style="color:red">*</span></label>
                                        <div class="col-sm-10">
                                            <div class="d-flex">
                                                <div class="input-group">
                                                    <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="beData.PartyLedgerId" id="cboParty" style="width:95%" ledgertype="3"
                                                            placeholder="** Select Party Name **" showdetails="true" confirm-action="PartySelectionChange(beData)" ledger-detail="beData.PartyLedger" side-bar-data="beData.partySideBarData"></select>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4" ng-hide="HideShow.PartyCostCenter==true">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-3 ">Party Cost Center</label>
                                        <div class="col-sm-9">
                                            <select autoShowHide="true" class="select2 serial form-control-sm" all-cost-center ng-model="beData.PartyCostCenter" id="cboPartyCostCenter" style="width:95%"
                                                    placeholder="** Select CostCenter **" showdetails="true" confirm-action="ShowSideBar(beData.partyCCSideBarData)" costcenter-detail="beData.PartyCC" side-bar-data="beData.partyCCSideBarData"></select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4" ng-hide="HideShow.SalesLedger==true">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-4 col-form-label">Sales A/C</label>
                                        <div class="col-sm-8">
                                            <select class="form-control form-control-sm select2" style="width: 100%; background-color: #fff" ng-model="beData.SalesLedgerId">
                                                <option ng-value="sl.LedgerId" ng-repeat="sl in SalesLedgerColl" ng-selected="itemDet.LedgerId==sl.LedgerId">{{sl.Name}}</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4" ng-hide="HideShow.Agent==true">
                                    <div class="form-group row">
                                        <label for="" class="col-sm-4 col-form-label">Salesman</label>
                                        <div class="col-sm-8">
                                            <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-sales-man ng-model="beData.AgentId" id="cboAgent" style="width:95%"
                                                    placeholder="** Select Salesman Name **" showdetails="true" confirm-action="ShowSideBar(beData.salesmanSideBarData)" salesman-detail="beData.SalesMan" side-bar-data="beData.salesmanSideBarData"></select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4" ng-hide="HideShow.TranCostCenter==true">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-3">Cost Center</label>
                                        <div class="col-sm-9">
                                            <select autoShowHide="true" class="select2 serial form-control-sm" sales-cost-center ng-model="beData.TranCostCenter" id="cboTranCostCenter" style="width:95%"
                                                    placeholder="** Select Sales CostCenter **" showdetails="true" confirm-action="ShowSideBar(beData.salescostcenterSideBarData)" salesman-detail="beData.TranCostCenterDet" side-bar-data="beData.salescostcenterSideBarData"></select>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-6" ng-hide="HideShow.Currency==true">
                                    <div class="row">
                                        <label for="inputEmail3" class="col-sm-3 ">Currency</label>
                                        <div class="col-sm-9">
                                            <div class="row">
                                                <div class="col-sm-6">
                                                    <select autoShowHide="true" class="select2 serial form-control-sm" all-currency ng-model="beData.CurrencyId" id="cboCurrency" style="width:95%"
                                                            placeholder="** Select Currency **" showdetails="true" confirm-action="ShowSideBar(beData.currencySideBarData)" currency-detail="beData.CurrencyDet" side-bar-data="beData.currencySideBarData"></select>
                                                </div>
                                                <div class="col-sm-6">
                                                    <div class="form-group row">
                                                        <label for="inputEmail3" class="col-sm-4 col-form-label">Rate</label>
                                                        <div class="col-sm-8">
                                                            <input type="number" class="form-control form-control-sm serial" placeholder="" ng-model="beData.CurRate" onfocus="this.select();">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-5">Product Bundle</label>
                                        <div class="col-sm-7">
                                            <select class="form-control form-control-sm" id="selectbox">
                                                <option>All Items</option>
                                                <option value="#myModal3">Package</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- end form fiels -->
                        <div class="table-scroll-x-y mt-2" style="max-height: calc(100vh - {{(HideShow.CostClass==true && HideShow.VoucherType==true) ? '250px' : '310px'}});">
                            <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                <thead>
                                    <tr>
                                        <th rowspan="2" class="text-center align-middle cstm-sticky" style="width: 50px; left: 0; z-index: 5;background-color:#fff!important;">S.N.</th>
                                        <th rowspan="2" class="text-center align-middle cstm-sticky" style="width: 200px; left: 50px; z-index: 5; background-color: #fff!important;">Particulars</th>
                                        <th ng-hide="HideShow.ProductDescription==true" rowspan="2" class="text-center align-middle" style="width: 150px; z-index: 2;background-color:#fff!important;">Description</th>
                                        <th ng-hide="HideShow.ProductLedger==true" rowspan="2" class="text-center align-middle" style="width: 150px; z-index: 2;background-color:#fff!important;">Sales Ledger</th>
                                        <th ng-hide="HideShow.Godown==true" rowspan="2" class="text-center align-middle" style="width: 150px; z-index: 2;background-color:#fff!important;">Godown</th>
                                        <th ng-hide="HideShow.Batch==true" rowspan="2" class="text-center align-middle" style="width: 100px; z-index: 2;background-color:#fff!important;">Batch No.</th>
                                        <th colspan="{{(HideShow.BilledQty==true ? 2 : 3 )}}" scope="colgroup" class="text-center" style="width: 250px; z-index: 2;background-color:#fff!important;">Quantity</th>
                                        <th ng-hide="HideShow.AlternetUnit1==true" colspan="2" scope="colgroup" class="text-center" style="width: 180px; z-index: 2;background-color:#fff!important;">Alt.Unit 1</th>
                                        <th ng-hide="HideShow.AlternetUnit2==true" colspan="2" scope="colgroup" class="text-center" style="width: 180px; z-index: 2;background-color:#fff!important;">Alt.Unit 2</th>
                                        <th rowspan="2" class="text-center align-middle" style="width: 90px;background-color:#fff!important;">Rate</th>
                                        <th ng-hide="HideShow.Discount==true" colspan="2" scope="colgroup" class="text-center" style="width: 180px; z-index: 2;background-color:#fff!important;">Discount</th>
                                        <th ng-hide="HideShow.Amount==true" rowspan="2" class="text-center align-middle" style="width: 90px;background-color:#fff!important;">Amount</th>
                                        <th ng-hide="HideShow.ExciseDuty==true" rowspan="2" class="text-center align-middle" style="width: 100px;background-color:#fff!important;">Excise Duty</th>
                                        <th ng-hide="HideShow.Vat==true" rowspan="2" class="text-center align-middle" style="width: 90px;background-color:#fff!important;">Taxable</th>
                                        <th ng-hide="HideShow.Vat==true" rowspan="2" class="text-center align-middle" style="width: 80px;background-color:#fff!important;">VAT</th>
                                        <th ng-hide="HideShow.EachNarration==true" rowspan="2" class="text-center align-middle" style="width: 250px;background-color:#fff!important;">Narration</th>
                                        <th rowspan="2" class="text-center align-middle" style="width: 90px;background-color:#fff!important;">Action</th>
                                    </tr>
                                    <tr>
                                        <th scope="col" class="cstm-sticky text-center" style="top: 30px; z-index: 2;background-color:#fff!important;">Actual</th>
                                        <th ng-hide="HideShow.BilledQty==true" scope="col" class="cstm-sticky text-center" style="top: 30px; z-index: 2; background-color: #fff !important;">Billed</th>
                                        <th scope="col" class="cstm-sticky text-center" style="top: 30px; z-index: 2; background-color: #fff !important;">Unit</th>
                                        <th ng-hide="HideShow.AlternetUnit1==true" scope="col" class="cstm-sticky text-center" style="top: 30px; z-index: 2; background-color: #fff !important;">Qty.</th>
                                        <th ng-hide="HideShow.AlternetUnit1==true" scope="col" class="cstm-sticky text-center" style="top: 30px; z-index: 2; background-color: #fff !important;">Unit</th>
                                        <th ng-hide="HideShow.AlternetUnit2==true" scope="col" class="cstm-sticky text-center" style="top: 30px; z-index: 2; background-color: #fff !important;">Qty.</th>
                                        <th ng-hide="HideShow.AlternetUnit2==true" scope="col" class="cstm-sticky text-center" style="top: 30px; z-index: 2; background-color: #fff !important;">Unit</th>
                                        <th ng-hide="HideShow.Discount==true" scope="col" class="cstm-sticky text-center" style="top: 30px; z-index: 2; background-color: #fff !important;">Per(%)</th>
                                        <th ng-hide="HideShow.Discount==true" scope="col" class="cstm-sticky text-center" style="top: 30px; z-index: 2; background-color: #fff !important;">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="itemDet in beData.ItemDetailsColl">
                                        <th class="align-middle cstm-sticky" style="width: 50px; text-align: center; left: 0; z-index: 3; background-color: #fff; text-align: center">{{$index+1}}({{itemDet.RowType}})</th>
                                        <td class="cstm-sticky" ng-show="itemDet.RowType=='P'" style="width: 200px; z-index: 3; left: 50px; background-color: #fff">
                                            <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-product ng-model="itemDet.ProductId" style="width:100%"
                                                    placeholder="** Select Product  **" showdetails="true" confirm-action="ProductSelectionChange(itemDet)" product-detail="itemDet.productDetail" side-bar-data="itemDet.sideBarData"></select>
                                        </td>
                                        <td class="cstm-sticky" ng-show="itemDet.RowType=='L'" style="width: 250px; z-index: 4; left: 50px; background-color: #fff">
                                            <select ng-disabled="itemDet.AutoCharge==true" autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="itemDet.LedgerId" ledgertype="1"
                                                    placeholder="** Select Additional Ledger **" showdetails="true" confirm-action="AditionalCostSelectionChange(itemDet,$index)" ledger-detail="itemDet.costLedgerDetail" side-bar-data="itemDet.costSideBarData"></select>
                                        </td>
                                        <td ng-hide="HideShow.ProductDescription==true"><input ng-show="itemDet.RowType=='P'" type="text" class="form-control form-control-sm" ng-model="itemDet.Description"></td>
                                        <td style="z-index: 1;" ng-hide="HideShow.ProductLedger==true">
                                            <select ng-disabled="itemDet.AutoCharge==true" class="form-control form-control-sm select2" active-select2 style="width: 100%; background-color: #fff" ng-model="itemDet.LedgerId" data-placeholder="**Select Sales Ledger**">
                                                <option ng-value="sl.LedgerId" ng-repeat="sl in SalesLedgerColl" ng-selected="itemDet.LedgerId==sl.LedgerId">{{sl.Name}}</option>
                                            </select>
                                        </td>
                                        <td style="z-index: 1;" ng-hide="HideShow.Godown==true">
                                            <select ng-disabled="itemDet.AutoCharge==true" class="form-control form-control-sm select2" active-select2 style="width: 100%; background-color: #fff" ng-model="itemDet.GodownId" data-placeholder="**Select Godown**">
                                                <option ng-repeat="cc in GodownColl track by cc.GodownId" ng-value="cc.GodownId" ng-selected="cc.GodownId == itemDet.GodownId">
                                                    {{cc.Name}}
                                                </option>
                                            </select>
                                        </td>
                                        <td ng-hide="HideShow.Batch==true">
                                            <select class="form-control form-control-sm select2" active-select2 ng-model="itemDet.Batch">
                                                <option selected="selected"></option>
                                            </select>
                                        </td>
                                        <td>
                                            <input ng-hide="itemDet.RowType=='L'" type="text" number-input class="form-control form-control-sm serial hideSideBar" name="ActualQty" style="text-align:center" onfocus="this.select();" ng-change="ChangeItemRowValue(itemDet,'aQty')" positive="true" noofdecimal="itemDet.QtyDecimal" ng-model="itemDet.ActualQty" ng-style="itemDet.IsNegativeQty==true && { 'color' : 'red' }">
                                        </td>
                                        <td ng-hide="HideShow.BilledQty==true">
                                            <input ng-hide="itemDet.RowType=='L'" type="text" number-input class="form-control form-control-sm serial hideSideBar" name="ActualQty" style="text-align:center" onfocus="this.select();" ng-change="ChangeItemRowValue(itemDet,'bQty')" positive="true" noofdecimal="itemDet.QtyDecimal" ng-model="itemDet.BilledQty" ng-style="itemDet.IsNegativeQty==true && { 'color' : 'red' }">
                                        </td>
                                        <td><input type="text" class="form-control  form-control-sm" ng-model="itemDet.UnitName" disabled></td>
                                        <td ng-hide="HideShow.AlternetUnit1==true">
                                            <input ng-hide="itemDet.RowType=='L'" type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-model="itemDet.ALValue1" ng-change="ChangeItemAlternetQty(itemDet,'unit1')">
                                        </td>
                                        <td ng-hide="HideShow.AlternetUnit1==true">{{itemDet.UnitName1}}</td>
                                        <td ng-hide="HideShow.AlternetUnit2==true">
                                            <input ng-hide="itemDet.RowType=='L'" type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-model="itemDet.ALValue2" ng-change="ChangeItemAlternetQty(itemDet,'unit2')">
                                        </td>
                                        <td ng-hide="HideShow.AlternetUnit2==true">{{itemDet.UnitName2}}</td>

                                        <td ng-show="itemDet.RowType=='L'"><input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-change="ChangeAdditionalRate(itemDet,'rate',$index)" ng-readonly="itemDet.CanEditRate==false" ng-model="itemDet.Rate"></td>
                                        <td ng-show="itemDet.RowType=='P'"><input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-change="ChangeItemRowValue(itemDet,'rate')" noofdecimal="itemDet.RateDecimal" ng-model="itemDet.Rate" ng-readonly="itemDet.CanEditRate==false" positive="true"></td>

                                        <td ng-hide="HideShow.Discount==true"><input type="text" ng-show="itemDet.RowType=='P'" class="form-control  form-control-sm" style="text-align:center" number-input ng-model="itemDet.DiscountPer" ng-change="ChangeItemRowValue(itemDet,'disPer')" positive="true"></td>
                                        <td ng-hide="HideShow.Discount==true"><input type="text" ng-show="itemDet.RowType=='P'" class="form-control form-control-sm" style="text-align:right" number-input ng-model="itemDet.DiscountAmt" ng-change="ChangeItemRowValue(itemDet,'disAmt')" positive="true"></td>
                                        <td ng-hide="itemDet.RowType=='P' || HideShow.Amount==true"><input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" onfocus="this.select();" name="Amount" ng-model="itemDet.Amount" noofdecimal="itemDet.AmountDecimal" ng-change="ChangeAdditionalRate(itemDet,'amt',$index)" ng-readonly="itemDet.CanEditRate==false"></td>
                                        <td ng-hide="itemDet.RowType=='L' || HideShow.Amount==true"><input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" onfocus="this.select();" name="Amount" ng-model="itemDet.Amount" noofdecimal="itemDet.AmountDecimal" ng-disabled="SelectedVoucher.CanEditProductAmount==false" ng-change="ChangeItemRowValue(itemDet,'amt')"></td>
                                        <td ng-hide="HideShow.ExciseDuty==true"><input type="text" class="form-control form-control-sm" number-input ng-model="itemDet.ExDutyAmount" positive="true"></td>
                                        <td ng-hide="HideShow.Vat==true"><input type="text" class="form-control form-control-sm" number-input ng-model="itemDet.TaxableAmt" positive="true"></td>
                                        <td ng-hide="HideShow.Vat==true"><input type="text" class="form-control form-control-sm" number-input ng-model="itemDet.VatAmount" positive="true" style="z-index:4"></td>
                                        <td ng-hide="HideShow.EachNarration==true"><input type="text" class="form-control form-control-sm" ng-model="itemDet.Narration"></td>
                                        <td class="project-actions text-center">
                                            <div class="btn-group-sm">
                                                <a class="btn btn-info text-white" ng-click="AddRowInTable($index)"><i class="fas fa-plus"></i></a>
                                                <a ng-hide="(itemDet.RowType=='L' && itemDet.AutoCharge==true)" class="btn btn-danger text-white" ng-click="delRowFromItemDetails($index)"><i class="fas fa-trash"></i></a>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>

            </div>
        </div>
        <!-- /.container-fluid -->
    </div>

    <footer class="main-footer control-btns pt-0">
        <div class="secondary-footer mb-2 mt-2">
            <div class="row">
                <div class="col-md-8 col-xl-9">
                    <div class="form-group">
                        <input type="text" list="lstNarration" class="form-control form-control-sm" name="" id="" rows="3" placeholder="Narration" ng-model="beData.Narration">
                        <datalist id="lstNarration">
                            <option ng-repeat="x1 in NarrationList track by $index" value="{{x1}}">
                        </datalist>
                    </div>
                </div>
                <div class="col-md-4 col-xl-3">
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-5 col-sm-6 col-form-label font-weight-bold text-dark text-right">Total:</label>
                        <div class="col-7 col-sm-6 col-md-6">
                            <input type="text" number-input class="form-control form-control-sm" style="text-align:right;" placeholder="" readonly ng-model="beData.TotalAmount">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-4">
                @*<button type="button" class="btn btn-default" data-toggle="modal" data-target="#aditionalCostModal">
                        Aditional Cost
                    </button>*@
                <button type="button" class="btn btn-default" data-toggle="modal" data-target="#documentAttachModal">
                    Document Attach ({{beData.AttechFiles.length}} )
                </button>
