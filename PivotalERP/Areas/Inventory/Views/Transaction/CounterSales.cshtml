<script>
    var isUppercase = true; // Default uppercase mode

    $(function () {
        // Function to build the numeric keypad for both types of input
        function buildKeypad(inputBoxClass, isAlpha) {
            var drop = '';
            var i = 1;

            // Clear (C) button changed to CL
            drop += '<button class="btn num-btn num-btn-clear">CL</button>';

            // Numbers (1-9) for both input boxes
            for (i; i < 10; i++) {
                drop += '<button class="btn num-btn">' + i + '</button>';
            }

            // Place the 0 button after 9
            drop += '<button class="btn num-btn">0</button>';

            // Alphabet buttons for regular input box only (QWERTY format)
            if (isAlpha) {
                var qwertyRows = [
                    ['Q', 'W', 'E', 'R', 'T', 'Y', 'U', 'I', 'O', 'P', '@@'],
                    ['A', 'S', 'D', 'F', 'G', 'H', 'J', 'K', 'L', ':', '/'],
                    ['↑', 'Z', 'X', 'C', 'V', 'B', 'N', 'M', '<', '>', '?'] // Moved '↑' before 'Z'
                ];

                // Render QWERTY alphabetic rows
                for (var row = 0; row < qwertyRows.length; row++) {
                    for (var col = 0; col < qwertyRows[row].length; col++) {
                        drop += '<button class="btn num-btn num-btn-alpha" data-letter="' + qwertyRows[row][col] + '">' + qwertyRows[row][col] + '</button>';
                    }
                    drop += '<br>'; // Line break after each row
                }

                // Special characters (only for text inputs)
                var specialChars = ['#', '$', '%', '&', '*', '(', ')', '-', '=', '+', '|', '\\', ';', '.', '_', '~'];
                for (var k = 0; k < specialChars.length; k++) {
                    drop += '<button class="btn num-btn special-char">' + specialChars[k] + '</button>';
                }
            }

            // Other buttons including (., -, DEL)
            drop = '<div class="numeric-keypad-box ' + inputBoxClass + '" style="display: none;"><div class="number-box">' + drop +
                '<button class="btn num-btn">.</button>' +
                '<button class="btn num-btn">-</button>' +

                // Shift button (for regular input fields, removed for numeric)
                (isAlpha ? '<button class="btn num-btn num-btn-space">⎵</button>' : '') +
                (isAlpha ? '<button class="btn num-btn num-btn-shift" style="font-weight: bold;">↑</button>' : '') +
                '<button class="btn num-btn num-btn-delete">DEL</button>' +

                // Close button to hide the keypad
                '<button class="btn num-btn num-btn-close"><i class="fas fa-times-circle text-danger"></i></button>' +
                '</div></div>';

            // Append the keypad to the input box
            $('.' + inputBoxClass).append(drop);
        }

        // Build keypads for both input boxes
        buildKeypad('input-box', true); // Alphabet + Special chars for the regular text input
        buildKeypad('input-number-box', false); // Numeric only keypad (no alphabet or special chars)

        // Keep track of the last focused input field
        var lastInput = null;
        $('input[type="text"]').on('focus', function () {
            lastInput = this;
        });

        // Show/hide the numeric keypad on clicking the input box
        $('input[type="text"]').click(function (e) {
            e.stopPropagation();
            var keypad = $(this).closest('.input-box, .input-number-box').find('.numeric-keypad-box');

            // Hide all other keypads except the one for the clicked input
            $('.numeric-keypad-box').not(keypad).hide();
            keypad.toggle();
        });

        // Button click logic for both keypads
        $(document).on('click', '.num-btn', function () {
            var input = lastInput;
            if (!input) return;  // Prevent if no input field is focused
            var str = $(input).val();

            switch ($(this).text()) {
                case 'CL':
                    $(input).val("");
                    break;

                case '0':
                    if (str == '0' || str == '-0') {
                        console.log('0 has exist at first');
                    } else {
                        $(input).val(str + "0");
                    }
                    break;

                case 'DEL':
                    if (str != '') {
                        $(input).val(str.substring(0, str.length - 1));
                    }
                    break;

                case '↑': // Shift button functionality (only for text input)
                    isUppercase = !isUppercase; // Toggle state
                    updateAlphabetCase(); // Update case of letters
                    break;

                case '⎵': // Space button functionality (only for text input)
                    $(input).val(str + " ");
                    break;

                default:
                    // For special characters and other buttons
                    var char = $(this).text();
                    if (isUppercase && (char === "'" || char === '"')) {
                        $(input).val(str + char); // No modification for these special characters on case toggle
                    } else {
                        $(input).val(str + $(this).text());
                    }
            }
        });

        // Function to update alphabet buttons (uppercase/lowercase toggle)
        function updateAlphabetCase() {
            $('.num-btn-alpha').each(function () {
                var letter = $(this).data('letter'); // Get the letter from data-attribute
                $(this).text(isUppercase ? letter.toUpperCase() : letter.toLowerCase()); // Update the button text
            });
        }

        // Close button functionality
        $(document).on('click', '.num-btn-close', function () {
            $(this).closest('.numeric-keypad-box').hide(); // Hide the keypad
        });

        // Hide the keypad when clicking outside
        $(document).click(function (e) {
            if (!$(e.target).closest('.input-box').length && !$(e.target).closest('.input-number-box').length) {
                $('.numeric-keypad-box').hide();
            }
        });
    });
</script>

