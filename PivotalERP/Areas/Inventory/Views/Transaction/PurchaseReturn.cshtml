                                    <td ng-show="SelectedVoucher.FixedProduct.ShowType==true">
                                        <input type="text" class="form-control form-control-sm" ng-model="curItemA.Type" disabled />
                                    </td>
                                    <td ng-show="SelectedVoucher.FixedProduct.ShowColor==true">
                                        <input type="text" class="form-control form-control-sm" ng-model="curItemA.Color" disabled />
                                    </td>
                                    <td ng-show="SelectedVoucher.FixedProduct.ShowKeyNo==true">
                                        <input type="text" class="form-control form-control-sm" ng-model="curItemA.KeyNo" disabled />
                                    </td>
                                    <td ng-show="SelectedVoucher.FixedProduct.ShowCodeNo==true">
                                        <input type="text" class="form-control form-control-sm" ng-model="curItemA.CodeNo" disabled />
                                    </td>
                                    <td ng-show="SelectedVoucher.FixedProduct.ShowMFGYear==true">
                                        <input type="text" class="form-control form-control-sm" ng-model="curItemA.MFGYear" disabled />
                                    </td>
                                    <td>
                                        <input type="text" number-input class="form-control form-control-sm serial" onfocus="this.select();" ng-model="curItemA.Amount" ng-change="ChangeFixedProductAmount(curItemA,$index)" />
                                    </td>

                                </tr>

                            </tbody>
                        </table>
                        <div class="col-md-12">
                            <dir-pagination-controls pagination-id="FixedProductPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                            </dir-pagination-controls>
                        </div>
