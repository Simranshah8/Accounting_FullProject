@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<link href="~/wwwroot/dynamic-erp/css/newCss.css" rel="stylesheet" />
<script src="~/jslib/inventory/transaction/PurchaseQuotation.js?v=20250922"></script>
<script>
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
	var TranId=@ViewBag.TranId;
	 var DefaultKeyValues = "@ViewBag.DefaultKeyValues";
</script>
<style>
    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .sale-page-wrap .content-wrapper-new {
        padding-left: 0px;
    }
    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>
<div ng-app="myApp" ng-controller="PurchaseQuotationController" ng-cloak>
    <form>
        <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
            <div class="overflow-hidden">
                @RenderPage("~/Views/Global/_WaitDialog.cshtml")
                @RenderPage("~/Views/Global/_LedgerDetails.cshtml")

                <!-- Page Content  -->
                <div class="content-wrapper-new main-sales-invoice-page-wrap">

                    <div class="card bodypart">
                        <div class="demo-container h-100">
                            <div class="demo-header">
                                <div class="card-header header-corner-triangle pt-1 pb-0 px-3">
                                    <div class="row">
                                        <div class="col-md-3">
                                            <h3 class="card-title">{{SelectedVoucher && SelectedVoucher.VoucherName ? SelectedVoucher.VoucherName : 'Purchase Quotation'}}</h3>
                                        </div>
                                        <div class="col-md-8" ng-hide="HideShow.CostClass==true && HideShow.VoucherType==true">
                                            <div class="row align-items-center">
                                                <div class="col-sm-4" ng-hide="HideShow.VoucherType==true">
                                                    <div class="form-group row" style="margin-bottom: 0 !important">
                                                        <label for="inputEmail3" class="col-sm-6 text-nowarp mb-0 d-flex align-items-center justify-content-end">Voucher Type<span style="color:red">*</span></label>
                                                        <div class="col-sm-6">
                                                            <select class="form-control form-control-sm  hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                                <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" ng-value="vt.VoucherId" ng-selected="vt.VoucherId == beData.VoucherId">
                                                                    {{vt.VoucherName}}
                                                                </option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col-sm-4" ng-hide="HideShow.CostClass==true">
                                                    <div class="form-group row">
                                                        <label for="inputEmail3" class="col-sm-4 text-nowarp mb-0 d-flex align-items-center justify-content-end">For Year<span style="color:red">*</span></label>
                                                        <div class="col-sm-8">
                                                            <select class="form-control form-control-sm  hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                                <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == beData.CostClassId">
                                                                    {{cc.Name}}
                                                                </option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col-sm-3" ng-show="SelectedVoucher.ActiveProject==true">
                                                    <div class="form-group row">
                                                        <label for="" class="col-sm-4 col-text-nowarp mb-0 d-flex align-items-center justify-content-end">Project</label>
                                                        <div class="col-sm-8">
                                                            <select class="form-control form-control-sm hideSideBar" active-select2 style="width: 100%;" ng-model="beData.ProjectId" data-placeholder="** select project **">
                                                                <option ng-repeat="cc in ProjectColl track by cc.ProjectId" ng-value="cc.ProjectId" ng-selected="cc.ProjectId == beData.ProjectId">
                                                                    {{cc.Name}}
                                                                </option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                        <div class="col-sm-1 ml-auto text-right">
                                            <div class="d-flex float-right mb-1">
                                                <div class="cursor-pointer"
                                                     data-toggle="collapse"
                                                     data-target="#collapseOne"
                                                     aria-expanded="{{!isCollapsed}}"
                                                     aria-controls="collapseOne"
                                                     ng-click="isCollapsed = !isCollapsed">
                                                    <i class="mt-2 mr-2 text-primary fas"
                                                       ng-class="{'fa-chevron-up': !isCollapsed, 'fa-chevron-down': isCollapsed}"></i>
                                                </div>
                                                <div class="dropdown cstm-more-actions">
                                                    <button class="btn btn-default right-sidebar-call dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                        More
                                                    </button>
                                                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                                        <div class="custom-menu">
                                                            <button type="button" id="" class="btn btn-text-link w-100 ctmRightSidebarCollapse"> Remaining Details  <i class="fas fa-arrow-right m-0"></i></button>
                                                            <button type="button" id="ctmRightSidebarCollapse1" class="btn btn-secondary" ng-click="UDFClick=!UDFClick" ng-show="SelectedVoucher.ActiveUDF==true">UDF</button>
                                                            <input class="btn btn-secondary" id="ctmRightSidebarCollapse2" type="file" accept="application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" product-file-model ng-model="ImportItemData.Files_TMP" itemfilepath="ItemFilePath" sheetcoll="SheetColl" />
                                                            <button class="btn btn-text-link w-100 dropdown-toggle w-100" type="button" ng-click="ShowMultipleModal()">
                                                                <i class="fas fa-file-import"></i> Create Multiple Data
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>

                                        </div>
                                    </div>
                                </div>
                                <div id="collapseOne" class="panel-collapse collapse in show" role="tabpanel" aria-labelledby="headingOne" ng-class="{'show': isCollapsed}">
                                    <div class="card-body px-3 py-1 gradient-bg">
                                        <div class="row">
                                            <div class="col-sm-3">
                                                <div class="form-group mb-2 d-flex">
                                                    <label style="min-width: 100px">Quotation No.<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                    <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                </div>
                                            </div>


                                            <div class="col-sm-9">
                                                <div class="d-flex justify-content-between" style="gap: 8px">
                                                    <div style="display: flex; flex-grow: 1;">
                                                        <div class="cstm-three-elems-wrap">
                                                            <div>
                                                                <div class="form-group d-flex ref-block-cstm" ng-hide="HideShow.RefNo==true">
                                                                    <label class="cstm-label-truncate" title="{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}" for="inputEmail3">{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}</label>
                                                                    <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.RefNo" onfocus="this.select();" @*ng-blur="GetInvoicefromSAP()"*@>
                                                                </div>
                                                            </div>
                                                            <div>
                                                            </div>
                                                            <div class="">
                                                                <div class="form-group d-flex cstm-entry-date-field" ng-hide="HideShow.EntryDate==true">
                                                                    <label class="cstm-label-truncate" for="inputEmail3">{{SelectedVoucher.EntryDateLabel ? SelectedVoucher.EntryDateLabel : 'Entry Date'}}</label>
                                                                    <input type="text" class="form-control form-control-sm float-right serial hideSideBar" name="EntryDate" date-picker ng-model="beData.EntryDate_TMP" date-detail="beData.EntryDateDet" />
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="cstm-voucher-date-group-field">
                                                        <div class="form-group d-flex" id="dvDTVoucher">
                                                            <label for="inputEmail3">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Invoice Date'}}<span style="color:red">*</span></label>
                                                            <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            @*<div class="col-sm-9">
                                                    <div class="d-flex justify-content-between" style="gap: 8px">
                                                        <div style="display: flex; flex-grow: 1;">
                                                            <div class="cstm-three-elems-wrap">
                                                                <div class="col-sm-3">
                                                                    <div class="form-group mb-2 d-flex" ng-hide="HideShow.RefNo==true">
                                                                        <label for="inputEmail3" style="min-width: 100px;">{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}</label>
                                                                        <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.RefNo">
                                                                    </div>
                                                                </div>

                                                                <div class="">
                                                                </div>
                                                                <div class="col-sm-3">
                                                                    <div class="form-group d-flex" ng-hide="HideShow.EntryDate==true">
                                                                        <label for="inputEmail3" style="min-width:100px;">{{SelectedVoucher.EntryDateLabel ? SelectedVoucher.EntryDateLabel : 'Entry Date'}}</label>
                                                                        <input type="text" class="form-control form-control-sm float-right serial hideSideBar" name="EntryDate" date-picker ng-model="beData.EntryDate_TMP" date-detail="beData.EntryDateDet" />
                                                                    </div>
                                                                </div>
                                                                <div class="cstm-voucher-date-group-field">
                                                                    <div class="form-group d-flex" id="dvDTVoucher">
                                                                        <label for="inputEmail3">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Invoice Date'}}<span style="color:red">*</span></label>
                                                                        <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>*@

                                            <div class="col-sm-8">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width: 100px;">Party A/C<span style="color:red">*</span></label>
                                                    <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="beData.PartyLedgerId" id="cboParty2" style="width:95%" ledgertype="2" fortransaction="true"
                                                            placeholder="** Select Party Name **" showdetails="true" confirm-action="PartySelectionChange(beData)" ledger-detail="beData.PartyLedger" side-bar-data="beData.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="5"></select>
                                                    <span class="cstm-detail-btn-wrap">
                                                        <a class="btn py-0 btn-default">
                                                            <span class="cstm-detail-btn" data-toggle="modal" data-target="#ledgerdetailid">
                                                                Detail
                                                            </span>
                                                        </a>
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="col-md-4" ng-show="HideShow.ActiveBarCode==false">
                                                <div class="form-group mb-2 d-flex">
                                                    <label for="inputEmail3" style="min-width:100px;">Bar Code</label>
                                                    <input barcode-scanner on-barcode-scan="barcodeScanned(barcode)" type="text" class="form-control form-control-sm" data-ng-model="beData.ProductBarCode" id="txtBarcode" name="txtBarcode" onfocus="this.select();" autocomplete="off" />
                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-hide="HideShow.PartyCostCenter==true">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width: 100px">Party Cost Center</label>
                                                    <select autoShowHide="true" class="select2 serial form-control form-control-sm" all-cost-center ng-model="beData.PartyCostCenter" id="cboPartyCostCenter" style="width:95%" fortransaction="true"
                                                            placeholder="** Select CostCenter **" showdetails="true" confirm-action="ShowSideBar(beData.partyCCSideBarData)" costcenter-detail="beData.PartyCC" side-bar-data="beData.partyCCSideBarData" voucher-id="SelectedVoucher.VoucherId" ledger-id="beData.PartyLedgerId" cost-center-type="2"></select>

                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-hide="HideShow.SalesLedger==true">
                                                <div class="select2-wrapper position-relative">
                                                    <div class="form-group d-flex ">
                                                        <label for="inputEmail3" style="min-width:100px;">Purchase A/C</label>
                                                        <select class="select2 serial form-control-sm i-append-in-sec" style="width: 100%; background-color: #fff" ng-model="beData.SalesLedgerId">
                                                            <option ng-value="sl.LedgerId" ng-repeat="sl in SalesLedgerColl" ng-selected="itemDet.LedgerId==sl.LedgerId">{{sl.Name}}</option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-4" ng-hide="HideShow.Agent==true">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width:100px;">Salesman</label>
                                                    <select class="form-control form-control-sm serial select2" style="width: 100%; background-color: #fff" ng-model="beData.AgentId">
                                                        <option ng-value="0">*select agent**</option>
                                                        <option ng-value="sl.AgentId" ng-repeat="sl in AgentColl" ng-selected="itemDet.AgentId==sl.AgentId">{{sl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-hide="HideShow.TranCostCenter==true">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width: 100px;">Cost Center</label>

                                                    <select autoShowHide="true" class="select2 serial form-control form-control-sm" all-cost-center ng-model="beData.TranCostCenter" id="cboTranCostCenter" style="width:95%" fortransaction="true"
                                                            placeholder="** Select Sales CostCenter **" showdetails="true" confirm-action="ShowSideBar(beData.salescostcenterSideBarData)" salesman-detail="beData.TranCostCenterDet" side-bar-data="beData.salescostcenterSideBarData" voucher-id="SelectedVoucher.VoucherId" ledger-id="beData.PartyLedgerId" cost-center-type="3"></select>

                                                </div>
                                            </div>


                                            <div class="col-sm-4" ng-hide="HideShow.Currency==true">
                                                <div class="row">
                                                    <label for="inputEmail3" class="col-sm-3 ">Currency</label>
                                                    <div class="col-sm-9">
                                                        <div class="row">
                                                            <div class="col-sm-6">
                                                                <select class=" form-control form-control-sm  serial" style="width: 100%;" ng-model="beData.CurrencyId">
                                                                    <option ng-repeat="curC in CurrencyColl" ng-value="curC.CurrencyId" ng-selected="curC.CurrencyId == beData.CurrencyId">
                                                                        {{curC.Name}}
                                                                    </option>
                                                                </select>
                                                            </div>
                                                            <div class="col-sm-6">
                                                                <div class="form-group row">
                                                                    <label for="inputEmail3" class="col-sm-4 col-form-label">Rate</label>
                                                                    <div class="col-sm-8">
                                                                        <input type="number" class="form-control form-control-sm serial" placeholder="" ng-model="beData.CurRate" onfocus="this.select();">
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                        <div class="row" ng-show="SelectedVoucher.ActiveUDF==true">
                                            <div class="col-sm-3" ng-repeat="uf in beData.UDFFeildsColl | filter: { FieldAfter: 4 }:true">
                                                <div class="form-group d-flex">
                                                    <label style="min-width: 100px;" class="cstm-label-truncate" title="{{uf.Name}}">{{uf.Name}} <span style="color:red" ng-show="uf.IsMandatory==true">*</span></label>
                                                    <udf-field cur-tran="beData" class="text-truncate show-tooltip" udf="uf" voucher="SelectedVoucher" change-event="ChangeUDFField(uf.NameId)"></udf-field>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- end form fiels -->

                            <div class="table-scroll-x-y table-container flex-grow-1">
                                <div class="outer-scroll-wrapper-h-scrollbar-fix">
                                    <div class="table-h-scrollbar-fix table-scroll-wrapper">
                                        <table id="main-table" make-table-resizable class="main-table table table-sm table-bordered bg-white cstm-sales-invoice-table border-0 dynamic-uiux-table">
                                            <thead style="background: #e6f5fb;">

                                                <tr>
                                                    <th rowspan="2" class="text-center align-middle cstm-sticky" style="width: 46px; left: 0; z-index: 3;">S.N.</th>
                                                    <th rowspan="2" class="text-center align-middle cstm-sticky highlight-on-scroll text-truncate" title="Particulars" style="width: 300px; left: 46px; z-index: 3;">Particulars</th>
                                                    <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 1 }:true" rowspan="2" class="text-center align-middle" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>
                                                    <th ng-hide="HideShow.ProductDescription==true" rowspan="2" class="text-center align-middle text-truncate" title="Description" style="width: 150px; z-index: 2;">Description</th>
                                                    <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 2 }:true" rowspan="2" class="text-center align-middle" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>
                                                    <th ng-hide="HideShow.ProductLedger==true" rowspan="2" class="text-center align-middle text-truncate" title="Purchase Ledger" style="width: 150px; z-index: 2;">Purchase Ledger</th>
                                                    <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 3 }:true" rowspan="2" class="text-center align-middle" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>
                                                    <th ng-hide="HideShow.Godown==true" rowspan="2" class="text-center align-middle text-truncate" title="Godown" style="width: 150px; z-index: 2;">Godown</th>
                                                    <th ng-show="SelectedVoucher.Product.ActiveRack==true" rowspan="2" class="text-center align-middle text-truncate" title="Rack" style="width: 150px; z-index: 2;">Rack</th>
                                                    <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 4 }:true" rowspan="2" class="text-center align-middle" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>
                                                    <th ng-hide="HideShow.CurrentBalance==true" rowspan="2" class="text-center align-middle text-truncate" title="Closing Stock" style="width: 150px; z-index: 2;">Closing Stock</th>

                                                    <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 5 }:true" rowspan="2" class="text-center align-middle text-truncate" title="Rack" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>
                                                    <th ng-hide="HideShow.Batch==true" rowspan="2" class="text-center align-middle" style="width: 150px; z-index: 2;">{{SelectedVoucher.Product.BatchLabel ? SelectedVoucher.Product.BatchLabel : 'Batch No.' }}</th>
                                                    <th ng-repeat="ud in SelectedVoucher.VoucherProductUDFColl  | filter: { FieldAfter: 6 }:true" rowspan="2" class="text-center align-middle text-truncate" ng-style="{ 'width': ud.ColWidth+'px' };">{{ud.Label}}</th>
                                                    <th ng-hide="HideShow.MFGDate==true" rowspan="2" class="text-center align-middle text-truncate" title="MFG.Date" style="width: 70px; z-index: 2;">MFG.Date</th>
                                                    <th ng-hide="HideShow.EXPDate==true" rowspan="2" class="text-center align-middle text-truncate" title="EXP.Date" style="width: 70px; z-index: 2;">EXP.Date</th>

                                                    <th ng-show="SelectedVoucher.FixedProduct.ShowEngineNo==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle text-truncate" title="EngineNo" style="width: 180px; z-index: 2;">{{SelectedVoucher.FixedProduct.EngineNo}}</th>
                                                    <th ng-show="SelectedVoucher.FixedProduct.ShowChassisNo==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle text-truncate" title="ChassisNo" style="width: 180px; z-index: 2;">{{SelectedVoucher.FixedProduct.ChassisNo}}</th>
                                                    <th ng-show="SelectedVoucher.FixedProduct.ShowRegdNo==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle text-truncate" title="RegdNo" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.RegdNo}}</th>

                                                    <th ng-show="SelectedVoucher.FixedProduct.ShowModel==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle text-truncate" title="Model" style="width: 180px; z-index: 2;">{{SelectedVoucher.FixedProduct.Model}}</th>
                                                    <th ng-show="SelectedVoucher.FixedProduct.ShowType==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle text-truncate" title="Type" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.Type}}</th>
                                                    <th ng-show="SelectedVoucher.FixedProduct.ShowColor==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle text-truncate" title="Color" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.Color}}</th>
                                                    <th ng-show="SelectedVoucher.FixedProduct.ShowKeyNo==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle text-truncate" title="KeyNo" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.KeyNo}}</th>
                                                    <th ng-show="SelectedVoucher.FixedProduct.ShowCodeNo==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle text-truncate" title="CodeNo" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.CodeNo}}</th>
                                                    <th ng-show="SelectedVoucher.FixedProduct.ShowMFGYear==true && beData.ForVehicle==true" rowspan="2" class="text-center align-middle text-truncate" title="MFGYear" style="width: 120px; z-index: 2;">{{SelectedVoucher.FixedProduct.MFGYear}}</th>

                                                    <th ng-show="comDet.Maintain==2" rowspan="2" class="text-center align-middle" title="Weight" style="width: 80px; z-index: 2;">Weight<br />(gm)</th>
