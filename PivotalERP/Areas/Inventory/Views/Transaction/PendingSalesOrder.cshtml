                                                                                    <td></td>
                                                                                    <td>
                                                                                        <input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-change="RecalculateAdditioncalCost(pv,adc,'rate',$index)" noofdecimal="itemDet.RateDecimal" ng-model="adc.Rate" ng-readonly="adc.CanEdit==false || adc.ReadOnlyQty==true">
                                                                                    </td>
                                                                                    <td>
                                                                                        <input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" name="Rate" onfocus="this.select();" ng-change="RecalculateAdditioncalCost(pv,adc,'amt',$index)" noofdecimal="itemDet.RateDecimal" ng-model="adc.Amount" ng-readonly="adc.CanEdit==false || adc.ReadOnlyQty==true">
                                                                                    </td>

                                                                                    <td></td>
                                                                                    <td></td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <td class="text-right" colspan="3"><b>GRAND-TOTAL</b></td>
                                                                                    <td>
                                                                                        <a class="p-1" href="#" ng-click="Print(pv.TranId,pv.VoucherId,pv.BranchId)">
                                                                                            <i class="fas fa-print text-primary"></i>
                                                                                        </a>
                                                                                    </td>
                                                                                    <td>
                                                                                    </td>
                                                                                    <td align="right">
                                                                                        <b>{{(pv.InvoiceAmount) |number:2}}</b>
                                                                                    </td>
                                                                                    <td align="center"><a href="#" class="btn btn-info btn-sm" ng-click="MakeSalesInvoice(pv,$index)">Invoice Now</a></td>

                                                                                    <td align="center"> <a href="#" class="btn btn-danger btn-sm" ng-click="CancelModal(pv,$index)">Cancel Order</a></td>
                                                                                </tr>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                </div>
                                                            </td>
                                                            <td></td>
                                                        </tr>



                                                    </tbody>
                                                </table>
                                            </div>
