                                                                                    </td>
                                                                                    <td>
                                                                                    </td>
                                                                                    <td align="right">
                                                                                        <b>{{(pv.ItemDetailsColl  | sumOfValue:'Amount') |number:2}}</b>
                                                                                    </td>

                                                                                    <td></td>
                                                                                    <td></td>
                                                                                </tr>
                                                                                <tr ng-repeat="adc in pv.AditionalChargeColl">
