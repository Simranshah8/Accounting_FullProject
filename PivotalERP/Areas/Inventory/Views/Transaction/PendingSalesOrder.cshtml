                                                                                        <button type="button" class="btn btn-sm btn-success" style="padding:3px;" ng-show="itemDet.BalQty>=itemDet.PendingOrderQty">{{itemDet.StockRemark}}({{itemDet.BalQty |number:2}})</button>
