                                                    <dir-pagination-controls pagination-id="PendingOrderPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                                    </dir-pagination-controls>
                                                </div>*@

                                        </div>
                                    </div>

                                </div>

                            </div>

                        </section>
