@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<link href="~/wwwroot/dynamic-erp/css/newCss.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.0/FileSaver.min.js" integrity="sha512-csNcFYJniKjJxRWRV1R7fvnXrycHP6qDR21mgz1ZP55xY5d+aHLfo9/FcGDQLfn2IfngbAHd8LdfsagcCqgTcQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="~/jslib/global/WebSocketEx.js"></script>
@*<script src="~/jslib/inventory/transaction/SalesInvoiceHulas.js"></script>*@
<script src="~/jslib/inventory/transaction/SalesInvoice.js?v=20250922"></script>
<script>
    var RecVoucherType = "@Convert.ToInt32(Dynamic.BusinessEntity.Account.VoucherTypes.Receipt)";
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
    var EntityDE = "@ViewBag.EntityDE";
    var ActiveFonePay ="@ViewBag.ActiveFonepay";
    var TranId =@ViewBag.TranId;
    var DefaultKeyValues = "@ViewBag.DefaultKeyValues";

</script>




<div ng-app="myApp" ng-controller="SalesInvoiceController" id="frmSalesInvoice" ng-cloak tabindex="0">
    <form>
        <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
            <div class="overflow-hidden">
                @RenderPage("~/Views/Global/_WaitDialog.cshtml")
                @RenderPage("~/Views/Global/_LedgerDetails.cshtml")

                <!-- Page Content  -->
                <div class="content-wrapper-new main-sales-invoice-page-wrap">
                    <div class="card bodypart">
                        <div class="demo-container h-100">
                            <div class="demo-header">
                                <div class="card-header header-corner-triangle pt-1 pb-0 px-3">
                                    <div class="row">
                                        <div class="col-md-3">
                                            <h3 class="card-title">{{SelectedVoucher && SelectedVoucher.VoucherName ? SelectedVoucher.VoucherName : 'Sales Invoice'}}</h3>
                                        </div>
                                        <div class="col-md-8" ng-hide="HideShow.CostClass==true && HideShow.VoucherType==true">
                                            <div class="row align-items-center">

                                                <div class="col-sm-4" ng-hide="HideShow.VoucherType==true">
                                                    <div class="form-group row">
                                                        <label for="inputEmail3" class="col-sm-6 col-form-label">Voucher Type<span style="color:red">*</span></label>
                                                        <div class="col-sm-6">
                                                            <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                                <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" ng-value="vt.VoucherId" ng-selected="vt.VoucherId == beData.VoucherId">
                                                                    {{vt.VoucherName}}
                                                                </option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-sm-3" ng-hide="HideShow.CostClass==true">
                                                    <div class="form-group row">
                                                        <label for="inputEmail3" class="col-sm-5 col-form-label">For Year<span style="color:red">*</span></label>
                                                        <div class="col-sm-7">
                                                            <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                                <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == beData.CostClassId">
                                                                    {{cc.Name}}
                                                                </option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>

                                        <!--Added by suresh for new UI on 6 ashar 2082-->
                                        <div class="col-sm-1 ml-auto text-right">
                                            <div class="d-flex float-right mb-1">
                                                <div class="cursor-pointer"
                                                     data-toggle="collapse"
                                                     data-target="#collapseOne"
                                                     aria-expanded="{{!isCollapsed}}"
                                                     aria-controls="collapseOne"
                                                     ng-click="isCollapsed = !isCollapsed">
                                                    <i class="mt-2 mr-2 text-primary fas"
                                                       ng-class="{'fa-chevron-up': !isCollapsed, 'fa-chevron-down': isCollapsed}"></i>
                                                </div>
                                                <div class="dropdown cstm-more-actions">
                                                    <button class="btn btn-default right-sidebar-call dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                        More
                                                    </button>
                                                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                                        <div class="custom-menu">
                                                            <button type="button" id="" class="btn btn-text-link w-100 ctmRightSidebarCollapse"> Remaining Details  <i class="fas fa-arrow-right m-0"></i></button>
                                                            <button type="button" id="ctmRightSidebarCollapse1" class="btn btn-secondary" ng-click="UDFClick=!UDFClick" ng-show="SelectedVoucher.ActiveUDF==true">UDF</button>
                                                            <input class="btn btn-secondary" id="ctmRightSidebarCollapse2" type="file" accept="application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" product-file-model ng-model="ImportItemData.Files_TMP" itemfilepath="ItemFilePath" sheetcoll="SheetColl" />
                                                            <button class="btn btn-text-link w-100 dropdown-toggle w-100" type="button" ng-click="ShowMultipleModal()">
                                                                <i class="fas fa-file-import"></i> Create Multiple Data
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                        <!--Ends-->
                                    </div>
                                </div>
                                <div id="collapseOne" class="panel-collapse collapse in show" role="tabpanel" aria-labelledby="headingOne" ng-class="{'show': isCollapsed}">
                                    <div class="card-body px-3 py-2 gradient-bg">
                                        <div class="row">
                                            <div class="col-sm-3">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width: 100px;">Invoice No.<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                    <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                </div>
                                            </div>

                                            <div class="col-sm-9">
                                                <div class="d-flex justify-content-between" style="gap: 8px">
                                                    <div style="display: flex; flex-grow: 1;">
                                                        <div class="cstm-three-elems-wrap">
                                                            <div>
                                                                <div class="form-group d-flex ref-block-cstm" @*ng-hide="HideShow.RefNo==true"*@>
                                                                    <label class="cstm-label-truncate" title="{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}" for="inputEmail3">{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}</label>
                                                                    <input type="text" class="form-control form-control-sm serial hideSideBar  text-truncate show-tooltip" placeholder="" ng-model="beData.RefNo" onfocus="this.select();" @*ng-blur="GetInvoicefromSAP()"*@>
                                                                </div>
                                                            </div>
                                                            <div>
                                                                <div class="form-group d-flex cstm-is-fixed-field" ng-show="comDet.Maintain==5">
                                                                    <div class="custom-control custom-checkbox">
                                                                        <input class="custom-control-input" type="checkbox"
                                                                               id="customCheckbox1" ng-model="beData.ForVehicle">
                                                                        <label for="customCheckbox1"
                                                                               class="custom-control-label" style="white-space: nowrap;">
                                                                            Fixed Product
                                                                        </label>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="">
                                                                <div class="form-group d-flex cstm-entry-date-field" ng-hide="HideShow.EntryDate==true">
                                                                    <label class="cstm-label-truncate" title="{{SelectedVoucher.EntryDateLabel ? SelectedVoucher.EntryDateLabel : 'Entry Date'}}">{{SelectedVoucher.EntryDateLabel ? SelectedVoucher.EntryDateLabel : 'Entry Date'}}</label>
                                                                    <input type="text" class="form-control form-control-sm float-right serial hideSideBar text-truncate show-tooltip" name="EntryDate" date-picker ng-model="beData.EntryDate_TMP" date-detail="beData.EntryDateDet" />
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="cstm-voucher-date-group-field">
                                                        <div class="form-group d-flex" id="dvDTVoucher">
                                                            <label for="inputEmail3" class="cstm-label-truncate" title="{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Invoice Date'}}">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Invoice Date'}}<span style="color:red">*</span></label>
                                                            <input type="text" class="form-control form-control-sm float-right serial hideSideBar text-truncate show-tooltip" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-show="comDet.Maintain==3">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" class="cstm-label-truncate" style="min-width:100px;">Patient Id</label>
                                                    <input type="text" class="form-control form-control-sm serial hideSideBar text-truncate show-tooltip" n placeholder="" ng-model="beData.RefNo" ng-blur="GetPatientById()" onfocus="this.select();">
                                                </div>
                                            </div>

                                            <div class="col-sm-3" ng-show="comDet.Maintain==3">
                                                <div class="form-group d-flex ssf-code-block-cstm">
                                                    <label for="inputEmail3">SSF Code</label>
                                                    <input type="text" class="form-control form-control-sm  serial  hideSideBar" placeholder="" ng-model="beData.SalesInvoiceDetail.SSFCode" ng-blur="SSFCodeLostFocus()">
                                                    <button type="button" class="btn px-2 btn-sm btn-outline-info nofocus" ng-click="ShowSSFDetails()"> :: </button>
                                                </div>
                                            </div>


                                            <div class="col-sm-3" ng-show="comDet.Maintain==3 || HideShow.ActiveSummaryEntry==false ">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width:100px;">Buyer<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm  serial" data-ng-model="beData.SalesInvoiceDetail.Buyes" list="lstBuyers" ng-change="ChangeBuyerSelection()" onfocus="this.select();">
                                                    <datalist id="lstBuyers">
                                                        <option data-ng-repeat="ttl in CashPartyColl" value="{{ttl.Buyes}}">
                                                    </datalist>
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-show="comDet.Maintain==3  || HideShow.ActiveSummaryEntry==false">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3">Address<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm  serial ml-3" ng-model="beData.SalesInvoiceDetail.Address" onfocus="this.select();">
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-show="comDet.Maintain==3  || HideShow.ActiveSummaryEntry==false">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width:100px;">Phone No.</label>
                                                    <input type="text" class="form-control form-control-sm  serial float-right" name="VoucherDate" ng-model="beData.SalesInvoiceDetail.PhoneNo" onfocus="this.select();" />
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-show="comDet.Maintain==3  || HideShow.ActiveSummaryEntry==false">
                                                <div class="form-group d-flex">

                                                    <label for="inputEmail3" style="min-width:80px;">PAN/VAT No.</label>
                                                    <input type="text" formatnumber="false" number-input positive="true" integer="true" class="form-control form-control-sm  serial" placeholder="" ng-model="beData.SalesInvoiceDetail.SalesTaxNo" maxlength="9" onfocus="this.select();">
                                                </div>
                                            </div>
                                            <div class="col-sm-3" ng-show="comDet.Maintain==3  || HideShow.ActiveSummaryEntry==false">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width:100px;">Bill Type</label>
                                                    <select class="form-control form-control-sm serial" style="width: 100%; background-color: #fff" ng-model="beData.SalesInvoiceDetail.PaymentTermsId" ng-change="ChangePaymentType(beData.SalesInvoiceDetail.PaymentTermsId)">
                                                        <option ng-value="x1.id" ng-repeat="x1 in AllPaymentTermColl" ng-selected="beData.SalesInvoiceDetail.PaymentTermsId==x1.id">{{x1.Name}}</option>
                                                    </select>
                                                    <a class="btn px-2 py-0 btn-outline-info text-info" ng-click="ShowBillImg()">
                                                        ::
                                                    </a>
                                                </div>
                                            </div>
                                            <div class="col-sm-6" ng-show="comDet.Maintain==3  || HideShow.ActiveSummaryEntry==false">
                                                <div class="form-group d-flex cstm-party-acc select2-wrapper position-relative">
                                                    <label for="inputEmail3" style="min-width: 100px;">Party A/C<span style="color:red">*</span></label>
                                                    <div class="input-group">
                                                        <select id="cboParty" autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="beData.PartyLedgerId" style="width:95%" ledgertype="3" fortransaction="true"
                                                                placeholder="** Select Party Name **" showdetails="true" confirm-action="PartySelectionChange(beData)" ledger-detail="beData.PartyLedger" side-bar-data="beData.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="14"></select>

                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-sm-8" ng-hide="comDet.Maintain==3  || HideShow.ActiveSummaryEntry==false">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width: 100px;">Party A/C<span style="color:red">*</span></label>
                                                    <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="beData.PartyLedgerId" id="cboParty2" style="width:95%" ledgertype="3" fortransaction="true"
                                                            placeholder="** Select Party Name **" showdetails="true" confirm-action="PartySelectionChange(beData)" ledger-detail="beData.PartyLedger" side-bar-data="beData.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="14"></select>
                                                    <span class="cstm-detail-btn-wrap">
                                                        <a class="btn py-0 btn-default">
                                                            <span class="cstm-detail-btn" data-toggle="modal" data-target="#ledgerdetailid">
                                                                Detail
                                                            </span>
                                                        </a>
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-show="HideShow.ActiveBarCode==false">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width: 100px;">Bar Code</label>
                                                    <input barcode-scanner on-barcode-scan="barcodeScanned(barcode)" type="text" class="form-control form-control-sm" data-ng-model="beData.ProductBarCode" id="txtBarcode" name="txtBarcode" onfocus="this.select();" autocomplete="off" />

                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-hide="HideShow.PartyCostCenter==true">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width: 100px;">Party CostCenter</label>
                                                    <select autoShowHide="true" class="select2 serial form-control-sm " all-cost-center ng-model="beData.PartyCostCenter" id="cboPartyCostCenter" style="width:95%" fortransaction="true"
                                                            placeholder="** Select CostCenter **" showdetails="true" confirm-action="ShowSideBar(beData.partyCCSideBarData)" costcenter-detail="beData.PartyCC" side-bar-data="beData.partyCCSideBarData" voucher-id="SelectedVoucher.VoucherId" ledger-id="beData.PartyLedgerId" cost-center-type="2"></select>

                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-hide="HideShow.SalesLedger==true">
                                                <div class="select2-wrapper position-relative">
                                                    <div class="form-group d-flex">
                                                        <label for="inputEmail3" style="min-width: 100px;">Sales A/C</label>

                                                        <select show-columns="false" autoShowHide="true" all-ledger ng-model="beData.SalesLedgerId" style="width:95%" ledgertype="5" fortransaction="true"
                                                                class="select2 serial form-control-sm i-append-in-sec" placeholder="** Select Sales Ledger **" showdetails="false" confirm-action="TranLedgerChange(beData)" ledger-detail="beData.TranLedger" side-bar-data="beData.tranSideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="14"></select>

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4" ng-show="BOMColl.length>0">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width: 100px;">B.O.M.</label>
                                                    <select class="form-control form-control-sm  serial select2" style="width: 100%; background-color: #fff" ng-model="beData.BOMTranId" ng-change="BOMChange()">
                                                        <option ng-value="sl.TranId" ng-repeat="sl in BOMColl" ng-selected="itemDet.TranId==sl.BOMTranId">{{sl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-2" ng-show="beData.SelectedBOM.ShowValidDate==true">
                                                <div class="form-group d-flex">
                                                    <label class="text-nowrap mr-4">Valid From</label>
                                                    <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.SelectedBOM.ValidFrom_TMP" date-detail="beData.SelectedBOM.ValidFromDet" />
                                                </div>
                                            </div>
                                            <div class="col-md-2" ng-show="beData.SelectedBOM.ShowValidDate==true">
                                                <div class="form-group d-flex">
                                                    <label class="text-nowrap mr-4">Valid To</label>
                                                    <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.SelectedBOM.ValidTo_TMP" date-detail="beData.SelectedBOM.ValidToDet" />
                                                </div>
                                            </div>
                                            <div class="col-md-2" ng-show="beData.SelectedBOM.ShowQty==true">
                                                <div class="form-group d-flex">
                                                    <label class="text-nowrap mr-4">Qty.</label>
                                                    <input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" onfocus="this.select();" positive="true" noofdecimal="4" ng-model="beData.SelectedBOM.TotalQty">
                                                </div>
                                            </div>
                                            <div class="col-md-2" ng-show="beData.SelectedBOM.ShowAmount==true">
                                                <div class="form-group d-flex">
                                                    <label class="text-nowrap mr-4">Amount</label>
                                                    <input type="text" number-input class="form-control form-control-sm serial hideSideBar" style="text-align:right" onfocus="this.select();" positive="true" noofdecimal="4" ng-model="beData.SelectedBOM.TotalAmount" ng-change="ChangeBOMTotalAmount()">
                                                </div>
                                            </div>
                                            <div class="col-md-4" ng-show="RateTypeColl.length>1">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width: 100px;">Price Level</label>
                                                    <select class="form-control form-control-sm  serial select2" style="width: 100%; background-color: #fff" ng-model="beData.RateTypeId">
                                                        <option ng-value="sl.RateTypeId" ng-repeat="sl in RateTypeColl" ng-selected="itemDet.RateTypeId==sl.RateTypeId">{{sl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-md-4" ng-hide="HideShow.Agent==true">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width: 100px;">Salesman</label>
                                                    <select class="form-control form-control-sm  serial select2" style="width: 100%; background-color: #fff" ng-model="beData.AgentId">
                                                        <option ng-value="0">*select agent**</option>
                                                        <option ng-value="sl.AgentId" ng-repeat="sl in AgentColl" ng-selected="itemDet.AgentId==sl.AgentId">{{sl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4" ng-hide="HideShow.PaymentUnder==true">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width: 100px;">Payment Under</label>
                                                    <select class="form-control form-control-sm serial select2" style="width: 100%; background-color: #fff" ng-model="beData.PaymentAgentId">
                                                        <option ng-value="0">*select payment under**</option>
                                                        <option ng-value="sl.AgentId" ng-repeat="sl in AgentColl" ng-selected="itemDet.AgentId==sl.PaymentAgentId">{{sl.Name}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4" ng-hide="HideShow.ProductCompany==true">
                                                <div class="form-group d-flex">
                                                    <label for="" style="min-width: 100px;">For Company</label>

                                                    <select autoShowHide="true" class="form-control form-control-sm select2 serial" product-company ng-model="beData.ProductCompanyId" id="cboProductCompany" style="width:95%"
                                                            data-placeholder="** Select Company Name **" showdetails="true" confirm-action="ShowSideBar(beData.productCompanySideBarData)" company-detail="beData.ProductCompany" side-bar-data="beData.productCompanySideBarData"></select>

                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-hide="HideShow.TranCostCenter==true">
                                                <div class="form-group d-flex">
                                                    <label for="inputEmail3" style="min-width: 100px;">Cost Center</label>
                                                    <select autoShowHide="true" class="select2 serial form-control-sm" all-cost-center ng-model="beData.TranCostCenter" id="cboTranCostCenter" style="width:95%" fortransaction="true"
                                                            placeholder="** Select Sales CostCenter **" showdetails="true" confirm-action="ShowSideBar(beData.salescostcenterSideBarData)" salesman-detail="beData.TranCostCenterDet" side-bar-data="beData.salescostcenterSideBarData" voucher-id="SelectedVoucher.VoucherId" ledger-id="beData.PartyLedgerId" cost-center-type="3"></select>
                                                </div>
                                            </div>

                                            <div class="col-sm-4" ng-hide="HideShow.Currency==true">
                                                <div class="row">
                                                    <div class="col-sm-8">
                                                        <div class="form-group d-flex">
                                                            <label for="inputEmail3" style="min-width: 100px;">Currency</label>
                                                            <select class=" form-control form-control-sm  serial" style="width: 100%;" ng-model="beData.CurrencyId">
                                                                <option ng-repeat="curC in CurrencyColl" ng-value="curC.CurrencyId" ng-selected="curC.CurrencyId == beData.CurrencyId">
                                                                    {{curC.Name}}
                                                                </option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4">
                                                        <div class="form-group d-flex">
                                                            <label for="inputEmail3" class="mr-2">Rate</label>
                                                            <input type="number" class="form-control form-control-sm serial" placeholder="" ng-model="beData.CurRate" onfocus="this.select();">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row" ng-show="SelectedVoucher.ActiveUDF==true">
