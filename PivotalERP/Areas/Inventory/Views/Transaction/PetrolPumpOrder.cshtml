@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .bg-olive {
        background-color: #068abf !important;
    }

    .form-qty {
        font-weight: 700 !important;
        text-align: end !important;
        font-size: 16px;
    }

    bg-olive.btn:not(:disabled):not(.disabled):active, .bg-olive.btn:not(:disabled):not(.disabled).active, .bg-olive.btn:active, .bg-olive.btn.active {
        background-color: #7abe5a !important;
        border-color: #7abe5a !important;
        color: #ffffff;
    }
</style>
<script>
    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
	 var DefaultKeyValues = "@ViewBag.DefaultKeyValues";
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.0/FileSaver.min.js" integrity="sha512-csNcFYJniKjJxRWRV1R7fvnXrycHP6qDR21mgz1ZP55xY5d+aHLfo9/FcGDQLfn2IfngbAHd8LdfsagcCqgTcQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="~/jslib/global/WebSocketEx.js"></script>
<script src="~/jslib/inventory/transaction/petrolPumpOrder.js?v=20250701"></script>

<div ng-app="myApp" ng-controller="PetrolPumpOrder" ng-class="{waiting: loadingstatus=='running'}" ng-cloak>
    <div class="container-fluid">
        <div class="content">
            @RenderPage("~/Views/Global/_WaitDialog.cshtml")
            @RenderPage("~/Views/Global/_LedgerDetails.cshtml")
            <div class="card">
                <div class="card-header header-corner-triangle overflow-hidden" ng-hide="HideShow.CostClass==true && HideShow.VoucherType==true">
                    <div class="row">
                        <h3 class="card-title">{{SelectedVoucher && SelectedVoucher.VoucherName ? SelectedVoucher.VoucherName : 'Sales Invoice'}}</h3>
                        <div class="col-sm-4" ng-hide="HideShow.VoucherType==true">
                            <div class="form-group row">
                                <label for="inputEmail3" class="col-sm-4 col-form-label">Voucher Type</label>
                                <div class="col-sm-8">
                                    <select class="form-control  hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()">
                                        <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" value="{{vt.VoucherId}}" ng-selected="vt.VoucherId == beData.VoucherId">
                                            {{vt.VoucherName}}
                                        </option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4" ng-hide="HideShow.CostClass==true">
                            <div class="form-group row">
                                <label for="inputEmail3" class="col-sm-4 col-form-label">For Year</label>
                                <div class="col-sm-8">
                                    <select class="form-control  hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()">
                                        <option ng-repeat="cc in CostClassColl track by cc.CostClassId" value="{{cc.CostClassId}}" ng-selected="cc.CostClassId == beData.CostClassId">
                                            {{cc.Name}}
                                        </option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <form>
                        <div class="row">
                            <div class="col-md-2 col-sm-6">
                                <div class="form-group">
                                    <label>Order No.</label>
                                    <input type="text" class="form-control form-control-sm serial" ng-model="beData.AutoManualNo" disabled>
                                </div>
                            </div>
                            <div class="col-md-2 col-sm-6">
                                <div class="form-group d-flex" id="dvDTVoucher">
                                     <label for="inputEmail3" style="min-width: 100px;">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Order Date'}}<span style="color:red">*</span></label>
                                     <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">
                                 </div>
                            </div>

                            <div class="col-md-2 col-sm-6">
                                <div class="form-group">
                                    <label>Coupon No</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="beData.RefNo" onfocus="this.select();">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group row">
                                    <div class="col-sm-11 mt-4">
                                        <div class="d-flex">
                                            <div class="input-group">
                                                <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="beData.PartyLedgerId" id="cboParty" style="width:95%" ledgertype="3" fortransaction="true"
                                                        placeholder="** Select Party Name **" showdetails="true" confirm-action="PartySelectionChange(beData)" ledger-detail="beData.PartyLedger" side-bar-data="beData.partySideBarData"></select>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4" ng-hide="beData.BillingAs==2">
                                <div class="form-group">
                                    <label>Buyer Name</label>
                                    <input type="text" class="form-control form-control-sm" data-ng-model="beData.SalesOrderDetail.Buyes" list="lstBuyers" ng-change="ChangeBuyerSelection()" onfocus="this.select();">
                                    <datalist id="lstBuyers">
                                        <option data-ng-repeat="ttl in CashPartyColl" value="{{ttl.Buyes}}">
                                    </datalist>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>Address</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="beData.SalesOrderDetail.Address" onfocus="this.select();">
                                </div>
                            </div>


                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>Contact No</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="beData.SalesOrderDetail.PhoneNo" onfocus="this.select();">
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>PanVatNo</label>
                                    <input type="text" formatnumber="false" number-input positive="true" integer="true" class="form-control form-control-sm" placeholder="" ng-model="beData.SalesOrderDetail.SalesTaxNo" maxlength="9" onfocus="this.select();">
                                </div>
                            </div>

                            <div class="col-md-2 col-sm-6">
                                <div class="form-group">
                                    <label>Vehicle No</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="beData.SalesOrderDetail.Goods" onfocus="this.select();">
                                </div>
                            </div>

                        </div>

                        <div class="btn-group-toggle" data-toggle="buttons" id="btnProductLst">
                            <label class="btn bg-olive  mr-2 mb-1" ng-repeat="p in ProductColl" ng-click="ClickOnProduct(p)">
                                <input type="radio" ng-value="p.ProductId" name="options" id="option_b{{$index}}" autocomplete="off"> {{p.Name}}
                            </label>
                        </div>

                        <div class="row mt-2">
                            <div class="col-md-4">
                                <div class="card p-2" style="background-color: #2dce523d">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="form-group d-flex">
                                                <label class="mr-2" style="width:90px"><b>Quantity</b></label>
                                                <input type="text" number-input class="form-control form-qty" onfocus="this.select();" ng-model="beData.ItemDetailsColl[0].ActualQty" ng-change="ChangeQtAmt('qty')" noofdecimal="beData.ItemDetailsColl[0].QtyDecimal">
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group d-flex">
                                                <label class="mr-2" style="width:90px"><b>Rate</b></label>
                                                <label class="form-control form-qty"><b>{{beData.ItemDetailsColl[0].Rate |number:beData.ItemDetailsColl[0].RateDecimal}}  {{beData.ItemDetailsColl[0].UnitName}}</b></label>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group d-flex">
                                                <label class="mr-2" style="width:90px"><b>Amount</b></label>
                                                <input number-input type="text" class="form-control form-qty" onfocus="this.select();" ng-model="beData.ItemDetailsColl[0].Amount" ng-change="ChangeQtAmt('amt')" noofdecimal="beData.ItemDetailsColl[0].AmountDecimal">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                    <footer class="main-footer">
                        <div class="text-right control-btns">
                            <button type="button" class="btn btn-default ml-1" ng-click="SearchData()">Search</button>
                            <button type="button" class="btn btn-default ml-1" ng-click="Print()" ng-show="lastTranId>0 && lastVoucherId>0">Re-Print</button>
                            <button type="button" class="btn btn-default ml-1" ng-click="Clear()">Reset</button>
                            <button type="button" class="btn btn-primary ml-1" ng-click="SaveSalesInvoice()" ng-disabled="loadingstatus=='running'">Save</button>
                        </div>

                    </footer>
                </div>
            </div>

        </div>
        <!-- /.container-fluid -->
    </div>


    <!--  Search Voucher right button Modal demo -->
    <div class="modal fade sales-invoice-page-modal document-attach-modal" id="searVoucherRightBtn" tabindex="-1" role="dialog" aria-labelledby="partyAccRightBtn" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Search Sales Invoice Voucher</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group row">
                                <label for="" class="col-sm-2 col-form-label col-form-label-sm text-center">Search By</label>
                                <div class="col-sm-10">
                                    <div class="input-group input-group-sm mb-3">
                                        <div class="input-group-prepend">
                                            <select class="form-control form-control-sm" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                <option ng-value="asp" ng-repeat="asp in VoucherSearchOptions">{{asp.text}}</option>
                                            </select>
                                        </div>
                                        <input type="text" class="form-control" placeholder="" ng-model="paginationOptions.SearchVal"  ng-change="ReSearchData(-1)">
                                        <div class="input-group-append">
                                            <div class="input-group-text">
                                                <span class="fas fa-search" ng-click="ReSearchData(-1)"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <form class="float-right">
                                <div class="form-row align-items-center">
                                    <div class="d-flex align-items-center">
                                        <label class="mr-sm-2 mb-0" for="inlineFormCustomSelect">Show</label>
                                        <input type="text" ng-model="paginationOptions.pageSize" class="form-control input-sm" placeholder="NoOfRows" @*ng-blur="ReSearchData(-2)"*@>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                    <div class="">
                        <table id="main-table" class="main-table table table-sm table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Miti</th>
                                    <th>Days</th>
                                    <th>Invoice No.</th>
                                    <th>Ref. No.</th>
                                    <th>Party Ledger</th>
                                    <th>Amount</th>
                                    <th>Voucher</th>
                                    <th>CostClass</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr dir-paginate="sd in SearchDataColl |orderBy:sortKey:reverse|itemsPerPage:paginationOptions.pageSize" total-items="paginationOptions.TotalRows" ng-class="{'bg-red': sd.IsCancel === true}">
                                    <td align="center">{{sd.VoucherDate |dateFormat}}</td>
                                    <td align="center">{{sd.VoucherMiti}}</td>
                                    <td align="center">{{sd.Days}}</td>
                                    <td align="center">{{sd.VoucherNo}}</td>
                                    <td>{{sd.RefNo}}</td>
                                    <td>{{sd.PartyLedger}}</td>
                                    <td align="right">
                                        {{sd.Amount |number:2}}
                                    </td>
                                    <td>{{sd.VoucherName}}</td>
                                    <td>{{sd.CostClass}}</td>
                                    <td>
                                        <a class="p-1" href="#" ng-click="GetTransactionById(sd)">
                                            <i class="fas fa-edit text-info"></i>
                                        </a>
                                        <a class="p-1" href="#" ng-click="DelTransactionById(sd)">
                                            <i class="fas fa-trash-alt text-danger"></i>
                                        </a>
                                        <a class="p-1" href="#" ng-click="PrintVoucher(sd.TranId,sd.VoucherId)">
                                            <i class="fas fa-print text-primary"></i>
                                        </a>
                                    </td>
                                </tr>
                            </tbody>

                        </table>
                        <dir-pagination-controls max-size="paginationOptions.pageSize" direction-links="true" boundary-links="true"
                                                 on-page-change="ReSearchData(newPageNumber)">
                        </dir-pagination-controls>
                    </div>

                </div>
                <!-- end modal body -->
                <div class="modal-footer justify-content-between align-items-center py-2">
                    <h6 class="mb-0">Total Record: {{paginationOptions.TotalRows}}</h6>
                    <div class="">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @RenderPage("~/Global/_ReportTemplates.cshtml")
    @RenderPage("~/Views/Global/_IsValidTran.cshtml")
</div>