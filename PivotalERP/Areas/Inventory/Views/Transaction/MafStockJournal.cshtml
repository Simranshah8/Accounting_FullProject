                                                            <a class="btn btn-danger" ng-click="delConsumptionRow($index)"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                            <tfoot style="position: sticky; z-index: 4; bottom: 0; background-color: #ececec!important ">
