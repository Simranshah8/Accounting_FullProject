                                                            <option ng-repeat="cc in SelectedVoucher.VoucherWiseGodownColl track by cc.GodownId" ng-value="cc.GodownId" ng-selected="cc.GodownId == itemDet.GodownId">
                                                                {{cc.Name}}
                                                            </option>
                                                        </select>
                                                    </td>
                                                    <td><input type="text" class="form-control  form-control-sm" ng-model="itemDet.BatchNo" style="text-align:center"></td>
                                                    <td><input type="text" class="form-control form-control-sm" date-picker ng-model="itemDet.MfgDate_TMP" date-detail="itemDet.MfgDateDet"></td>
                                                    <td><input type="text" class="form-control form-control-sm" date-picker ng-model="itemDet.ExpDate_TMP" date-detail="itemDet.ExpDateDet"></td>
                                                    <td>
                                                        <input type="text" number-input class="form-control form-control-sm" ng-model="itemDet.Qty" name="ActualQty" style="text-align:center">
                                                    </td>
                                                    <td><input type="text" disabled class="form-control  form-control-sm" ng-model="itemDet.Unit" style="text-align:center"></td>
                                                    <td><input type="text" number-input class="form-control  form-control-sm" ng-model="itemDet.Rate" style="text-align:center"></td>
                                                    <td><input type="text" number-input class="form-control  form-control-sm" ng-model="itemDet.Amount" style="text-align:right"></td>
                                                    <td class="project-actions no-print text-center pr-0">
                                                        <div class="btn-group-sm">
                                                            <a class="btn btn-info" ng-click="AddProductionRow($index)"><i class="fas fa-plus"></i></a>
                                                            <a class="btn btn-danger" ng-click="delProductionRow($index)"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                            <tfoot style="position: sticky; z-index: 4; bottom: 0; background-color: #ececec!important ">
                                                <tr>
                                                    <td colspan="6" class="text-right"><b>Total</b></td>
                                                    <td class="text-center"><b>1212</b></td>
                                                    <td></td>
                                                    <td></td>
                                                    <td class="text-right"><b>213123</b></td>
                                                    <td></td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <div class="card">
                                <div class="card-header py-1 header-primary" style="background-color: #068abfe8; color: #ffffff;">
                                    <h5 class="mb-0">Cost Of Components</h5>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-scroll-x-y mb-2" style="height:auto!important;max-height: 24rem!important" ;>
                                        <table id="main-table-production" class="main-table table table-sm table-bordered bg-white">
                                            <thead>
                                                <tr>
                                                    <th class="text-center px-1" style="width: 50px; background-color: #ececec !important">S.No</th>
