                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width: 100px;">Builty No</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.BuiltyNo" />
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width: 100px;">Gate InWard Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.GateInWardDate_TMP" date-detail="beData.LCDetail.GateInWardDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width: 100px;">Bill Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.BillDate_TMP" date-detail="beData.LCDetail.BillDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width: 100px;">P.P.Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.PPDate_TMP" date-detail="beData.LCDetail.PPDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width: 100px;">L.C. Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.LCDate_TMP" date-detail="beData.LCDetail.LCDateDet">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group d-flex mb-1">
                                                    <label class="mt-1" style="min-width: 100px;">Builty Date</label>
                                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.BuiltyDate_TMP" date-detail="beData.LCDetail.BuiltyDateDet">
                                                </div>
                                            </div>
                                        </div>

                                        @*<div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label>Narration</label>
                            <input type="text" list="lstNarration" class="form-control form-control-sm hideSideBar" name="" id="" rows="3" placeholder="Narration" ng-model="beData.Narration">
                            <datalist id="lstNarration">
                                <option ng-repeat="x1 in NarrationList track by $index" value="{{x1}}">
                            </datalist>
                        </div>
                    </div>
                </div>*@

                                    </div>
                                </div>
                            </div>
                                <div class="table-scroll-x-y table-container flex-grow-1">
                                    <div class="outer-scroll-wrapper-h-scrollbar-fix">
                                        <div class="table-h-scrollbar-fix table-scroll-wrapper">
                                            <table id="main-table" make-table-resizable class="main-table table table-sm table-bordered bg-white cstm-sales-invoice-table border-0 dynamic-uiux-table">
                                                <thead style="background: #e6f5fb;">
                                                    <tr>
                                                        <th class="text-center text-truncate" style="width: 50px;">S.No.</th>
                                                        <th class="text-center text-truncate" style="width: 60px;">Code</th>
                                                        <th class="text-center text-truncate" style="width: 200px;">Landed Cost</th>
                                                        <th class="text-center text-truncate" style="width: 150px;">Allocation By</th>
                                                        <th class="text-center text-truncate" style="width: 150px;">Cost As</th>
                                                        <th class="text-center text-truncate" style="width: 120px;">Cost For</th>
                                                        <th class="text-center text-truncate" style="width: 120px;"> Amount</th>
                                                        <th class="text-center text-truncate" style="width: 200px;"> Broker Ledger</th>
                                                        <th class="text-center text-truncate" ng-show="SelectedVoucher.EachNarrationEntry==true" style="width: 150px;">Narration</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr ng-repeat="lc in LanedCostColl">
                                                        <td align="center">{{$index+1}}</td>
                                                        <td align="center">{{lc.CostCenterCode}}</td>
                                                        <td>
                                                            {{lc.CostCenterName}}
                                                        </td>
                                                        <td>
                                                            <select class="form-control form-control-sm " style="width: 100%;" ng-model="lc.AditionalCostOnTheBasis" data-placeholder="** Allocation By **">
                                                                <option ng-value="cl.id" ng-repeat="cl in AditionalCostTypeList" ng-selected="cl.id==lc.AditionalCostOnTheBasis">{{cl.text}}</option>
                                                            </select>

                                                        </td>
                                                        <td>
                                                            <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="lc.CostAs">
                                                                <option ng-repeat="vt in CostAsColl" ng-value="vt.id" ng-selected="vt.id == lc.CostAs">
                                                                    {{vt.text}}
                                                                </option>
                                                            </select>
                                                        </td>
                                                        <td>
                                                            <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="lc.CostAsId" ng-show="lc.CostAs==2">
                                                                <option ng-repeat="vt in CostProductColl" ng-value="vt.id" ng-selected="vt.id == lc.CostAsId">
                                                                    {{vt.text}}
                                                                </option>
                                                            </select>
                                                            <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="lc.CostAsId" ng-show="lc.CostAs==3">
                                                                <option ng-repeat="vt in CostProductGroupColl" ng-value="vt.id" ng-selected="vt.id == lc.CostAsId">
                                                                    {{vt.text}}
                                                                </option>
                                                            </select>
                                                            <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="lc.CostAsName" ng-show="lc.CostAs==4">
                                                                <option ng-repeat="vt in CostModuleColl" ng-value="vt.Model" ng-selected="vt.id == lc.CostAsName">
                                                                    {{vt.Model}}
                                                                </option>
                                                            </select>
                                                        </td>
                                                        <td><input type="text" number-input noofdecimal="SelectedVoucher.NoOfDecimalPlaces" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="lc.DrAmount" ng-change="ChangeDrCrAmount()"></td>
                                                        <td>
                                                            <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="lc.BrokerLedgerId" style="width:95%" ledgertype="2" fortransaction="true"
                                                                    placeholder="** Select Party Name **" showdetails="false" confirm-action="PartySelectionChange(lc)" ledger-detail="lc.PartyLedger" side-bar-data="lc.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="8"></select>
                                                        </td>
                                                        <td ng-show="SelectedVoucher.EachNarrationEntry==true"><input type="text" onfocus="this.select();" class="form-control form-control-sm" ng-model="lc.Narration"></td>

                                                    </tr>

                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                    </div>
                    <footer class="main-footer control-btns pt-0">
                        <div class="secondary-footer mb-1 mt-1">
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <input type="text" list="lstNarration" class="form-control form-control-sm hideSideBar" name="" id="" rows="3" placeholder="Narration" ng-model="beData.Narration">
                                        <datalist id="lstNarration">
                                            <option ng-repeat="x1 in NarrationList track by $index" value="{{x1}}">
                                        </datalist>
                                    </div>
                                </div>
                                <div class=" col-md-3">
                                    <div class="form-group row">
                                        <label for="" class="col-md-6">TOTAL AMOUNT.</label>
                                        <label class="form-control form-control-sm col-md-6">
                                            {{ beData.DrAmount |number:SelectedVoucher.NoOfDecimalPlaces }}
                                        </label>
                                    </div>
                                </div>
                                <div class=" col-md-1">

                                </div>

                            </div>
                            <div class="row ">

                                <div class="col-md-4 mt-1">
                                    <button type="button" class="btn btn-default dynamic-uiux" data-toggle="modal" data-target="#documentAttachModal">
                                        Document Attach ({{ (beData.AttechFiles.length+(beData.DocumentColl ? beData.DocumentColl.length : 0)) }} )
                                    </button>

                                </div>
                                <div class="col-md-8 mt-1">
                                    <span class="d-block text-right">
                                        <button type="button" class="btn btn-default" style="min-width: 80px;" ng-click="SearchData()">Search</button>
                                        <button type="button" class="btn btn-default" style="min-width: 80px;" ng-click="Print()">Re-Print</button>
                                        <button type="button" class="btn btn-outline-danger" style="min-width: 80px;" ng-click="Clear()">Reset</button>
                                        <button type="button" class="btn btn-primary" style="min-width: 80px;" ng-click="SaveJournal()" ng-disabled="loadingstatus=='running'">{{beData.Mode}}</button>
                                    </span>
                                </div>
                            </div>

                        </div>
                    </footer>


                </div>
                <!--Billwise Detail Modal Ends-->
            </div>
        </div>

        @RenderPage("~/Views/Global/_IsValidTran.cshtml")
    </form>

    <div class="modal fade sales-quotation-page-modal document-attach-modal modal-static-esc modal-header-n-sec-scrollbar-fix" id="searVoucherRightBtn" tabindex="-1" role="dialog" aria-labelledby="partyAccRightBtn" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header p-2">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Search Addtional Journal</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group row">
                                <label for="" class="col-sm-2 col-form-label col-form-label-sm text-center">Search By</label>
                                <div class="col-sm-10">
                                    <div class="input-group input-group-sm mb-3">
                                        <div class="input-group-prepend">
                                            <select class="form-control form-control-sm" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                <option ng-value="asp" ng-repeat="asp in VoucherSearchOptions">{{asp.text}}</option>
                                            </select>
                                        </div>
                                        <input type="text" class="form-control form-control-sm" placeholder="" ng-model="paginationOptions.SearchVal" ng-change="ReSearchData(-1)">
                                        <div class="input-group-append">
                                            <div class="input-group-text">
                                                <span class="fas fa-search" ng-click="ReSearchData(-1)"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <form class="float-right">
                                <div class="form-row align-items-center">
                                    <div class="d-flex align-items-center">
                                        <label class="mr-sm-2 mb-0" for="inlineFormCustomSelect">Show</label>
                                        <input type="text" ng-model="paginationOptions.pageSize" class="form-control form-control-sm input-sm" placeholder="NoOfRows" @*ng-blur="ReSearchData(-2)"*@>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                    <div class="table-scroll-x-y mb-1 table-container card" style="height:auto !important;">
                        <table id="main-table" class="main-table table table-sm table-bordered bg-white text-nowrap table-hover dynamic-uiux-table" style="table-layout: auto;">
                            <thead>
                                <tr>
                                    <th style="z-index: 3;">Voucher No</th>
                                    <th style="z-index: 3;">RefNo</th>
                                    <th style="z-index: 3;">Voucher Date</th>
                                    <th style="z-index: 3;">Voucher Name</th>
                                    <th style="z-index: 3;">CostClass</th>
                                    <th style="z-index: 3;">Amount</th>
                                    <th class="cstm-sticky" style="right:0; z-index: 5;">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr dir-paginate="sd in SearchDataColl |orderBy:sortKey:reverse|itemsPerPage:paginationOptions.pageSize" total-items="paginationOptions.TotalRows">
                                    <td align="center">{{sd.VoucherNo}}</td>

                                    <td>{{sd.RefNo}}</td>
                                    <td align="center">{{sd.VoucherDate |dateFormat}}</td>
                                    <td>{{sd.VoucherName}}</td>
                                    <td>{{sd.CostClass}}</td>
                                    <td>{{sd.Amount |number:3}}</td>
                                    <td class="text-center cstm-sticky" style="z-index: 3;    right: 0;   background-color: white !important;">
                                        <a class="p-1" href="#" ng-click="GetTransactionById(sd)">
                                            <i class="fas fa-edit text-info"></i>
                                        </a>
                                        <a class="p-1" href="#" ng-click="DelTransactionById(sd)">
                                            <i class="fas fa-trash-alt text-danger"></i>
                                        </a>
                                        <a class="p-1" href="#" ng-click="PrintVoucher(sd.TranId,sd.VoucherId)">
                                            <i class="fas fa-print text-primary"></i>
                                        </a>
                                    </td>
                                </tr>
                            </tbody>

                        </table>

                    </div>
                    <dir-pagination-controls max-size="paginationOptions.pageSize" direction-links="true" boundary-links="true"
                                             on-page-change="ReSearchData(newPageNumber)">
                    </dir-pagination-controls>
                </div>
                <!-- end modal body -->
                <div class="modal-footer justify-content-between align-items-center py-2">
                    <h6 class="mb-0">Total Record: {{paginationOptions.TotalRows}}</h6>
                    <div class="">
                        <button type="button" class="btn btn-sm btn-outline-secondary dynamic-uiux-sm-btn" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

