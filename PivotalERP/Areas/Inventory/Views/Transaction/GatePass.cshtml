@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<link href="~/wwwroot/dynamic-erp/css/newCss.css" rel="stylesheet" />
<script src="~/jslib/inventory/transaction/GatePass.js?v=20250922"></script>
<script>

    var VoucherType = "@ViewBag.VoucherType";
    var EntityId = "@ViewBag.EntityId";
	var TranId=@ViewBag.TranId;
	 var DefaultKeyValues = "@ViewBag.DefaultKeyValues";
</script>
<style>
    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .sale-page-wrap .content-wrapper-new {
        padding-left: 0px;
    }
    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>
<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>

<div ng-app="myApp" ng-controller="GatePassController" ng-init="LoadData()">
    <div class="sale-page-wrap">
        <div class="overflow-hidden">
            <!-- Page Content  -->
            <div class="content-wrapper-new main-sales-invoice-page-wrap">
                <div class="card bodypart">
                    <div class="demo-container h-100">
                        <div class="demo-header">
                            <div class="card-header header-corner-triangle pt-1 pb-0 px-3">
                                <div class="row">
                                    <div class="col-md-3">
                                        <h3 class="card-title">{{SelectedVoucher && SelectedVoucher.VoucherName ? SelectedVoucher.VoucherName : 'Sales Order'}}</h3>
                                    </div>
                                    <div class="col-md-8" ng-hide="HideShow.CostClass==true && HideShow.VoucherType==true && PendingRefVoucherColl.lenght==0">
                                        <div class="row align-items-center">
                                            <div class="col-sm-4" ng-hide="HideShow.VoucherType==true">
                                                <div class="form-group row">
                                                    <label for="inputEmail3" class="col-sm-6 text-nowarp mb-0 d-flex align-items-center justify-content-end">Voucher Type<span style="color:red">*</span></label>
                                                    <div class="col-sm-6">
                                                        <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                            <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" ng-value="vt.VoucherId" ng-selected="vt.VoucherId == beData.VoucherId">
                                                                {{vt.VoucherName}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-4" ng-hide="HideShow.CostClass==true">
                                                <div class="form-group row">
                                                    <label for="inputEmail3" class="col-sm-4">For Year<span style="color:red">*</span></label>
                                                    <div class="col-sm-8">
                                                        <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()" ng-disabled="beData.TranId>0">
                                                            <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == beData.CostClassId">
                                                                {{cc.Name}}
                                                            </option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-sm-1 ml-auto text-right">
                                        <div class="d-flex float-right">
                                            <div class="cursor-pointer"
                                                 data-toggle="collapse"
                                                 data-target="#collapseOne"
                                                 aria-expanded="{{!isCollapsed}}"
                                                 aria-controls="collapseOne"
                                                 ng-click="isCollapsed = !isCollapsed">
                                                <i class="mt-2 mr-2 text-primary fas"
                                                   ng-class="{'fa-chevron-up': !isCollapsed, 'fa-chevron-down': isCollapsed}"></i>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>

                            <div id="collapseOne" class="panel-collapse collapse in show" role="tabpanel" aria-labelledby="headingOne" ng-class="{'show': isCollapsed}">
                                <div class="card-body py-1 gradient-bg">
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <div class="form-group d-flex mb-1">
                                                <label style="min-width: 100px;">Gate Pass No.</label>
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                            </div>
                                        </div>

                                        <div class="col-sm-9">
                                            <div class="d-flex justify-content-between" style="gap: 8px">
                                                <div style="display: flex; flex-grow: 1;">
                                                    <div class="cstm-three-elems-wrap">
                                                        <div>
                                                            <div class="form-group d-flex ref-block-cstm" ng-hide="HideShow.RefNo==true">
                                                                <label class="cstm-label-truncate" title="{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}" for="inputEmail3">{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}</label>
                                                                <input type="text" class="form-control form-control-sm float-right serial hideSideBar" placeholder="" ng-model="beData.RefNo">
                                                            </div>
                                                        </div>
                                                        <div>

                                                        </div>
                                                        <div class="">
                                                            <div class="form-group d-flex cstm-entry-date-field" ng-hide="HideShow.EntryDate==true">
                                                                <label class="cstm-label-truncate" for="inputEmail3">{{SelectedVoucher.EntryDateLabel ? SelectedVoucher.EntryDateLabel : 'Entry Date'}}</label>
                                                                <input type="text" class="form-control form-control-sm float-right serial hideSideBar" name="EntryDate" date-picker ng-model="beData.EntryDate_TMP" date-detail="beData.EntryDateDet" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="cstm-voucher-date-group-field">
                                                    <div class="form-group d-flex" id="dvDTVoucher">
                                                        <label for="inputEmail3">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Date'}}<span style="color:red">*</span></label>
                                                        <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">

                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        @*<div class="col-sm-3">
                        <div class="form-group d-flex" ng-hide="HideShow.RefNo==true">
                            <label for="inputEmail3" style="min-width:120px;">{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}</label>
                            <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.RefNo">
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group d-flex" ng-hide="HideShow.EntryDate==true">
                            <label for="inputEmail3" style="min-width:120px;">{{SelectedVoucher.EntryDateLabel ? SelectedVoucher.EntryDateLabel : 'Entry Date'}}</label>
                            <input type="text" class="form-control form-control-sm float-right serial hideSideBar" name="EntryDate" date-picker ng-model="beData.EntryDate_TMP" date-detail="beData.EntryDateDet" />
                        </div>
                    </div>

                    <div class="col-sm-3">
                        <div class="form-group d-flex" id="dvDTVoucher">
                            <label for="inputEmail3" style="min-width: 100px;">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Date'}}<span style="color:red">*</span></label>
                            <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">
                        </div>
                    </div>*@

                                        <div class="col-sm-4">
                                            <div class="form-group d-flex mb-1">
                                                <label style="min-width: 100px;">Destination</label>
                                                <input type="text" class="form-control form-control-sm  serial hideSideBar" placeholder="" ng-model="beData.GatePassDetails.Destination">
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group d-flex mb-1">
                                                <label style="min-width: 100px;">Delivery Through</label>
                                                <select class="form-control form-control-sm select2" ng-model="beData.GatePassDetails.DeliveryThrough">
                                                    <option ng-repeat="DT in DeliveryThroughList" ng-value="DT.DeliveryThroughId" ng-selected="DT.Name == beData.GatePassDetails.DeliveryThrough">
                                                        {{DT.Name}}
                                                    </option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group d-flex mb-1">
                                                <label style="min-width: 100px;">Delivery Doc No.</label>
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" ng-model="beData.GatePassDetails.DeliveryDocNo" />
                                            </div>
                                        </div>

                                        <div class="col-sm-4">
                                            <div class="form-group d-flex mb-1">
                                                <label style="min-width: 100px;">Transporter</label>
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.GatePassDetails.Transporter">
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group d-flex mb-1">
                                                <label style="min-width: 100px;">Drive'sContactNo.</label>
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.GatePassDetails.DriverContactNo">
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group d-flex mb-1">
                                                <label style="min-width: 100px;">License No.</label>
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" ng-model="beData.GatePassDetails.LicenseNo" />
                                            </div>
                                        </div>

                                        <div class="col-sm-4">
                                            <div class="form-group d-flex mb-1">
                                                <label style="min-width: 100px;">Driver's Name</label>
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.GatePassDetails.DriverName">
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group d-flex mb-1">
                                                <label style="min-width: 100px;">Vehicle No.</label>
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.GatePassDetails.VehicleNo">
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group d-flex mb-1">
                                                <label style="min-width: 100px;">Builty No.</label>
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" ng-model="beData.GatePassDetails.BuiltyNo" />
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group d-flex mb-1">
                                                <label style="min-width: 100px;">Total Weight</label>
                                                <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.GatePassDetails.TotalWT">
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <!-- end form fiels -->
                        <div class="table-scroll-x-y table-container flex-grow-1">
                            <div class="outer-scroll-wrapper-h-scrollbar-fix">
                                <div class="table-h-scrollbar-fix table-scroll-wrapper">
                                    <table id="main-table" make-table-resizable class="main-table table table-sm table-bordered bg-white cstm-sales-invoice-table border-0 dynamic-uiux-table">
                                        <thead style="background: #e6f5fb;">
                                            <tr>
                                                <th rowspan="2" class="text-center align-middle" style="width:60px;z-index: 3;">SN.</th>
                                                <th rowspan="2" class="text-center align-middle particular-col-width" style="width:270px;z-index: 3;">Voucher Type</th>
                                                <th rowspan="2" class="text-center align-middle" style="width:150px;z-index: 3;">Voucher No.</th>
                                                <th rowspan="2" class="text-center align-middle" style="width:150px;z-index: 3;">Destination</th>
                                                <th rowspan="2" class="text-center align-middle" style="width:100px;z-index: 3;">Qty</th>
                                                <th rowspan="2" class="text-center align-middle" style="width:90px;z-index: 3;">Unit</th>
                                                <th rowspan="2" class="text-center align-middle" style="width:100px;z-index: 3;">Remarks</th>
                                                <th rowspan="2" class="text-center align-middle cstm-sticky sticky-action-col highlight-on-scroll" style="width: 76px;">
                                                    @*Action*@
                                                    <select id="table-action-select" class="form-control form-control-sm action-dropdown">
                                                        <option value="" disabled selected>Action</option>
                                                        <option value="save">Save Layout</option>
                                                        <option value="reset">Reset Layout</option>
                                                    </select>
                                                </th>

                                            </tr>

                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="D in beData.ItemDetailsColl">
                                                <th align="center">
                                                    {{$index+1}}
                                                </th>
                                                <td>
                                                    <select class="form-control form-control-sm select2" ng-model="D.VoucherType" ng-change="getVoucherList(D)">
                                                        <option ng-repeat="VT in VoucherTypeColls" ng-value="VT.id" ng-selected="VT.id == D.VoucherType">
                                                            {{VT.text}}
                                                        </option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <select class="form-control form-control-sm select2" active-select2 ng-model="D.SelectedVoucher" ng-change="getVoucherDet(D)">
                                                        <option ng-repeat="VT in D.VoucherColl" ng-value="VT" ng-selected="VT.TranId == D.RefTranId">
                                                            {{VT.VoucherNo}} - {{VT.Amount |number:2}}
                                                        </option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input type="text" class="form-control form-control-sm" ng-model="D.Destination">
                                                </td>
                                                <td>
                                                    <input type="text" number-input class="form-control form-control-sm" ng-model="D.Qty">
                                                </td>
                                                <td>
                                                    Unit
                                                </td>
                                                <td>
                                                    <input type="text" class="form-control form-control-sm serial " ng-model="D.Remarks">
                                                </td>

                                                <td class="project-actions no-print text-center cstm-sticky sticky-action-col highlight-on-scroll" style="z-index:3;">
                                                    <div class="btn-group btn-group-sm">
                                                        <a class="btn btn-info text-white" data-toggle="tooltip" data-placement="top" title="" data-original-title="Add Row" ng-click="AddRowInItemDetails($index)"><i class="fas fa-plus"></i></a>
                                                        <a class="btn btn-danger text-white ml-2" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete Row." ng-click="delRowFromItemDetails($index)"><i class="fas fa-trash"></i></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
            </div>
        </div>
        <!-- /.container-fluid -->
    </div>

    <footer class="main-footer control-btns pt-0">
        <div class="secondary-footer mt-2">
            <div class="row">
                <div class="col-md-8 col-xl-9">
                    <div class="form-group">
                        <input type="text" list="lstNarration" class="form-control form-control-sm hideSideBar" name="" id="" rows="3" ng-model="beData.AttechFiles" placeholder="Narration">
                    </div>
                </div>
                <div class="col-md-4 col-xl-3">
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-5 col-sm-6 col-form-label font-weight-bold text-dark text-right">Total:</label>
                        <div class="col-7 col-sm-6 col-md-6">
                            <input type="text" number-input class="form-control form-control-sm " style="text-align:right;" placeholder="" ng-model="beData.TotalAmount">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <button type="button" class="btn btn-default" data-toggle="modal" data-target="#documentAttachModal">
                    Document Attach ({{ (beData.AttechFiles.length+(beData.DocumentColl ? beData.DocumentColl.length : 0)) }})
                </button>
            </div>
            <div class="col-sm-8">
                <form class="form-inline justify-content-end">
                    <button type="button" class="btn btn-default ml-1" ng-click="SearchData()">Search</button>
                    <button type="button" class="btn btn-default ml-1" ng-click="Print()" ng-show="lastTranId>0 && lastVoucherId>0">Re-Print</button>
                    <button type="button" class="btn btn-default ml-1" ng-click="Clear()">Reset</button>
                    <button type="button" class="btn btn-primary ml-1" ng-click="SaveGatePass()" ng-disabled="loadingstatus=='running'">Save</button>
                </form>
            </div>
        </div>
    </footer>

