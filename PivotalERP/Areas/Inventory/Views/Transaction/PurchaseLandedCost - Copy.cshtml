@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/inventory/transaction/PurchaseLandedCost.js"></script>
<script>
    var VoucherType = @ViewBag.VoucherType;
    var EntityId = @ViewBag.EntityId;
	var TranId=@ViewBag.TranId;
</script>
<style>
    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }

    .os-theme-dark > .os-scrollbar, .os-theme-light > .os-scrollbar {
        padding: 1px !important;
    }
</style>

<div ng-app="myApp" ng-controller="PurchaseLandedCostController" ng-cloak>
    <div class="container-fluid">
        <!-- Main content -->
        <div class="sale-page-wrap">
            <div class="overflow-hidden">
                @RenderPage("~/Views/Global/_WaitDialog.cshtml")
                @RenderPage("~/Views/Global/_LedgerDetails.cshtml")
                <!-- Page Content  -->
                <div class="content-wrapper-new" style="margin-bottom:105px!important">
                    <div class="card mt-2 bodypart1">
                        <div class="demo-container1">
                            <div class="demo-header">

                                <div class="panel-group snj-panel" id="accordion" role="tablist" aria-multiselectable="true">
                                    <div class="panel panel-default">
                                        <div class="panel-heading active" role="tab" id="headingOne">  
                                            <div class="row mt-1" data-toggle="collapse" data-target="#collapseOne"
                                                 aria-expanded="{{!isCollapsed}}" aria-controls="collapseOne"
                                                 ng-click="isCollapsed = !isCollapsed">
                                                <div class="col-sm-4" ng-hide="HideShow.VoucherType==true">
                                                    <div class="form-group row">
                                                        <label for="inputEmail3" class="col-sm-4 col-form-label">Voucher Type<span style="color:red">*</span></label>
                                                        <div class="col-sm-8">
                                                            <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()">
                                                                <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" ng-value="vt.VoucherId" ng-selected="vt.VoucherId == beData.VoucherId">
                                                                    {{vt.VoucherName}}
                                                                </option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-sm-4" ng-hide="HideShow.CostClass==true">
                                                    <div class="form-group row">
                                                        <label for="inputEmail3" class="col-sm-4 col-form-label">For Year<span style="color:red">*</span></label>
                                                        <div class="col-sm-8">
                                                            <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="getVoucherNo()">
                                                                <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == beData.CostClassId">
                                                                    {{cc.Name}}
                                                                </option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-4 text-right">
                                                    <i class="mt-2 mr-2 fas" ng-class="{'fa-chevron-up': !isCollapsed, 'fa-chevron-down': isCollapsed}"></i>
                                                </div>
                                            </div>
                                            </div>

                                      
                                        <div id="collapseOne" class="panel-collapse collapse in show" role="tabpanel" aria-labelledby="headingOne" ng-class="{'show': !isCollapsed}" >
                                            <div class="card p-2">
                                                <div class="row">
                                                    <div class="col-md-3">
                                                        <div class="form-group d-flex mb-1">
                                                            <label for="" class="mt-1" style="min-width:110px;">Voucher No.</label>
                                                            <input type="text" class="form-control form-control-sm serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                            <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false" title="{{beData.TranId>0 ? beData.TranId : ''}}">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="form-group d-flex mb-1">
                                                            <label for="" class="mt-1 mr-2" style="min-width:50px">Ref No.</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="beData.RefNo" style="width:100%" />
                                                            <button class="btn btn-sm btn-default" style="min-width:80px;" data-toggle="modal" @*data-target="#PurchaseList"*@ ng-click="GetPurchaseList()">Voucher</button>

                                                        </div>
                                                    </div>
                                                    <div class="col-md-2"></div>
                                                    <div class="col-md-3">
                                                        <div class="form-group d-flex" id="dvDTVoucher">
                                                            <label for="inputEmail3" style="min-width: 100px;">{{SelectedVoucher.VoucherDateLabel ? SelectedVoucher.VoucherDateLabel : 'Voucher Date'}}<span style="color:red">*</span></label>
                                                            <input type="text" class="form-control form-control-sm float-right serial hideSideBar" date-picker ng-model="beData.VoucherDate_TMP" date-detail="beData.VoucherDateDet" confirm-action="getVoucherNoOnly()" title="{{(SelectedVoucher.DateStyle==1 ? beData.VoucherDateDet.dateBS : (beData.VoucherDateDet.dateAD |dateFormat))}}" date-style="SelectedVoucher.DateStyle" id="dtVoucherDate" voucherid="SelectedVoucher.VoucherId">
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row" ng-repeat="pi in beData.PurchaseJournalColl">
                                                    <div class="col-md-3">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">Purchase Miti/Date</label>
                                                            <label class="form-control form-control-sm">{{pi.VoucherDateBS}} ( {{pi.VoucherDate |dateFormat}} )</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">Invoice/Ref.No.</label>
                                                            <label class="form-control form-control-sm">{{pi.VoucherNo}} ( {{pi.RefNo}} )</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">Vendor Name</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="pi.PartyName" readonly />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">Currency</label>
                                                            <label class="form-control form-control-sm">{{pi.Currency}}({{pi.CurRate}})</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">Total Qty.</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="pi.TotalQty" readonly />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">Total Value</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="pi.TotalItemAmount" readonly />
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-3" ng-hide="EPDet['LCDetail.GateInWardNo'].ShowHide==2">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">{{GetLabel('LCDetail.GateInWardNo')}}</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.GateInWardNo" />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3" ng-hide="EPDet['LCDetail.BillDateNo'].ShowHide==2">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">{{GetLabel('LCDetail.BillDateNo')}}</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.BillDateNo" />
                                                        </div>
                                                    </div>

                                                    <div class="col-md-3" ng-hide="EPDet['LCDetail.PPNo'].ShowHide==2">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:120px;">{{GetLabel('LCDetail.PPNo')}}</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.PPNo" />
                                                        </div>
                                                    </div>

                                                    <div class="col-md-3" ng-hide="EPDet['LCDetail.LCNo'].ShowHide==2">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">{{GetLabel('LCDetail.LCNo')}}</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.LCNo" />
                                                        </div>
                                                    </div>

                                                    <div class="col-md-3" ng-hide="EPDet['LCDetail.JobNo'].ShowHide==2">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">{{GetLabel('LCDetail.JobNo')}}</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.JobNo" />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3" ng-hide="EPDet['LCDetail.BuiltyNo'].ShowHide==2">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">{{GetLabel('LCDetail.BuiltyNo')}}</label>
                                                            <input type="text" class="form-control form-control-sm" ng-model="beData.LCDetail.BuiltyNo" />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3" ng-hide="EPDet['LCDetail.GateInWardDate'].ShowHide==2">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:120px;">{{GetLabel('LCDetail.GateInWardDate')}}</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.GateInWardDate_TMP" date-detail="beData.LCDetail.GateInWardDateDet">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3" ng-hide="EPDet['LCDetail.BillDate'].ShowHide==2">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">{{GetLabel('LCDetail.BillDate')}}</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.BillDate_TMP" date-detail="beData.LCDetail.BillDateDet">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3" ng-hide="EPDet['LCDetail.PPDate'].ShowHide==2">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">{{GetLabel('LCDetail.PPDate')}}</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.PPDate_TMP" date-detail="beData.LCDetail.PPDateDet">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3" ng-hide="EPDet['LCDetail.LCDate'].ShowHide==2">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:110px;">{{GetLabel('LCDetail.LCDate')}}</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.LCDate_TMP" date-detail="beData.LCDetail.LCDateDet">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3" ng-hide="EPDet['LCDetail.BuiltyDate'].ShowHide==2">
                                                        <div class="form-group d-flex mb-1">
                                                            <label class="mt-1" style="min-width:120px;">{{GetLabel('LCDetail.BuiltyDate')}}</label>
                                                            <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.LCDetail.BuiltyDate_TMP" date-detail="beData.LCDetail.BuiltyDateDet">
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="row" ng-show="SelectedVoucher.ActiveUDF==true">
                                                    <div class="col-sm-3" ng-repeat="uf in beData.UDFFeildsColl | filter: { FieldAfter: 4 }:true">
                                                        <div class="form-group d-flex">
                                                            <label style="min-width: 120px;">{{uf.Name}} <span style="color:red" ng-show="uf.IsMandatory==true">*</span></label>
                                                            <udf-field udf="uf" voucher="SelectedVoucher" change-event="ChangeUDFField(uf.NameId)"></udf-field>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                    
                                  
                                </div>

                                <!--Tab Creation Starts-->
                                <div class="card card-primary card-outline card-outline-tabs">
                                    <div class="card-header p-0 border-bottom-0">
                                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                                            <li class="nav-item">
                                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"><b> Common Cost</b></a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false"><b>Item Wise Cost</b></a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link" id="custom-tabs-four-others-tab" data-toggle="pill" href="#custom-tabs-four-others" role="tab" aria-controls="custom-tabs-four-others" aria-selected="false"><b>Others Cost</b></a>
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="card-body p-2">
                                        <div class="tab-content" id="custom-tabs-four-tabContent">
                                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                                <div class="table-scroll-x-y pb-1 card" style="height:auto !important; max-height: calc(100vh - 24rem) !important;">
                                                    <table id="main-table" class="main-table table table-sm table-bordered bg-white">
                                                        <thead class="text-center">
                                                            <tr>
                                                                <th style="width: 50px; background-color: #ececec!important">S.No.</th>
                                                                <th style="width: 60px; background-color: #ececec !important">Code</th>
                                                                <th style="width: 200px; background-color: #ececec !important">Landed Cost</th>
                                                                <th style="width: 200px; background-color: #ececec !important" ng-hide="EPDet['LCDetail.ActiveLedger'].ShowHide==2 || EPDet['LCDetail.ActiveLedger'].DefaultValue==false">Ledger</th>
                                                                <th style="width: 150px; background-color: #ececec !important">Type</th>
                                                                <th style="width: 150px; background-color: #ececec !important">Allocation By</th>
                                                                <th style="width: 120px; background-color: #ececec !important"> Amount</th>
                                                                <th style="width: 200px; background-color: #ececec !important;z-index:3"> Credit Ledger</th>
                                                                <th ng-show="SelectedVoucher.EachNarrationEntry==true" style="width: 150px; background-color: #ececec !important">Narration</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <tr ng-repeat="lc in LandedCostColl">
                                                                <td align="center">{{$index+1}}</td>
                                                                <td align="center">{{lc.CostCenterCode}}</td>
                                                                <td>
                                                                    {{lc.CostCenterName}}
                                                                </td>
                                                                <td ng-hide="EPDet['LCDetail.ActiveLedger'].ShowHide==2 || EPDet['LCDetail.ActiveLedger'].DefaultValue==false">
                                                                    <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="lc.LedgerId" style="width:95%" ledgertype="1" fortransaction="true"
                                                                            placeholder="** Select LC Name **" showdetails="false" confirm-action="PartySelectionChange(lc)" ledger-detail="lc.LCLedger" side-bar-data="lc.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="8"></select>
                                                                </td>
                                                                <td>
                                                                    <select class="form-control form-control-sm " style="width: 100%;" ng-model="lc.TaxType" data-placeholder="** Tax Type**">
                                                                        <option ng-value="cl.id" ng-repeat="cl in TaxTypeColl" ng-selected="cl.id==lc.TaxType">{{cl.text}}</option>
                                                                    </select>
                                                                </td>
                                                                <td>
                                                                    <select class="form-control form-control-sm " style="width: 100%;" ng-model="lc.AditionalCostOnTheBasis" data-placeholder="** Allocation By **">
                                                                        <option ng-value="cl.id" ng-repeat="cl in AditionalCostTypeList" ng-selected="cl.id==lc.AditionalCostOnTheBasis">{{cl.text}}</option>
                                                                    </select>

                                                                </td>

                                                                <td><input type="text" number-input noofdecimal="SelectedVoucher.NoOfDecimalPlaces" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="lc.DrAmount" ng-change="ChangeDrCrAmount()"></td>
                                                                <td>
                                                                    <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="lc.BrokerLedgerId" style="width:95%" ledgertype="1" fortransaction="true"
                                                                            placeholder="** Select Party Name **" showdetails="false" confirm-action="PartySelectionChange(lc)" ledger-detail="lc.PartyLedger" side-bar-data="lc.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="8"></select>
                                                                </td>
                                                                <td ng-show="SelectedVoucher.EachNarrationEntry==true"><input type="text" onfocus="this.select();" class="form-control form-control-sm" ng-model="lc.Narration"></td>

                                                            </tr>


                                                        </tbody>
                                                        <tfoot>
                                                            <tr>
                                                                <td align="center" colspan="5">Total :-</td>
                                                                <td align="right">
                                                                    <b>{{((LandedCostColl) | sumOfValue:'DrAmount') |number:2}}</b>
                                                                </td>
                                                                <td>
                                                                </td>
                                                                <td ng-show="SelectedVoucher.EachNarrationEntry==true">
                                                                </td>
                                                            </tr>

                                                        </tfoot>
                                                    </table>

                                                </div>

                                            </div>
                                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">
                                                <div class="table-scroll-x-y pb-1 card " style="height:auto !important; max-height: calc(100vh - 24rem) !important;">

                                                    <table id="item-table" class="main-table table table-sm table-bordered bg-white">
                                                        <thead class="text-center">
                                                            <tr>
                                                                <th class="cstm-sticky" style="width: 50px;left:0;z-index:3; background-color: #ececec!important">S.No.</th>
                                                                <th class="cstm-sticky" style="width: 100px; left: 0; z-index: 3; left: 50px; background-color: #ececec !important">Code</th>
                                                                <th class="cstm-sticky" style="width: 100px; left: 0; z-index: 3; left: 150px; background-color: #ececec !important">H.S.Code</th>
                                                                <th class="cstm-sticky" style="width: 250px; left: 0; z-index: 3; left: 250px; background-color: #ececec !important ">Name</th>
                                                                <th style="width: 150px; background-color: #ececec !important">Qty.</th>
                                                                <th style="width: 150px; background-color: #ececec !important">Amount</th>
                                                                @*<th style="width: 150px; background-color: #ececec !important">Tax Base(Vat)</th>*@
                                                                <th style="width: 220px; background-color: #ececec !important" ng-repeat="lc in ProductLandedCostColl" title="{{lc.LedgerName}}"> {{lc.CostCenterName}}</th>
                                                                <th style="width: 200px; background-color: #ececec !important;z-index:3"> Total </th>

                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <tr ng-repeat="lc in ProductWiseCostColl">
                                                                <td align="center" class="cstm-sticky" style="left: 0; z-index: 2; background-color: #ffffff !important">{{$index+1}}</td>
                                                                <td align="center" class="cstm-sticky" style="left: 50px; z-index: 2; background-color: #ffffff !important">{{lc.Code}}</td>
                                                                <td align="center" class="cstm-sticky" style="left: 150px; z-index: 2; background-color: #ffffff !important">{{lc.HSCode}}</td>
                                                                <td  class="cstm-sticky" style="left: 250px; z-index: 2; background-color: #ffffff !important">
                                                                    {{lc.ProductName}}
                                                                </td>
                                                                <td align="center">{{lc.Qty |number:2}} {{lc.Unit}}</td>
                                                                <td align="right">{{lc.Amount |number:2}}</td>
                                                                @*<td>
                                            <input type="text" number-input noofdecimal="SelectedVoucher.NoOfDecimalPlaces" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="lc.TaxBaseAmt">
                                        </td>*@
                                                                <td ng-repeat="cc in lc.LandedCostColl">
                                                                    <input type="text" ng-paste="PasteData($index)" onpaste="return false" number-input noofdecimal="SelectedVoucher.NoOfDecimalPlaces" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="cc.DrAmount" ng-change="ChangeProductWiseCost(lc,cc)">
                                                                </td>
                                                                <td align="right">{{lc.TotalAmount |number:2}}</td>
                                                            </tr>
                                                            <tr>
                                                                <td align="center" colspan="4">Total :- </td>
                                                                <td align="center">
                                                                    <b>{{((ProductWiseCostColl) | sumOfValue:'Qty') |number:2}}</b>
                                                                </td>
                                                                <td align="right">
                                                                    <b>{{((ProductWiseCostColl) | sumOfValue:'Amount') |number:2}}</b>
                                                                </td>
                                                                @*<td align="right">
                                            <b>{{((ProductWiseCostColl) | sumOfValue:'TaxBaseAmt') |number:2}}</b>
                                        </td>*@
                                                                <td align="right" ng-repeat="pcc in ProductWiseCreditLedgerColl">
                                                                    <b>{{pcc.TotalAmount  |number:2}}</b>
                                                                </td>
                                                                <td align="right">
                                                                    <b>{{((ProductWiseCostColl) | sumOfValue:'TotalAmount') |number:2}}</b>
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td align="center" colspan="6">Credit Ledger</td>
                                                                <td ng-repeat="pcc in ProductWiseCreditLedgerColl">
                                                                    <select autoShowHide="true" class="select2 serial form-control-sm" all-ledger ng-model="pcc.BrokerLedgerId" style="width:95%" ledgertype="1" fortransaction="true"
                                                                            placeholder="** Select Party Name **" showdetails="false" confirm-action="PartySelectionChange(pcc)" ledger-detail="pcc.PartyLedger" side-bar-data="pcc.partySideBarData" voucher-id="SelectedVoucher.VoucherId" vouchertype="8"></select>
                                                                </td>
                                                                <td>
                                                                </td>
