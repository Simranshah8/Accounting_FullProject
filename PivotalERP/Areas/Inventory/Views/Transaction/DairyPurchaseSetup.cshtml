                                                    <td>2 </td>
                                                    <td>5</td>
                                                    <td>4.5</td>
                                                    <td>30%</td>
                                                    <td>10</td>
                                                    <td>10</td>
                                                    <td>10</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <div id="shiftform">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Name</label>
                                                <input type="text" class="form-control form-control-sm" ng-model="newDet.Name" />
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <label>Order No</label>
                                                <input type="number" class="form-control form-control-sm" ng-model="newDet.OrderNo" />
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <label>Status</label>
                                                <select class="form-control form-control-sm " ng-model="newDet.Status">
                                                    <option>Active</option>
                                                    <option>Deactive</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label>Description</label>
                                                <textarea class="form-control form-control-sm" rows="1" ng-model="newDet.Description"></textarea>
                                            </div>
                                        </div>
                                    </div>

                                    <footer class="main-footer">
                                        <div class="text-right control-btns">
                                            <button type="button" class="btn btn-default" id="backshift">Back to List</button>
                                            <button type="button" class="btn btn-default" ng-click="Clearshift()">Cancel</button>
                                            <button type="button" class="btn btn-primary" ng-click="SaveUpdateshift()" ng-disabled="loadingstatus=='running'">Save</button>
                                        </div>

                                    </footer>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
            <!-- /.container-fluid -->
        </div>
    </div>
    <!-- /.container-fluid -->
</div>