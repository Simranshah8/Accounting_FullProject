                                                            </tr>
                                                        </thead>

                                                        <tbody>
                                                            <tr ng-repeat="cl in CurData.LogDateColl">
                                                                <td>{{cl.LogDateTime}}</td>
                                                                <td>{{cl.UserName}} </td>
                                                            </tr>                                                           

                                                        </tbody>

                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="Partywise" role="tabpanel" aria-labelledby="custom-tabs-partywise">
