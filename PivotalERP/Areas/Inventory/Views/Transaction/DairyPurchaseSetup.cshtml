
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<script src="~/jslib/inventory/transaction/Dairypurchasesetup.js"></script>
<div ng-app="myApp" ng-controller="DairyPurchaseController" ng-class="{waiting: loadingstatus=='running'}" ng-init="LoadData()" ng-cloak>
