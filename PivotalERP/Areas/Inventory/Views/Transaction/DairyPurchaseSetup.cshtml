                                                                        <option ng-repeat="sh in ProductColl" ng-value="sh.ProductId">{{sh.Name}}</option>
                                                                    </select>
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>Fat Rate</td>
                                                                <td>
                                                                    <input type="text" number-input class="form-control form-control-sm" ng-model="CurData.FAT" onfocus="this.select()" style="text-align: right;">
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>SNF Rate</td>
                                                                <td>
                                                                    <input type="text" number-input class="form-control form-control-sm" ng-model="CurData.SNF" onfocus="this.select()" style="text-align: right;">
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td>TS %</td>
