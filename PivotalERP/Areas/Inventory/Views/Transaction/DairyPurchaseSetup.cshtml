                                                                <td>Maximum Rate</td>
                                                                <td>
                                                                    <input type="text" number-input class="form-control form-control-sm" ng-model="CurData.MaxRate" onfocus="this.select()" style="text-align: right;">
                                                                </td>
                                                            </tr>

                                                        </tbody>

                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="card m-0">
                                            <div class="card-header py-2" style="background-color: #068abf; color: #fff;">
