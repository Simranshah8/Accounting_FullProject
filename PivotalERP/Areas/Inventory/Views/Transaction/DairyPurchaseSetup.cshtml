                                                                <td>Topping Charge</td>
                                                                <td>
                                                                    <input type="text" number-input class="form-control form-control-sm" ng-model="CurData.Topping" onfocus="this.select()" style="text-align: right;">
                                                                </td>
                                                            </tr>
