                                        <tr>
                                            <th>

                                                <div class="custom-control custom-checkbox">
                                                    <input class="custom-control-input" type="checkbox" id="chkSelectAll" ng-model="IsSelectedAll" ng-change="SelectAllLedger(IsSelectedAll)">
                                                    <label for="chkSelectAll" class="custom-control-label"> Name </label>
