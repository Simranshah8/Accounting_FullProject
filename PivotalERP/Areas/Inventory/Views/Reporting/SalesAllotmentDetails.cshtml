    <!--  Party's Allotment Status Modal demo -->
    <div class="modal fade sales-invoice-page-modal document-attach-modal" id="partyStatusDialog" role="dialog" aria-labelledby="partyStatusDialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">{{CurParty.CustomerName}}</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="box box-danger direct-chat direct-chat-danger">

                        <div class="box-footer">
                            <div class="">
                                <table id="main-table" class="main-table table table-sm table-striped table-bordered">
                                    <thead>
                                        <tr>
                                            <th align="center">SN.</th>
                                            <th align="center">Status</th>
                                            <th align="center">User</th>
                                            <th align="center">At Time</th>
                                        </tr>
                                    </thead>
