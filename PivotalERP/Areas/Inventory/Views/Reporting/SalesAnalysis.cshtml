<script>
    $('.modal').on('shown.bs.modal', function () {
        var $modalBody = $(this).find('.modal-body');

        // Allow left/right arrow keys when focused on the modal
        $modalBody.on('keydown', function (e) {
            if (e.keyCode === 37) { // left arrow
                $(this)[0].scrollLeft -= 50;
                e.preventDefault();
            }
            if (e.keyCode === 39) { // right arrow
                $(this)[0].scrollLeft += 50;
                e.preventDefault();
            }
        });

        // Shift + mouse wheel = horizontal scroll
        $modalBody.on('wheel', function (e) {
            if (e.originalEvent.shiftKey || e.originalEvent.deltaX !== 0) {
                e.preventDefault();
                this.scrollLeft += e.originalEvent.deltaY || e.originalEvent.deltaX * 3;
            }
        });

        // Make the modal body focusable so arrow keys work
        $modalBody.attr('tabindex', '-1').focus();
    });
</script>