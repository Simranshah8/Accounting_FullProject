@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/inventory/reporting/PendingSalesAllotment.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="PendingSalesAllotment" ng-init="LoadData()">
    <!-- Main content -->
    <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
        <div class="overflow-hidden">
            <nav id="sidebarzz" class="order-last float-right active active">
                <div class="custom-menu">
                    <button type="button" id="ctmRightSidebarCollapse" class="btn btn-primary"></button>
                </div>
                <div class="" id="firstpanel">
                    <div class="right-box-wrap">

                        <!--Anything to be added here-->
                    </div>
                </div>
            </nav>
            <div class="content-wrapper-new">
                <section class="">
                    <div class="container-fluid">
                        <section class="iframe-content-starts-here">
                            <div class="tab-content">
                                <div id="day-book-section">
                                    <div class="card p-2">
                                        <div class="row">
                                            <div class="col-sm-3">
                                                <div class="d-inline-block">
                                                    <div class="input-group input-group-sm">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">From:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" date-picker ng-model="PendingSalesAllotment.DateFrom_TMP" style="max-width:100px" date-detail="PendingSalesAllotment.DateFromDet" />
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text">To:</span>
                                                        </div>
                                                        <input class="form-control text-dark input-sm" type="text" date-picker ng-model="PendingSalesAllotment.DateTo_TMP" style="max-width:100px" date-detail="PendingSalesAllotment.DateToDet" />
                                                    </div>
                                                </div>
                                            </div>


                                            <div class="col-sm-4">
                                                <div class="form-group d-flex">
                                                    <label class="mt-1 mr-2">Report Type</label>
                                                    <select class="form-control form-control-sm select2 ml-2" style="width:60%" data-placeholder="**Select Report Type**" ng-model="PendingSalesAllotment.ReportType">
                                                        <option ng-value="1" selected>Pending Only</option>
                                                        <option ng-value="2">Clear Only</option>
                                                        <option ng-value="3">Both</option>
                                                        <option ng-value="4">Un-Post</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="col-md-5">
                                                <div class="form-group">
                                                    <a href="#" class="btn btn-primary load px-1" style="float: right; min-width: 75px" data-toggle="tooltip" data-placement="top" title="" data-original-title="Load" ng-click="GetPendingSalesAllotment()" ng-disabled="loadingstatus=='running'"><i class="fas fa-download"> &nbsp;&nbsp;Load</i></a>
                                                </div>
                                            </div>

                                        </div>
                                    </div>

                                    <div class="card p-2 ">
                                        <header class="row">
                                            <div class="col-md-5 col-sm-5">
                                                <div class="clearfix">
                                                    <form class="form-inline">
                                                        <div class="input-group input-group-sm mr-sm-2">
                                                            <div class="input-group-prepend">
                                                                <span class="input-group-text cstm">Find:</span>
                                                            </div>
                                                            <!-- <input type="text" class="form-control border-left-0" placeholder=""> -->
                                                            <select class="form-control pr-0"
                                                                    id="exampleFormControlSelect1">
                                                                <option>Contain</option>
                                                                <option>Prefix</option>
                                                            </select>
                                                        </div>
                                                        <div class="input-group input-group-sm" style="width: 150px;">
                                                            <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">

                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-default">
                                                                    <i class="fas fa-search"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>

                                            <div class="col-md-7 col-sm-7 text-right">
                                                <form class="form-inline  float-right">
                                                    <div class="input-group input-group-sm mr-sm-2">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text cstm">Search By:</span>
                                                        </div>
                                                        <div class="input-group-prepend">
                                                            <select class="form-control form-control-sm select2bs4" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                                <option ng-value="asp" ng-repeat="asp in columnDefs">{{asp.headerName}}</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="input-group input-group-sm" style="width: 155px;">
                                                        <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="paginationOptions.SearchVal">

                                                        <div class="input-group-append">
                                                            <button type="submit" class="btn btn-default">
                                                                <i class="fas fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <div class="dropdown dnld-file ml-2">
                                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                                type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                                aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right"
                                                             aria-labelledby="dropdownMenuButton">
                                                            <span class="dropdown-item">Choose an option:</span>
                                                            <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                                     class="img-fluid exports-icon" alt="Excel image">
                                                                Excel
                                                            </a>
                                                            <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                                <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                                     class="img-fluid exports-icon">
                                                                CSV
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       title="Print" ng-click="Print()">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                    <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       data-placement="bottom" title="Save List State" ng-click="saveRptListState()">
                                                        <i class="fas fa-save"></i>
                                                    </a>
                                                </form>

                                            </div>

                                        </header>
                                        @*<div ui-grid="gridOptions"
             ui-grid-resize-columns
             ui-grid-move-columns
             ui-grid-selection
             ui-grid-exporter
             ui-grid-pinning
             ui-grid-filtering
             ui-grid-save-state style="height: calc(100vh - 200px); max-width: 100%;">
        </div>*@

                                        <div id="datatable" style="height: calc(100vh - 10rem); width: 100%;" class="ag-theme-alpine" ag-grid="gridOptions"></div>
                                        <div id="myGridBottom" style="height: 50px;" class="ag-theme-alpine"></div>
                                        @*<div id="datatable" style="height: calc(100vh - 11rem); width: 100%; " class="ag-theme-alpine"></div>
                                        <div id="myGridBottom" style="height:50px;" class="ag-theme-alpine"></div>*@
                                    </div>

                                </div>

                            </div>

                        </section>
                        <!-- /.row -->
                    </div>
                    <!--/. container-fluid -->
                </section>

            </div>

            <!-- /.content -->
            <!-- Add ReportTemplates Modal Dailog -->
            <div class="modal fade bd-example-modal-xl sales-invoice-page-modal" id="FrmPrintReport" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenter2Title" aria-hidden="true">
                <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-xl" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h6 class="modal-title" id="exampleModalCenterTitle">Report Viewer</h6>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <div class="row">
                                <iframe id="frmRpt" style='width: 100%; height: 600px; background-color: white; visibility:visible;' frameborder='0' scrolling='yes'></iframe>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Filter Button Generation DialogBox *@
            <div class="modal fade bd-example-modal-lg sales-invoice-page-modal" id="itemAllocationForModal" tabindex="-1" role="dialog" aria-labelledby="itemAllocationForModalTitle" aria-hidden="true">
                <div class="modal-dialog  modal-dialog-centered modal-xl" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h6 class="modal-title" id="exampleModalCenterTitle">Filter</h6>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body gradient-bg">
                            <div class="row">
                                <div class="col-sm-4">
                                    <div class="form-group">
                                        <label>Branch</label>
                                        <select class="custom-select" style="width: 100%;" ng-model="para.BranchId">
                                            <option ng-value="vt.BranchId" ng-repeat="vt in BranchList" ng-selected="vt.BranchId==para.BranchId">{{vt.Name}}</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group">
                                        <label>Voucher</label>
                                        <select class="custom-select" style="width: 100%;" ng-model="para.VoucherId">
                                            <option ng-value="vt.VoucherId" ng-repeat="vt in VoucherList" ng-selected="vt.VoucherId==para.VoucherId">{{vt.VoucherName}}</option>
                                        </select>

                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group">
                                        <label>Ledger</label>
                                        <select class="custom-select" style="width: 100%;" ng-model="para.LedgerName">
                                            <option ng-value="at.LedgerName" ng-repeat="at in LedgerList" ng-selected="at.LedgerName==para.LedgerName">{{at.Name}}</option>
                                        </select>

                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-4">
                                    <div class="form-group">
                                        <label>User</label>
                                        <select class="custom-select" style="width: 100%;" ng-model="para.UserId">
                                            <option ng-value="tt.UserId" ng-repeat="tt in UserList" ng-selected="tt.UserId==para.UserId">{{tt.UserName}}</option>
                                        </select>
                                    </div>
                                </div>
                                @*<div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Ledger Group</label>
                                            <select class="custom-select" style="width: 100%;" ng-model="para.LedgerGroup">
                                                <option ng-value="st.LedgerGroup" ng-repeat="st in LedgerGroupList" ng-selected="st.LedgerGroup==para.LedgerGroup">{{st.Name}}</option>
                                            </select>

                                        </div>
                                    </div>*@

                            </div>

                            <div class="table table-responsive">
                                <table id="main-table" class="main-table table table-sm table-striped table-bordered">
                                    <thead>
                                        <tr>
                                            <th style="width: 10px">SN.</th>
                                            <th style="width: 200px">Element</th>
                                            <th>Expression</th>
                                            <th style="width: 100px">Value</th>
                                            <th style="width: 130px">Add/or</th>
                                            <th scope="col" style="width: 10px">Action</th>

                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <th>{{index+1}}</th>
                                            <td>
                                                <select ng-model="fc.text" class="form-control select2bs4 form-control-sm" style="width: 100%;">
                                                    <option ng-repeat="fc in FilterColumnColl">{{fc.text}}</option>
                                                </select>
                                            </td>
                                            <td>  <select ng-model="ec.text" class="form-control select2bs4 form-control-sm" style="width: 100%;"><option ng-repeat="ec in ExpressionColl">{{ec.text}}</option></select></td>
                                            <td>  <input type="text" /></td>
                                            <td>  <select ng-model="cc.text" class="form-control select2bs4 form-control-sm" style="width: 100%;"><option ng-repeat="cc in ConditionColl">{{cc.text}}</option></select></td>

                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <a href="#" class="btn btn-info" data-toggle="tooltip" data-placement="top" title="" data-original-title="Add Row" ng-click="AddRowInItemDetails($index,false)"><i class="fas fa-plus"></i></a>
                                                    <a href="#" class="btn btn-danger" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete Row." ng-click="delRowFromItemDetails($index)"><i class="fas fa-trash"></i></a>
                                                </div>
                                            </td>

                                        </tr>

                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="modal-footer py-2">

                            <button type="button" class="btn btn-sm btn-primary">Accept</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!--Modal Added by suresh on mangsir 6 for view icon of table starts-->
    <div class="modal fade" id="modal-showDocument">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">{{SelectedTran.VoucherName}}-{{SelectedTran.AutoManualNo}}</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="table-responsive">
                            <table class="table table-hover border">
                                <thead>
                                    <tr>
                                        <th scope="col" style="width: 20px">SN.</th>
                                        <th scope="col" style="width:150px">Name</th>
                                        <th scope="col" style="width: 130px">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="dcc in SelectedTran.DocumentColl">
                                        <th scope="row">{{$index+1}}</th>
                                        <td>{{dcc.Name}}</td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a href="{{dcc.DocPath}}" class="btn btn-warning" data-toggle="tooltip" data-placement="top" title="" data-original-title="Download doc." download="{{dcc.Name}}"><i class="fas fa-download"></i></a>
                                                <a href="#" class="btn btn-info" data-toggle="tooltip" data-placement="top" title="" data-original-title="View doc" ng-click="ShowPersonalImg(dcc)"><i class="fas fa-eye"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="time-label">
                    <span class="d-block border-0 p-3 text-center">
                        <button type="button" class="btn btn-sm btn-danger" data-dismiss="modal" style="min-width: 90px;">Close</button>
                    </span>
                </div>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!--Ends-->

    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-body mb-0 p-2">
                    <iframe class="responsive-iframe" ng-hide="viewImg.FileType === 'image'" id="pdfViewer" style="width: 100%; height: 700px; border: none;"></iframe>
                    <img ng-show="viewImg.FileType === 'image'" ng-src="{{viewImg.ContentPath}}" alt="" style="width: 100%; height: auto;" id="imgPreviewAdd">
                </div>
                <div class="modal-footer p-2">
                    <div><a href="{{viewImg.ContentPath}}" download>Download</a></div>
                    <button class="btn btn-success btn-rounded btn-sm ml-4 btn-add text-center" data-dismiss="modal" type="button" style="min-width: 70px;">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!--Modal Added by suresh on mangsir 6 for view icon of table starts-->
    <div class="modal fade" id="modal-post">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Post {{SelectedVoucherP.VoucherName}} {{ SelectedVoucherP.AutoManualNo }} </h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea class="form-control form-control-sm" rows="2" placeholder="" ng-model="SelectedVoucherP.VerifyRemarks"></textarea>
                    </div>
                </div>
                <div class="time-label">
                    <span class="d-block border-0 p-3 text-center">
                        <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="PostVoucher()">Post</button>
                    </span>
                </div>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!--Ends-->
    <!--Modal Added by suresh on mangsir 6 for view icon of table starts-->
    <div class="modal fade" id="modal-verifyv">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Verify {{SelectedVoucher.VoucherName}} {{ SelectedVoucher.AutoManualNo }} </h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea class="form-control form-control-sm" rows="2" placeholder="" ng-model="SelectedVoucher.VerifyRemarks"></textarea>
                    </div>
                </div>
                <div class="time-label">
                    <span class="d-block border-0 p-3 text-center">
                        <button type="button" class="btn btn-sm btn-danger" data-dismiss="modal" style="min-width: 90px;">Cancel</button>
                        <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="VerifyVoucher()">Save</button>
                    </span>
                </div>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!--Ends-->
    <!--Modal Added by suresh on mangsir 6 for view icon of table starts-->
    <div class="modal fade" id="modal-rejectv">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Reject {{SelectedVoucher.VoucherName}} {{ SelectedVoucher.AutoManualNo }} </h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Reason for reject</label>
                        <textarea class="form-control form-control-sm" rows="2" placeholder="" ng-model="SelectedVoucher.RejectRemarks"></textarea>
                    </div>
                </div>
                <div class="time-label">
                    <span class="d-block border-0 p-3 text-center">
                        <button type="button" class="btn btn-sm btn-danger" data-dismiss="modal" style="min-width: 90px;">Cancel</button>
                        <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="RejectVoucher()">Save</button>
                    </span>
                </div>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!--Ends-->

@RenderPage("~/Views/Global/_RptContentMenu.cshtml")

</div>

<script>
    (function ($) {

        "use strict";

        var fullHeight = function () {

            $('.js-fullheight').css('height', $(window).height());
            $(window).resize(function () {
                $('.js-fullheight').css('height', $(window).height());
            });

        };
        fullHeight();

        $('#ctmRightSidebarCollapse').on('click', function () {
            $('#sidebarzz').toggleClass('active');
        });


    })(jQuery);
</script>
