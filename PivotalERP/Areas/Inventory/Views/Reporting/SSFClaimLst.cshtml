@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.RptFormsEntity.SSFClaimList)";
</script>
<script src="~/jslib/inventory/reporting/SSFClaimLst.js"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="ssfClaimLstController">
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="tab-content">
                    <div id="day-book-section">
                        <div class="card p-2">
                            <div class="row">
                                <div class="col-sm-3">
                                    <div class="d-inline-block">
                                        <div class="input-group input-group-sm">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">From:</span>
                                            </div>
                                            <input class="form-control text-dark input-sm" type="text" date-picker ng-model="ProductGroupSummary.DateFrom_TMP" style="max-width:100px" date-detail="ProductGroupSummary.DateFromDet" />
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">To:</span>
                                            </div>
                                            <input class="form-control text-dark input-sm" type="text" date-picker ng-model="ProductGroupSummary.DateTo_TMP" style="max-width:100px" date-detail="ProductGroupSummary.DateToDet" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                </div>
                                <div class="col-sm-1">
                                    <button type="button" class="btn btn-primary load float-right" style="min-width: 90px;" ng-click="GetProductGroupSummary()"><i class="fas fa-download"> &nbsp;&nbsp;Load</i></button>
                                </div>
                                <div class="col-sm-2">
                                    <button type="button" class="btn btn-primary load float-right" style="min-width: 90px;" ng-click="ReAttachRB()"><i class="fas fa-upload"> &nbsp;&nbsp;Re-Attach Running Bills</i></button>
                                </div>
                            </div>

                        </div>
                        <div class="card p-2 ">
                            <header class="row">
                                <div class="col-md-5 col-sm-5">
                                    <div class="clearfix">
                                        <form class="form-inline">
                                            <div class="input-group input-group-sm mr-sm-2">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text cstm">Find:</span>
                                                </div>
                                                <!-- <input type="text" class="form-control border-left-0" placeholder=""> -->
                                                <select class="form-control pr-0"
                                                        id="exampleFormControlSelect1">
                                                    <option>Contain</option>
                                                    <option>Prefix</option>
                                                </select>
                                            </div>
                                            <div class="input-group input-group-sm" style="width: 150px;">
                                                <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">

                                                <div class="input-group-append">
                                                    <button type="submit" class="btn btn-default">
                                                        <i class="fas fa-search"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                <div class="col-md-7 col-sm-7 text-right">
                                    <form class="form-inline  float-right">
                                        <div class="input-group input-group-sm mr-sm-2">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text cstm">Search By:</span>
                                            </div>
                                            <div class="input-group-prepend">
                                                <select class="form-control form-control-sm select2bs4" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                    <option ng-value="asp" ng-repeat="asp in VoucherSearchOptions">{{asp.text}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="input-group input-group-sm" style="width: 150px;">
                                            <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="paginationOptions.SearchVal">

                                            <div class="input-group-append">
                                                <button type="submit" class="btn btn-default">
                                                    <i class="fas fa-search"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <div class="dropdown dnld-file ml-2" title="Download File">
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                    type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                    <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                         class="img-fluid exports-icon" alt="Excel image">
                                                    Excel
                                                </a>
                                                <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                    <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                         class="img-fluid exports-icon">
                                                    CSV
                                                </a>
                                            </div>
                                        </div>
                                        <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                           title="Print" ng-click="Print()">
                                            <i class="fas fa-print"></i>
                                        </a>
                                        <a class="btn btn-secondary btn-light btn-sm ml-2" data-target="#itemAllocationForModal">
                                            <i class="fas fa-filter"></i>
                                        </a>
                                    </form>

                                </div>

                            </header>

                            @*<div id="datatable" style="height: calc(100vh - 12rem);width: 100%;" class="ag-theme-alpine"></div>
                                <div id="myGridBottom" style="height: 50px;" class="ag-theme-alpine"></div>*@

                            <div id="datatable" style="height: calc(100vh - 10rem); width: 100%;" class="ag-theme-alpine" ag-grid="gridOptions"></div>
                            <div id="myGridBottom" style="height: 50px;" class="ag-theme-alpine"></div>
                        </div>

                    </div>

                </div>

            </section>
            <!-- /.row -->
        </div>
        <!--/. container-fluid -->
    </section>




    <!-- /.content -->
    <!-- Add ReportTemplates Modal Dailog -->
    <div class="modal fade bd-example-modal-xl sales-invoice-page-modal" id="FrmPrintReport" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenter2Title" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Report Viewer</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <iframe id="frmRpt" style='width: 100%; height: 600px; background-color: white; visibility:visible;' frameborder='0' scrolling='yes'></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Filter Button Generation DialogBox *@
    <div class="modal fade bd-example-modal-lg sales-invoice-page-modal" id="itemAllocationForModal" tabindex="-1" role="dialog" aria-labelledby="itemAllocationForModalTitle" aria-hidden="true">
        <div class="modal-dialog  modal-dialog-centered modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Filter</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="row">
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label>Branch</label>
                                <select class="custom-select" style="width: 100%;" ng-model="para.BranchId">
                                    <option ng-value="vt.BranchId" ng-repeat="vt in BranchList" ng-selected="vt.BranchId==para.BranchId">{{vt.Name}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label>Voucher</label>
                                <select class="custom-select" style="width: 100%;" ng-model="para.VoucherId">
                                    <option ng-value="vt.VoucherId" ng-repeat="vt in VoucherList" ng-selected="vt.VoucherId==para.VoucherId">{{vt.VoucherName}}</option>
                                </select>

                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label>Ledger</label>
                                <select class="custom-select" style="width: 100%;" ng-model="para.LedgerName">
                                    <option ng-value="at.LedgerName" ng-repeat="at in LedgerList" ng-selected="at.LedgerName==para.LedgerName">{{at.Name}}</option>
                                </select>

                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label>User</label>
                                <select class="custom-select" style="width: 100%;" ng-model="para.UserId">
                                    <option ng-value="tt.UserId" ng-repeat="tt in UserList" ng-selected="tt.UserId==para.UserId">{{tt.UserName}}</option>
                                </select>
                            </div>
                        </div>
                        @*<div class="col-sm-4">
                                <div class="form-group">
                                    <label>Ledger Group</label>
                                    <select class="custom-select" style="width: 100%;" ng-model="para.LedgerGroup">
                                        <option ng-value="st.LedgerGroup" ng-repeat="st in LedgerGroupList" ng-selected="st.LedgerGroup==para.LedgerGroup">{{st.Name}}</option>
                                    </select>

                                </div>
                            </div>*@

                    </div>

                    <div class="table table-responsive">
                        <table id="main-table" class="main-table table table-sm table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th style="width: 10px">SN.</th>
                                    <th style="width: 200px">Element</th>
                                    <th>Expression</th>
                                    <th style="width: 100px">Value</th>
                                    <th style="width: 130px">Add/or</th>
                                    <th scope="col" style="width: 10px">Action</th>

                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <th>{{index+1}}</th>
                                    <td>
                                        <select ng-model="fc.text" class="form-control select2bs4 form-control-sm" style="width: 100%;">
                                            <option ng-repeat="fc in FilterColumnColl">{{fc.text}}</option>
                                        </select>
                                    </td>
                                    <td>  <select ng-model="ec.text" class="form-control select2bs4 form-control-sm" style="width: 100%;"><option ng-repeat="ec in ExpressionColl">{{ec.text}}</option></select></td>
                                    <td>  <input type="text" /></td>
                                    <td>  <select ng-model="cc.text" class="form-control select2bs4 form-control-sm" style="width: 100%;"><option ng-repeat="cc in ConditionColl">{{cc.text}}</option></select></td>

                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="#" class="btn btn-info" data-toggle="tooltip" data-placement="top" title="" data-original-title="Add Row" ng-click="AddRowInItemDetails($index,false)"><i class="fas fa-plus"></i></a>
                                            <a href="#" class="btn btn-danger" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete Row." ng-click="delRowFromItemDetails($index)"><i class="fas fa-trash"></i></a>
                                        </div>
                                    </td>

                                </tr>

                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer py-2">

                    <button type="button" class="btn btn-sm btn-primary">Accept</button>
                </div>
            </div>
        </div>
    </div>


    <!--Modal Added by suresh on mangsir 6 for view icon of table starts-->
    <div class="modal fade" id="modal-reattachment">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">{{SelectedTran.ClaimId}}- {{SelectedTran.Name}}</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="table-responsive">
                            <table id="main-table" class="table table-sm table-head-fixed table-bordered">
                                <thead>
                                    <tr>
                                        <th class="px-0 text-center" style="width: 40px; background-color: #ececec!important">S.No</th>
                                        <th style="width: 150px; background-color: #ececec !important">Name</th>
                                        <th style="width: 100px; background-color: #ececec !important">File</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="dl in SelectedTran.AttachmentList">
                                        <td class="align-middle text-center pl-0">{{$index+1}}</td>
                                        <td>
                                            {{dl.Name}}
                                        </td>
                                        <td>
                                            <input type="file" class="form-control-file border p-0 bg-white" file-model-resize ng-model="dl.File_TMP" fileread="dl.FileData">
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="time-label">
                    <span class="d-block border-0 p-3 text-center">
                        <button type="button" class="btn btn-sm btn-danger" data-dismiss="modal" style="min-width: 90px;" ng-click="ReAttachmentUpload()">Upload</button>
                    </span>
                </div>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!--Ends-->
    <!--Modal Added by suresh on mangsir 6 for view icon of table starts-->
    <div class="modal fade" id="status-reattachment">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">{{SelectedTran.ClaimId}}- {{SelectedTran.Name}}</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="table-responsive">
                            <table id="main-table" class="table table-sm table-head-fixed table-bordered">
                                <thead>
                                    <tr>
                                        <th class="px-0 text-center" style="width: 40px; background-color: #ececec!important">S.No</th>
                                        <th style="width: 150px; background-color: #ececec !important">Name</th>
                                        <th style="width: 100px; background-color: #ececec !important">Value</th>
                                    </tr>
                                </thead>
                                <tbody ng-repeat="dc in CurStatusDataColl">                                    
                                    <tr ng-repeat="(key, value) in dc">
                                        <td class="align-middle text-center pl-0">{{$index+1}}</td>
                                        <td>
                                            {{key}}
                                        </td>
                                        <td>
                                            {{value}}
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="time-label">
                    <span class="d-block border-0 p-3 text-center">
                        <button type="button" class="btn btn-sm btn-danger" data-dismiss="modal" style="min-width: 90px;">Ok</button>
                    </span>
                </div>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!--Ends-->
	
	@RenderPage("~/Views/Global/_RptContentMenu.cshtml")
</div>