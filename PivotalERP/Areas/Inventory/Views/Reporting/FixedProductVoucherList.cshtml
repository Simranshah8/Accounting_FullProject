
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script>

    var EntityId = "@ViewBag.EntityId";
</script>
@*<script src="~/Scripts/ag-grid-community.js"></script>
    <link href="~/Scripts/ag-grid.css" rel="stylesheet" />
    <link href="~/Scripts/ag-theme-balham.css" rel="stylesheet" />
    <script src="~/jslib/main.js"></script>*@
<script src="~/jslib/inventory/reporting/FixedProductVoucherList.js"></script>

<style>
    .numericAlignment {
        text-align: right;
    }

    .headerAligment {
        text-align: center;
    }

    .dateAlignment {
        text-align: center;
    }
</style>
<div ng-app="myApp" ng-controller="FixedProductVoucherList" ng-class="{waiting: loadingstatus=='running'}" @*ng-init="GetAllDayBook()"*@>
    @RenderPage("~/Views/Global/_WaitDialog.cshtml")
    <!-- Main content -->
    <div class="content third-level-scroll-only">
        <!-- Page Content  -->
        <div class="container-fluid" style="width:100%;">
            <div class="card overflow-hidden">
                <div class="card-header header-corner-triangle border">
                    <form action="">
                        <div class="row" style="display:flex;justify-content:space-between">
                            <div class="col-sm-4">
                                <div class="d-inline-block">

                                    <div class="input-group input-group-sm">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text">From:</span>
                                        </div>
                                        <input type="text"
                                               class="form-control form-control-sm" date-picker ng-model="para.dateFrom">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text">To:</span>
                                        </div>
                                        <input class="form-control text-dark input-sm" type="text" date-picker ng-model="para.dateTo" style="max-width:100px" />
                                    </div>
                                </div>
                            </div>


                            <div class="col-sm-4">
                                <div class="form-group d-flex">
                                    <label>Select Product</label>
                                    <select class="form-control form-control-sm select2 ml-2" style="width: 70%;" ng-model="para.ProductId">
                                        <option ng-value="tt.ProductId" ng-repeat="tt in ProductList" ng-selected="tt.ProductId==para.ProductId">{{tt.Name}}</option>
                                    </select>

                                </div>

                            </div>
                            <div class="col-sm-4">
                                <div class="form-group">
                                    <a href="#" class="btn btn-primary btn-sm" style="float: right; max-width: 100px" data-toggle="tooltip" data-placement="top" title="" data-original-title="Load" ng-click="LoadReport()"><i class="fas fa-download">Load</i></a>
                                </div>
                            </div>
                        </div>


                        <div class="row">
                            <div class="col-sm-12" style="font-size:10px;">
                                <label>Filter Applied:</label>

                            </div>

                        </div>
                        <br />


                    </form>


                </div>

            </div>

        </div>


        <div class="row">

            <div class="col-md-12">
                @*<div id="datatable" style="height: calc(100vh - 200px);width: 100%;" class="ag-theme-balham" ag-grid="gridOptions"></div>*@
                <div ui-grid="gridOptions"
                     ui-grid-resize-columns
                     ui-grid-move-columns
                     ui-grid-selection
                     ui-grid-tree-view
                     ui-grid-exporter
                     ui-grid-pinning
                     ui-grid-save-state
                     class="grid" style="height: calc(100vh - 200px);width: 100%;"></div>
            </div>

        </div>

    </div>

    <!-- /.container-fluid -->



    <footer class="main-footer control-btns" @*style="height:50px"*@>

        <div class="row">
            <div class="col-sm-3">
                <div class="form-group row">


                    <div class="input-group input-group-sm">
                        <div class="input-group-prepend">
                            <select class="form-control form-control-sm select2bs4" style="width: 100%;">
                                <option value="1" selected>Contain</option>
                                <option value="2">Prefix</option>
                                <option value="3">Sufix</option>
                            </select>
                        </div>
                        <input type="text" class="form-control text-dark input-sm" placeholder="Search" ng-model="filterValue" ng-change="filter()">
                    </div>
                </div>
            </div>
            <div class="col-sm-3">


            </div>
            <div class="col-sm-6 text-right">
                <button type="button" class="btn btn-primary ml-1" ng-click="saveRptListState()">Save State</button>
                <button type="button" class="btn-sm btn-default" data-toggle="modal" data-target="#itemAllocationForModal"><i class="fas fa-filter">Filter</i></button>
                <button type="button" class="btn-secondary btn-sm" ng-click="Print()"><i class="fas fa-print">Print</i></button>
                <button type="button" class="btn-primary btn-sm"><i class="fas fa-file-export">Export</i></button>
            </div>
        </div>
    </footer>
    <div class="modal fade bd-example-modal-lg sales-invoice-page-modal" id="itemAllocationForModal" tabindex="-1" role="dialog" aria-labelledby="itemAllocationForModalTitle" aria-hidden="true">
        <div class="modal-dialog  modal-dialog-centered modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Filter</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="row">
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label>Branch</label>
                                <select class="custom-select" style="width: 100%;" ng-model="para.BranchId">
                                    <option ng-value="vt.BranchId" ng-repeat="vt in BranchList" ng-selected="vt.BranchId==para.BranchId">{{vt.Name}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label>Voucher</label>
                                <select class="custom-select" style="width: 100%;" ng-model="para.VoucherId">
                                    <option ng-value="vt.VoucherId" ng-repeat="vt in VoucherList" ng-selected="vt.VoucherId==para.VoucherId">{{vt.VoucherName}}</option>
                                </select>

                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label>Ledger</label>
                                <select class="custom-select" style="width: 100%;" ng-model="para.LedgerName">
                                    <option ng-value="at.LedgerName" ng-repeat="at in LedgerList" ng-selected="at.LedgerName==para.LedgerName">{{at.Name}}</option>
                                </select>

                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label>User</label>
                                <select class="custom-select" style="width: 100%;" ng-model="para.UserId">
                                    <option ng-value="tt.UserId" ng-repeat="tt in UserList" ng-selected="tt.UserId==para.UserId">{{tt.UserName}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label>Ledger Group</label>
                                <select class="custom-select" style="width: 100%;" ng-model="para.LedgerGroup">
                                    <option ng-value="st.LedgerGroup" ng-repeat="st in LedgerGroupList" ng-selected="st.LedgerGroup==para.LedgerGroup">{{st.Name}}</option>
                                </select>

                            </div>
                        </div>

                    </div>

                    <div class="table table-responsive">
                        <table id="main-table" class="main-table table table-sm table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th style="width: 10px">SN.</th>
                                    <th style="width: 200px">Element</th>
                                    <th>Expression</th>
                                    <th style="width: 100px">Value</th>
                                    <th style="width: 130px">Add/or</th>
                                    <th scope="col" style="width: 10px">Action</th>

                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <th>{{index+1}}</th>
                                    <td>
                                        <select ng-model="fc.text" class="form-control select2bs4 form-control-sm" style="width: 100%;">
                                            <option ng-repeat="fc in FilterColumnColl">{{fc.text}}</option>
                                        </select>
                                    </td>
                                    <td>  <select ng-model="ec.text" class="form-control select2bs4 form-control-sm" style="width: 100%;"><option ng-repeat="ec in ExpressionColl">{{ec.text}}</option></select></td>
                                    <td>  <input type="text" /></td>
                                    <td>  <select ng-model="cc.text" class="form-control select2bs4 form-control-sm" style="width: 100%;"><option ng-repeat="cc in ConditionColl">{{cc.text}}</option></select></td>

                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="#" class="btn btn-info" data-toggle="tooltip" data-placement="top" title="" data-original-title="Add Row" ng-click="AddRowInItemDetails($index,false)"><i class="fas fa-plus"></i></a>
                                            <a href="#" class="btn btn-danger" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete Row." ng-click="delRowFromItemDetails($index)"><i class="fas fa-trash"></i></a>
                                        </div>
                                    </td>

                                </tr>

                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer py-2">

                    <button type="button" class="btn btn-sm btn-primary">Accept</button>
                </div>
            </div>
        </div>
    </div>
@RenderPage("~/Views/Global/_RptContentMenu.cshtml")

</div>  