@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script>
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.RptFormsEntity.ProductRackList)";
</script>
<script src="~/jslib/inventory/reporting/ProductRackList.js?v=2"></script>

<div ng-app="myApp" ng-controller="ProductRackList" ng-class="{waiting: loadingstatus=='running'}">
    @RenderPage("~/Views/Global/_WaitDialog.cshtml")
    <div class="sale-page-wrap" data-bind="nextFieldOnEnter:true">
        <div class="overflow-hidden">
            <nav id="sidebarzz" class="order-last float-right active active">
                <div class="custom-menu">
                    <button type="button" id="ctmRightSidebarCollapse" class="btn btn-primary"></button>
                </div>
                <div class="" id="firstpanel">
                    <div class="right-box-wrap">

                        <!--Anything to be added here-->
                    </div>
                </div>
            </nav>
            <div class="content-wrapper-new">
                <!-- Main content -->
                <div class="">
                    <!-- Page Content  -->
                    <div class="container-fluid">
                        <div class="card">
                            <div class="card-header header-corner-triangle py-1 px-2">

                                <form action="" class="m-0">
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <h3 class="mb-0">Product Rack List</h3>

                                        </div>
                                        <div class="col-sm-5">
                                            <div class="form-group d-flex mb-0">
                                                <label class="mr-2 mt-1">Select Godown</label>
                                                <select class="form-control form-control-sm select2 mr-2 mt-1" style="width: 50%;" ng-model="beData.GodownId" data-placeholder="**Select Godown**">
                                                    <option ng-value="tt.GodownId" ng-repeat="tt in GodownList" ng-selected="tt.GodownId==beData.GodownId">{{tt.Name}}</option>
                                                </select>

                                            </div>

                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group  mb-0">
                                                <a href="#" class="btn btn-primary load px-1" style="float: right; min-width: 75px" data-toggle="tooltip" data-placement="top" title="" data-original-title="Load" ng-click="GetAllProductRackList()"><i class="fas fa-download"> &nbsp;&nbsp;Load</i></a>
                                            </div>
                                        </div>
                                    </div>


                                </form>


                            </div>

                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <header class="row">
                                    <div class="col-md-5 col-sm-5">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm mr-sm-2">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Find:</span>
                                                    </div>
                                                    <!-- <input type="text" class="form-control border-left-0" placeholder=""> -->
                                                    <select class="form-control pr-0"
                                                            id="exampleFormControlSelect1">
                                                        <option>Contain</option>
                                                        <option>Prefix</option>
                                                    </select>
                                                </div>
                                                <div class="input-group input-group-sm" style="width: 150px;">
                                                    <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">

                                                    <div class="input-group-append">
                                                        <button type="submit" class="btn btn-default">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>

                                    <div class="col-md-7 col-sm-7 text-right">
                                        <form class="form-inline  float-right">
                                            <div class="input-group input-group-sm mr-sm-2">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text cstm">Search By:</span>
                                                </div>
                                                @*Edited by bibek start here Added Angular for Search*@

                                                <div class="input-group-prepend">
                                                    <select class="form-control form-control-sm select2bs4" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                        <option ng-value="asp" ng-repeat="asp in columnDefs">{{asp.headerName}}</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="input-group input-group-sm" style="width: 180px;">
                                                <input type="text" name="table_search" class="form-control float-right" placeholder="Search" ng-model="paginationOptions.SearchVal">
                                                @*Edited by bibek End here*@

                                                <div class="input-group-append">
                                                    <button type="submit" class="btn btn-default">
                                                        <i class="fas fa-search"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="dropdown dnld-file ml-2">
                                                <button class="btn btn-secondary btn-light btn-sm dropdown-toggle"
                                                        type="button" id="dropdownMenuButton" data-toggle="dropdown"
                                                        aria-haspopup="true" aria-expanded="false">
                                                    <i class="fas fa-download"></i>
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right"
                                                     aria-labelledby="dropdownMenuButton">
                                                    <span class="dropdown-item">Choose an option:</span>
                                                    <a class="dropdown-item" href="#" ng-click="DownloadAsXls()">
                                                    <img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png"
                                                         class="img-fluid exports-icon" alt="Excel image">
                                                    Excel
                                                </a>
                                                <a class="dropdown-item" href="#" ng-click="onBtExportCSV()">
                                                    <img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png"
                                                         class="img-fluid exports-icon">
                                                    CSV
                                                </a>
                                                </div>
                                            </div>
                                            <a href="#" class="btn btn-secondary btn-light btn-sm ml-2" ng-click="Print()">
                                                <i class="fas fa-print"></i>
                                            </a>

                                             <a href="#" class="btn btn-secondary btn-light btn-sm ml-2"
                                                       data-placement="bottom" title="Save List State" ng-click="saveRptListState()">
                                                        <i class="fas fa-save"></i>
                                                    </a>
                                        </form>

                                    </div>

                                </header>                                
                                <div id="datatable" style="height: calc(100vh - 10rem); width: 100%;" class="ag-theme-alpine" ag-grid="gridOptions"></div>
                            </div>
                        </div>



                    </div>
                    <!-- /.container-fluid -->
                </div>

            </div>





        </div>
    </div>

    <!--Modal Added by suresh on mangsir 6 for view icon of table starts-->
    <div class="modal fade" id="modal-post">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Post {{SelectedProduct.Name}} {{ SelectedProduct.RackCode }} </h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group col-md-4">
                        <label>Rack</label>
                        <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="SelectedProduct.RackId">
                            <option ng-value="asp.RackId" ng-repeat="asp in RackColl" ng-selected="asp.RackId==SelectedProduct.RackId">{{asp.Name}}-{{asp.Description}}</option>
                        </select>
                    </div>
                    <div class="form-group col-md-8">
                        <label>Notes</label>
                        <textarea class="form-control form-control-sm" rows="2" placeholder="" ng-model="SelectedProduct.Notes"></textarea>
                    </div>
                </div>
                <div class="time-label">
                    <span class="d-block border-0 p-3 text-center">
                        <button type="button" class="btn btn-sm btn-success" style="min-width: 90px;" ng-click="UpdateProductRack()">Update</button>
                    </span>
                </div>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!--Ends-->
@RenderPage("~/Views/Global/_RptContentMenu.cshtml")
</div>

<script>
    (function ($) {

        "use strict";

        var fullHeight = function () {

            $('.js-fullheight').css('height', $(window).height());
            $(window).resize(function () {
                $('.js-fullheight').css('height', $(window).height());
            });

        };
        fullHeight();

        $('#ctmRightSidebarCollapse').on('click', function () {
            $('#sidebarzz').toggleClass('active');
        });


    })(jQuery);
</script>
