@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/mis/misreporting.js"></script>
<div ng-app="myApp" ng-controller="misWeeklySalesCtrl" ng-class="{waiting: loadingstatus=='running'}">
    @RenderPage("~/Views/Global/_WaitDialog.cshtml")
    <!-- Main content -->
    <div class="content  third-level-scroll-only">
        <!-- Page Content  -->
        <div class="container-fluid">
            <div class="container-fluid" style="width:100%;">
                <div class="card overflow-hidden">
                    <div class="card-header header-corner-triangle border">
                            <div class="row">
                                <div class="col-sm-11">
                                    <label>WEEKLY SALES REPORT:</label>
                                </div>
                                <div class="col-sm-1">
                                    <div class="form-group">
                                        <a href="#" class="btn btn-primary btn-sm" style="float: right; max-width: 100px" data-toggle="tooltip" data-placement="top" title="" data-original-title="Load" ng-click="PrintCompetitorSales()" ng-disabled="loadingstatus=='running'"><i class="fas fa-download">Load</i></a>
                                    </div>
                                </div>
                            </div>
                    </div>

                </div>

            </div>

            <div class="row">
                <div class="col-md-12">
                    <iframe id="frmRptTabulation" style='width: 100%;height:calc(100vh - 200px);background-color: white;visibility: visible;' frameborder='0' scrolling='yes'></iframe>
                </div>
            </div>
        </div>
        <!-- /.container-fluid -->
    </div>



    <footer class="main-footer control-btns">

        <div class="row">
            <div class="col-sm-3">
                <div class="form-group row">
                    <div class="input-group input-group-sm">
                        <div class="input-group-prepend">
                            <label>Find :</label>
                        </div>
                        <input type="text" name="table_search" class="form-control text-dark input-sm" placeholder="Search" ng-model="search" ng-change="onFilterTextBoxChanged()">
                    </div>
                </div>
            </div>
            <div class="col-sm-3">

            </div>
            <div class="col-sm-6 text-right">
                <button type="button" class="btn-secondary btn-sm"><i class="fas fa-print" ng-disabled="loadingstatus=='running'">Print</i></button>
                <button type="button" class="btn-primary btn-sm" ng-click="onBtExport()"><i class="fas fa-file-export" ng-disabled="loadingstatus=='running'">Export</i></button>
            </div>
        </div>
    </footer>

</div>