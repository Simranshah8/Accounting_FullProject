@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<script src="~/jslib/inventory/reporting/sales.js"></script>
<div ng-app="myApp" ng-controller="pendingSOSummaryCtrl" ng-class="{waiting: loadingstatus=='running'}">
    @RenderPage("~/Views/Global/_WaitDialog.cshtml")
    <!-- Main content -->
    <div class="content  third-level-scroll-only">
        <!-- Page Content  -->
        <div class="container-fluid">
            <div class="container-fluid" style="width:100%;">
                <div class="card overflow-hidden">
                    <div class="card-header header-corner-triangle border">
                            <div class="row">
                                <div class="col-sm-11">
                                    <label>PENDING SALES ORDER SUMMARY</label>
                                </div>
                                <div class="col-sm-1">
                                    <div class="form-group">
                                        <a href="#" class="btn btn-primary btn-sm" style="float: right; max-width: 100px" data-toggle="tooltip" data-placement="top" title="" data-original-title="Load" ng-click="GetData()" ng-disabled="loadingstatus=='running'"><i class="fas fa-download">Load</i></a>
                                    </div>
                                </div>
                            </div>
                    </div>

                </div>

            </div>

            <div class="row">
                <div class="col-md-12">
                    <div id="datatable" style="height: calc(100vh - 200px);width: 100%;" class="ag-theme-alpine"></div>
                </div>
            </div>
        </div>
        <!-- /.container-fluid -->
    </div>


@RenderPage("~/Views/Global/_RptContentMenu.cshtml")
</div>