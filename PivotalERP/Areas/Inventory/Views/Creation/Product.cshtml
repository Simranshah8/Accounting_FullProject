        <div class="modal fade sales-quotation-page-modal document-attach-modal" id="searVoucherRightBtn" tabindex="-1" role="dialog" aria-labelledby="partyAccRightBtn" aria-hidden="true">
            <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-lg" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h6 class="modal-title" id="exampleModalCenterTitle">Search Product</h6>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body gradient-bg">
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group row">
                                    <label for="" class="col-sm-2 col-form-label col-form-label-sm text-center">Search By</label>
                                    <div class="col-sm-10">
                                        <div class="input-group input-group-sm mb-3">
                                            <div class="input-group-prepend">
                                                <select class="form-control form-control-sm select2bs4" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                    <option ng-value="asp" ng-repeat="asp in VoucherSearchOptions" ng-selected="asp.text==paginationOptions.SearchColDet.text">{{asp.text}}</option>
                                                </select>
                                            </div>
                                            <input type="text" class="form-control" placeholder="" ng-model="paginationOptions.SearchVal" ng-change="ReSearchData(-1)">
                                            <div class="input-group-append">
                                                <div class="input-group-text">
                                                    <span class="fas fa-search" ng-click="ReSearchData(-1)"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <form class="float-right">
                                    <div class="form-row align-items-center">
                                        <div class="d-flex align-items-center">
                                            <label class="mr-sm-2 mb-0" for="inlineFormCustomSelect">Show</label>
                                            <input type="text" ng-model="paginationOptions.pageSize" class="form-control input-sm" placeholder="NoOfRows" @*ng-blur="ReSearchData(-2)"*@>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="">
                            <table id="main-table" class="main-table table table-sm table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Alias</th>
                                        <th>Code</th>
                                        <th>Group</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr dir-paginate="sd in SearchDataColl |orderBy:sortKey:reverse|itemsPerPage:paginationOptions.pageSize" total-items="paginationOptions.TotalRows">
                                        <td>{{sd.Name}}</td>
                                        <td>{{sd.Alias}}</td>
                                        <td>{{sd.Code}}</td>
                                        <td>{{sd.GroupName}}</td>
                                        <td>
                                            <a class="p-1" href="#" ng-click="GetProductById(sd)">
                                                <i class="fas fa-edit text-info"></i>
                                            </a>
                                            <a class="p-1" href="#" ng-click="DelProductById(sd)">
                                                <i class="fas fa-trash-alt text-danger"></i>
                                            </a>
                                            <a class="p-1" href="#" ng-click="UpdateAsGlobal(cr)">
                                                <i class="fas fa-globe text-info"></i>
                                            </a>
                                        </td>
                                    </tr>
                                </tbody>

                            </table>
                            <dir-pagination-controls max-size="paginationOptions.pageSize" direction-links="true" boundary-links="true"
