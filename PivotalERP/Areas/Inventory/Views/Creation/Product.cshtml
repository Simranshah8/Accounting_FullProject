
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
@*<style>
    .iframe-mode {
        overflow-x: hidden;
    }
</style>*@
<script>
     var TranId =@ViewBag.TranId;
    var ProductEntity =@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Product);
    var EntityId = "@Convert.ToInt32(Dynamic.BusinessEntity.Global.FormsEntity.Product)";
</script>
<script src="~/jslib/global/math.min.js"></script>
<script src="~/jslib/inventory/creation/Product.js?v=@Dynamic.BusinessEntity.Global.AppVer.Ver"></script>
<script src="~/jslib/export/tableExport.js"></script>
<script src="~/jslib/export/jquery.base64.js"></script>

<script src="~/jslib/export/jspdf/libs/sprintf.js"></script>
<script src="~/jslib/export/jspdf/jspdf.js"></script>
<script src="~/jslib/export/jspdf/libs/base64.js"></script>

<style>
    .resp-vtabs .resp-tabs-list li {
        padding: 0.1rem 1rem 0.1rem 1.5rem !important;
    }

    label {
        margin-bottom: 0.1rem !important;
        font-size: 13px;
    }

    .form-group {
        margin-bottom: 0.1rem !important;
    }
</style>

<div ng-app="myApp" ng-controller="Product" ng-init="LoadData()" ng-cloak>
    <div class="row">
        <div class="col-sm-8 col-lg-10 order-md-2">
            <div class="card">
                <div class="card-header p-2">
                    <ul class="nav nav-pills">
                        <li class="nav-item"><a class="nav-link active" href="#basic-info" data-toggle="tab">Basic Info</a></li>
                        <li class="nav-item"><a class="nav-link" href="#additional-details" data-toggle="tab">{{GetLabel('AditionalDetails_Panel')}}</a></li>
                        <li class="nav-item"><a class="nav-link" href="#product-costing" data-toggle="tab">{{GetLabel('ProductCosting_Panel')}}</a></li>
                        <li class="nav-item"><a class="nav-link" href="#for-automobiles" data-toggle="tab" ng-show="comDet.Maintain==5">{{GetLabel('For_Automobiles_Panel')}}</a></li>
                        <li class="nav-item"><a class="nav-link" href="#for-petrolpump" data-toggle="tab" ng-show="comDet.Maintain==1">{{GetLabel('For_Petrol_Pump_Panel')}}</a></li>
                        <li class="nav-item"><a class="nav-link" href="#for-termcondition" data-toggle="tab">{{GetLabel('Term_Condition_Panel')}}</a></li>
                        <li class="nav-item"><a class="nav-link" href="#for-ecommerce" data-toggle="tab">For Ecommerce</a></li>
                        <li class="nav-item"><a class="nav-link" href="#for-preferedsupplier" data-toggle="tab">{{GetLabel('Prefered_Supplier_Panel')}}</a></li>
                        <li class="nav-item"><a class="nav-link" href="#for-defaultrack" data-toggle="tab">{{GetLabel('Default_Rack_Panel')}}</a></li>
                        <li class="nav-item"><a class="nav-link" href="#for-productUdf" data-toggle="tab">{{GetLabel('Product_Wise_UDF_Panel')}}</a></li>
                    </ul>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="tab-content">
                        <div class="active tab-pane" id="basic-info">
                            <div class="row">
                                <div class="col-sm-6">
                                    <!-- text input -->
                                    <div class="form-group">
                                        <label title="{{newProduct.ProductId>0 ? newProduct.ProductId : ''}}">{{GetLabel('Name')}}<span style="color:red">*</span></label>
                                        <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newProduct.Name" ng-blur="GenerateCode()" title="{{newProduct.ProductId>0 ? newProduct.ProductId : ''}}" text-case="{{GenConfig.TextCase}}">
                                    </div>
                                </div>

                                <div class="col-sm-4">
                                    <div class="form-group">
                                        <label>{{GetLabel('Alias')}}</label>
                                        <input type="text" class="form-control" placeholder="" ng-model="newProduct.Alias" text-case="{{GenConfig.TextCase}}">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group">
                                        <label>{{GetLabel('SNo')}}</label>
                                        <input type="number" class="form-control" placeholder="" ng-model="newProduct.SNo">
                                    </div>
                                </div>

                                <div class="col-sm-6">
                                    <div class="form-group">
                                        <label>{{GetLabel('ProductGroupId')}}<span style="color:red">*</span></label>
                                        <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newProduct.ProductGroupId" data-placeholder="**Select Group Name**" ng-change="GenerateCode()">
                                            <option ng-value="u.ProductGroupId" ng-repeat="u in ProductGroupList" ng-selected="u.ProductGroupId==newProduct.ProductGroupId">{{u.Name}}</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-6" ng-show="SubGroupColl1.length>0 && EPDet.ProductGroupId.ShowHide!=2">
                                    <div class="form-group">
                                        <label>Sub Group 1<span style="color:red">*</span></label>
                                        <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.SubGroup1" data-placeholder="** Select SubGroup **" ng-change="ChangeGroup(2,newLedger.SubGroup1)">
                                            <option ng-value="pl.ProductGroupId" ng-repeat="pl in SubGroupColl1" ng-selected="pl.ProductGroupId==newLedger.SubGroup1">{{pl.Name}}</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-6" ng-show="SubGroupColl2.length>0 && EPDet.ProductGroupId.ShowHide!=2">
                                    <div class="form-group">
                                        <label>Sub Group 2<span style="color:red">*</span></label>
                                        <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.SubGroup2" data-placeholder="** Select SubGroup **" ng-change="ChangeGroup(3,newLedger.SubGroup2)">
                                            <option ng-value="pl.ProductGroupId" ng-repeat="pl in SubGroupColl2" ng-selected="pl.ProductGroupId==newLedger.SubGroup2">{{pl.Name}}</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-6" ng-show="SubGroupColl3.length>0 && EPDet.ProductGroupId.ShowHide!=2">
                                    <div class="form-group">
                                        <label>Sub Group 3<span style="color:red">*</span></label>
                                        <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.SubGroup3" data-placeholder="** Select SubGroup **" ng-change="ChangeGroup(4,newLedger.SubGroup3)">
                                            <option ng-value="pl.ProductGroupId" ng-repeat="pl in SubGroupColl3" ng-selected="pl.ProductGroupId==newLedger.SubGroup3">{{pl.Name}}</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-6" ng-show="SubGroupColl4.length>0 && EPDet.ProductGroupId.ShowHide!=2">
                                    <div class="form-group">
                                        <label>Sub Group 4<span style="color:red">*</span></label>
                                        <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newLedger.SubGroup4" data-placeholder="** Select SubGroup **" ng-change="ChangeGroup(5,newLedger.SubGroup4)">
                                            <option ng-value="pl.ProductGroupId" ng-repeat="pl in SubGroupColl4" ng-selected="pl.ProductGroupId==newLedger.SubGroup4">{{pl.Name}}</option>
                                        </select>
                                    </div>
                                </div>



                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('BaseUnitId')}}</label>
                                        <select class="form-control form-control-sm" style="width: 100%;" ng-model="newProduct.BaseUnitId" ng-change="ChangeBaseUnit()" data-placeholder="**Select Base Unit**">
                                            <option ng-value="u.UnitId" ng-repeat="u in BaseUnitList" ng-selected="u.UnitId==newProduct.BaseUnitId">{{u.Name}}</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('Code')}}<span style="color:red">*</span></label>
                                        <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newProduct.Code">
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('HSCode')}}</label>
                                        <input type="text" class="form-control form-control-sm" placeholder="H.S. Code" ng-model="newProduct.HSCode">
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('ProductCategoriesId')}}</label>
                                        <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newProduct.ProductCategoriesId" data-placeholder="**Select Category Name**">
                                            <option ng-value="u.ProductCategoriesId" ng-repeat="u in ProductCategoriesList" ng-selected="u.ProductCategoriesId==newProduct.ProductCategoriesId">{{u.Name}}</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('ProductTypeId')}}</label>
                                        <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newProduct.ProductTypeId" data-placeholder="**Select Product Type Name**" ng-change="ChangeProductType(newProduct.ProductTypeId)">
                                            <option ng-value="u.ProductTypeId" ng-repeat="u in ProductTypeList" ng-selected="u.ProductTypeId==newProduct.ProductTypeId">{{u.Name}}</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('PurchaseLedgerId')}}</label>
                                        <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="newProduct.PurchaseLedgerId" id="cboPurchaseLedger" @*style="width:95%"*@ ledgertype="1"
                                                placeholder="** Select Purchase Name **" showdetails="false" confirm-action="PartySelectionChange(beData)" ledger-detail="newProduct.PurchaseLedgerInfo" side-bar-data="newProduct.partySideBarData"></select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('PurchaseReturnLedgerId')}}</label>
                                        <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="newProduct.PurchaseReturnLedgerId" id="cboPurchaseRetrurnLedger" @*style="width:95%"*@ ledgertype="1"
                                                placeholder="** Select Return Name **" showdetails="false" confirm-action="PartySelectionChange(beData)" ledger-detail="newProduct.PurchaseReturnLedgerInfo" side-bar-data="newProduct.partySideBarData"></select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('SalesLedgerId')}}</label>
                                        <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="newProduct.SalesLedgerId" id="cboSalesLedger" @*style="width:95%"*@ ledgertype="1"
                                                placeholder="** Select Sales Name **" showdetails="false" confirm-action="PartySelectionChange(beData)" ledger-detail="newProduct.SalesLedgerInfo" side-bar-data="newProduct.partySideBarData"></select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('SalesReturnLedgerId')}}</label>
                                        <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="newProduct.SalesReturnLedgerId" id="cboSalesReturnLedger" @*style="width:95%"*@ ledgertype="1"
                                                placeholder="** Select Return Name **" showdetails="false" confirm-action="PartySelectionChange(beData)" ledger-detail="newProduct.SalesReturnLedgerInfo" side-bar-data="newProduct.partySideBarData"></select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('BR_PurchaseLedgerId')}}</label>
                                        <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="newProduct.BR_PurchaseLedgerId" @*style="width:95%"*@ ledgertype="1"
                                                placeholder="** Select Purchase Name **" showdetails="false" confirm-action="PartySelectionChange(beData)" ledger-detail="newProduct.BRPurchaseLedgerInfo" side-bar-data="newProduct.partySideBarData"></select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('BR_SalesLedgerId')}}</label>
                                        <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="newProduct.BR_SalesLedgerId" @*style="width:95%"*@ ledgertype="1"
                                                placeholder="** Select Sales Name **" showdetails="false" confirm-action="PartySelectionChange(beData)" ledger-detail="newProduct.BRSalesLedgerInfo" side-bar-data="newProduct.partySideBarData"></select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('IncomeLedgerId')}}</label>
                                        <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="newProduct.IncomeLedgerId" id="cboIncomeLedgerId" @*style="width:95%"*@ ledgertype="1"
                                                placeholder="** Select Income Ledger **" showdetails="false" confirm-action="PartySelectionChange(beData)" ledger-detail="newProduct.IncomeLedgerIdInfo" side-bar-data="newProduct.partySideBarData"></select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label>{{GetLabel('ExpensesLedgerId')}}</label>
                                        <select autoShowHide="true" class="form-control form-control-sm select2 serial" all-ledger ng-model="newProduct.ExpensesLedgerId" id="cboExpensesLedgerId" @*style="width:95%"*@ ledgertype="1"
                                                placeholder="** Select Expenses Ledger **" showdetails="false" confirm-action="PartySelectionChange(beData)" ledger-detail="newProduct.ExpensesLedgerIdInfo" side-bar-data="newProduct.partySideBarData"></select>
                                    </div>
                                </div>
                                <div class="col-sm-{{vUF.ColWidth}}" ng-repeat="uf in UDFFeildsColl | filter: { FieldAfter: 1 }:true">
                                    <div class="form-group">
                                        <label>{{uf.Name}} <span style="color:red" ng-show="uf.IsMandatory==true">*</span></label>
                                        <udf-field udf="uf" change-event="ChangeUDFField(uf.NameId)"></udf-field>
                                    </div>
                                </div>
                               
                                <div class="col-sm-12">
                                    <div class="form-group">
                                        <label>{{GetLabel('Description')}}</label>
                                        <input type="text" class="form-control" placeholder="" ng-model="newProduct.Description">
                                    </div>
                                </div>
                            </div>
                            <!-- row -->
                        </div>
                        <!-- /.tab-pane -->
                        <div class="tab-pane" id="additional-details">
                            <div class="row">
                                <div class="col-md-2">
                                    <div class="mb-2 text-center">
                                        <img id="imgProductPhoto" ng-src="{{newProduct.PhotoData || newProduct.PhotoPath}}" alt="..." class="img-thumbnail">
                                    </div>
                                    <div class="text-center">
                                        <label for="choose-file-father" type="button" class="btn btn-outline-secondary btn-sm"><i class="fas fa-camera w-t"></i> Add Image</label>
                                        <input id="choose-file-father" type="file" accept=".jpg,.jpeg,.png" style="display: none;" file-model ng-model="newProduct.Photo_TMP" @*after-selected="AddStudentPhoto()"*@ fileread="newProduct.PhotoData" />
                                    </div>
                                </div>
                                <div class="col-md-10">
                                    <div class="row">
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>{{GetLabel('DebtorTypeId')}}</label>
                                                <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newProduct.DebtorTypeId" data-placeholder="** Select Debtor Type **">
                                                    <option ng-value="cl.DebtorTypeId" ng-repeat="cl in DebtorTypeList" ng-selected="cl.DebtorTypeId==newProduct.DebtorTypeId">{{cl.Name}}</option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>{{GetLabel('ProductDivisionId')}}</label>
                                                <select class="form-control form-control-sm select2" ng-model="newProduct.ProductDivisionId" data-placeholder="**Select Product Division**">
                                                    <option ng-value="pd.id" ng-repeat="pd in ProductDivisionList" ng-selected="pd.id==newProduct.ProductDivisionId">{{pd.Name}}</option>

                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>{{GetLabel('ProductBrandId')}}</label>
                                                <select class="form-control form-control-sm select2" ng-model="newProduct.ProductBrandId" data-placeholder="**Select Brand*">
                                                    <option ng-value="pb.id" ng-repeat="pb in ProductBrandList" ng-selected="pb.id==newProduct.ProductBrandId">{{pb.Name}}</option>

                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>{{GetLabel('ProductColorId')}}</label>
                                                <select class="form-control form-control-sm select2" ng-model="newProduct.ProductColorId" data-placeholder="**Select Product Color**">
                                                    <option ng-value="pcl.id" ng-repeat="pcl in ProductColorList" ng-selected="pcl.id==newProduct.ProductColorId">{{pcl.Name}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>{{GetLabel('ProductFlavourId')}}</label>
                                                <select class="form-control form-control-sm select2" ng-model="newProduct.ProductFlavourId" data-placeholder="**Select Flavour**">
                                                    <option ng-value="pf.id" ng-repeat="pf in ProductFlavourList" ng-selected="pf.id==newProduct.ProductFlavourId">{{pf.Name}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>{{GetLabel('ProductShapeId')}}</label>
                                                <select class="form-control form-control-sm select2" ng-model="newProduct.ProductShapeId" data-placeholder="**Select Shape Name**">
                                                    <option ng-value="ps.id" ng-repeat="ps in ProductShapeList" ng-selected="ps.id==newProduct.ProductShapeId">{{ps.Name}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>{{GetLabel('ProductCompanyId')}}</label>
                                                <select class="form-control form-control-sm select2" ng-model="newProduct.ProductCompanyId" data-placeholder="**Select Company Name**">
                                                    <option ng-value="u.id" ng-repeat="u in ProductCompanyList" ng-selected="u.id==newProduct.ProductCompanyId">{{u.Name}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>{{GetLabel('PurchaseCCRate')}}</label>
                                                <input type="text" number-input noofdecimal="6" class="form-control form-control-sm" placeholder="" ng-model="newProduct.PurchaseCCRate">
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>{{GetLabel('PurchaseRateFormula')}}</label>
                                                <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newProduct.PurchaseRateFormula">
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>{{GetLabel('SalesCCRate')}}</label>
                                                <input type="text" number-input noofdecimal="6" class="form-control form-control-sm" placeholder="" ng-model="newProduct.SalesCCRate">
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="form-group">
                                                <label>{{GetLabel('SalesRateFormula')}}</label>
                                                <input type="text" class="form-control form-control-sm" placeholder="" ng-model="newProduct.SalesRateFormula">
                                            </div>
                                        </div>
                                        <div class="col-sm-3">
                                            <div class="form-group">
                                                <label>{{GetLabel('WarrantyMonth')}}</label>
                                                <input type="number" class="form-control form-control-sm" placeholder="" ng-model="newProduct.WarrantyMonth">
                                            </div>
                                        </div>
                                        <div class="col-sm-3">
                                            <div class="form-group">
                                                <label>{{GetLabel('TSCRate')}}</label>
                                                <input type="text" number-input noofdecimal="6" class="form-control form-control-sm" placeholder="" ng-model="newProduct.TSCRate">
                                            </div>
                                        </div>
                                        <div class="col-sm-3" ng-show="comDet.Maintain==2">
                                            <div class="form-group">
                                                <label> {{GetLabel('RateOf')}}</label>
                                                <input type="text" number-input noofdecimal="6" class="form-control form-control-sm" placeholder="" ng-model="newProduct.RateOf">
                                            </div>
                                        </div>
                                        <div class="col-sm-3" ng-show="comDet.Maintain==2">
                                            <div class="form-group">
                                                <label>{{GetLabel('LossRate')}}</label>
                                                <input type="text" number-input noofdecimal="6" class="form-control form-control-sm" placeholder="" ng-model="newProduct.LossRate">
                                            </div>
                                        </div>
                                        <div class="col-sm-3">
                                            <div class="form-group">
                                                <label>{{GetLabel('ProfitMarginRate')}}</label>
                                                <input type="text" number-input noofdecimal="3" class="form-control form-control-sm" placeholder="" ng-model="newProduct.ProfitMarginRate" positive="true">
                                            </div>
                                        </div>
                                        <div class="col-sm-3">
                                            <div class="form-group">
                                                <label> {{GetLabel('VatRate')}}</label>
                                                <input type="text" number-input noofdecimal="6" class="form-control form-control-sm" placeholder="" ng-model="newProduct.VatRate" positive="true">
                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <label>{{GetLabel('EXDutyRate')}}</label>
                                                <input type="text" number-input noofdecimal="6" class="form-control form-control-sm" placeholder="" ng-model="newProduct.EXDutyRate" positive="true">
                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <label>{{GetLabel('ExDutyUnitId')}}</label>
                                                <select class="form-control form-control-sm" style="width: 100%;" ng-model="newProduct.ExDutyUnitId" data-placeholder="**Select Excise Unit**">
                                                    <option ng-value="u.UnitId" ng-repeat="u in BaseUnitList" ng-selected="u.UnitId==newProduct.ExDutyUnitId">{{u.Name}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <label>{{GetLabel('ExciseOn')}}</label>
                                                <select class="form-control form-control-sm" style="width: 100%;" ng-model="newProduct.ExciseOn" data-placeholder="**Select Excise On**">
                                                    <option ng-value="u.id" ng-repeat="u in ExciseOnColl" ng-selected="u.id==newProduct.ExciseOn">{{u.text}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-3">
                                            <div class="form-group">
                                                <label>{{GetLabel('DiscountOn')}}</label>
                                                <select class="form-control form-control-sm" style="width: 100%;" ng-model="newProduct.DiscountOn" data-placeholder="**Select Discount On**">
                                                    <option ng-value="0">**select discount on**</option>
                                                    <option ng-value="u.id" ng-repeat="u in ExciseOnColl" ng-selected="u.id==newProduct.DiscountOn">{{u.text}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-3">
                                            <div class="form-group">
                                                <label>{{GetLabel('PurchaseUnitId')}}</label>
                                                <select class="form-control form-control-sm" ng-model="newProduct.PurchaseUnitId" data-placeholder="**Select Purchase Unit**">
                                                    <option ng-value="u.UnitId" ng-repeat="u in BaseUnitList" ng-selected="u.UnitId==newProduct.PurchaseUnitId">{{u.Name}}</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-sm-3">
                                            <div class="form-group">
