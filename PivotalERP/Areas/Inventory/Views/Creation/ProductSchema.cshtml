
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<div class="content">
    <div class="container-fluid">
        <div class="card p-2">
            <div class="row d-flex">
                <div class="col-sm-4">
                    <div class="form-group d-flex">
                        <label for="name" class=" mr-3">Name:</label>
                        <input type="text" class="form-control form-control-sm ml-2" style="width:70%;">
                    </div>
                </div>
                <div class="col-sm-8">
                    <div class="form-group d-flex justify-content-end">
                        <label for="name">Notes:</label>
                        <input type="text" class="form-control form-control-sm ml-2" style="width:90%;">
                    </div>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4">
                    <div class="form-group d-flex">
                        <label for="name">Voucher:</label>
                        <select class="form-control form-control-sm select2 ml-2"
                                style="width:70%;">
                            <option selected="selected"></option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                        </select>
                    </div>
                    <div class="form-group d-flex">
                        <label for="name" class="pr-2 mr-4">Area:</label>
                        <select class="form-control form-control-sm select2 "
                                style="width:70%;">
                            <option selected="selected"></option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                        </select>
                    </div>
                    <div class="form-group d-flex">
                        <label for="name" class="pr-1 mr-3">ledger:</label>
                        <select class="form-control form-control-sm select2"
                                style="width:70%;">
                            <option selected="selected"></option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                        </select>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div>
                        <div class="form-group d-flex">
                            <div class="d-flex">
                                <label for="name" class="mt-1">Date From:</label>
                                <input type="date" class="form-control form-control-sm ml-2"
                                       style="width:50%;">
                            </div>
                            <div class="d-flex">
                                <label for="name" class="mt-1">Date To:</label>
                                <input type="date" class="form-control form-control-sm ml-2"
                                       style="width:50%;">
                            </div>
                        </div>
                    </div>
                    <div class="form-group d-flex">
                        <label for="name" style="margin-right:40px;">Agent:</label>
                        <select class="form-control form-control-sm select2 "
                                style="width:60%;">
                            <option selected="selected"></option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                        </select>
                    </div>
                    <div class="form-group d-flex">
                        <label for="name" class="mr-1">Product Group:</label>
                        <select class="form-control form-control-sm select2 "
                                style="width:55%;">
                            <option selected="selected"></option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                        </select>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="form-group d-flex justify-content-end">
                        <label for="name">Description:</label>
                        <input type="text" class="form-control form-control-sm ml-2" style="width: 60%;">
                    </div>
                    <div class="form-group d-flex justify-content-end">
                        <label for="name">Ledger Group:</label>
                        <select class="form-control form-control-sm select2 ml-2"
                                style="width:60%;">
                            <option selected="selected"></option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                        </select>
                    </div>
                    <div class="form-group d-flex justify-content-end">
                        <label for="name">Product:</label>
                        <select class="form-control form-control-sm select2 ml-2"
                                style="width:60%;">
                            <option selected="selected"></option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                        </select>
                    </div>
                </div>
            </div>
            <table id="main-table"
                   class="main-table table table-sm table-bordered bg-white">
                <thead>
                    <tr style="background-color: #e8e8e8;">
                        <th rowspan="2" class="col-sm-1 text-center align-middle">ID.</th>
                        <th rowspan="2" class="col-sm-2 text-center align-middle">Sales Qty</th>
                        <th rowspan="2" class="col-sm-1 text-center align-middle">Free Qty</th>
                        <th rowspan="2" class="col-sm-2 text-center align-middle">Alternate Product</th>
                        <th colspan="2" scope="colgroup" class="col-sm-2 text-center"
                            style="width: 300px">Discount</th>
                        <th colspan="2" scope="colgroup" class="col-sm-2 text-center"
                            style="width: 300px">Scheme</th>
                        <th rowspan="2" class="col-sm-2 text-center align-middle">Description</th>
                    </tr>
                    <tr style="background-color: #e8e8e8;">
                        <th scope="col" style="top: 35px">
                            Amt
                        </th>
                        <th scope="col" style="top: 35px">
                            Per(%)
                        </th>
                        <th scope="col" style="top: 35px">
                            Amt
                        </th>
                        <th scope="col" style="top: 35px">
                            Per(%)
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr style="background-color: #fff;">
                        <td class="align-middle">1</td>
                        <td class="text-right align-middle">0.00</td>
                        <td class="text-right align-middle">0.00</td>
                        <td class="text-right align-middle">0.00</td>
                        <td class="text-right align-middle">0.00</td>
                        <td class="text-right align-middle">0.00</td>
                        <td class="text-right align-middle">0.00</td>
                        <td class="text-right align-middle">0.00</td>
                        <td></td>
                    </tr>

                </tbody>
            </table>

            <footer class="main-footer">
                <div class="text-right control-btns">
                    <button type="button" class="btn btn-outline-secondary btn-sm" ng-click=""
                            style="font-size: 15px;">
                        Reset
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" ng-click=""
                            style="font-size: 15px;">
                        Edit
                    </button>
                    <button type="button" class="btn btn-primary btn-sm " ng-click=""
                            style="font-size: 15px;">
                        Save
                    </button>
                </div>
            </footer>
        </div>
    </div>
</div>
