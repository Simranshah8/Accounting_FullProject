
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")



<script src="~/jslib/inventory/creation/ProductFlavour.js"></script>
<div class="hold-transaction layout-navbar-fixed" ng-app="myApp" ng-controller="ProductFlavour" ng-class="{waiting: loadingstatus=='running'}" ng-init="GetAlProductFlavour()" ng-cloak>

    <div class="box-body">
        <div class="content">
            <div class="p-1"></div>
            <div class="container-fluid">
                <div class="card card-primary card-outline card-outline-tabs">
                    <div class="card-header p-0 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true"> List</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">Product Flavour</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body">
                        <div class="tab-content" id="custom-tabs-four-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">
                                <header class="row">
                                    <div class="col-md-8">
                                        <div class="clearfix">
                                            <form class="form-inline">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text cstm">Show</span>
                                                    </div>
                                                    <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.ProductFlavour">
                                                        <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.ProductFlavour">{{pp.text}}</option>
                                                    </select>
                                                    <div class="input-group-append">
                                                        <span class="input-group-text bg-white"><small>entries</small></span>
                                                    </div>
                                                </div>
                                                <div class="input-group input-group-sm table-search-filed">
                                                    <input class="form-control form-control-navbar" type="search"
                                                           placeholder="Search" aria-label="Search" ng-model="searchData.ProductFlavour">
                                                    <div class="input-group-append">
                                                        <button class="btn btn-default border-left-0" type="submit">
                                                            <i class="fas fa-search"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- end col-md-8 -->
                                    <div class="col-md-4 text-right">
                                        <div class="dropdown dnld-file"
                                             data-placement="top" title="Download File">
                                            <a class="btn btn-secondary btn-light btn-sm wait"
                                               title="Refresh" ng-click="GetAlProductFlavour()">
                                                <i class="fas fa-sync-alt"></i>
                                            </a>
                                            <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                    id="dropdownMenuButton" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-right"
                                                 aria-labelledby="dropdownMenuButton">
                                                <span class="dropdown-item">Choose an option:</span>
                                                <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'ProductFlavour'" report-name="'List Of ProductFlavour'" ignore-column="'3'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                                <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false',reportName:'ProductFlavour',ignoreColumn:'3' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                            </div>
                                            <a print-tbl report-name="'List Of Product Flavour'" table-id="'#datatable'" class="btn btn-secondary btn-light btn-sm wait"
                                               title="Print">
                                                <i class="fas fa-print"></i>
                                            </a>
                                        </div>


                                    </div>
                                </header>
                                <div class="search-toolbar mb-3 mt-2">
                                    <table cellpadding="12" class="table table-bordered table-striped table-hover table-sm" id="datatable">
                                        <thead>
                                            <tr>
                                                <th style="text-align:center;width:10%">

                                                    S.No
                                                    <span class="glyphicon sort-icon" ng-show="sortKey=='ProductFlavourId'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                </th>

                                                <th ng-click="sort('Name')" style="text-align: left; width: 40% ">
                                                    Name
                                                    <span class="glyphicon sort-icon" ng-show="sortKey=='Name'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                </th>

                                                <th ng-click="sort('Alias')" style="text-align: left; width: 20%;">
                                                    Alias
                                                    <span class="glyphicon sort-icon" ng-show="sortKey=='Alias'" ng-class="{'glyphicon-chevron-up':reverse,'glyphicon-chevron-down':!reverse}"></span>
                                                </th>


                                                <th style="text-align: center; width: 15%;">Action</th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr dir-paginate="beData in ProductFlavourColl|orderBy:sortKey:reverse|filter:searchData.ProductFlavour|itemsPerPage:perPage.ProductFlavour" current-page="currentPages.ProductFlavour" pagination-id="ProductFlavourPagination">


                                                <td style=" text-align:center;margin:auto">
                                                    {{$index+1}}
                                                </td>
                                                <td style=" text-align: left; margin: auto">
                                                    {{beData.Name}}
                                                </td>

                                                <td style="text-align: left; margin: auto">
                                                    {{beData.Alias}}
                                                </td>
                                                <td class="project-actions" style="text-align:center;width:10%">
                                                    <div class="btn-group-sm">
                                                        <a href="#" class="btn btn-sm btn-info" ng-click="getProductFlavourById(beData)"><i class="fas fa-pencil-alt"></i></a>
                                                        <a href="#" class="btn btn-sm btn-danger" ng-click="deleteProductFlavour(beData,$index)"><i class="fas fa-trash"></i></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <div class="col-md-12">
                                        <dir-pagination-controls pagination-id="ProductFlavourPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                        </dir-pagination-controls>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                                <div class="p-2">
                                    <form>

                                        <div class="row">
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label>Name<span style="color:red">*</span></label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.Name">
                                                </div>
                                            </div>
                                            <div class="col-sm-3">
                                                <div class="form-group">
                                                    <label>Alias</label>
                                                    <input type="text" class="form-control form-control-sm" ng-model="beData.Alias">
                                                </div>
                                            </div>
                                        </div>

                                    </form>
                                    <footer class="main-footer">
                                        <div class="text-right control-btns">
                                            <button type="button" class="btn btn-default" ng-click="ClearProductFlavour()">Reset</button>
                                            @*<button type="button" class="btn btn-secondary" ng-click="AddCostCategory()">Save & Close</button>*@
                                            <button type="button" class="btn btn-primary" ng-click="SaveUpdateProductFlavour()">Save</button>
                                        </div>

                                    </footer>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.container-fluid -->
        </div>




    </div>
</div>



<style>

    .table table-bordered table-striped table-hover table-sm td {
        font-size: x-small;
        line-height: 10px;
    }
</style>
