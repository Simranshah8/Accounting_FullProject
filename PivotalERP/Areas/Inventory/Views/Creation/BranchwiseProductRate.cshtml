
@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<div class="content">
    <div class="container-fluid">
        <div class="card p-2">
            <div class="row mt-2 mb-3 d-flex">
                <div class="col-sm-10">
                    <div class="form-group d-flex">
                        <label for="name" class="pr-2 mt-1">Branch Name:</label>
                        <select class="form-control form-control-sm select2 ml-2"
                                style="width:70%;">
                            <option selected="selected"></option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                        </select>
                    </div>
                </div>
                <div class="col-sm-2">
                    <div class="form-group d-flex">
                        <label for="name" class="mt-1">Date:</label>
                        <input type="date" class="form-control form-control-sm ml-2 text-right" ng-model="" style="width:70%;">
                    </div>
                </div>
            </div>
            <div class="row mt-2 mb-3 d-flex">
                <div class="col-sm-11">
                    <div class="form-group d-flex">
                        <label for="name" class="pr-2 mt-1">Product Group:</label>
                        <select class="form-control form-control-sm select2 ml-1"
                                style="width:63%;">
                            <option selected="selected"></option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                        </select>
                    </div>
                </div>
                <div class="col-sm-1">
                    <div class="form-group">
                        <input type="submit" value="Load">
                    </div>
                </div>
            </div>
            <table id="maintable" class="table table-bordered table-hover table-sm  ">
                <thead>
                    <tr style="text-align:center;font-weight:bold;background-color:#e8e8e8;">
                        <th class="col-sm-1">
                            S.No.
                        </th>
                        <th class="col-sm-7">
                            Product
                        </th>
                        <th class="col-sm-2">
                            per
                        </th>
                        <th class="col-sm-2">
                            Sale
                        </th>
                    </tr>
                </thead>
                <tr style="text-align:center">
                    <td>
                        1
                    </td>
                    <td> </td>
                    <td></td>
                </tr>
            </table>
            <footer class="main-footer">
                <div class="text-right control-btns">
                    <button type="button" class="btn btn-outline-secondary btn-sm" ng-click=""
                            style="font-size: 15px;">
                        Reset
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" ng-click=""
                            style="font-size: 15px;">
                        Edit
                    </button>
                    <button type="button" class="btn btn-primary btn-sm " ng-click=""
                            style="font-size: 15px;">
                        Save
                    </button>
                </div>
            </footer>
        </div>
    </div>
</div>

