@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")

<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>

<script src="~/jslib/inventory/creation/GatePass.js"></script>
<div ng-app="myApp" ng-controller="GatePassController" ng-init="LoadData()">
    <div class="sale-page-wrap">
        <div class="overflow-hidden">
            <!-- Page Content  -->
            <div class="content-wrapper-new">
                <div class="card">
                    <div class="card-header header-corner-triangle overflow-hidden py-1">
                        <div class="row">
                            <h3 class="card-title mr-4">{{SelectedVoucher && SelectedVoucher.VoucherName ? SelectedVoucher.VoucherName : 'Gate Pass'}}</h3>
                            <div class="col-md-4" ng-hide="HideShow.VoucherType==true">
                                <div class="form-group mb-0 row">
                                    <label class="col-md-4 text-nowrap">Voucher Type</label>
                                    <div class="col-md-8">
                                        <select class="form-control form-control-sm select2 hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()">
                                            <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" value="{{vt.VoucherId}}" ng-selected="vt.VoucherId == beData.VoucherId">
                                                {{vt.VoucherName}}
                                            </option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-body py-2">
                        <div class="row">
                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width: 120px;">Gate Pass No.</label>

                                    <input type="text" class="form-control form-control-sm serial" placeholder="" ng-model="beData.AutoManualNo" readonly ng-hide="HideShow.AutoVoucherNo==true">
                                    <input type="text" class="form-control form-control-sm serial hideSideBar" placeholder="" ng-model="beData.ManualVoucherNO" ng-hide="HideShow.AutoVoucherNo==false">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label for="inputEmail3" style="min-width:120px;">{{SelectedVoucher.RefNoName ? SelectedVoucher.RefNoName : 'Ref. No.'}}</label>
                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="beData.RefNo">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width:120px;">Voucher Date</label>
                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.EntryDate_TMP" date-detail="beData.EntryDateDet" />
                                </div>
                            </div>

                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width: 120px;">Destination</label>
                                    <input type="text" class="form-control form-control-sm ml-1" placeholder="">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width:120px;">Delivery Through</label>
                                    <select class="form-control form-control-sm select2" ng-model="beData.Delivery">
                                        <option ng-repeat="DT in DeliveryThroughList" ng-value="DT.DeliveryThroughId" ng-selected="DT.DeliveryThroughId == beData.Delivery">
                                            {{DT.Name}}
                                        </option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width:120px;">Delivery Doc No.</label>
                                    <input type="text" class="form-control form-control-sm" ng-model="beData.AttechFiles" />
                                </div>
                            </div>

                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width: 120px;">Transporter</label>
                                    <input type="text" class="form-control form-control-sm ml-1" placeholder="" ng-model="beData.AttechFiles">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width:120px;">Drive'sContactNo.</label>
                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="beData.AttechFiles">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width:120px;">License No.</label>
                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.AttechFiles" />
                                </div>
                            </div>

                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width: 120px;">Driver's Name</label>
                                    <input type="text" class="form-control form-control-sm ml-1" placeholder="" ng-model="beData.AttechFiles">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width:120px;">Vehicle No.</label>
                                    <input type="text" class="form-control form-control-sm" placeholder="" ng-model="beData.AttechFiles">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width:120px;">Builty No.</label>
                                    <input type="text" class="form-control form-control-sm" date-picker ng-model="beData.AttechFiles" />
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group d-flex mb-1">
                                    <label style="min-width: 120px;">TotalWT</label>
                                    <input type="text" class="form-control form-control-sm ml-1" placeholder="" ng-model="beData.AttechFiles">
                                </div>
                            </div>
                        </div>

                    </div>
                    <!-- end form fiels -->
                    <div class="card-body pb-1 pt-0">
                        <div class="table-scroll-x-y" style="height:calc(100vh - 20.5rem)!important;">
                            <table id="main-table" class="main-table table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th rowspan="2" class="text-center align-middle" style="width:60px;z-index: 3; background-color: #ececec !important">SN.</th>
                                        <th rowspan="2" class="text-center align-middle particular-col-width" style="width:270px;z-index: 3; background-color: #ececec !important">Voucher Type</th>
                                        <th rowspan="2" class="text-center align-middle" style="width:150px;z-index: 3; background-color: #ececec !important">Voucher No.</th>
                                        <th rowspan="2" class="text-center align-middle" style="width:150px;z-index: 3; background-color: #ececec !important">Destination</th>
                                        <th rowspan="2" class="text-center align-middle" style="width:100px;z-index: 3; background-color: #ececec !important">Qty</th>
                                        <th rowspan="2" class="text-center align-middle" style="width:90px;z-index: 3; background-color: #ececec !important">Unit</th>
                                        <th rowspan="2" class="text-center align-middle" style="width:100px;z-index: 3; background-color: #ececec !important">Remarks</th>
                                        <th rowspan="2" class="text-center align-middle" style="width:70px;z-index: 3; background-color: #ececec !important">Action</th>
                                    </tr>

                                </thead>
                                <tbody>
                                    <tr ng-repeat="D in beData.ItemDetailsColl">
                                        <th align="center">
                                            {{$index+1}}
                                        </th>
                                        <td>
                                            <select class="form-control form-control-sm select2" ng-model="D.VoucherId">
                                                <option ng-repeat="VT in VoucherTypeColls" ng-value="VT.id" ng-selected="VT.id == D.VoucherId">
                                                    {{VT.text}}
                                                </option>
                                            </select>
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" ng-model="D.VoucherNo">
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" ng-model="D.AttechFiles">
                                        </td>
                                        <td>
                                            <select class="form-control form-control-sm" style="width: 100%; background-color: #fff" ng-model="D.TranUnitId">
                                                <option ng-value="bc.UnitId" ng-repeat="bc in itemDet.productDetail.AlternetUnitColl" ng-selected="D.TranUnitId==bc.UnitId">{{bc.UnitName}}</option>
                                            </select>
                                            <input type="text" class="form-control  form-control-sm" ng-model="itemDet.UnitName" disabled ng-hide="itemDet.productDetail.AlternetUnitColl.length>0 &&  HideShow.AlternetUnit==true">

                                        </td>
                                        <td>
                                            <input type="text" number-input class="form-control form-control-sm serial " ng-model="D.AttechFiles" style="text-align:center">
                                        </td>

                                        <td><input type="text" class="form-control form-control-sm serial" ng-model="D.AttechFiles"></td>

                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <a class="btn btn-info text-white" data-toggle="tooltip" data-placement="top" title="" data-original-title="Add Row" ng-click="AddRowInItemDetails($index)"><i class="fas fa-plus"></i></a>
                                                <a class="btn btn-danger text-white ml-2" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete Row." ng-click="delRowFromItemDetails($index)"><i class="fas fa-trash"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>

            </div>
        </div>
        <!-- /.container-fluid -->
    </div>

    <footer class="main-footer control-btns pt-0">
        <div class="secondary-footer mt-2">
            <div class="row">
                <div class="col-md-8 col-xl-9">
                    <div class="form-group">
                        <input type="text" list="lstNarration" class="form-control form-control-sm hideSideBar" name="" id="" rows="3" ng-model="beData.AttechFiles" placeholder="Narration">
                    </div>
                </div>
                <div class="col-md-4 col-xl-3">
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-5 col-sm-6 col-form-label font-weight-bold text-dark text-right">Total:</label>
                        <div class="col-7 col-sm-6 col-md-6">
                            <input type="text" number-input class="form-control form-control-sm " style="text-align:right;" placeholder="" ng-model="beData.TotalAmount">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <button type="button" class="btn btn-default" data-toggle="modal" data-target="#documentAttachModal">
                    Document Attach ({{ (beData.AttechFiles.length+(beData.DocumentColl ? beData.DocumentColl.length : 0)) }})
                </button>
            </div>
            <div class="col-sm-8">
                <form class="form-inline justify-content-end">
                    <button type="button" class="btn btn-default ml-1" ng-click="ClearData()">Clear</button>
                    <button type="button" class="btn btn-secondary ml-1" data-toggle="modal"  ng-click="GetAllGatePass()">Search</button>
                    <button type="button" class="btn btn-primary ml-1" ng-click="SaveUpdateGatePass()" ng-disabled="loadingstatus=='running'">Save</button>
                </form>
            </div>
        </div>
    </footer>

    <!--  Document Attach footer Modal demo -->
    @*file-upload modal*@
    <div class="modal fade sales-invoice-page-modal document-attach-modal" id="documentAttachModal" tabindex="-1" role="dialog" aria-labelledby="documentAttachModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title" id="exampleModalCenterTitle">Document Attach</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="timeline-item">
                        <div class="add-more-than-one-form-block">
                            <form>
                                <article>
                                    <div class="row">

                                        <div class="col-sm-10">
                                            <div class="row">
                                                <div class="col-sm-4">
                                                    <div class="form-group">
                                                        <label>Attach Document</label>
                                                        <div class="form-group">
                                                            <input type="file" id="flMoreFiles" class="form-control-file border p-0 bg-white" file-model ng-model="attachFile">
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label>Description</label>
                                                        <input type="text" class="form-control form-control-sm"
                                                               ng-model="docDescription"
                                                               placeholder="">
                                                    </div>
                                                </div>
                                                <div class="col-sm-2">
                                                    <div class="d-flex">
                                                        <div>
                                                            <label class="invisible d-block">for height</label>
                                                            <button type="button" class="btn btn-sm btn-outline-secondary light-btn" ng-click="AddMoreFiles(attachFile,docDescription)"><i class="fas fa-plus"></i> Add More</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            </form>
                        </div>
                        <div class="pb-3">
                            <div class="table-responsive">
                                <table class="table table-hover border bg-white">
                                    <thead>
                                        <tr>
                                            <th scope="col" style="width: 20px">SN.</th>

                                            <th scope="col">File Name</th>
                                            <th scope="col">Description</th>
                                            <th scope="col" style="width: 130px">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr ng-repeat="ac in beData.DocumentColl">
                                            <th scope="row">{{$index+1}}</th>

                                            <td>{{ac.Name}}</td>
                                            <td>{{ac.Description}}</td>
                                            <td>
                                                <div>
                                                    <a class="p-1" href="#" ng-click="ShowPersonalImg(ac)" data-toggle="tooltip" data-placement="top" title="" data-original-title="View doc">
                                                        <i class="fas fa-eye text-secondary"></i>
                                                    </a>

                                                    <a class="p-1" data-toggle="tooltip" data-placement="top" title="" data-original-title="Delete doc." ng-click="delAttachmentFiles($index)">
                                                        <i class="fas fa-trash-alt text-danger"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-sm btn-add btn-outline-secondary" style="width:50px" data-dismiss="modal">Ok</button>
                </div>
            </div>
        </div>
    </div>

    <!--New Modal Adde by Prasahnt Starts-->
    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-body mb-0 p-2">
                    <iframe class="responsive-iframe" ng-hide="viewImg.FileType === 'image'" id="pdfViewer" style="width: 100%; height: 700px; border: none;"></iframe>
                    <img ng-show="viewImg.FileType === 'image'" ng-src="{{viewImg.ContentPath}}" alt="" style="width: 100%; height: auto;" id="imgPreviewAdd">
                </div>
                <div class="modal-footer p-2">
                    <div><a href="{{viewImg.ContentPath}}" download>Download</a></div>
                    <button class="btn btn-success btn-rounded btn-sm ml-4 btn-add text-center" data-dismiss="modal" type="button" style="min-width: 70px;">Close</button>
                </div>
            </div>
        </div>
    </div>
    <!--Ends-->
    <!--  Search Voucher right button Modal demo -->
    <div class="modal fade sales-quotation-page-modal document-attach-modal" id="searVoucherRightBtn" tabindex="-1" role="dialog" aria-labelledby="partyAccRightBtn" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalCenterTitle">Search Gate Pass</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body gradient-bg">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group row">
                                <label for="" class="col-sm-2 col-form-label col-form-label-sm text-center">Search By</label>
                                <div class="col-sm-10">
                                    <div class="input-group input-group-sm mb-3">
                                        <div class="input-group-prepend">
                                            <select class="form-control form-control-sm select2bs4" style="width: 100%;" ng-model="paginationOptions.SearchColDet">
                                                <option ng-value="asp" ng-repeat="asp in VoucherSearchOptions">{{asp.text}}</option>
                                            </select>
                                        </div>
                                        <input type="text" class="form-control form-control-sm" placeholder="" ng-model="paginationOptions.SearchVal">
                                        <div class="input-group-append">
                                            <div class="input-group-text">
                                                <span class="fas fa-search" ng-click="ReSearchData(-1)"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <form class="float-right">
                                <div class="form-row align-items-center">
                                    <div class="d-flex align-items-center">
                                        <label class="mr-sm-2 mb-0" for="inlineFormCustomSelect">Show</label>
                                        <input type="text" ng-model="paginationOptions.pageSize" class="form-control form-control-sm input-sm" placeholder="NoOfRows" @*ng-blur="ReSearchData(-2)"*@>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                    <div class="">
                        <table id="main-table" class="main-table table table-sm table-bordered bg-white text-nowrap table-hover" style="table-layout: auto;">
                            <thead>
                                <tr>
                                    <th>Voucher No</th>
                                    <th>Ref No.</th>
                                    <th>Voucher Date</th>
                                    <th>Voucher Name</th>
                                    <th>CostClass</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr dir-paginate="sd in SearchDataColl |orderBy:sortKey:reverse|itemsPerPage:paginationOptions.pageSize" total-items="paginationOptions.TotalRows">
                                    <td align="center">{{sd.VoucherNo}}</td>
                                    <td>{{sd.RefNo}}</td>
                                    <td align="center">{{sd.VoucherDate |dateFormat}}</td>

                                    <td>{{sd.VoucherName}}</td>
                                    <td>{{sd.CostClass}}</td>
                                    <td>
                                        <a class="p-1" href="#" ng-click="GetClassById(cl)">
                                            <i class="fas fa-edit text-info"></i>
                                        </a>
                                        <a class="p-1" href="#" ng-click="DelClassById(cl)">
                                            <i class="fas fa-trash-alt text-danger"></i>
                                        </a>
                                        <a class="p-1" href="#" ng-click="PrintVoucher(sd.TranId,sd.VoucherId)">
                                            <i class="fas fa-print text-primary"></i>
                                        </a>
                                    </td>
                                </tr>
                            </tbody>

                        </table>
                        <dir-pagination-controls max-size="paginationOptions.pageSize" direction-links="true" boundary-links="true"
                                                 on-page-change="ReSearchData(newPageNumber)">
                        </dir-pagination-controls>
                    </div>

                </div>
                <!-- end modal body -->
                <div class="modal-footer justify-content-between align-items-center py-2">
                    <h6 class="mb-0">Total Record: {{paginationOptions.TotalRows}}</h6>
                    <div class="">
                        <button type="button" class="btn btn-sm btn-outline-secondary load" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>