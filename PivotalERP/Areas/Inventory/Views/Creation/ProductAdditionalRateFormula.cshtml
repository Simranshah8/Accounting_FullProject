@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<div class="content">
    <div class="container-fluid">

        <div class="card p-2">
            <div class="row mt-2 mb-3 d-flex">
                <div class="col-sm-5">
                    <div class="form-group d-flex">
                        <label for="name" class="pr-2 mt-1">Select Branch:</label>
                        <select class="form-control form-control-sm select2 ml-2"
                                style="width:70%;">
                            <option selected="selected"></option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                        </select>
                    </div>
                </div>
                <div class="col-sm-7">
                    <div class="form-group d-flex">
                        <label for="name" class="pr-2 mt-1">Select Production Group:</label>
                        <select class="form-control form-control-sm select2 ml-2"
                                style="width:60%;">
                            <option selected="selected"></option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                        </select>
                    </div>
                </div>

            </div>
            <table id="maintable" class="table table-bordered table-hover table-sm  ">
                <thead>
                    <tr style="text-align:center;font-weight:bold;background-color:#e8e8e8;">
                        <th class="col-sm-1">
                            S.No.
                        </th>
                        <th class="col-sm-2">
                            Product Name
                        </th>
                        <th class="col-sm-2">
                            Sales Quotation
                        </th>
                        <th class="col-sm-2">
                            Sales Order
                        </th>
                        <th class="col-sm-1">
                            Dispatch
                        </th>
                        <th class="col-sm-2">
                            Delivery Note
                        </th>
                        <th class="col-sm-2">
                            Sales Invoice
                        </th>

                    </tr>
                </thead>
                <tr style="text-align:center">
                    <td>
                        1
                    </td>
                    <td> </td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                </tr>
            </table>
            <footer class="main-footer">
                <div class="text-right control-btns">
                    <button type="button" class="btn btn-outline-secondary btn-sm" ng-click=""
                            style="font-size: 15px;">
                        Reset
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" ng-click=""
                            style="font-size: 15px;">
                        Edit
                    </button>
                    <button type="button" class="btn btn-primary btn-sm " ng-click=""
                            style="font-size: 15px;">
                        Save
                    </button>
                </div>
            </footer>

        </div>
    </div>
    <!-- /.container-fluid -->
</div>