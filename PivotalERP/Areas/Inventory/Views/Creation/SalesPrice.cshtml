@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>
<script src="~/jslib/Setup/AllowProductGroup.js"></script>
<script src="~/jslib/inventory/creation/SalesPrice.js"></script>
<div ng-app="myApp" ng-controller="SalesPriceController" ng-class="{waiting: loadingstatus=='running'}" ng-init="LoadData()">
    <div class="container-fluid">
        <div class="tab-content">
            <div class="card p-2">
                <div class="row">
                    <div class="col-md-2">
                        <div class="form-group">
                            <label for="">Rate Type</label>
                            <select class="form-control form-control-sm select2" ng-model="newPrice.RateTypeId">
                                <option ng-value="cl.Id" ng-repeat="cl in RateTypeColl">{{cl.Name}}</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label for="">Group</label>
                            <select class="form-control form-control-sm select2" ng-model="newPrice.GroupId">
                                <option ng-value="cl.ProductGroupId" ng-repeat="cl in ProductGroupColl">{{cl.Name}}</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label for="">Brand</label>
                            <select class="form-control form-control-sm select2" ng-model="newPrice.BrandId">
                                <option ng-value="cl.ProductBrandId" ng-repeat="cl in ProductBrandColl">{{cl.Name}}</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label for="">Applicable From</label>
                            <input type="text"
                                   class="form-control form-control-sm" date-picker ng-model="newPrice.ApplicableFrom_TMP" date-detail="newPrice.ApplicableFromDet" title="{{(newPrice.ApplicableFromDet.dateAD |dateFormat)}}">
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group mt-4 text-right">
                            <a href="#" class="btn btn-primary load px-1" style="min-width: 90px; padding-top: 4px; padding-bottom: 4px;" data-toggle="tooltip" data-placement="top" title="" data-original-title="Load" ng-click="GetSalesPrice()" ng-disabled="loadingstatus=='running'"><i class="fas fa-download w-t"> &nbsp;</i>Load</a>
                            <button type="button"
                                    class="btn btn-md btn-primary"
                                    style="min-width: 90px; padding-top: 4px; padding-bottom: 4px;" ng-click="SaveSalesPrice()">
                                <i class="fas fa-database w-t"></i>&nbsp;Update Data
                            </button>
                            <button type="button"
                                    class="btn btn-md btn-default"
                                    style="min-width: 90px; padding-top: 4px; padding-bottom: 4px;">
                                Reset
                            </button>
                        </div>
                    </div>

                </div>
                <div class="row">
                    <div class="col-md-2">
                        <form class="form-inline">
                            <div class="input-group input-group-sm table-search-filed" style="width:100%">
                                <input class="form-control form-control-navbar"
                                       type="search"
                                       placeholder="Search"
                                       aria-label="Search" ng-model="searchData.AllowProductGroup" />
                                <div class="input-group-append">
                                    <button class="btn btn-default border-left-0"
                                            type="submit">
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class="card p-2">

                <div class="table-scroll-x-y table-scroll" style="max-height: calc(100vh - 9rem);">
                    <table id="maintable" class="table table-bordered table-hover table-sm">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:60px; z-index: 3; background-color: #ececec !important">S.No.</th>
                                <th style="width:180px; z-index: 3; background-color: #ececec !important"> Name</th>
                                <th style="width: 120px; z-index: 3; background-color: #ececec !important">Code</th>
                                <th style="width: 120px; z-index: 3; background-color: #ececec !important">Is Taxable</th>
                                <th style="width: 120px; z-index: 3; background-color: #ececec !important">UOM</th>
                                <th style="width: 120px; z-index: 3; background-color: #ececec !important">From Qty.</th>
                                <th style="width: 120px; z-index: 3; background-color: #ececec !important">LessThan Qty.</th>
                                <th style="width: 120px; z-index: 3; background-color: #ececec !important">Rate</th>
                                <th style="width: 120px; z-index: 3; background-color: #ececec !important">Dis%</th>
                                <th style="width: 120px; z-index: 3; background-color: #ececec !important">Dis.Amt.</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr ng-repeat="el in SalesPriceList |filter:searchData.AllowProductGroup">
                                <td class="text-center">
                                    {{$index+1}}
                                    <a class="p-1" href="#" data-original-title="Add Row" ng-click="AddRow(el,$index)">
                                        <i class="fas fa-plus text-info"></i>
                                    </a>
                                </td>
                                <td>{{el.Name}}</td>
                                <td>{{el.Code}}</td>
                                <td>{{el.IsTaxable |yesNoFormat}}</td>
                                <td>{{el.UOM}}</td>
                                <td class="text-center">
                                    <input type="text" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="el.FromQty" positive="true">
                                </td>
                                <td class="text-center">
                                    <input type="text" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="el.LessThanQty" positive="true">
                                </td>
                                <td class="text-center">
                                    <input type="text" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="el.Rate" positive="true">
                                </td>
                                <td class="text-center">
                                    <input type="text" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="el.DisPer" positive="true">
                                </td>
                                <td class="text-center">
                                    <input type="text" number-input noofdecimal="2" style="text-align:right" onfocus="this.select();" class="form-control form-control-sm" ng-model="el.DisAmt" positive="true">
                                </td>
                            </tr>

                        </tbody>

                    </table>
                </div>



            </div>

        </div>

    </div>


</div>