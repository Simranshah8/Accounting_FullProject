@{

    ViewBag.Title = "";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/jslib/inventory/creation/ProductScheme.js"></script>
<div ng-app="myApp" ng-controller="ProductScheme" ng-cloak>

    <div class="p-4">
        <div class="content">
            <div class="container-fluid">

                <div class="card">
                    <div class="card-header header-corner-triangle">
                        <h3 class="card-title">Product Scheme</h3>
                    </div>
                    <div class="card-body px-5 pb-5 pt-4">
                        <form>
                            <div class="row">
                                <div class="col-sm-6">
                                    <div class="form-group">
                                        <label>Name</label>
                                        <input type="text" class="form-control" ng-model="newProductScheme.Name">
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="form-group">
                                        <label>Note</label>
                                        <input type="text" class="form-control" ng-model="newProductScheme.Note">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-6">
                                    <div class="form-group">
                                        <label>Voucher</label>
                                        <div class="col-sm-12">
                                            <select class="form-control hideSideBar" height:90%;" >
                                                <option >
                                                    
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="form-group">
                                        <label for="exampleFormControlTextarea1">Description</label>
                                        <textarea class="form-control" id="exampleFormControlTextarea1" rows="3" ng-model="newProductScheme.Description"></textarea>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-sm-3">
                                    <div class="form-group row">
                                        <label>Date From: </label>
                                        <div class="col-sm-8">
                                            <input type="text" class="form-control" date-picker ng-model="p.ApplicableForm_TMP " date-detail="p.ApplicationFromDet">                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group row">
                                        <label>Date To: </label>
                                        <div class="col-sm-8">
                                            <input type="text" class="form-control" date-picker ng-model="p.ApplicableForm_TMP " date-detail="p.ApplicationFromDet">                                        </div>
                                    </div>
                                </div>
                            </div>
                            <br />
                            <div class="row">
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-2 col-form-label">Area</label>
                                        <div class="col-sm-8">
                                            <select class="form-control >
                                                <option>
                                                    
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-2 col-form-label">Agent</label>
                                        <div class="col-sm-8">
                                            <select class="form-control " style="width: 100%;">
                                                <option >
                                                    
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-3 col-form-label">Ledger Group</label>
                                        <div class="col-sm-8">
                                            <select class="form-control  hideSideBar" style="width: 100%;" ng-model="beData.VoucherId" ng-change="getVoucherNo()">
                                                <option ng-repeat="vt in VoucherTypeColl track by vt.VoucherId" value="{{vt.VoucherId}}" ng-selected="vt.VoucherId == beData.VoucherId">
                                                    {{vt.VoucherName}}
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-3 col-form-label">Ledger</label>
                                        <div class="col-sm-8">
                                            <select class="form-control  " style="width: 100%;" >
                                                    <option>
                                                    
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-3 col-form-label">Product Group</label>
                                        <div class="col-sm-8">
                                            <select class="form-control  " style="width: 100%;">
                                                <option>
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label for="inputEmail3" class="col-sm-3 col-form-label">Product</label>
                                        <div class="col-sm-8">
                                            <select class="form-control  ">
                                                <option >
                                                    
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </form>
                    </div>
                    <table class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>S.No</th>
                                <th>Sales Qty.</th>
                                <th>Free Qty.</th>
                                <th>Alternet Product</th>
                                <th>Discount</th>
                                <th>Description</th>
                        </thead>
                        <tbody>
                            <tr>
                                <td>1</td>
                                <td>0.0</td>
                                <td>0.0</td>
                                <td></td>
                                <td>0.00</td>
                                <td>0.00</td>
                            </tr>
                        </tbody>

                    </table>
                </div>

                <footer class="main-footer">
                    <div class="text-right control-btns">
                        <button type="button" class="btn btn-secondary" ng-click="ClearProductScheme()">Reset</button>
                        <button type="button" class="btn btn-info" ng-click="SaveUpdateProductScheme()">Save and Close</button>
                        <button type="button" class="btn btn-success" ng-click="SaveUpdateProductScheme()">Save</button>
                    </div>

                </footer>

            </div>

        </div>

    </div>

    <!-- /.container-fluid -->
</div>