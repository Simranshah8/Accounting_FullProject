@{

    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
<style>
    .table-scroll-x-y {
        height: auto !important;
    }
</style>
<script src="~/jslib/AppCMS/ProductDisplay.js?v=1"></script>
<div class="hold-transition  layout-navbar-fixed" ng-app="myApp" ng-controller="ProductDisplayController" ng-init="LoadData()">
    <section class="content">
        <div class="container-fluid">
            <section class="iframe-content-starts-here">
                <div class="tab-content" id="table-listing">
                    <!-- Second Tab Content -->
                    <div class="card p-2">
                        <header class="row mb-2">
                            <div class="col-md-7">
                                <div class="clearfix">
                                    <form class="form-inline">
                                        <div class="input-group input-group-sm mr-sm-2">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text cstm">Show</span>
                                            </div>
                                            <!-- <input type="text" class="form-control border-left-0" placeholder=""> -->
                                            <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.ProductDisplay">
                                                <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="pp.value==perPage.ProductDisplay">{{pp.text}}</option>
                                            </select>
                                            <div class="input-group-append">
                                                <span class="input-group-text bg-white"><small>entries</small></span>
                                            </div>
                                        </div>
                                        <div class="input-group input-group-sm table-search-filed">
                                            <input class="form-control form-control-navbar"
                                                   type="search" placeholder="Search"
                                                   aria-label="Search" ng-model="searchData.ProductDisplay">
                                            <div class="input-group-append">
                                                <button class="btn btn-default border-left-0"
                                                        type="submit">
                                                    <i class="fas fa-search"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <div class="col-md-5 text-right">
                                <div class="dropdown dnld-file">
                                    <button class="btn btn-secondary btn-light dropdown-toggle" type="button"
                                            id="dropdownMenuButton" data-toggle="dropdown"
                                            aria-haspopup="true" aria-expanded="false">
                                        <i class="fas fa-download"></i>
                                    </button>
                                    <div class="dropdown-menu dropdown-menu-right"
                                         aria-labelledby="dropdownMenuButton">
                                        <span class="dropdown-item">Choose an option:</span>
                                        <a class="dropdown-item wait" export-excel table-id="'#datatable'" sheet-name="'debtorcreditortypes'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'csv',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'pdf',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/pdf.png" class="img-fluid exports-icon" alt="Excel image"> PDF</a>
                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'doc',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/word.png" class="img-fluid exports-icon" alt="Excel image"> Word</a>
                                        <a class="dropdown-item wait" onClick="$('#datatable').tableExport({type:'json',escape:'false'});"><img src="~/wwwroot/dynamic-erp/images/flaticons/gmail.png" class="img-fluid exports-icon" alt="Excel image"> JSON</a>
                                    </div>
                                    <a print-tbl table-id="'#datatable'" class="btn btn-secondary btn-light wait">
                                        <i class="fas fa-print"></i>
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm btn-primary"
                                            id="open-form-btn" style="font-size:14px;">
                                        <i class="fas fa-plus w-t"></i> Add ProductDisplay
                                    </button>
                                </div>
                            </div>
                        </header>
                        <div>
                            <div class="table-scroll-x-y  table-scroll" style="max-height: calc(100vh - 100px);">
                                <table id="main-table"
                                       class="main-table table table-sm table-bordered bg-white">
                                    <thead>
                                        <tr>
                                            <th style="width: 70px">Order No</th>
                                            <th style="width: 250px">Title</th>
                                            <th style="width: 350px">Description</th>
                                            <th style="width: 70px">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr dir-paginate="cl in ProductDisplayList | filter:searchData.ProductDisplay | itemsPerPage: perPage.ProductDisplay" current-page="currentPages.ProductDisplay" pagination-id="ProductDisplayPagination">
                                            <td>{{cl.OrderNo}}</td>
                                            <td>{{cl.Title}}</td>
                                            <td>{{cl.Description}}</td>
                                            <td>
                                                <a class="p-1" href="#" ng-click="ShowPersonalImg(cl)">
                                                    <i class="fas fa-eye text-secondary"></i>
                                                </a>
                                                <a class="p-1" href="#" ng-click="GetProductDisplayById(cl)">
                                                    <i class="fas fa-edit text-info"></i>
                                                </a>
                                                <a class="p-1" href="#" ng-click="DelProductDisplayById(cl)">
                                                    <i class="fas fa-trash-alt text-danger"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <!-- table end -->
                            </div>
                        </div>
                        <footer class="row align-items-center">
                            <div class="col-md-12">
                                <dir-pagination-controls pagination-id="ProductDisplayPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                </dir-pagination-controls>
                            </div>
                        </footer>
                    </div>
                </div>
                <!-- form area starts -->
                <div id="notice-form">
                    <div>
                        <div class="card">
                            <div class="card-body">
                                <div class="timeline-item">
                                    <div class="row">
                                        <div class="col-md-8">
                                            <div class="row">
                                                <div class="col-md-8" id="meet-others">
                                                    <div class="form-group">
                                                        <label for="">Category</label>
                                                        <select class="form-control form-control-sm select2" style="width: 100%;" ng-model="newProductDisplay.ProductCategoriesId" data-placeholder="** Category Name**">
                                                            <option ng-value="u.ProductCategoriesId" ng-repeat="u in ProductCategoriesList" ng-selected="u.ProductCategoriesId==newProductDisplay.ProductCategoriesId">{{u.Name}}</option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label for="">Sales Rate.</label>
                                                        <input type="number"
                                                               class="form-control form-control-sm" ng-model="newProductDisplay.SalesRate" />
                                                    </div>
                                                </div>
                                                <!-- select for others -->
                                                <div class="col-md-8" id="meet-others">
                                                    <div class="form-group">
                                                        <label for="">Title</label>
                                                        <input type="text"
                                                               class="form-control form-control-sm" ng-model="newProductDisplay.Title" />
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <label for="">Order No.</label>
                                                        <input type="number"
                                                               class="form-control form-control-sm" ng-model="newProductDisplay.OrderNo" />
                                                    </div>
                                                </div>
                                                <!-- fields after clicking radio button ends -->
                                                <div class="col-md-12">
                                                    <div class="form-group">
                                                        <label>Description</label>
                                                        <textarea class="form-control form-control-sm" ng-model="newProductDisplay.Description"
                                                                  rows="3"></textarea>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="time-label">
                                                <span class="d-block border-0 p-3 text-center">
                                                    <button type="button"
                                                            class="btn btn-info"
                                                            id="back-to-list"
                                                            style="min-width: 90px">
                                                        Back to List
                                                    </button>
                                                    <button type="button" class="btn  btn-default" style="min-width: 90px;" ng-click="ClearProductDisplay()">Reset</button>
                                                    <button type="button" class="btn  btn-success" style="min-width: 90px;" ng-click="SaveUpdateProductDisplay()">{{newProductDisplay.Mode}}</button>
                                                </span>
                                            </div>
                                        </div>

                                        <div class="col-md-4">
                                            <label for="" class="invisible">Photo</label>
                                            <div class="person-photo-attachment-wrap text-center">
                                                <div class="img-wrap mx-auto" style="width:100%;">
                                                    <img ng-src="{{newProductDisplay.PhotoData[0] || newProductDisplay.ImagePath}}" class="img-fluid" alt="" id="imgPhoto1">
                                                </div>
                                                <label for="choose-file" type="button" class="btn btn-outline-secondary btn-sm" style="font-size:14px;">Upload Image</label>
                                                <input id="choose-file" class="btn btn-outline-secondary btn-sm" style="display: none;" type="file" accept=".jpg,.jpeg,.png" file-model-resize ng-model="newProductDisplay.Photo_TMP" fileread="newProductDisplay.PhotoData" />
                                                <a ng-click="ClearProductDisplayPhoto()" href="#" class="text-danger d-block mt-3">remove current image</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- END timeline item -->
                </div>
                <!-- form area ends -->
            </section>
            <!-- /.row -->
        </div>
        <!--/. container-fluid -->
    </section>
    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-body mb-0 p-0">
                    <img ng-src="{{viewImg.ContentPath}}" alt="" style="width:100%; height: 70vh;">
                </div>
                <div class="modal-footer">
                    <div><a href="{{viewImg.ContentPath}}" download>Download</a></div>
                    <button class="btn btn-success btn-rounded btn-sm ml-4 text-center" data-dismiss="modal" type="button" style="min-width: 90px;">Close</button>
                </div>
            </div>
        </div>
    </div>

</div>

