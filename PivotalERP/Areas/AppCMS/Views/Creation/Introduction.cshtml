    <!-- /.content -->
    @* photo upload Modal*@
    <!-- Vision Statement Photo modal -->
    <div class="modal fade" id="updateVision" tabindex="-1" aria-labelledby="updateVisionLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="updateVisionLabel">Upload Photo</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <i class="flaticon-close"></i>
                    </button>
                </div>
                <div class="modal-body text-center" border-0 pb-0" file-dropzone="[image/png, image/jpeg]"
                     data-max-file-size="3" ng-model="newVisionStatement.PhotoVision_TMP" @*after-selected="AddAboutUsPhoto()"*@ fileread="newVisionStatement.PhotoDataVision">
                    <div class="photo-upload-wrap">
                        <span class="static-content">
                            <img ng-src="{{newVisionStatement.PhotoDataVision || newVisionStatement.ImagePath}}" class="img-fluid" id="imgVision">
                            <span>Drag & Drop your<br>image here</span>
                        </span>
                    </div>
                    <div class="text-muted pb-3">or</div>
                    <label for="choose-fileVision" type="button" class="btn btn-secondary btn-light btn-sm">Upload Image</label>
                    <input id="choose-fileVision" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newVisionStatement.PhotoVision_TMP" @*after-selected="AddStudentPhoto()"*@ fileread="newVisionStatement.PhotoDataVision" />
                    <a ng-click="ClearVisionStatementPhotoVision()" href="#" class="text-danger d-block mt-3">remove current image</a>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-dafault" data-dismiss="modal">Ok</button>
                    @*<button type="button" class="btn btn-secondary px-4" ng-click="AddAboutUsImage()">Save</button>*@
                </div>
            </div>
        </div>
    </div>


    <!-- Founder Message Photo modal -->
    <div class="modal fade" id="updateFounder" tabindex="-1" aria-labelledby="updateFounderLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="updateFounderLabel">Upload Photo</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <i class="flaticon-close"></i>
                    </button>
                </div>
                <div class="modal-body text-center" border-0 pb-0" file-dropzone="[image/png, image/jpeg]"
                     data-max-file-size="3" ng-model="newTestimonial.PhotoFounder_TMP" @*after-selected="AddAboutUsPhoto()"*@ fileread="newTestimonial.PhotoDataFounder">
                    <div class="photo-upload-wrap">
                        <span class="static-content">
                            <img ng-src="{{newTestimonial.PhotoDataFounder || newTestimonial.ImagePath}}" class="img-fluid" id="imgFounder">
                            <span>Drag & Drop your<br>image here</span>
                        </span>
                    </div>
                    <div class="text-muted pb-3">or</div>
                    <label for="choose-fileFounder" type="button" class="btn btn-secondary btn-light btn-sm">Upload Image</label>
                    <input id="choose-fileFounder" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newTestimonial.PhotoFounder_TMP" @*after-selected="AddStudentPhoto()"*@ fileread="newTestimonial.PhotoDataFounder" />
                    <a ng-click="ClearTestimonialPhotoFounder()" href="#" class="text-danger d-block mt-3">remove current image</a>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-dafault" data-dismiss="modal">Ok</button>
                    @*<button type="button" class="btn btn-secondary px-4" ng-click="AddAboutUsImage()">Save</button>*@
                </div>
            </div>
        </div>
    </div>
    <div aria-hidden="true" aria-labelledby="myModalLabel" class="modal fade" id="PersonalImg" role="dialog" tabindex="-1">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-body mb-0 p-0">
                    <img ng-src="{{viewImg.ContentPath}}" alt="" style="width:100%; height: 70vh;">
                </div>
                <div class="modal-footer">
                    <div><a href="{{viewImg.ContentPath}}" target="_blank" download>Download</a></div>
                    <button class="btn btn-success btn-rounded btn-sm ml-4 text-center" data-dismiss="modal" type="button" style="min-width: 90px;">Close</button>
                </div>
            </div>
        </div>
    </div>
    <!-- Staff Heirarchy photo model -->
    <div class="modal fade" id="updatePhoto" tabindex="-1" aria-labelledby="updatePhotoLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="updatePhotoLabel">Upload Photo</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <i class="flaticon-close"></i>
                    </button>
                </div>
                <div class="modal-body text-center" border-0 pb-0" file-dropzone="[image/png, image/jpeg]"
                     data-max-file-size="3" ng-model="newStaffHierarchy.Photo_TMP" @*after-selected="AddStaffHierarchyPhoto()"*@ fileread="newStaffHierarchy.PhotoData">
                    <div class="photo-upload-wrap">
                        <span class="static-content">
                            <img ng-src="{{newStaffHierarchy.PhotoData || newStaffHierarchy.ImagePath}}" class="img-fluid" id="imgPhoto">
                            <span>Drag & Drop your<br>image here</span>
                        </span>
                    </div>
                    <div class="text-muted pb-3">or</div>
                    <label for="choose-file" type="button" class="btn btn-secondary btn-light btn-sm">Upload Image</label>
                    <input id="choose-file" type="file" accept=".jpg,.jpeg,.pdf,doc,docx,application/msword,.png" style="display: none;" file-model ng-model="newStaffHierarchy.Photo_TMP" @*after-selected="AddStudentPhoto()"*@ fileread="newStaffHierarchy.PhotoData" />
                    <a ng-click="ClearStaffHierarchyPhoto()" href="#" class="text-danger d-block mt-3">remove current image</a>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-dafault" data-dismiss="modal">Ok</button>
                    @*<button type="button" class="btn btn-secondary px-4" ng-click="AddStaffHierarchyImage()">Save</button>*@
                </div>
            </div>
        </div>
    </div>
</div>

