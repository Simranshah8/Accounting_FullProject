@{
    ViewBag.Title = "";
    Layout = null;
}
@RenderPage("~/Views/Global/_GlobalLayout.cshtml")
@*<script src="~/jslib/export/tableExport.js"></script>
    <script src="~/jslib/export/jquery.base64.js"></script>
    <script src="~/jslib/export/jspdf/libs/sprintf.js"></script>
    <script src="~/jslib/export/jspdf/jspdf.js"></script>*@

<script src="~/jslib/EmployeePerformance/GoalReleased.js"></script>

<div class="hold-transition layout-navbar-fixed" ng-app="myApp" ng-controller="GoalReleasedController" ng-init="LoadData()">
    <div class="content">
        <div class="container-fluid">
            <div class="card">
                <div class="card-header p-0 border-bottom-0">
                    <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="custom-tabs-four-home-tab" data-toggle="pill" href="#custom-tabs-four-home" role="tab" aria-controls="custom-tabs-four-home" aria-selected="true">Goal Released</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="custom-tabs-four-profile-tab" data-toggle="pill" href="#custom-tabs-four-profile" role="tab" aria-controls="custom-tabs-four-profile" aria-selected="false">Team Members</a>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-2">
                    <div class="tab-content" id="custom-tabs-four-tabContent">
                        <div class="tab-pane fade show active" id="custom-tabs-four-home" role="tabpanel" aria-labelledby="custom-tabs-four-home-tab">

                            <div class="row pt-1">
                                <div class="col-sm-3" ng-hide="HideShow.CostClass==true">
                                    <div class="form-group row mb-0">
                                        <label for="" class="col-sm-4 col-form-label text-nowrap">Fiscal Year</label>
                                        <div class="col-sm-8">
                                            <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="beData.CostClassId" ng-change="GetEmployeeGoalRelease()">
                                                <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == beData.CostClassId">
                                                    {{cc.Name}}
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group row align-items-center">
                                        <label class="col-md-3 col-form-label"> Goal SetUp</label>
                                        <div class="col-md-9">
                                            <select class="form-control form-control-sm select2" ng-model="beData.GoalSetupId" ng-change="GetEmployeeGoalRelease()">
                                                <option ng-repeat="pp in GoalSetupList" ng-value="pp.id" ng-selected="pp.id==beData.GoalSetupId"> {{pp.text}} </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group row align-items-center">
                                        <label class="col-md-2 col-form-label p-0"> For </label>
                                        <div class="col-md-10">
                                            <select class="form-control form-control-sm" ng-model="beData.ForId" ng-change="GetEmployeeGoalRelease()">
                                                <option ng-value="pp.id" ng-repeat="pp in ForColl" ng-selected="pp.id==beData.ForId"> {{pp.value}} </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group text-right">
                                        <button type="button" class="btn btn-default btn-sm load mr-2" ng-click="GetEmployeeGoalRelease()"> <span class="fas fa-sync-alt mr-2"></span>Load</button>
                                        <button type="button" class="btn btn-primary btn-sm load" ng-click="SaveGoalReleasedColl()"> <span class="fas fa-save mr-2"></span>Save</button>
                                    </div>
                                </div>
                            </div>
                            <header class="row">
                                <div class="col-md-8">
                                    <div class="clearfix">
                                        <form class="form-inline">
                                            <div class="input-group input-group-sm mr-2">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text cstm">Show</span>
                                                </div>
                                                <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.GoalReleased">
                                                    <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="">{{pp.text}}</option>
                                                </select>
                                                <div class="input-group-append">
                                                    <span class="input-group-text bg-white"><small>entries</small></span>
                                                </div>
                                            </div>
                                            <div class="input-group input-group-sm table-search-filed">
                                                <input class="form-control form-control-navbar" type="search"
                                                       placeholder="Search" aria-label="Search" ng-model="searchData.GoalReleased">
                                                <div class="input-group-append">
                                                    <button class="btn btn-default border-left-0" type="submit">
                                                        <i class="fas fa-search"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                                <div class="col-md-4 text-right">
                                    <div class="dropdown dnld-file" data-placement="top" title="Download File">
                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                id="dropdownMenuButton" data-toggle="dropdown"
                                                aria-haspopup="true" aria-expanded="false">
                                            <i class="fas fa-download"></i>
                                        </button>
                                        <div class="dropdown-menu dropdown-menu-right"
                                             aria-labelledby="dropdownMenuButton">
                                            <span class="dropdown-item">Choose an option:</span>
                                            <a class="dropdown-item wait" export-excel table-id="'#GoalReleased'" sheet-name="'GoalReleased'" report-name="'List of GoalReleased'" ignore-column="'3'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                            <a class="dropdown-item wait" onClick="$('#GoalReleased').tableExport({type:'csv',escape:'false',reportName:'GoalReleased',ignoreColumn:'3' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                        </div>
                                        <a print-tbl report-name="'GoalReleased'" table-id="'#GoalReleased'" class="btn btn-secondary btn-light btn-sm wait" title="Print">
                                            <i class="fas fa-print"></i>
                                        </a>
                                    </div>
                                </div>
                            </header>
                            <div class="table-scroll-x-y table-container flex-grow-1" style="max-height:calc(100vh - 8rem) !important;">
                                <div class="outer-scroll-wrapper-h-scrollbar-fix">
                                    <div class="table-h-scrollbar-fix table-scroll-wrapper">
                                        <table id="GoalReleased" class="main-table table table-sm table-bordered bg-white cstm-sales-invoice-table border-0 dynamic-uiux-table">
                                            <thead>
                                                <tr>
                                                    <th style="width: 60px; background-color: #e6f5fb !important; z-index: 4;">S.No.</th>
                                                    <th style="width: 100px; background-color: #e6f5fb !important;">EmpCode</th>
                                                    <th style="width: 160px; background-color: #e6f5fb !important;">Name</th>
                                                    <th style="width: 140px; background-color: #e6f5fb !important;">Company</th>
                                                    <th style="width: 140px; background-color: #e6f5fb !important;">Branch</th>
                                                    <th style="width: 150px; background-color: #e6f5fb !important;">Department</th>
                                                    <th style="width: 120px; background-color: #e6f5fb !important;">Status</th>
                                                    <th style="width: 80px; background-color: #e6f5fb !important;">

                                                        <div class="custom-control custom-checkbox ml-2">
                                                            <input class="custom-control-input" type="checkbox" id="customStatus" ng-model="SelectAll" ng-change="SelectAllStatus(SelectAll)">
                                                            <label for="customStatus" class="custom-control-label">Action</label>
                                                        </div>
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="cl in GoalReleasedList | filter:searchData.GoalReleased | itemsPerPage: perPage.GoalReleased" current-page="currentPages.GoalReleased" pagination-id="GoalReleasedPagination">
                                                    <td>{{$index+1}}</td>
                                                    <td>{{cl.EmployeeCode}}</td>
                                                    <td>{{cl.EmployeeName}} <i class="fas fa-exclamation-triangle ml-2 text-warning" ng-if="!cl.UserId" title="Need to Create UserId"></i></td>
                                                    <td>{{cl.CompanyRelationship}}</td>
                                                    <td>{{cl.BranchName}}</td>
                                                    <td>{{cl.Department }}</td>
                                                    <td ng-class="{'text-success': cl.Status, 'text-danger': !cl.Status}">{{cl.StatusName}}</td>
                                                    <td class="text-center">
                                                        <div class="custom-control custom-checkbox">
                                                            <input class="custom-control-input" type="checkbox" id="customStatus_{{$index+1}}" ng-model="cl.Status" ng-change="ChangeStatus(cl)">
                                                            <label for="customStatus_{{$index+1}}" class="custom-control-label"></label>
                                                        </div>
                                                    </td>

                                                </tr>
                                            </tbody>
                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="GoalReleasedPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="tab-pane fade" id="custom-tabs-four-profile" role="tabpanel" aria-labelledby="custom-tabs-four-profile-tab">

                            <div class="row pt-1">
                                <div class="col-md-3" ng-hide="HideShow.CostClass==true">
                                    <div class="form-group row mb-0">
                                        <label for="" class="col-sm-4 col-form-label text-nowrap">Fiscal Year</label>
                                        <div class="col-sm-8">
                                            <select class="form-control form-control-sm hideSideBar" style="width: 100%;" ng-model="newDet.CostClassId" ng-change="GetEmpGoalSetupBySupId()">
                                                <option ng-repeat="cc in CostClassColl track by cc.CostClassId" ng-value="cc.CostClassId" ng-selected="cc.CostClassId == newDet.CostClassId">
                                                    {{cc.Name}}
                                                </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group row mb-0">
                                        <label for="" class="col-sm-4 col-form-label text-nowrap">Supervisor</label>
                                        <div class="col-sm-8">
                                            <select class="form-control form-control-sm select2" ng-model="newDet.SupUserId" ng-change="GetEmpGoalSetupBySupId()">
                                                <option ng-repeat="pp in SupervisorList" ng-value="pp.UserId"> {{pp.SupervisorName}} </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group row mb-0">
                                        <label for="" class="col-sm-4 col-form-label text-nowrap">Goal Setup</label>
                                        <div class="col-sm-8">
                                            <select class="form-control form-control-sm" ng-model="newDet.GoalSetupId" ng-change="GetEmpGoalSetupBySupId()">
                                                <option ng-value="pp.id" ng-repeat="pp in SupGoalSetupList"> {{pp.text}} </option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group text-right">
                                        <button type="button" class="btn btn-default btn-sm load mr-2" ng-click="GetEmpGoalSetupBySupId()"> <span class="fas fa-sync-alt mr-2"></span>Load</button>
                                        <button type="button" class="btn btn-primary btn-sm load" ng-click="SaveTeamMemberColl()"> <span class="fas fa-save mr-2"></span>Save</button>
                                    </div>
                                </div>
                            </div>
                            <header class="row">
                                <div class="col-md-8">
                                    <div class="clearfix">
                                        <form class="form-inline">
                                            <div class="input-group input-group-sm mr-2">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text cstm">Show</span>
                                                </div>
                                                <select class="form-control border-left-0 border-right-0 pr-0" ng-model="perPage.TeamMember">
                                                    <option ng-value="pp.value" ng-repeat="pp in perPageColl" ng-selected="">{{pp.text}}</option>
                                                </select>
                                                <div class="input-group-append">
                                                    <span class="input-group-text bg-white"><small>entries</small></span>
                                                </div>
                                            </div>
                                            <div class="input-group input-group-sm table-search-filed">
                                                <input class="form-control form-control-navbar" type="search"
                                                       placeholder="Search" aria-label="Search" ng-model="searchData.TeamMember">
                                                <div class="input-group-append">
                                                    <button class="btn btn-default border-left-0" type="submit">
                                                        <i class="fas fa-search"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                                <div class="col-md-4 text-right">
                                    <div class="dropdown dnld-file" data-placement="top" title="Download File">
                                        <button class="btn btn-secondary btn-light btn-sm dropdown-toggle" type="button"
                                                id="dropdownMenuButton" data-toggle="dropdown"
                                                aria-haspopup="true" aria-expanded="false">
                                            <i class="fas fa-download"></i>
                                        </button>
                                        <div class="dropdown-menu dropdown-menu-right"
                                             aria-labelledby="dropdownMenuButton">
                                            <span class="dropdown-item">Choose an option:</span>
                                            <a class="dropdown-item wait" export-excel table-id="'#TeamMember'" sheet-name="'Team Member'" report-name="'List of Team Member'" ignore-column="'3'"><img src="~/wwwroot/dynamic-erp/images/flaticons/excel.png" class="img-fluid exports-icon" alt="Excel image"> Excel</a>
                                            <a class="dropdown-item wait" onClick="$('#TeamMember').tableExport({type:'csv',escape:'false',reportName:'TeamMember',ignoreColumn:'3' });"><img src="~/wwwroot/dynamic-erp/images/flaticons/csv.png" class="img-fluid exports-icon" alt="Excel image"> CSV</a>
                                        </div>
                                        <a print-tbl report-name="'GoalReleased'" table-id="'#GoalReleased'" class="btn btn-secondary btn-light btn-sm wait" title="Print">
                                            <i class="fas fa-print"></i>
                                        </a>
                                    </div>
                                </div>
                            </header>
                            <div class="table-scroll-x-y table-container flex-grow-1" style="max-height:calc(100vh - 8rem) !important;">
                                <div class="outer-scroll-wrapper-h-scrollbar-fix">
                                    <div class="table-h-scrollbar-fix table-scroll-wrapper">
                                        <table id="TeamMember" class="main-table table table-sm table-bordered bg-white cstm-sales-invoice-table border-0 dynamic-uiux-table">
                                            <thead>
                                                <tr>
                                                    <th style="width: 60px; background-color: #e6f5fb !important; z-index: 4;">S.No.</th>
                                                    <th style="width: 100px; background-color: #e6f5fb !important;">EmpCode</th>
                                                    <th style="width: 160px; background-color: #e6f5fb !important;">Name</th>
                                                    <th style="width: 140px; background-color: #e6f5fb !important;">Company</th>
                                                    <th style="width: 140px; background-color: #e6f5fb !important;">Branch</th>
                                                    <th style="width: 150px; background-color: #e6f5fb !important;">Department</th>
                                                    <th style="width: 120px; background-color: #e6f5fb !important;">Status</th>
                                                    <th style="width: 80px; background-color: #e6f5fb !important;">

                                                        <div class="custom-control custom-checkbox ml-2">
                                                            <input class="custom-control-input" type="checkbox" id="customStatus1" ng-model="SelectAll" ng-change="SelectAllStatusTM(SelectAll)">
                                                            <label for="customStatus1" class="custom-control-label">Action</label>
                                                        </div>
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr dir-paginate="cl in TeamMemberList | filter:searchData.TeamMember | itemsPerPage: perPage.TeamMember" current-page="currentPages.TeamMember" pagination-id="TeamMemberPagination">
                                                    <td>{{$index+1}}</td>
                                                    <td>{{cl.EmployeeCode}}</td>
                                                    <td>{{cl.EmployeeName}} <i class="fas fa-exclamation-triangle ml-2 text-warning" ng-if="!cl.UserId" title="Need to Create UserId"></i></td>
                                                    <td>{{cl.CompanyRelationship}}</td>
                                                    <td>{{cl.BranchName}}</td>
                                                    <td>{{cl.Department }}</td>
                                                    <td ng-class="{'text-success': cl.Status, 'text-danger': !cl.Status}">{{cl.StatusName}}</td>
                                                    <td class="text-center">
                                                        <div class="custom-control custom-checkbox">
                                                            <input class="custom-control-input" type="checkbox" id="customStatus1_{{$index+1}}" ng-model="cl.Status" ng-change="ChangeStatus(cl)">
                                                            <label for="customStatus1_{{$index+1}}" class="custom-control-label"></label>
                                                        </div>
                                                    </td>

                                                </tr>
                                            </tbody>
                                        </table>
                                        <div class="col-md-12">
                                            <dir-pagination-controls pagination-id="TeamMemberPagination" boundary-links="true" on-page-change="pageChangeHandler(newPageNumber)" template-url="/Scripts/dirPagination.tpl.html">
                                            </dir-pagination-controls>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>

</div>

