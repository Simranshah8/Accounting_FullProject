using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using Dynamic.DataAccess.Global;

namespace Dynamic.BL.Payroll
{

	public class InsuranceType
	{

		Dynamic.DA.Payroll.InsuranceTypeDB db = null;

		int _UserId = 0;

		public InsuranceType(int UserId, string hostName, string dbName)
		{
			this._UserId = UserId;
			db = new Dynamic.DA.Payroll.InsuranceTypeDB(hostName, dbName);
		}
		public ResponeValues SaveFormData(Dynamic.BE.Payroll.InsuranceType beData)
		{
			bool isModify = beData.InsuranceId > 0;
			ResponeValues isValid = IsValidData(ref beData, isModify);
			if (isValid.IsSuccess)
				return db.SaveUpdate(beData, isModify);
			else
				return isValid;
		}
		public Dynamic.BE.Payroll.InsuranceTypeCollections GetAllInsuranceType(int EntityId)
		{
			return db.getAllInsuranceType(_UserId, EntityId);
		}
		public Dynamic.BE.Payroll.InsuranceType GetInsuranceTypeById(int EntityId, int InsuranceId)
		{
			return db.getInsuranceTypeById(_UserId, EntityId, InsuranceId);
		}
		public ResponeValues DeleteById(int EntityId, int InsuranceId)
		{
			return db.DeleteById(_UserId, EntityId, InsuranceId);
		}
		public ResponeValues IsValidData(ref Dynamic.BE.Payroll.InsuranceType beData, bool IsModify)
		{
			ResponeValues resVal = new ResponeValues();
			try
			{
				if (beData == null)
				{
					resVal.ResponseMSG = GLOBALMSG.NO_DATA_FOUND;
				}
				else if (IsModify && beData.InsuranceId == 0)
				{
					resVal.ResponseMSG = GLOBALMSG.INVALID_DATA + " For Modify";
				}
				else if (!IsModify && beData.InsuranceId != 0)
				{
					resVal.ResponseMSG = GLOBALMSG.INVALID_DATA + " For Save";
				}
				else if (beData.CUserId == 0)
				{
					resVal.ResponseMSG = "Invalid User for CRUD";
				}
				else if (string.IsNullOrEmpty(beData.Name))
				{
					resVal.ResponseMSG = "Please ! Enter Name ";
				}
				else
				{
					resVal.IsSuccess = true;
					resVal.ResponseMSG = "Valid";
				}
			}
			catch (Exception ee)
			{
				resVal.IsSuccess = false;
				resVal.ResponseMSG = ee.Message;
			}
			return resVal;
		}
	}

}

