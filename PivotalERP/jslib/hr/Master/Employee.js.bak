    $scope.ClearEmpPhoto = function () {
        $timeout(function () {
            $scope.$apply(function () {
                $scope.newDet.PhotoData = null;
                $scope.newDet.Photo_TMP = [];
            });

        });
        $('#imgEmp').attr('src', '');
        $('#imgPhoto1').attr('src', '');
    };

    $scope.ClearCitiFront = function () {
