
@{
    Layout = null;
}
<style>
    .dropdown-menu li.selected {
        background-color: #d9edf7;
    }

    .dropdown-menu {
        padding: 0;
        border: 1px solid #ccc;
        z-index: 1050 !important; /* Ensure it's above other elements */
        position: absolute !important; /* Override any conflicting position */
    }

    .dropdown-header {
        /* position: sticky;*/
        top: 0;
        background-color: #fff;
        z-index: 1;
        padding: 8px;
        border-bottom: 1px solid #ececec;
    }

        .dropdown-header label,
        .dropdown-menu li label {
            display: flex;
            align-items: flex-start;
            gap: 5px; /* Space between checkbox and label text */
            line-height: 1.2; /* Adjust line height for better readability */
        }

        .dropdown-header input[type="checkbox"],
        .dropdown-menu input[type="checkbox"] {
            flex-shrink: 0; /* Prevent the checkbox from resizing */
            margin-top: 2px; /* Align with the label text */
        }

    .dropdown-options {
        max-height: 250px; /* Set the desired height for the scrollable area */
        overflow-y: auto;
        padding: 8px;
    }

    .dropdown-menu li {
        padding: 5px; /* Add padding for better spacing between options */
    }

        .dropdown-menu li:hover {
            background-color: #f0f0f0; /* Highlight background on hover */
            border-radius: 4px;
        }
</style>

<div class="d-flex">
    <div class="dropdown" style="width: 100% !important;">
        <button class="btn btn-default btn-sm load dropdown-toggle text-left" type="button" data-toggle="dropdown" style="width: 100% !important;">
            <span class="dropdown-text"> Select  {{MSData.SelectedCount}}</span>
            <span class="caret"></span>
        </button>
        <ul class="dropdown-menu p-2" style="width: 260px;">
            <li class="dropdown-header">
                <input type="search" class="form-control form-control-sm" placeholder="Search..." ng-model="MSData.searchData" />
                <label class="pt-2">
                    <input type="checkbox" class="selectall" ng-change="ChangeSelectAll_MS()" ng-model="MSData.SelectAll" />
                    <span class="select-text">Select</span> All
                </label>
            </li>
            <li class="p-0">
                <ul class="dropdown-options p-0">
                    <li ng-repeat="r in MSData.DataColl |filter:MSData.searchData"><a href="#"><label><input ng-change="ChangeSelect_MS()" name='options[]' type="checkbox" class="option justone" ng-model="r.IsSelected" />{{r[MSData.Label]}}</label></a></li>
                </ul>
            </li>
            <li class="p-2 border-top text-right">
                <button type="button" class="btn btn-primary btn-sm apply-btn" style="width:85px; font-size:12px;" ng-click="Click_MS()">Apply</button>
            </li>
        </ul>
    </div>
</div>
<script>
    $(document).ready(function () {
        $('.dropdown-menu').parent().on('show.bs.dropdown', function () {
            $(this).find('.dropdown-menu').appendTo('body');
        });


        $(document).on('click', '.dropdown-menu', function (e) {
            e.stopPropagation();
        });


        $(document).on('click', '.apply-btn', function () {
            var $dropdown = $(this).closest('.dropdown');
            var $menu = $('.dropdown-menu');


            $menu.removeClass('show');
            $dropdown.removeClass('show');


            $dropdown.find('.dropdown-toggle').attr('aria-expanded', 'false');
        });
    });
</script>


