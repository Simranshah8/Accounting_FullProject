@model Dynamic.BusinessEntity.Security.User

@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Pivotal ERP</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/wwwroot/plugins/fontawesome-free/css/all.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
    <!-- icheck bootstrap -->
    <link rel="stylesheet" href="~/wwwroot/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/wwwroot/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="~/wwwroot/dynamic-erp/css/main.css">
    <!-- Google Font: Source Sans Pro -->
    <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700" rel="stylesheet">
</head>

<body>
    <div class="login-page">
        <div class="container h-100">
            <div class="row justify-content-center align-items-center h-100">
                <div class="col-lg-8 mx-auto">
                    <div class="card">
                        <div class="row no-gutters">
                            <div class="col-md-6 left-box rounded-left">
                                <div class="left-box-img-wrap">
                                    <div class="text-center">
                                        @*<img class="img-fluid col-md-8" src="~/wwwroot/dynamic-erp/images/Logo1.jpeg" alt="">*@
                                        <img class="img-fluid col-md-8" src="~/wwwroot/dist/img/Dynamicerp.png" alt="">
                                    </div>
                                    <div>
                                        <img class="img-fluid" src="~/wwwroot/dist/img/login-page-left-box.png" alt="">
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card-body login-card-body">
                                    <h4 class="">Login</h4>
                                    <p class="login-box-msg">Welcome back, please login to your account.</p>
                                    <div class="text-danger">
                                        <label>
                                            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                        </label>
                                    </div>
                                    <form method="post" asp-controller="Home" asp-action="Login" asp-route-returnurl="@Model.ResponseMSG">
                                        <div class="input-group mb-3">
                                            @*<input type="text" class="form-control" placeholder="UserName" asp-for="UserName">*@
                                            @Html.TextBoxFor(p1 => p1.UserName, new { @class = "form-control", @placeholder = "user name", @id = "txtUserName", @required = true })
                                            <div class="input-group-append">
                                                <div class="input-group-text">
                                                    <span class="fas fa-envelope"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="input-group mb-3">
                                            @*<input type="password" class="form-control" placeholder="Password" asp-for="Password">*@
                                            @Html.PasswordFor(p1 => p1.Password, new { @class = "form-control", @placeholder = "password", @id = "txtPassword", @required = true })
                                            <div class="input-group-append">
                                                <div class="input-group-text">
                                                    <span class="fas fa-lock"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            @Html.DropDownListFor(p1 => p1.DBName, new SelectList((SelectList)@ViewBag.CompanyList, "Value", "Text"), new { @class = "form-control", @required = true, @placeholder = "Select Company" })
                                        </div>
                                        <div class="row mt-3">
                                            <div class="col-8">
                                                <div class="icheck-primary">
                                                    <input type="checkbox" id="remember">
                                                    <label for="remember" asp-for="IsUserNeverExpire">
                                                        Remember Me
                                                    </label>
                                                </div>
                                            </div>
                                            <!-- /.col -->
                                            <div class="col-4">
                                                <button type="submit" class="btn btn-primary btn-block">Sign In</button>
                                            </div>
                                            <!-- /.col -->
                                        </div>
                                    </form>

                                    <p class="forgot-password">
                                        <a href="forgot-password.html"><span class="fas fa-lock mr-2"></span> forgot your password?</a>
                                    </p>
                                </div>
                                <!-- /.login-card-body -->
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <!-- /.login-box -->
    <!-- jQuery -->
    <script src="~/wwwroot/plugins/jquery/jquery.min.js"></script>
    <!-- Bootstrap 4 -->
    <script src="~/wwwroot/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- AdminLTE App -->
    <script src="~/wwwroot/dist/js/adminlte.min.js"></script>

</body>

</html>